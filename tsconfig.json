{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*",
    "./worker-configuration.d.ts"
  ],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "~/assets/*": ["./src/assets/*"],
      "~/composables/*": ["./src/composables/*"],
      "~/utils/*": ["./src/utils/*"],
      "~/components/*": ["./src/components/*"],
      "~/contents/*": ["./src/contents/*"]
    }
  }
}
