---
import kestraLogo from "../../assets/kestra-logo-big.png"

interface Props {
    title: string
}

const { title } = Astro.props
---

<div class="home-page-header">
    <h2>{title}</h2>
    <slot />
</div>

<style lang="scss">
    .home-page-header {
        h2 {
            padding-top: 0;
            font-size: 1rem;
            font-weight: 400;
            margin: 1rem 0;
            &::before {
                display: none;
            }
        }

        .kestra-logo {
            display: none;
            @include media-breakpoint-up(md) {
                display: block;
            }
            float: right;
            width: 132px;
            margin: 3rem;
            margin-top: 0;
        }
    }
</style>
