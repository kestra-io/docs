---
interface Props {
  href?: string;
  variant?: 'primary' | 'outline';
  type?: 'button' | 'submit';
}
const { href, variant = 'primary', type = 'button' } = Astro.props;
---
{href
  ? <a href={href} data-variant={variant}><slot /></a>
  : <button type={type} data-variant={variant}><slot /></button>
}