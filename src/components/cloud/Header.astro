---
import { Image } from "astro:assets"
import { Icon } from "astro-icon/components"

import cloudVisual from "~/components/cloud/assets/cloud.svg"
import gradient1 from "~/components/cloud/assets/gradient-1.svg"
import gradient2 from "~/components/cloud/assets/gradient-2.svg"
import soc2Img from "~/components/layout/assets/soc2.png"
import gdprImg from "~/components/layout/assets/gdpr.svg"

import CloudForm from "~/components/cloud/Form.vue"

const FEATURES = [
    {
        icon: "mdi:gift-outline",
        title: "Up to 3 months free",
        desc: "Full access while you get set up.",
    },
    {
        icon: "mdi:autorenew",
        title: "We handle the upgrades",
        desc: "Hosting, scaling and version upgrades, managed for you.",
    },
    {
        icon: "mdi:shield-lock-outline",
        title: "Stay Secure",
        desc: "Enterprise-grade RBAC, SSO, and audit logs.",
    },
    {
        icon: "mdi:server-outline",
        title: "Bring your own compute",
        desc: "Run tasks in your own environment. Your data never leaves your server.",
    },
]

const TRUST_CENTER_URL =
    "https://app.drata.com/trust/0a8e867d-7c4c-4fc5-bdc7-217f9c839604"
---

<section class="header">
    <div class="row m-0">
        <div class="col-xl-6 col-12 left-column">
            <div class="img-title" data-usal="fade-r">
                <Image src={cloudVisual} alt="Cloud Visual" />
                <h1>
                    Kestra, fully managed.<br /><span class="highlight"
                        >Try it today.</span
                    >
                </h1>
            </div>

            <div class="description" data-usal="fade-r">
                <h2>You build the pipelines.<br />We run the platform.</h2>
                <p>
                    Kestra, managed by the team that built it. We handle
                    hosting, scaling and upgrades, with SSO, custom roles, a
                    secret manager, remote runners and Apps, without operating
                    any of it.
                </p>
            </div>

            <div class="feature-grid">
                {
                    FEATURES.map((f, index) => (
                        <div
                            class="feature-item"
                            data-usal={`fade-u delay-${index * 50}`}
                        >
                            <div class="title-row">
                                <Icon name={f.icon} class="icon" />
                                <h5>{f.title}</h5>
                            </div>
                            <small>{f.desc}</small>
                        </div>
                    ))
                }
            </div>

            <div class="trust" data-usal="fade-u">
                <div class="bottom-tiles">
                    <a href={TRUST_CENTER_URL} target="_blank" class="tile">
                        <Image src={soc2Img} alt="SOC 2" />
                        <small>SOC 2 Type 1 / Type 2</small>
                    </a>
                    <a href={TRUST_CENTER_URL} target="_blank" class="tile">
                        <Image src={gdprImg} alt="GDPR" />
                        <small>GDPR</small>
                    </a>
                </div>
                <small class="trust-verified">
                    Verified on our <a href={TRUST_CENTER_URL} target="_blank"
                        >Trust Center</a
                    >
                </small>
            </div>
        </div>

        <div class="col-xl-6 col-12 right-column" id="get-access">
            <div class="form-container" data-usal="zoomin-d">
                <CloudForm client:idle />
            </div>
            <img
                src={gradient1.src}
                class="gradient gradient-1"
                alt="gradient"
            />
            <img
                src={gradient2.src}
                class="gradient gradient-2"
                alt="gradient"
            />
        </div>
    </div>
</section>

<style lang="scss">
    .header {
        overflow: hidden;

        .row {
            .left-column {
                background: url("~/components/cloud/assets/left-bg.png")
                    no-repeat center / cover;
                padding: $rem-2;
                @include media-breakpoint-up(lg) {
                    padding: 5rem 7.75rem;
                }
                display: flex;
                flex-direction: column;
                gap: $rem-2;

                .img-title {
                    display: flex;
                    align-items: center;
                    gap: $rem-1;

                    @include media-breakpoint-down(md) {
                        flex-direction: column;
                        align-items: center;
                    }
                }

                .description {
                    h2 {
                        margin-bottom: $rem-1;
                    }
                    @include media-breakpoint-up(lg) {
                        max-width: 612px;
                        h2 {
                            font-size: 1.875rem;
                        }
                    }
                }

                .feature-grid {
                    display: grid;
                    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
                    gap: 1.8rem;

                    .feature-item {
                        display: flex;
                        flex-direction: column;
                        gap: 0.5rem;

                        .title-row {
                            display: flex;
                            align-items: center;
                            gap: 0.5rem;

                            .icon {
                                font-size: $font-size-lg;
                                color: var(--ks-icon-color);
                                flex-shrink: 0;
                            }
                            h5 {
                                margin: 0;
                            }
                        }

                        small {
                            font-size: $font-size-sm;
                            color: var(--ks-content-secondary);
                        }
                    }
                }

                .trust {
                    display: flex;
                    flex-direction: column;
                    gap: 0.75rem;
                    margin-top: $rem-2;

                    .trust-verified {
                        font-size: $font-size-xs;
                        font-family: $font-family-monospace;
                        color: var(--ks-content-secondary);

                        a {
                            color: var(--ks-content-color-highlight);
                            text-decoration: none;
                            &:hover {
                                text-decoration: underline;
                            }
                        }
                    }
                }

                .bottom-tiles {
                    display: flex;
                    max-width: 316px;
                    border: 1px solid var(--ks-border-secondary);
                    border-radius: $border-radius-lg;
                    overflow: hidden;
                    background: var(--ks-background-secondary);

                    .tile {
                        flex: 1;
                        display: flex;
                        flex-direction: column;
                        align-items: center;
                        gap: $rem-1;
                        padding: $rem-1 $rem-2;
                        text-decoration: none;
                        color: inherit;

                        &:first-child {
                            border-right: 1px solid var(--ks-border-secondary);
                        }

                        img {
                            width: 45px;
                            height: 45px;
                            transition: transform 0.2s ease-in-out;
                            &:hover {
                                transform: scale(1.1);
                            }
                        }

                        small {
                            font-size: $font-size-xs;
                            font-family: $font-family-monospace;
                            color: var(--ks-content-secondary);
                            line-height: 1;
                            white-space: nowrap;
                        }
                    }
                }
            }

            .right-column {
                background: #141414;
                position: relative;
                overflow: hidden;
                padding: $rem-4 $rem-1;
                display: flex;
                flex-direction: column;
                align-items: stretch;
                justify-content: stretch;
                min-height: 100%;

                .form-container {
                    position: relative;
                    z-index: 10;
                    width: 100%;
                    flex: 1;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                .gradient {
                    position: absolute;
                    right: 0;
                    width: 100%;
                    height: 100%;

                    @include media-breakpoint-down(lg) {
                        object-fit: cover;
                        pointer-events: none;
                    }

                    &-1 {
                        top: 0;
                    }
                    &-2 {
                        bottom: -10rem;
                    }
                }
            }
        }
    }
</style>
