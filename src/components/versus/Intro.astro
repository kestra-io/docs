---
import BrandedHero from "~/components/common/BrandedHero.astro"
import swordSvg from "./assets/sword.svg?raw"

interface Props {
    title?: string | null
    description?: string
    competitor?: {
        name?: string
        monogram?: string
    }
    secondaryCta?: {
        label: string
        href: string
    }
}

const {
    title,
    description,
    competitor,
    secondaryCta = { label: "Book a Demo", href: "/demo" },
} = Astro.props as Props
---

<BrandedHero
    title={title ?? ""}
    description={description ?? ""}
    cta={{ label: "Get Started", href: "/get-started" }}
    {secondaryCta}
    secondaryIcon={competitor?.monogram}
    secondaryLabel={competitor?.name}
    highlightKestraOnlyAtStart={true}
>
    <div class="sword" slot="between" set:html={swordSvg} aria-hidden="true" />
</BrandedHero>

<style lang="scss">
    .sword {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 60px;
        flex-shrink: 0;

        :global(svg) {
            width: 100%;
            height: 100%;
        }

        @include media-breakpoint-down(md) {
            width: 36px;
            height: 40px;
        }
    }
</style>
