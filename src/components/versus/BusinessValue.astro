---
import { Image } from "astro:assets"
import kestraLogo from "./assets/ks.svg?raw"
import Card from "~/components/common/CardPair.astro"

interface Props {
    mainTitle?: string
    kestra?: {
        title?: string
        list?: string[]
    }
    competitor?: {
        logo?: any
        title?: string
        list?: string[]
        shadowColor?: string
        bulletColor?: string
    }
    footerText?: string
}

const { mainTitle, kestra, competitor, footerText } = Astro.props as Props
---

<section>
    <div class="container">
        <h2 set:html={mainTitle} />
        <div class="comparison-box d-flex flex-column flex-lg-row">
            <Card isKestra={true} logo={kestraLogo} logoAlt="Kestra logo">
                <h5>{kestra?.title}</h5>
                <ul>
                    {kestra?.list?.map((item) => <li>{item}</li>)}
                </ul>
            </Card>
            <Card
                logo={competitor?.logo}
                logoAlt="Competitor logo"
                shadowColor={competitor?.shadowColor}
            >
                <h5>{competitor?.title}</h5>
                <ul>
                    {competitor?.list?.map((item: any) => <li>{item}</li>)}
                </ul>
            </Card>
        </div>
        {footerText && <p class="footer-text" set:html={footerText} />}
    </div>
</section>

<style
    lang="scss"
    define:vars={{
        competitorShadowColor: competitor?.shadowColor,
        competitorBulletColor: competitor?.bulletColor,
    }}
>
    section {
        padding: $spacer * 4 0;
        background: var(--ks-background-body);

        @include media-breakpoint-down(lg) {
            padding: $spacer * 2 0.75rem;
        }

        .container {
            display: flex;
            flex-direction: column;
            gap: $rem-2;

            @include media-breakpoint-up(lg) {
                padding: 0;
            }
        }

        .comparison-box {
            gap: $rem-2;
            width: 100%;

            :global(.kestra) li::before {
                color: $primary;
            }

            :global(.competitor) li::before {
                color: var(--competitorBulletColor);
            }

            ul {
                list-style: none;
                padding: 0;
                margin: 0;

                li {
                    font-size: $font-size-md;
                    line-height: 1.4;
                    display: flex;
                    gap: $spacer * 0.5;
                    margin-bottom: 0.25rem;

                    &::before {
                        content: "→";
                        display: inline-block;
                        font-weight: bold;
                    }
                }
            }
        }

        .footer-text {
            max-width: 850px;
            color: var(--ks-content-primary);
            text-align: center;
            margin-inline: auto;
            @include media-breakpoint-up(lg) {
                font-size: $h5-font-size;
            }
        }
    }
</style>
