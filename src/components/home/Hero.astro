---
import DeclarativeIcon from "./assets/hero/declarative.svg"
import AnyLangIcon from "./assets/hero/any-lang.svg"
import ApiFirstIcon from "./assets/hero/api-first.svg"
import PluginsIcon from "./assets/hero/plugin.svg"
import LockInIcon from "./assets/hero/lock-in.svg"
import SelfHostedIcon from "./assets/hero/self-hosted.svg"
import CloudIcon from "./assets/hero/cloud.svg"
import HeroAnimation from "~/components/common/animations/hero.astro"
---

<section aria-labelledby="hero-heading">
    <div class="hero">
        <h1 id="hero-heading">
            One Platform to Run and Control
            <span class="gradient">All Your Workflows</span>
        </h1>
        <p>
            Kestra is the open-source orchestration platform for data, AI, and
            infrastructure workflows. Event-driven, language-agnostic, and built
            for enterprise scale.
        </p>
        <div class="tags">
            <span><DeclarativeIcon />Declarative</span>
            <span><AnyLangIcon />Any Language</span>
            <span><ApiFirstIcon />API-First</span>
            <span><PluginsIcon />1200+ Plugins</span>
            <span><LockInIcon />No Lock-in</span>
            <span><SelfHostedIcon />Self-Hosted</span>
            <span><CloudIcon />Cloud</span>
        </div>
        <div class="buttons">
            <a href="/get-started" class="btn btn-lg btn-primary me-3 mb-2">
                Get started
            </a>
            <a href="/pricing" class="btn btn-lg btn-secondary mb-2">
                See all plans
            </a>
        </div>

        <HeroAnimation class="animation" />
    </div>

    <style lang="scss">
        @use "~/assets/styles/variable" as *;

        section {
            margin-top: 4rem;
            background: url("./assets/hero/bg-grid.svg") no-repeat center bottom;
        }

        .hero {
            display: grid;
            grid-template-columns: 820px 1fr;
            gap: 1rem;
            color: var(--ks-content-primary);
            padding: 5rem;
            margin-inline: auto;
            max-width: 1400px;
        }

        .animation {
            grid-area: 1/2/6/2;
            position: absolute;
            right: 200px;
            @include media-breakpoint-up(lg) {
                left: 50%;
            }
        }

        .hero h1 {
            grid-area: 1/1/2/2;
            font-weight: 500;
            font-size: 3.5rem;
            line-height: 3.9375rem;
            margin-bottom: 1.5rem;
        }

        .gradient {
            background: linear-gradient(90deg, #718bfe, #c6d1ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p {
            grid-area: 2/1/3/2;
            font-size: 1.3rem;
            color: var(--ks-content-secondary);
        }

        .tags {
            grid-area: 3/1/4/2;
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-top: 1rem;
        }

        .tags span {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            border: $block-border;
            padding: 0.5rem 0.7rem;
            border-radius: 9999px;
            color: var(--ks-content-secondary);
            font-size: 0.875rem;
            svg {
                color: #718bfe;
                width: 18px;
                height: 18px;
            }
        }

        .buttons {
            grid-area: 4/1/5/2;
            margin-top: 2rem;
        }

        .hero-animation {
            background: url("/images/hero-animation.png") no-repeat center;
            background-size: contain;
        }
    </style>
</section>
