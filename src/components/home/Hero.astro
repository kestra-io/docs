---
import DeclarativeIcon from "./assets/hero/declarative.svg"
import AnyLangIcon from "./assets/hero/any-lang.svg"
import ApiFirstIcon from "./assets/hero/api-first.svg"
import PluginsIcon from "./assets/hero/plugin.svg"
import LockInIcon from "./assets/hero/lock-in.svg"
import SelfHostedIcon from "./assets/hero/self-hosted.svg"
import CloudIcon from "./assets/hero/cloud.svg"
import HeroAnimation from "./hero-animation.astro"
import AnimatedWord from "./AnimatedWord.vue"
---

<section aria-labelledby="hero">
    <div class="mobile-bg"></div>
    <div class="hero">
        <h1 id="hero">
            One Platform to <AnimatedWord
                words={["Run", "Control", "Govern"]}
                client:load
            />
            <br />
            <span class="gradient">All Your Workflows</span>
        </h1>
        <p>
            Kestra is the open-source orchestration platform for data, AI, and
            infrastructure workflows. Event-driven, language-agnostic, and built
            for enterprise scale.
        </p>
        <div class="tags">
            <span><DeclarativeIcon />Declarative</span>
            <span><AnyLangIcon />Any Language</span>
            <span><ApiFirstIcon />API-First</span>
            <span><PluginsIcon />1200+ Plugins</span>
            <span><LockInIcon />No Lock-in</span>
            <span><SelfHostedIcon />Self-Hosted</span>
            <span><CloudIcon />Cloud</span>
        </div>
        <div class="buttons">
            <a href="/docs/quickstart" class="btn btn-lg btn-primary me-3 mb-2">
                Get started
            </a>
            <a href="/pricing" class="btn btn-lg btn-secondary mb-2">
                See all plans
            </a>
        </div>
    </div>
    <div class="hero-animation">
        <HeroAnimation />
    </div>
</section>

<style lang="scss">
    @use "~/assets/styles/variable" as *;

    section {
        padding-top: 100px;
        position: relative;
        @include media-breakpoint-up(md) {
            padding-top: 2rem;
            background: url("./assets/hero/bg-grid.svg") no-repeat center bottom;
        }
    }

    .hero {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 5rem 2rem;
        margin-inline: auto;
        max-width: 1400px;
        overflow: hidden;
        position: relative;
        z-index: 2;
        margin-top: 20vw;
        @include media-breakpoint-up(md) {
            padding-right: 18rem;
            margin-top: 0;
        }
    }

    .mobile-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: url("./assets/hero/bg-mobile.png") no-repeat center center;
        background-size: cover;
        z-index: 0;
        @include media-breakpoint-up(md) {
            display: none;
        }
    }

    .hero-animation {
        position: absolute;
        right: 0;
        top: 50px;
        z-index: 1;
        display: none;

        @include media-breakpoint-up(md) {
            display: block;
            left: 50%;
            transform: scale(0.5) translateX(18%);
            width: auto;
        }
        @include media-breakpoint-up(xl) {
            left: 50%;
            transform: scale(0.8);
        }
    }

    .hero h1 {
        grid-area: 1/1/2/2;
        font-weight: 500;
        font-size: 1.8rem;
        @include media-breakpoint-up(md) {
            font-size: 3.5rem;
            line-height: 3.9375rem;
            margin-bottom: 1.5rem;
        }
    }

    .gradient {
        background: linear-gradient(90deg, #718bfe, #c6d1ff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .hero p {
        grid-area: 2/1/3/2;
        color: var(--hp-color-dark-secondary);
        @include media-breakpoint-up(md) {
            font-size: 1.3rem;
        }
    }

    .tags {
        display: none;
        @include media-breakpoint-up(md) {
            grid-area: 3/1/4/2;
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            max-width: 800px;
        }
    }

    .tags span {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0.5rem 0.7rem;
        border-radius: 9999px;
        color: var(--hp-color-dark-tertiary);
        font-size: 0.875rem;
        svg {
            color: #718bfe;
            width: 18px;
            height: 18px;
        }
    }

    .buttons {
        grid-area: 4/1/5/2;
        a {
            width: 100%;
        }
        @include media-breakpoint-up(md) {
            margin-top: 3rem;
            a {
                width: auto;
            }
        }
    }
</style>
