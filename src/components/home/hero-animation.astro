<style lang="scss">
    .stack-inner {
        width: 720px;
        height: 526px;
        position: relative;
    }
    .block {
        position: absolute;
        width: 720px;
        left: 0;
    }
    .block:nth-child(1) {
        top: 256px;
        z-index: 1;
    }
    .block:nth-child(2) {
        top: 83px;
        z-index: 2;
    }
    .block:nth-child(3) {
        top: -90px;
        z-index: 3;
    }
    .block:nth-child(1) {
        animation: float1 4s ease-in-out infinite 0s;
    }
    .block:nth-child(2) {
        animation: float2 4s ease-in-out infinite 0.8s;
    }
    .block:nth-child(3) {
        animation: float3 4s ease-in-out infinite 1.6s;
    }
    @keyframes float1 {
        0%,
        100% {
            transform: translateY(0px);
        }
        50% {
            transform: translateY(-10px);
        }
    }
    @keyframes float2 {
        0%,
        100% {
            transform: translateY(0px);
        }
        50% {
            transform: translateY(-10px);
        }
    }
    @keyframes float3 {
        0%,
        100% {
            transform: translateY(0px);
        }
        50% {
            transform: translateY(-10px);
        }
    }
    .ng-glow,
    .nb-glow,
    .na-glow {
        will-change: opacity;
    }
    .ng-glow {
        animation: stroke-glow 3s ease-in-out infinite 0s;
    }
    .nb-glow {
        animation: stroke-glow 3s ease-in-out infinite 0.4s;
    }
    .na-glow {
        animation: stroke-glow 3s ease-in-out infinite 0.8s;
    }
    @keyframes stroke-glow {
        0%,
        100% {
            opacity: 0;
        }
        50% {
            opacity: 1;
        }
    }

    /* Kestra pulse animation */
    .logo-inactive {
        filter: grayscale(1) brightness(0.7);
        transition:
            filter 0.6s ease,
            opacity 0.6s ease;
    }
    .logo-active {
        filter: grayscale(0) brightness(1);
        transition:
            filter 0.6s ease,
            opacity 0.6s ease;
    }
    .block:nth-child(3) svg g[id^="ai-logo"] {
        isolation: isolate;
    }

    .block svg {
        overflow: visible;
    }

    @keyframes dash-march {
        to {
            stroke-dashoffset: 180;
        }
    }
    :global([id^="corner-lines-"]) {
        :global(line) {
            opacity: 0.5;
            stroke-width: 1;
            stroke-dasharray: 4 7;
            stroke-dashoffset: 0;
            transition:
                stroke-width 0.3s ease,
                opacity 0.3s ease;
            filter: grayscale(1);
        }
        &:global(.corner-lines-active line) {
            opacity: 0.75;
            stroke-width: 2;
            stroke-dasharray: 4 7;
            animation: dash-march 4s linear infinite;
            filter: grayscale(0);
        }
    }

    @keyframes kestra-pulse {
        0%,
        100% {
            opacity: 0.15;
            transform: scale(0.85);
        }
        40% {
            opacity: 1;
            transform: scale(1.2);
        }
        65% {
            opacity: 0.5;
            transform: scale(1);
        }
    }
    @keyframes kestra-pulse-pink {
        0%,
        100% {
            opacity: 0.15;
            transform: scale(0.85);
        }
        40% {
            opacity: 1;
            transform: scale(1.2);
        }
        65% {
            opacity: 0.5;
            transform: scale(1);
        }
    }
    .kestra-anim path {
        opacity: 0.15;
        transform-box: fill-box;
        transform-origin: center;
        will-change: transform, opacity;
        animation: kestra-pulse 1.6s ease-in-out infinite;
    }
    .kestra-anim path:nth-child(1) {
        animation-delay: 0s;
    }
    .kestra-anim path:nth-child(2) {
        animation-delay: 0.18s;
    }
    .kestra-anim path:nth-child(3) {
        animation-delay: 0.36s;
    }
    .kestra-anim path:nth-child(4) {
        animation-delay: 0.54s;
    }
    .kestra-anim path:nth-child(5) {
        animation-delay: 0.72s;
    }
    .kestra-anim path:nth-child(6) {
        animation-delay: 0.9s;
    }
    .kestra-anim path:nth-child(7) {
        animation-delay: 1.08s;
        animation-name: kestra-pulse-pink;
    }

    @keyframes glowPulse {
        0%,
        100% {
            opacity: 0.8;
        }
        50% {
            opacity: 1;
        }
    }
</style>
<script>
    // Randomise animation durations on load
    ;(function () {
        function r(min: number, max: number) {
            return (min + Math.random() * (max - min)).toFixed(2) + "s"
        }

        // Float des blocs
        const blocks = document.querySelectorAll(".block")
        blocks.forEach((b) => {
            const dur = r(3, 6)
            ;(b as HTMLElement).style.animationDuration = dur
        })

        // Pulse lueurs violettes (glowPulse)
        document.querySelectorAll('[style*="glowPulse"]').forEach((el) => {
            const cur = (el as HTMLElement).style.animation
            ;(el as HTMLElement).style.animation = cur.replace(
                /[\d.]+s/,
                r(1.8, 4),
            )
        })

        // Kestra paths
        document.querySelectorAll(".kestra-anim path").forEach((p) => {
            ;(p as HTMLElement).style.animationDuration = r(1.2, 2.8)
        })

        // Background glow
        const bg = document.querySelector('[style*="bgGlowPulse"]')
        if (bg) (bg as HTMLElement).style.animationDuration = r(2.5, 5)
    })()
</script>

