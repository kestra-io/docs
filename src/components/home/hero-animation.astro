    function setLabelRunning(i: number, color: string) {
        const l = labelGroups[i]
        if (!l) return
        l.g.setAttribute("opacity", "1")
        // Reset and show Kestra animated logo, hide check
        const kg = l.g.querySelector(".kestra-anim")
        if (kg) {
            // Reset animation
            ;(kg as HTMLElement).querySelectorAll("path").forEach((p, ki) => {
                p.style.animationName =
                    ki === 6 ? "kestra-pulse-pink" : "kestra-pulse"
                p.style.opacity = "0.15"
                p.style.transform = ""
            })
            ;(kg as HTMLElement).style.transition = "none"
            ;(kg as HTMLElement).style.opacity = "1"
            kg.setAttribute("opacity", "1")
        }
        l.iconG.setAttribute("opacity", "0")
        l.iconG.style.opacity = "0"
        const tgIds = ["txtC", "txtB", "txtA"]
        l.text.setAttribute("fill", "url(#" + tgIds[i] + ")")
        l.text.textContent = runLabels[i]
        // Different speed per block so final displayed value differs
        // Infra: slow (~2s shown), Data: medium (~1.2s), AI: fast (~0.8s)
        const speeds = [0.51, 0.31, 0.21]
        const speed = speeds[i]
        if (timerIntervals[i]) clearInterval(timerIntervals[i])
        timerStarts[i] = Date.now()
        if (l.timer) {
            l.timer.textContent = "0.00s"
            l.timer.setAttribute("fill", GRAY)
            timerIntervals[i] = setInterval(() => {
                const elapsed = ((Date.now() - timerStarts[i]) / 1000) * speed
                l.timer.textContent = elapsed.toFixed(2) + "s"
            }, 50)
        }
    }

    function animateCornerLines(layer: string) {
        // Brighten the SVG corner lines for this block and add marching animation
        const g = document.getElementById("corner-lines-" + layer)
        if (!g) return
        g.classList.add("corner-lines-active")
        // Auto-deactivate after 2s
        setTimeout(() => {
            g.classList.remove("corner-lines-active")
        }, 2000)
    }

    function setLabelDone(i: number) {
        const l = labelGroups[i]
        if (!l) return
        spinning[i] = false
        if (spinRAFs[i]) {
            cancelAnimationFrame(spinRAFs[i])
            spinRAFs[i] = null
        }
        if (timerIntervals[i]) {
            clearInterval(timerIntervals[i])
            timerIntervals[i] = null
        }
        // Stop Kestra animation - fully colored
        const kg2 = l.g.querySelector(".kestra-anim")
        if (kg2) {
            kg2.querySelectorAll("path").forEach((p) => {
                p.style.animationName = "none"
                p.style.opacity = "1"
                p.style.transform = "scale(1)"
            })
            // Fade out Kestra logo
            ;(kg2 as HTMLElement).style.transition = "opacity 0.4s ease"
            setTimeout(() => {
                ;(kg2 as HTMLElement).style.opacity = "0"
            }, 200)
        }

        // Fade in check after short delay
        setTimeout(() => {
            l.iconG.setAttribute("opacity", "1")
            l.iconG.setAttribute("transform", "translate(-18,-12) scale(1.1)")
            l.iconPath.setAttribute("d", CHECK_PATH)
            l.iconPath.setAttribute("fill", GREEN)
            l.iconG.style.transition = "opacity 0.4s ease"
            l.iconG.style.opacity = "0"
            requestAnimationFrame(() => {
                l.iconG.style.opacity = "1"
            })
        }, 300)

        // Hide Kestra anim, show check (handled above with delay)
        const tgIdsDone = ["txtC", "txtB", "txtA"]
        l.text.setAttribute("fill", "url(#" + tgIdsDone[i] + ")")
        l.text.textContent = doneLabels[i]
        if (l.timer) {
            // Freeze at current displayed value (already scaled by speed)
            const frozen = l.timer.textContent
            if (timerIntervals[i]) {
                clearInterval(timerIntervals[i])
                timerIntervals[i] = null
            }
            l.timer.textContent = frozen
            l.timer.setAttribute("fill", GRAY)
            l.timer.setAttribute("opacity", "0.6")
        }
    }

    function setLabelIdle(i: number) {
        const l = labelGroups[i]
        if (!l) return
        spinning[i] = false
        if (spinRAFs[i]) {
            cancelAnimationFrame(spinRAFs[i])
            spinRAFs[i] = null
        }
        if (timerIntervals[i]) {
            clearInterval(timerIntervals[i])
            timerIntervals[i] = null
        }
        l.g.setAttribute("opacity", "0")
        const kg = l.g && l.g.querySelector(".kestra-anim")
        if (kg) kg.setAttribute("opacity", "0")
        l.iconG.setAttribute("opacity", "0")
        if (l.timer) l.timer.textContent = ""
    }

