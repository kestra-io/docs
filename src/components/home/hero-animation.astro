                        el.classList.remove("logo-inactive")
                        el.classList.add("logo-active")
                        el.style.opacity = "1"
                    } else {
                        el.classList.remove("logo-active")
                        el.classList.add("logo-inactive")
                        el.style.opacity = "0.5"
                    }
                },
                delay + (inOut ? i * 120 : i * 30),
            )
        })
    }

