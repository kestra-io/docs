<script>
    const blocks = document.querySelectorAll(".block")
    const blockInfra = blocks[0]
    const blockData = blocks[1]
    const blockAI = blocks[2]

    const infraLogos = ["ic-logo-1", "ic-logo-2", "ic-logo-3", "ic-logo-4"]
    const dataLogos = ["dt-logo-1", "dt-logo-2", "dt-logo-3", "dt-logo-4"]
    const aiLogos = ["ai-logo-1", "ai-logo-2", "ai-logo-3", "ai-logo-4"]
    const colors = { infra: "#ff9900", data: "#4090ff", ai: "#2dff5c" }

    // ── Block glow + animated border ──────────────────────────────────────
    // We inject a rotating gradient border overlay into the SVG when active
    // The isometric top face path: M60,175 L360,55 L660,175 L360,295 Z
    // The front faces paths are also animated

    let borderAnims: { [key: number]: number } = {} // blockIndex -> animFrame id

    function setBlockGlow(block: HTMLElement, active: boolean, color: string) {
        const svg = block.querySelector("svg")
        if (!svg) return
        const idx = Array.from(document.querySelectorAll(".block")).indexOf(
            block,
        )

        // Cancel previous anim
        if (borderAnims[idx]) {
            cancelAnimationFrame(borderAnims[idx])
            delete borderAnims[idx]
        }

        // Remove existing overlay
        const old = svg.querySelector("#border-overlay-" + idx)
        if (old) old.remove()

        svg.style.transition = "filter 0.7s ease"
        if (!active) {
            svg.style.filter = ""
            return
        }

        svg.style.filter = `drop-shadow(0 0 10px ${color}) drop-shadow(0 0 22px ${color}55)`

        // Create defs for conic gradient (simulated via SVG)
        // We use a <linearGradient> that we rotate over time
        const ns = "http://www.w3.org/2000/svg"
        const defs =
            svg.querySelector("defs") ||
            svg.insertBefore(
                document.createElementNS(ns, "defs"),
                svg.firstChild,
            )

        // Create gradient
        const gradId = "border-grad-" + idx
        let grad = defs.querySelector("#" + gradId)
        if (!grad) {
            grad = document.createElementNS(ns, "linearGradient")
            grad.setAttribute("id", gradId)
            grad.setAttribute("gradientUnits", "userSpaceOnUse")
            // stops: color → white → color
            ;[
                [0, "#ffffff"],
                [0.3, color],
                [0.6, "#ffffff"],
                [1, color],
            ].forEach(([o, c]) => {
                const stop = document.createElementNS(ns, "stop")
                stop.setAttribute("offset", String(o))
                stop.setAttribute("stop-color", String(c))
                grad!.appendChild(stop)
            })
            defs.appendChild(grad)
        }

        // Create overlay group
        const g = document.createElementNS(ns, "g")
        g.setAttribute("id", "border-overlay-" + idx)
        g.setAttribute("pointer-events", "none")

        // Top face border
        const top = document.createElementNS(ns, "path")
        top.setAttribute("d", "M60,175 L360,55 L660,175 L360,295 Z")
        top.setAttribute("fill", "none")
        top.setAttribute("stroke", `url(#${gradId})`)
        top.setAttribute("stroke-width", "2.5")
        top.setAttribute("opacity", "0.9")
        g.appendChild(top)

        // Front left face
        const fl = document.createElementNS(ns, "path")
        fl.setAttribute("d", "M60,175 L360,295 L360,337 L60,217 Z")
        fl.setAttribute("fill", "none")
        fl.setAttribute("stroke", `url(#${gradId})`)
        fl.setAttribute("stroke-width", "2.5")
        fl.setAttribute("opacity", "0.7")
        g.appendChild(fl)

        // Front right face
        const fr = document.createElementNS(ns, "path")
        fr.setAttribute("d", "M660,175 L360,295 L360,337 L660,217 Z")
        fr.setAttribute("fill", "none")
        fr.setAttribute("stroke", `url(#${gradId})`)
        fr.setAttribute("stroke-width", "2.5")
        fr.setAttribute("opacity", "0.7")
        g.appendChild(fr)

        svg.insertBefore(g, svg.querySelector("g[filter]") || svg.lastChild)

        // Animate gradient rotation by updating x1,y1,x2,y2
        let angle = 0
        const cx = 360,
            cy = 175 // center of the isometric shape
        const r = 320
        function animBorder() {
            angle += 1.2
            const rad = (angle * Math.PI) / 180
            grad!.setAttribute("x1", String(cx + Math.cos(rad) * r))
            grad!.setAttribute("y1", String(cy + Math.sin(rad) * r))
            grad!.setAttribute("x2", String(cx + Math.cos(rad + Math.PI) * r))
            grad!.setAttribute("y2", String(cy + Math.sin(rad + Math.PI) * r))
            borderAnims[idx] = requestAnimationFrame(animBorder)
        }
        animBorder()

        // Activate/deactivate spin border
        const filterIds = ["glC", "glB", "glA"]
        const borderId = "spin-border-" + filterIds[idx]
        const borderEl = svg.querySelector("#" + borderId)
        if (borderEl) {
            if (active) {
                borderEl.classList.remove("active")
                void (borderEl as HTMLElement).offsetWidth // reflow to restart animation
                borderEl.classList.add("active")
            } else {
                borderEl.classList.remove("active")
            }
        }
    }

    // ── Logo fade ──────────────────────────────────────────────────────────
    function fadeLogos(
        ids: string[],
        inOut: boolean,
        delay = 0,
        duration = 0.5,
    ) {
        ids.forEach((id, i) => {
            const el = document.getElementById(id)
            if (!el) return
            setTimeout(
                () => {
