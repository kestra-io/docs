    // Store original loop 1 logos
    const loop1Logos: Record<string, string> = {}

    function captureLoop1Logos() {
        Object.keys(loop2Logos).forEach((id) => {
            const el = document.getElementById(id)
            if (el) loop1Logos[id] = el.innerHTML
        })
    }

    function swapLogos(toLoop2: boolean) {
        Object.keys(loop2Logos).forEach((id) => {
            const el = document.getElementById(id)
            if (!el) return
            el.innerHTML = toLoop2
                ? loop2Logos[id as keyof typeof loop2Logos]
                : loop1Logos[id] || ""
            // Restore inactive state
            el.classList.remove("logo-active")
            el.classList.add("logo-inactive")
            el.style.opacity = "0.5"
        })
        // Adjust positions for loop 2 specific logos
        const ic3 = document.getElementById("ic-logo-3")
        const ic4 = document.getElementById("ic-logo-4")
        if (ic3)
            ic3.setAttribute(
                "transform",
                toLoop2
                    ? "translate(498,147) skewY(-22) scale(0.87)"
                    : "translate(378,137) skewY(-22) scale(0.87)",
            )
        if (ic4)
            ic4.setAttribute(
                "transform",
                toLoop2
                    ? "translate(580,157) skewY(-22) scale(0.87) translate(-218,-59)"
                    : "translate(520,137) skewY(-22) scale(0.87) translate(-218,-59)",
            )
    }

    let currentLoop = 1
    function switchLoopLogos() {
        currentLoop = currentLoop === 1 ? 2 : 1
        swapLogos(currentLoop === 2)
    }

    // ── Sequencer ──────────────────────────────────────────────────────────
    const PHASE = 5000
    const TRANS = 500

    function runPhase(phase: number) {
        const allLogos = [infraLogos, dataLogos, aiLogos]

        // Reset all glows
        ;[blockInfra, blockData, blockAI].forEach((b) =>
            setBlockGlow(b as HTMLElement, false, ""),
        )

        // On restart (phase 0), reset everything and switch loops
        if (phase === 0) {
            switchLoopLogos()
            // Reset all logos to inactive state
            ;[...infraLogos, ...dataLogos, ...aiLogos].forEach((id) => {
                const el = document.getElementById(id)
                if (!el) return
                el.classList.remove("logo-active")
                el.classList.add("logo-inactive")
                el.style.opacity = "0.5"
            })
            ;[0, 1, 2].forEach((i) => setLabelIdle(i))
            // Reset corner lines
            document.querySelectorAll('[id^="corner-lines-"]').forEach((g) => {
                g.classList.remove("corner-lines-active")
            })
        }

        setTimeout(() => {
            const phaseNames = ["infra", "data", "ai"]
            const blockList = [blockInfra, blockData, blockAI]
            const colorList = [colors.infra, colors.data, colors.ai]
            const block = blockList[phase]
            const color = colorList[phase]

            setBlockGlow(block as HTMLElement, true, color)
            fadeLogos(allLogos[phase], true)
            setLabelRunning(phase, color)

            // At 78% → switch to done
            setTimeout(() => {
                setLabelDone(phase)
                animateCornerLines(phaseNames[phase])
            }, PHASE * 0.78)
        }, TRANS)

        setTimeout(() => runPhase((phase + 1) % 3), PHASE + TRANS)
    }

    // Reset all to idle at start
    ;[0, 1, 2].forEach((i) => setLabelIdle(i))
    captureLoop1Logos()
    setTimeout(() => setBlockGlow(blockAI as HTMLElement, false, ""), 100)
    runPhase(0)

    // ── Particules lueur AI ─────────────────────────────────────────────────
    ;(function () {
        const COLORS = ["#8A2EF2", "#a050f8", "#C08EF9", "#d4aaff", "#ffffff"]
        function rand(min: number, max: number) {
            return min + Math.random() * (max - min)
        }

        function initParticles(canvasId: string, count: number): () => void {
            const canvas = document.getElementById(
                canvasId,
            ) as HTMLCanvasElement | null
            if (!canvas) return () => {}
            const ctx = canvas.getContext("2d")!
            const W = canvas.width,
                H = canvas.height

            class Particle {
                x!: number
                y!: number
                vy!: number
                size!: number
                alpha!: number
                color!: string
                life!: number
                maxLife!: number
                opacity!: number
                constructor() {
                    this.reset(true)
                }
                reset(init: boolean) {
                    this.x = rand(20, W - 20)
                    this.y = init ? rand(0, H) : H - 30 + rand(0, 10)
                    this.vy = rand(0.3, 1.1)
                    this.size = rand(0.8, 2.2)
                    this.alpha = rand(0.3, 0.9)
                    this.color =
                        COLORS[Math.floor(Math.random() * COLORS.length)]
                    this.life = 0
                    this.maxLife = rand(60, 180)
                }
                update() {
                    this.y -= this.vy
                    this.life++
                    const t = this.life / this.maxLife
                    this.opacity =
                        t < 0.2 ? t / 0.2 : t > 0.75 ? 1 - (t - 0.75) / 0.25 : 1
                    if (this.y < -5 || this.life >= this.maxLife)
                        this.reset(false)
                }
                draw() {
                    ctx.save()
                    ctx.globalAlpha = this.alpha * this.opacity
                    ctx.fillStyle = this.color
                    ctx.shadowColor = this.color
                    ctx.shadowBlur = 4
                    ctx.beginPath()
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2)
                    ctx.fill()
                    ctx.restore()
                }
            }

            const particles = Array.from(
                { length: count },
                () => new Particle(),
            )
            return function tick() {
                ctx.clearRect(0, 0, W, H)
                particles.forEach((p) => {
                    p.update()
                    p.draw()
                })
            }
        }

        const particleTicks = [
            initParticles("glow-particles", 22),
            initParticles("glow-particles-b", 22),
            initParticles("glow-particles-c", 22),
        ]
        function particleLoop() {
            particleTicks.forEach((tick) => tick())
            requestAnimationFrame(particleLoop)
        }
        particleLoop()
    })()
</script>
