---
import { Image } from "astro:assets"

import agent from "./assets/overview/agent.png"
import code from "./assets/overview/code.png"
import eventDriven from "./assets/overview/event-driven.png"
import governance from "./assets/overview/governance.png"

const images = [
    {
        src: code,
        alt: "Code workflows",
        className: "code-workflow",
        title: "Declarative Orchestration",
        description:
            "Write workflows in YAML. Version them. Review them. Ship them.",
    },
    {
        src: agent,
        alt: "Agent workflows",
        className: "agent-workflow",
        title: "Connect Everything",
        description:
            "Cloud, data, infra, CI/CD, ITSM, messaging. Plug into your entire stack.",
    },
    {
        src: eventDriven,
        alt: "Event-driven workflows",
        className: "event-driven-workflow",
        title: "Batch and Event-Driven",
        description:
            "Cron, events, webhooks, messages. One engine to run them all.",
    },
    {
        src: governance,
        alt: "Governance workflows",
        className: "governance-workflow",
        title: "Governance and Reliability",
        description:
            "Retries, timeouts, SLAs, RBAC, audit logs. SOC 2, Built to run in production.",
    },
]
---

<section class="platform-overview" aria-labelledby="platform-heading">
    <h2 id="platform-heading">One Platform. All Your Workflows.</h2>
    <div class="platform-wrapper">
        <div class="image-stack">
            {
                images.map(({ src, alt, title, description, className }, i) => (
                    <figure>
                        <figcaption class={className}>
                            <h3>{title}</h3>
                            <p>{description}</p>
                        </figcaption>
                        <Image
                            src={src}
                            alt={alt}
                            class="stack-image"
                            style={`--i: ${i - (images.length - 1) / 2};`}
                            loading="lazy"
                        />
                    </figure>
                ))
            }
        </div>
    </div>
</section>

<script>
    const THRESHOLD = -250
    const stack = document.querySelector(".platform-wrapper")
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                const isEntryAboveTheFold =
                    entry.boundingClientRect.top < THRESHOLD
                entry.target.classList.toggle(
                    "expanded",
                    entry.isIntersecting || isEntryAboveTheFold,
                )
            })
        },
        { threshold: 0.6 },
    )
    if (stack) {
        observer.observe(stack)
    }
</script>

<style lang="scss">
    section {
        padding: 5rem 2rem;
        background-color: white;
        background-image:
            linear-gradient(
                to bottom,
                var(--hp-background-purple-light) 0%,
                var(--hp-background-purple-light) 1%,
                color-mix(
                        in srgb,
                        var(--hp-background-purple-light) 20%,
                        white 50%
                    )
                    40%,
                #ffffffdf 100%
            ),
            radial-gradient(
                ellipse at top center,
                transparent 0,
                #ffffff20 35%,
                #ffffff 70%
            ),
            linear-gradient(
                to right,
                var(--hp-border-secondary) 1px,
                transparent 1px
            ),
            linear-gradient(
                to bottom,
                var(--hp-border-secondary) 1px,
                transparent 1px
            );
        background-size:
            100% 100%,
            100% 100%,
            var(--hp-grid-size) var(--hp-grid-size),
            var(--hp-grid-size) var(--hp-grid-size);
        background-position: center bottom;
        color: var(--hp-content-secondary);
        text-align: center;
    }
    .platform-overview {
        text-align: center;
        padding: 4rem 0;
        color: var(--hp-content-primary);
    }

    .platform-wrapper {
        position: relative;
        max-width: 1250px;
        margin: 0 auto;
        padding: 0 1rem;
        --stack-offset: -320px;
        figure {
            border-radius: 0.5rem;
            overflow: hidden;
            border: 1px solid var(--hp-border-secondary);
            box-shadow: -10px 30px 20px rgba(167, 150, 255, 0.2);
        }
        @include media-breakpoint-up(md) {
            --stack-offset: -50px;
            &.expanded {
                --stack-offset: -150px;
                figcaption {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            figure {
                border: none;
            }
        }
        figcaption {
            position: static;
            transition: all 0.3s ease;
            background-color: #ffffffaa;
            padding: 1rem;
            border-radius: 0.5rem;
            @include media-breakpoint-up(md) {
                opacity: 0;
                background-color: transparent;
                position: absolute;
                width: 250px;
                z-index: 3;
                &:before {
                    content: "";
                    position: absolute;
                    z-index: 1;
                    width: 115px;
                    height: 1px;
                    background: var(--hp-border-secondary);
                    top: 2rem;
                }
                &:after {
                    content: "";
                    position: absolute;
                    z-index: 2;
                    width: 5px;
                    height: 5px;
                    border-radius: 4px;
                    background: var(--hp-border-secondary);
                    top: 30px;
                }
            }
            h3 {
                font-size: 1rem;
                margin-bottom: 0.5rem;
            }
            p {
                font-size: 0.8rem;
                color: var(--hp-content-secondary);
                margin: 0;
            }
        }
        .event-driven-workflow,
        .code-workflow {
            left: 1rem;
            text-align: left;
            @include media-breakpoint-up(md) {
                left: 0;
                text-align: right;
            }
            &:before {
                left: 100%;
            }
            &:after {
                right: -115px;
            }
        }

        .event-driven-workflow {
            top: 230px;
        }
        .code-workflow {
            bottom: 70px;
        }

        .governance-workflow,
        .agent-workflow {
            right: 0;

            text-align: left;
            &:before {
                right: 100%;
            }
            &:after {
                left: -115px;
            }
        }

        .governance-workflow {
            top: 80px;
        }
        .agent-workflow {
            bottom: 200px;
        }

        @include media-breakpoint-up(md) {
            .code-workflow,
            .agent-workflow {
                transform: translateY(-150px);
            }

            .event-driven-workflow,
            .governance-workflow {
                transform: translateY(150px);
            }
        }
    }

    .image-stack {
        position: relative;
        margin: 4rem auto 0;
        max-width: 1200px;
        @include media-breakpoint-up(md) {
            height: 700px;
        }
    }

    .stack-image {
        border-top: 1px solid var(--hp-border-secondary);
        @include media-breakpoint-up(md) {
            border: 1px solid var(--hp-border-secondary);
            border-radius: 1rem;
            position: absolute;
            z-index: 1;
            left: 51%;
            top: 30%;
            width: 438px;
            box-shadow:
                -3px 4px 0 0 var(--hp-border-secondary),
                -10px 30px 20px rgba(167, 150, 255, 0.2);
            transform: translateX(-50%)
                translateY(calc(var(--i) * var(--stack-offset, -50px)))
                scaleY(0.7) skew(20deg) rotate(-9deg);
            transition: transform 0.3s ease;
        }
    }
</style>
