---
import { Image } from "astro:assets"

const COMPANIES = [
    "brainlab",
    "bloomberg",
    "fila",
    "apple",
    "toyota",
    "jpmorgan",
    "t-system",
]
const logos = import.meta.glob<{ default: ImageMetadata }>(
    "/src/components/home/assets/companies/*.svg",
    { eager: true },
)
---

<div class:list={["logo-carousel"]}>
    <div class="companies-container">
        <div class="companies">
            {
                [...COMPANIES, ...COMPANIES].map((company, index) => (
                    <Image
                        src={
                            logos[
                                `/src/components/home/assets/companies/${company}.svg`
                            ].default
                        }
                        alt={company}
                        class:list={[
                            "company-logo",
                            { "d-lg-none": index >= COMPANIES.length },
                        ]}
                    />
                ))
            }
        </div>
    </div>
</div>

<style lang="scss">
    .logo-carousel {
        display: flex;
        flex-direction: column;
        margin: 1rem 0;
    }

    span {
        font-family: $font-family-monospace;
        font-size: $font-size-xs;
        color: var(--ks-content-primary);
        @include media-breakpoint-up(lg) {
            margin-bottom: 1rem;
        }
    }

    .companies-container {
        width: 100%;
        overflow: hidden;
        @include media-breakpoint-down(sm) {
            margin-top: 1rem;
            -webkit-mask-image: linear-gradient(
                to right,
                transparent,
                black 10%,
                black 90%,
                transparent
            );
            mask-image: linear-gradient(
                to right,
                transparent,
                black 10%,
                black 90%,
                transparent
            );
        }

        .companies {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 2px;

            @include media-breakpoint-up(sm) {
                gap: 2rem;
                margin-left: -14px;
            }
            @include media-breakpoint-up(xl) {
                gap: 3rem;
            }
            @include media-breakpoint-up(xxl) {
                gap: 5rem;
            }

            @include media-breakpoint-down(lg) {
                width: max-content;
                animation: marquee 20s linear infinite;
            }

            .company-logo {
                flex-shrink: 0;
                object-fit: contain;
                filter: brightness(0) invert(1);
            }
        }
    }

    @keyframes marquee {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }
</style>
