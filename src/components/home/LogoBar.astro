---
const svgModules = import.meta.glob<string>("/src/assets/companies/*.svg", {
    eager: true,
    import: "default",
})

const logos = Object.entries(svgModules)
    .map(([path, SvgComponent]) => ({
        name: path.split("/").pop()!.replace(".svg", ""),
        SvgComponent,
    }))
    // randomize the order of logos on each page load
    .sort((a, b) => 0.5 - Math.random())
---

<section class="logo-bar" aria-label="Trusted by leading companies">
    <div class="logo-bar-track-wrapper">
        <div class="logo-bar-track">
            {
                [...logos, ...logos].map(({ name, SvgComponent }) => (
                    <div class="logo-bar-item" aria-label={name}>
                        <SvgComponent />
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style lang="scss">
    .logo-bar {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 0;
    }

    .logo-bar-title {
        font-family: $font-family-monospace;
        font-size: $font-size-xs;
        color: var(--ks-content-primary);
        margin-bottom: 1rem;
    }

    .logo-bar-track-wrapper {
        width: 100%;
        overflow: hidden;
        position: relative;
        padding: 0.5rem;
    }

    .logo-bar-track {
        display: flex;
        align-items: center;
        gap: 3rem;
        width: max-content;
        animation: scroll-right 120s linear infinite;
    }

    .logo-bar-item {
        flex-shrink: 0;
        height: 40px;
        width: auto;
        min-width: 100px;
        display: flex;
        align-items: center;
        justify-content: center;

        :global(svg) {
            height: 100%;
            width: auto;
            display: block;
        }
    }

    @keyframes scroll-right {
        0% {
            transform: translateX(-50%);
        }
        100% {
            transform: translateX(0);
        }
    }
</style>
