---
import FeatureCard from "./FeatureCard.astro"
const features = [
    {
        eyebrow: "Pipelines",
        title: "Ship Pipelines Faster and Keep Them Reliable",
        body: "Standardize how your team builds and maintains data pipelines with built-in observability and rollbacks.",
        stats: [
            { value: "10x", label: "faster pipeline delivery" },
            { value: "90%", label: "reduction in pipeline failures" },
        ],
        cta: { label: "Explore data pipelines", href: "/pipelines" },
    },
    {
        eyebrow: "Infrastructure",
        title: "Automate Infrastructure With Governance, Not Scripts",
        body: "Provision, configure, and tear down infrastructure as code with full audit trails and approval flows.",
        stats: [
            { value: "6x", label: "faster provisioning" },
            { value: "80%", label: "less manual ops work" },
        ],
        cta: {
            label: "Explore infrastructure automation",
            href: "/infrastructure",
        },
    },
    {
        eyebrow: "Operations",
        title: "Operationalize AI Workflows Without Production Chaos",
        body: "Run, monitor, and govern LLM pipelines and AI agents with the same platform as your data workflows.",
        stats: [
            { value: "50x", label: "faster iteration" },
            { value: "3x", label: "fewer incidents" },
        ],
        cta: { label: "Explore AI orchestration", href: "/ai" },
    },
]
---

<section aria-labelledby="features-heading">
    <h2 id="features-heading" class="sr-only">Platform Features</h2>
    <ul role="list">
        {features.map((f) => <FeatureCard {...f} />)}
    </ul>
</section>
