---
import type { AshbyJob } from "~/utils/careers"
import FilterForm from "./FilterForm.vue"

interface Props {
    positions?: AshbyJob[]
}

const { positions = [] } = Astro.props

const departments = new Map<string, string>()
const locations = new Map<string, string>()

for (const position of positions) {
    if (position.department) {
        departments.set(position.department.id, position.department.name)
    }
    if (position.location) {
        locations.set(position.location.id, position.location.name)
    }
}
---

<section class="header-container">
    <div class="header container">
        <slot>
            <h1>Open roles</h1>
            <p>
                Drive innovation in a globally distributed, collaborative
                environment
            </p>
            <FilterForm
                departments={departments}
                locations={locations}
                client:idle
            />
        </slot>
    </div>
</section>

<style lang="scss">
    .header-container {
        --careers-grid-size: 55px;
        --careers-grid-color: color-mix(
            in srgb,
            var(--ks-border-secondary) 30%,
            var(--ks-background-purple-light) 70%
        );
        background-image:
            radial-gradient(
                ellipse farthest-side at 50% -40px,
                var(--ks-background-purple-hover) 0%,
                color-mix(
                        in srgb,
                        var(--ks-background-purple-hover),
                        transparent 5%
                    )
                    10%,
                color-mix(
                        in srgb,
                        var(--ks-background-purple-hover),
                        transparent 40%
                    )
                    15%,
                color-mix(in srgb, var(--ks-background-body), transparent 45%)
                    60%,
                var(--ks-background-body) 75%
            ),
            linear-gradient(
                to right,
                var(--careers-grid-color) 1px,
                transparent 1px
            ),
            linear-gradient(
                to bottom,
                var(--careers-grid-color) 1px,
                transparent 1px
            );
        background-size:
            110% 100%,
            var(--careers-grid-size) var(--careers-grid-size),
            var(--careers-grid-size) var(--careers-grid-size);
        background-position:
            center top,
            center bottom,
            center bottom;
        .header {
            padding-top: 9rem;
            padding-bottom: 2rem;

            h1 {
                font-weight: 600;
            }

            h1,
            p {
                color: var(--ks-content-primary);
                text-align: left;
                margin-bottom: 0.5rem;
            }

            p {
                margin-bottom: 2rem;
            }
        }
    }
</style>
