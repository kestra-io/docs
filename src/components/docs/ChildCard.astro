---
import { getCollection } from "astro:content"
import ChevronRightIcon from "vue-material-design-icons/ChevronRight.vue"
import MDCParserAndRenderer from "~/components/MDCParserAndRenderer.astro"
import generateId from "~/utils/generateId"

interface Props {
    title?: string
    directory?: string
}

const { title, directory } = Astro.props

const currentPage =
    directory ??
    (Astro.url.pathname.endsWith("/")
        ? Astro.url.pathname.slice(0, -1)
        : Astro.url.pathname)

const contentPath = currentPage.replace("/docs/", "")

const docs = await getCollection("docs")

const children = await Promise.all(
    docs
        .filter(
            (doc) =>
                doc.id.startsWith(`${contentPath}/`) &&
                !doc.id.slice(contentPath.length + 1).includes("/"),
        )
        .sort((a, b) => {
            if (a.filePath && b.filePath) {
                return a.filePath.localeCompare(b.filePath)
            }
            return a.id.localeCompare(b.id)
        })
        .map(async (doc) => {
            const firstLine = doc.body
                ?.split("\n")
                .find(
                    (line) =>
                        line.trim().length > 0 &&
                        !line.startsWith("#") &&
                        !line.trim().startsWith("import "),
                )
            const basePath = doc.id.replace(/\/[^/]+$/, "")
            const description =
                doc.data.description ??
                (firstLine
                    ? firstLine.replace(
                          /\[([^\]]+)\]\(([^)]+)\)/g,
                          (match, text, url) => {
                              if (url.startsWith(".")) {
                                  const resolvedPath = basePath
                                      ? `${basePath}/${url}`
                                      : url
                                  const newUrl = `/docs/${generateId({ entry: resolvedPath })}`
                                  return `[${text}](${newUrl})`
                              }
                              return match
                          },
                      )
                    : "")

            return {
                title: doc.data.title,
                description,
                path: `/docs/${doc.id}`,
                release: doc.data.release,
            }
        }),
)
---

{title ? <h2 class="ks-title">{title}</h2> : null}
<div class="ks-card-grid">
    {
        children.map((item) => (
            <a href={item.path} class="ks-card">
                <h4 class="ks-card-title">{item.title}</h4>
                <MDCParserAndRenderer
                    content={item.description}
                    class:list={["ks-card-text"]}
                />
                <ChevronRightIcon class="ks-card-icon" />
            </a>
        ))
    }
</div>

<style lang="scss">
    @import "~/assets/styles/variable";

    h2.ks-title {
        padding: 0;
        font-size: $font-size-xl;
        border: none;
        margin-top: 3rem;
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .ks-card-grid {
        display: grid;
        // as many 300px columns you can fit in the container with a minimum gap of 1rem
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1rem;

        .ks-card {
            border-radius: 0.75rem;
            text-decoration: none;
            background: var(--ks-background-primary);
            color: var(--ks-content-primary);
            border: 1px solid var(--ks-border-primary);
            box-shadow: 2px 3px 16px 0px var(--ks-shadows-light);
            transition: all 0.3s;
            padding: 1rem;
            padding-inline-end: 3rem;
            // show title adn description on the first column and the icon on the second column
            display: grid;
            grid-template-columns: 1fr 2rem;
            align-items: start;
            @include media-breakpoint-up(md) {
                gap: 1rem;
                grid-template-rows: 1rem 1fr;
                padding: 1.5rem;
            }
            h4 {
                font-size: 1rem;
                margin-bottom: 0.25rem;
                grid-area: 1 / 1 / 2 / 2;
                @include media-breakpoint-up(sm) {
                    height: 1rem;
                    overflow: hidden;
                    text-overflow: ellipsis;
                    white-space: nowrap;
                }
            }

            .ks-card-text {
                // show description under the title in the same column as the title
                grid-area: 2 / 1 / 3 / 2;
                font-size: 0.875rem;
                margin-bottom: 0;
                :global(p) {
                    color: var(--ks-content-secondary);
                    margin-bottom: 0;
                    overflow: hidden;
                    display: -webkit-box;
                    line-clamp: 3;
                    -webkit-line-clamp: 3;
                    -webkit-box-orient: vertical;
                    text-overflow: ellipsis;
                }
            }

            .ks-card-icon {
                // show the icon on the right side of the card
                grid-area: 1 / 2 / 3 / 3;
                align-self: center;
                color: var(--ks-content-secondary);
                font-size: 2rem;
                :global(svg) {
                    bottom: 0;
                }
            }

            &:hover {
                border-color: var(--ks-border-active);
                .ks-card-icon {
                    color: var(--ks-border-active);
                }
            }
        }
    }
</style>
