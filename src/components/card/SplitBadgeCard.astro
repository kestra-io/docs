---
import { Icon } from "astro-icon/components"

interface Item {
    title: string
    description: string
    wide?: boolean
}

interface Props {
    badge: string
    badgeIcon?: string
    title: string
    description: string
    items?: Item[]
    signal?: string
    rightWidth?: string
    rightHeight?: string
    rightHeightXl?: string
    rightHeightMd?: string
    hideRightOnSm?: boolean
    verticalAlign?: "center" | "stretch"
}

const {
    badge,
    badgeIcon,
    title,
    description,
    items: rawItems,
    signal,
    rightWidth = "625px",
    rightHeight,
    rightHeightXl,
    rightHeightMd,
    hideRightOnSm = false,
    verticalAlign = "stretch",
} = Astro.props as Props

const items: Item[] = [...(rawItems ?? [])]
if (signal) {
    items.push({ title: "What you get", description: signal, wide: true })
}

const rootStyle = [
    `--right-width: ${rightWidth}`,
    rightHeight ? `--right-height: ${rightHeight}` : null,
    rightHeightXl ? `--right-height-xl: ${rightHeightXl}` : null,
    rightHeightMd ? `--right-height-md: ${rightHeightMd}` : null,
]
    .filter(Boolean)
    .join("; ")

const cardClass = [
    "split-badge-card",
    `align-${verticalAlign}`,
    hideRightOnSm ? "hide-right-sm" : null,
]
---

<div class:list={cardClass} style={rootStyle}>
    {
        Astro.slots.has("mobile-image") && (
            <div class="mobile-image">
                <slot name="mobile-image" />
            </div>
        )
    }
    <div class="content">
        <div class="badge" data-usal="zoomin">
            {badgeIcon && <Icon name={badgeIcon} class="badge-icon" />}
            <span>{badge}</span>
        </div>
        <h3 set:html={title} data-usal="fade-r" />
        <p data-usal="fade-l" set:html={description} />
        {
            items.length > 0 && (
                <div class="items-grid">
                    {items.map((item) => (
                        <div
                            class:list={["item-card", { wide: item.wide }]}
                            data-usal="zoomin"
                        >
                            <h4>{item.title}</h4>
                            <p set:html={item.description} />
                        </div>
                    ))}
                </div>
            )
        }
        <slot name="extra" />
    </div>
    <div class="right">
        <slot name="right" />
    </div>
</div>

<script>
    document.addEventListener("astro:page-load", () => {
        const cards = document.querySelectorAll(".split-badge-card")
        if (cards.length === 0) return

        const observer = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    const card = entry.target as HTMLElement
                    card.classList.toggle("is-folded", !entry.isIntersecting)
                }
            },
            { threshold: 0.15 },
        )
        for (const card of cards) {
            observer.observe(card as HTMLElement)
        }
    })
</script>

<style lang="scss">
    .split-badge-card {
        position: relative;
        display: flex;
        flex-direction: row;
        width: 100%;
        padding-left: 4rem;
        justify-content: space-between;
        gap: 4rem;
        border-radius: 1rem;
        border: 1px solid var(--ks-border-secondary);
        background: var(--ks-background-primary);
        box-shadow: 2px 3px 16px 0 var(--ks-shadows-light);
        overflow: hidden;

        opacity: 1;
        transform: translateY(0) scale(1);
        transform-origin: center top;
        transition:
            opacity 0.55s ease-out,
            transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);

        &.align-stretch {
            align-items: stretch;
        }

        &.align-center {
            align-items: center;
        }

        @include media-breakpoint-down(xl) {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
            padding-left: 0;
        }

        &.is-folded {
            opacity: 0;
            transform: translateY(-32px) scale(0.94);
        }

        .mobile-image {
            display: none;
            object-fit: cover;
            width: 100%;

            @include media-breakpoint-down(sm) {
                display: block;
            }

            :global(img) {
                width: 100%;
                height: auto;
                object-fit: cover;
            }
        }

        .badge {
            width: fit-content;
            padding: 0.375rem 1.125rem;
            gap: 0.5rem;
            border-radius: 2.5rem;
            border: 1px solid var(--ks-border-active);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: $font-size-xs;
            color: var(--ks-content-color-highlight);

            @include media-breakpoint-up(xl) {
                position: absolute;
                top: 2rem;
                left: 2rem;
                margin-bottom: 1.125rem;
            }

            .badge-icon {
                font-size: 1rem;
                margin-top: -2px;
            }
        }

        .content {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
            gap: 2rem;
            flex: 1;
            padding-block: 4rem;

            @include media-breakpoint-up(xl) {
                padding-top: 5.125rem;
            }

            @include media-breakpoint-down(xl) {
                padding: 2rem 2rem 0;
                width: 100%;
            }

            @include media-breakpoint-down(sm) {
                padding: 2rem;
            }

            h3 {
                color: var(--ks-content-primary);
                margin: 0;
            }

            > p {
                color: var(--ks-content-secondary);
                margin: 0;
            }

            > p :global(code) {
                font-family: $font-family-monospace;
                font-size: 0.85em;
                background: var(--ks-background-purple-light);
                color: var(--ks-content-primary);
                padding: 0.1rem 0.35rem;
                border-radius: 4px;
                border: 1px solid var(--ks-border-primary);
            }
        }

        .items-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            width: 100%;

            @include media-breakpoint-up(xl) {
                max-width: 600px;
            }

            @include media-breakpoint-down(md) {
                grid-template-columns: 1fr;
            }

            .item-card {
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
                padding: 1rem 1.5rem;
                border-radius: 0.625rem;
                background: var(--ks-background-primary);
                border: 1px solid var(--ks-border-secondary);
                box-shadow: 2px 0.1875rem 1rem 0 var(--ks-shadows-light);

                &.wide {
                    grid-column: span 2;
                    width: 100%;

                    @include media-breakpoint-down(md) {
                        grid-column: span 1;
                    }
                }

                h4 {
                    font-size: $font-size-sm;
                    margin: 0;
                    color: var(--ks-content-primary);
                    font-weight: 600;
                }

                p {
                    font-size: $font-size-xs;
                    margin: 0;
                    color: var(--ks-content-secondary);
                    line-height: 1.55;
                }
            }
        }

        .right {
            width: var(--right-width, 625px);
            flex: 0 0 var(--right-width, 625px);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            align-self: stretch;
            background: var(
                --right-bg,
                linear-gradient(
                    157.65deg,
                    #5733c5 5.65%,
                    #141414 28.44%,
                    #000000 51.96%,
                    #5d61ff 86.31%
                )
            );
            height: var(--right-height, auto);

            @include media-breakpoint-down(xl) {
                width: 100%;
                flex: 0 0 auto;
                align-self: auto;
                height: var(--right-height-xl, var(--right-height, auto));
            }

            @include media-breakpoint-down(md) {
                height: var(
                    --right-height-md,
                    var(--right-height-xl, var(--right-height, auto))
                );
            }
        }

        &.hide-right-sm .right {
            @include media-breakpoint-down(sm) {
                display: none;
            }
        }
    }
</style>
