---
const { id = "host-switcher" } = Astro.props as { id?: string };
---

<div class="switcher" id={id}>
    <button class="active" data-type="self-hosted">Kestra Enterprise Edition</button>
    <button data-type="cloud-hosted">Kestra Cloud</button>
</div>

<script>
    document.addEventListener("astro:page-load", () => {
        const switcher = document.getElementById("host-switcher");
        if (!switcher) return;

        const buttons = switcher.querySelectorAll("button");
        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                buttons.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");

                document.querySelectorAll<HTMLElement>("[data-host]").forEach((el) => {
                    el.classList.toggle("d-none", el.dataset.host !== btn.dataset.type);
                });
            });
        });
    });
</script>

<style lang="scss">
    .switcher {
        display: flex;
        margin: 0 auto 3rem;
        gap: 2.5rem;
        justify-content: center;

        button {
            border: none;
            background: transparent;
            padding: 0.5rem 0;
            font-size: 1.125rem;
            font-weight: 600;
            cursor: pointer;
            color: var(--ks-content-tertiary);
            white-space: nowrap;
            border-bottom: 3px solid transparent;
            transition: all 0.2s ease;

            &:hover {
                color: var(--ks-content-primary);
            }

            &.active {
                color: var(--ks-content-primary);
                border-bottom-color: var(--ks-content-primary);
            }
        }
    }
</style>
