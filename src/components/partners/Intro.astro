---
import Link from "~/components/common/Link.astro"
import Squared from "~/components/layout/Squared.vue"
import HeroIcon from "~/assets/landing/partners/icon-partner.svg?raw"
---

<Squared>
    <div class="icon" set:html={HeroIcon} role="img" />
    <div class="content">
        <h1>Kestra Partner Ecosystem</h1>
        <p>
            Whether you are building something new, upgrading a legacy stack, or
            re-platforming, you can trust Kestra and our partner ecosystem to
            make that journey a success.
        </p>
        <Link href="/partners" class="btn btn-primary">Become a Partner</Link>
    </div>
</Squared>

<style lang="scss">
    .icon {
        width: 344px;
        margin: 0 auto;
        display: flex;
        justify-content: center;
        align-items: center;

        :global(svg) {
            width: 100%;
            height: 100%;
        }
    }

    .content {
        text-align: center;
        max-width: 100%;
        margin: 0 auto;

        @include media-breakpoint-up(md) {
            max-width: 590px;
        }

        p {
            margin: 1.5rem 0;
        }
    }
</style>
