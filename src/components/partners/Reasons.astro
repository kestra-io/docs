---
import { Icon } from "astro-icon/components"

const REASONS = [
    "Partner Badge",
    "Partner Directory Listing",
    "Marketing & Co-branding Materials",
    "Partner Enablement",
    "Priority Services Routing",
    "Sandbox Enterprise Edition",
    "Feature Early Access",
]
---

<section class="reasons">
    <div class="container">
        <h2 class="mb-5 text-center">Reasons to integrate with Kestra</h2>
        <div class="row g-3 justify-content-center">
            {
                REASONS.map((reason) => (
                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="reason-card">
                            <Icon name="mdi:image-filter-center-focus-strong" />
                            <h5 class="mt-3 text-center">{reason}</h5>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style lang="scss">
    .reasons {
        width: 100%;
        padding: 4rem 1rem;
        background: var(--ks-background-secondary);

        .container {
            display: flex;
            flex-direction: column;
            gap: 2rem;
            align-items: center;
            justify-content: center;

            .row {
                width: 100%;
            }
        }

        .reason-card {
            width: 100%;
            height: 160px;
            border-radius: 8px;
            padding: 32px;
            background: var(--ks-background-primary);
            border: 1px solid var(--ks-border-secondary);
            box-shadow: 2px 3px 16px 0px var(--ks-shadows-light);
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;

            [data-icon] {
                color: var(--ks-icon-color);
                font-size: 1.5rem;
            }
        }
    }
</style>
