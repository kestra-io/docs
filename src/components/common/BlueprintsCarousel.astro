---
import Carousel from "~/components/common/Carousel.vue"
import BlueprintCard from "~/components/layout/BlueprintCard.astro"
import { $fetchApi } from "~/utils/fetch"

const { blueprints } = Astro.props

const tags = await $fetchApi<BlueprintTag[]>("/blueprints/versions/latest/tags")

const iconsStash = await $fetchApi<{
    [group: string]: { name: string; icon: string }
}>("/plugins/icons")
---

<Carousel client:load>
    {
        blueprints.map((blueprint: Blueprint) => (
            <BlueprintCard
                blueprint={blueprint}
                tags={tags}
                iconsStash={iconsStash}
                href={`/blueprints/${blueprint.id}`}
            />
        ))
    }
</Carousel>

<style lang="scss">
    :global(.carousel-content .blueprint) {
        flex: 0 0 350px !important;
        width: 350px !important;
    }
</style>
