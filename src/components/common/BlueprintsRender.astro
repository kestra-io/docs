---
import BlueprintsCarousel from "~/components/common/BlueprintsCarousel.astro"
import { fetchTotalBlueprintsCount } from "~/utils/blueprints/blueprintCount"

const { blueprints } = Astro.props
const totalBlueprints = await fetchTotalBlueprintsCount()
---

<section>
    <div class="container">
        <h1><span class="highlight">{totalBlueprints}+ Blueprints,</span> Ready to Build.</h1>
        <p>
            Jump start your workflows with a growing library of workflow
            templates
        </p>
    </div>
    <BlueprintsCarousel {blueprints} />
    <div class="button-container">
        <a href="/blueprints" class="btn btn-lg btn-primary">
            Explore Blueprints
        </a>
    </div>
</section>

<style lang="scss">
    section {
        background: var(--ks-background-tertiary);
        padding: 3rem 1.25rem;
    }

    .container {
        text-align: center;
    }

    p {
        color: var(--ks-content-secondary);
    }

    .button-container {
        text-align: center;
        margin-block: 3rem;
    }
</style>
