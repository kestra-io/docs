<script is:inline>
    ;(function () {
        var root = document.querySelector(".oa-3")
        function isPaused() {
            return !!root.closest(".paused")
        }

        var WF_RIGHT = 40 + 76
        var WF_CY = 186 + 38
        var KB_L = 270,
            KB_T = 50,
            KB_W = 160
        var TRIG_LEFT = KB_L + 20
        var TRIG_RIGHT = KB_L + 140
        var TRIG_CY = {
            event: KB_T + 58 + 36,
            schedule: KB_T + 58 + 80 + 36,
            webhook: KB_T + 58 + 150 + 36,
        }
        var G_LEFT = KB_L + KB_W + 50
        var GANTT_CY = {
            event: TRIG_CY.event,
            schedule: TRIG_CY.schedule,
            webhook: TRIG_CY.webhook,
        }

        var svg = root.querySelector("#oa3-svgLines")
        var defs = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "defs",
        )
        svg.appendChild(defs)

        function addBase(d) {
            var p = document.createElementNS(
                "http://www.w3.org/2000/svg",
                "path",
            )
            p.setAttribute("d", d)
            p.setAttribute("stroke", "rgba(255,255,255,0.15)")
            p.setAttribute("stroke-width", "1.5")
            p.setAttribute("stroke-dasharray", "4 4")
            p.setAttribute("fill", "none")
            svg.appendChild(p)
        }

        var keys = ["event", "schedule", "webhook"]
        keys.forEach(function (k) {
            var ty = TRIG_CY[k]
            var midX = (WF_RIGHT + TRIG_LEFT) / 2
            var d =
                "M " +
                WF_RIGHT +
                " " +
                WF_CY +
                " C " +
                midX +
                " " +
                WF_CY +
                ", " +
                midX +
                " " +
                ty +
                ", " +
                TRIG_LEFT +
                " " +
                ty
            addBase(d)
        })

        var beamPaths = {}
        function makeBeam(key, d, c0, c1, x1, y1, x2, y2, i) {
            var gId = "oa3-g-" + i
            var grad = document.createElementNS(
                "http://www.w3.org/2000/svg",
                "linearGradient",
            )
            grad.setAttribute("id", gId)
            grad.setAttribute("gradientUnits", "userSpaceOnUse")
            grad.setAttribute("x1", x1)
            grad.setAttribute("y1", y1)
            grad.setAttribute("x2", x2)
            grad.setAttribute("y2", y2)
            var s1 = document.createElementNS(
                "http://www.w3.org/2000/svg",
                "stop",
            )
            s1.setAttribute("offset", "0%")
            s1.setAttribute("stop-color", c0)
            var s2 = document.createElementNS(
                "http://www.w3.org/2000/svg",
                "stop",
            )
            s2.setAttribute("offset", "100%")
            s2.setAttribute("stop-color", c1)
            grad.appendChild(s1)
            grad.appendChild(s2)
            defs.appendChild(grad)
            var p = document.createElementNS(
                "http://www.w3.org/2000/svg",
                "path",
            )
            p.setAttribute("d", d)
            p.setAttribute("stroke", "url(#" + gId + ")")
            p.setAttribute("stroke-width", "2.5")
            p.setAttribute("stroke-linecap", "round")
            p.setAttribute("fill", "none")
            p.setAttribute("stroke-dasharray", "500")
            p.setAttribute("stroke-dashoffset", "500")
            p.style.opacity = "0"
            svg.appendChild(p)
            beamPaths[key] = p
        }

        var trigColors = {
            event: ["rgba(124,111,255,1)", "#f7c948"],
            schedule: ["rgba(124,111,255,1)", "#48f7a0"],
            webhook: ["rgba(124,111,255,1)", "#48c3f7"],
        }
        var outColors = {
            event: ["#631BFF", "#f7c948"],
            schedule: ["#631BFF", "#48f7a0"],
            webhook: ["#631BFF", "#48c3f7"],
        }

        keys.forEach(function (k, i) {
            var ty = TRIG_CY[k],
                gy = GANTT_CY[k]
            var midXin = (WF_RIGHT + TRIG_LEFT) / 2
            var dIn =
                "M " +
                WF_RIGHT +
                " " +
                WF_CY +
                " C " +
                midXin +
                " " +
                WF_CY +
                ", " +
                midXin +
                " " +
                ty +
                ", " +
                TRIG_LEFT +
                " " +
                ty
            var midXout = (TRIG_RIGHT + G_LEFT) / 2
            makeBeam(
                "in-" + k,
                dIn,
                trigColors[k][0],
                trigColors[k][1],
                WF_RIGHT,
                WF_CY,
                TRIG_LEFT,
                ty,
                i,
            )
            makeBeam(
                "out-" + k,
                "M " +
                    TRIG_RIGHT +
                    " " +
                    ty +
                    " C " +
                    midXout +
                    " " +
                    ty +
                    ", " +
                    midXout +
                    " " +
                    gy +
                    ", " +
                    G_LEFT +
                    " " +
                    gy,
                outColors[k][0],
                outColors[k][1],
                TRIG_RIGHT,
                ty,
                G_LEFT,
                gy,
                i + 10,
            )
        })

        function fireBeam(key, cb) {
            var p = beamPaths[key]
            p.style.animation = "none"
            p.setAttribute("stroke-dashoffset", "500")
            p.style.opacity = "1"
            p.offsetHeight
            p.style.animation = "oa3-beam-travel 0.7s ease-in forwards"
            p.addEventListener(
                "animationend",
                function () {
                    p.style.animation = "none"
                    p.style.opacity = "0"
                    p.setAttribute("stroke-dashoffset", "500")
                    if (cb) cb()
                },
                { once: true },
            )
        }

        var execCount = 1041
        var counterNum = root.querySelector("#oa3-counterNum")
        var counter = root.querySelector("#oa3-counter")
        function bumpCounter() {
            execCount++
            counterNum.textContent = "#" + execCount.toLocaleString("fr-FR")
            counter.classList.add("flash")
            setTimeout(function () {
                counter.classList.remove("flash")
            }, 600)
        }

        var gantt = root.querySelector("#oa3-gantt")
        var bars = [root.querySelector("#oa3-bar1")]
        var logs = [
            root.querySelector("#oa3-log1"),
            root.querySelector("#oa3-log2"),
            root.querySelector("#oa3-log3"),
            root.querySelector("#oa3-log4"),
        ]
        var ganttLabel = root.querySelector("#oa3-ganttLabel")

        function setGanttIdle() {
            gantt.className = "idle"
            ganttLabel.textContent = ""
            bars.forEach(function (b) {
                b.style.animation = "none"
                b.className = "gantt-bar"
                b.style.transform = "scaleX(0)"
            })
            logs.forEach(function (l) {
                l.classList.remove("show")
            })
        }
        function setGanttRunning() {
            gantt.className = "running"
            ganttLabel.textContent = "Running"
            bars.forEach(function (b) {
                b.style.animation = "none"
                b.style.transform = "scaleX(0)"
                b.offsetHeight
                b.className = "gantt-bar animating"
            })
            logs.forEach(function (l) {
                l.classList.remove("show")
            })
            ;[0, 1, 2].forEach(function (i) {
                setTimeout(
                    function () {
                        logs[i].classList.add("show")
                    },
                    200 + i * 400,
                )
            })
        }
        function setGanttSuccess() {
            gantt.className = "success"
            ganttLabel.textContent = "Success"
            bars.forEach(function (b) {
                b.style.animation = "none"
                b.style.transform = "scaleX(1)"
            })
            setTimeout(function () {
                logs[3].classList.add("show")
            }, 100)
        }

        var triggers = [
            { key: "event", el: root.querySelector("#oa3-trigEvent") },
            { key: "schedule", el: root.querySelector("#oa3-trigSchedule") },
            { key: "webhook", el: root.querySelector("#oa3-trigWebhook") },
        ]
        var idx = 0
        var kestraBox = root.querySelector("#oa3-kestraBox")
        var boxWorkflow = root.querySelector("#oa3-boxWorkflow")

        function resetAll() {
            boxWorkflow.classList.remove("active")
            kestraBox.classList.remove("active")
            triggers.forEach(function (t) {
                t.el.classList.remove("active")
            })
            setGanttIdle()
        }

        function runSequence() {
            resetAll()
            var trig = triggers[idx]
            idx = (idx + 1) % triggers.length
            boxWorkflow.classList.add("active")
            setTimeout(function () {
                fireBeam("in-" + trig.key, function () {
                    boxWorkflow.classList.remove("active")
                    kestraBox.classList.add("active")
                    trig.el.classList.add("active")
                    bumpCounter()
                    setTimeout(function () {
                        kestraBox.classList.remove("active")
                        trig.el.classList.remove("active")
                        setGanttRunning()
                        setTimeout(function () {
                            setGanttSuccess()
                            wait(runSequence, 1800)
                        }, 1600)
                    }, 1000)
                })
            }, 300)
        }

        function wait(fn, ms) {
            setTimeout(function () {
                if (isPaused()) wait(fn, 100)
                else fn()
            }, ms)
        }

        wait(runSequence, 600)
    })()
</script>

