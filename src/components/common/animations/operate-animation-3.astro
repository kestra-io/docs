<style>
    .oa-3 {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100%;
        font-family: "Segoe UI", sans-serif;
        overflow: hidden;

        .scene-wrapper {
            width: 580px;
            height: 500px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .scene {
            position: relative;
            width: 780px;
            height: 400px;
            display: flex;
            align-items: center;
            justify-content: center;
            left: 30px;
            transform: scale(0.85);
            transform-origin: center center;
            flex-shrink: 0;
        }

        #oa3-boxWorkflow {
            position: absolute;
            width: 76px;
            height: 76px;
            left: 40px;
            top: 186px;
            border-radius: 12px;
            border: 1.5px solid rgba(255, 255, 255, 0.18);
            background: rgba(255, 255, 255, 0.04);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 5px;
            transition:
                border-color 0.3s,
                box-shadow 0.3s,
                background 0.3s;
        }
        #oa3-boxWorkflow .label {
            font-size: 9px;
            color: rgba(255, 255, 255, 0.4);
            font-weight: 600;
            letter-spacing: 0.07em;
            text-transform: uppercase;
        }
        #oa3-boxWorkflow.active {
            border-color: rgba(124, 111, 255, 1);
            box-shadow:
                0 0 16px 2px rgba(124, 111, 255, 0.45),
                0 0 4px 1px rgba(124, 111, 255, 0.9);
            background: rgba(124, 111, 255, 0.08);
        }

        #oa3-kestraBox {
            position: absolute;
            left: 270px;
            top: 50px;
            width: 160px;
            height: 300px;
            border-radius: 16px;
            border: 1.5px dashed rgba(255, 255, 255, 0.22);
            background: rgba(255, 255, 255, 0.02);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 14px 0 10px;
            transition:
                border-color 0.3s,
                box-shadow 0.3s;
        }
        #oa3-kestraBox.active {
            border-color: #631bff;
            border-style: solid;
            box-shadow:
                0 0 28px rgba(99, 27, 255, 0.5),
                inset 0 0 16px rgba(99, 27, 255, 0.15);
        }

        .kestra-logo-wrap {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            margin-bottom: 10px;
        }

        .trigger-item {
            width: 120px;
            height: 72px;
            border-radius: 10px;
            border: 1.5px solid rgba(255, 255, 255, 0.13);
            background: rgba(255, 255, 255, 0.03);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            margin: 4px 0;
            transition:
                border-color 0.3s,
                box-shadow 0.3s,
                background 0.3s;
        }
        .trigger-item .label {
            font-size: 8px;
            color: rgba(255, 255, 255, 0.35);
            font-weight: 600;
            letter-spacing: 0.07em;
            text-transform: uppercase;
        }
        #oa3-trigEvent.active {
            border-color: #f7c948;
            box-shadow: 0 0 12px rgba(247, 201, 72, 0.35);
            background: rgba(247, 201, 72, 0.06);
        }
        #oa3-trigSchedule.active {
            border-color: rgba(72, 247, 160, 1);
            box-shadow: 0 0 12px rgba(72, 247, 160, 0.35);
            background: rgba(72, 247, 160, 0.06);
        }
        #oa3-trigWebhook.active {
            border-color: rgba(72, 195, 247, 1);
            box-shadow: 0 0 12px rgba(72, 195, 247, 0.35);
            background: rgba(72, 195, 247, 0.06);
        }

        #oa3-counter {
            margin-top: 8px;
            font-family: "JetBrains Mono", monospace;
            font-size: 10px;
            color: rgba(255, 255, 255, 0.3);
            white-space: nowrap;
            letter-spacing: 0.04em;
        }
        #oa3-counter .num {
            color: rgba(255, 255, 255, 0.9);
            font-weight: 500;
        }
        #oa3-counter.flash .num {
            color: #fff;
            text-shadow: 0 0 8px #fff;
        }

        #oa3-gantt {
            position: absolute;
            left: 480px;
            top: 125px;
            width: 180px;
            border-radius: 12px;
            border: 1.5px solid rgba(255, 255, 255, 0.13);
            background: rgba(255, 255, 255, 0.03);
            padding: 14px 14px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .gantt-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .gantt-status-label {
            font-size: 12px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.2);
            letter-spacing: 0.04em;
            transition: color 0.3s;
        }
        .gantt-icon-wrap {
            position: relative;
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }
        .gantt-icon {
            position: absolute;
            top: 0;
            left: 0;
            width: 16px;
            height: 16px;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .gantt-bars {
            display: flex;
            flex-direction: column;
            gap: 7px;
        }

        .gantt-bar-wrap {
            height: 6px;
            border-radius: 3px;
            background: rgba(255, 255, 255, 0.06);
            overflow: hidden;
        }
        .gantt-bar {
            height: 100%;
            width: 100%;
            border-radius: 3px;
            transform: scaleX(0);
            transform-origin: left;
            transition: background 0.4s;
        }
        .gantt-bar.animating {
            animation: oa3-bar-grow-rtl 1.6s ease-out forwards;
        }

        .gantt-divider {
            height: 1px;
            background: rgba(255, 255, 255, 0.07);
            margin: 4px 0;
        }

        .gantt-logs {
            display: flex;
            flex-direction: column;
            gap: 4px;
            overflow: hidden;
        }
        .log-line {
            font-family: "JetBrains Mono", monospace;
            font-size: 8px;
            line-height: 1.4;
            color: rgba(255, 255, 255, 0.25);
            opacity: 0;
            transform: translateY(4px);
            transition:
                opacity 0.3s,
                transform 0.3s;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .log-line.show {
            opacity: 1;
            transform: translateY(0);
        }
        .log-line .log-time {
            color: rgba(255, 255, 255, 0.18);
        }
        .log-line .log-ok {
            color: #48f7a0;
        }
        .log-line .log-info {
            color: #659ad2;
        }
        .log-line .log-warn {
            color: #f7c948;
        }

        #oa3-gantt.running .gantt-status-label {
            color: #659ad2;
        }
        #oa3-gantt.running .gantt-icon.spin-icon {
            opacity: 1;
            animation: oa3-spin 1s linear infinite;
        }
        #oa3-gantt.running .gantt-bar {
            background: #659ad2;
        }
        #oa3-gantt.success .gantt-status-label {
            color: #48f7a0;
        }
        #oa3-gantt.success .gantt-icon.check-icon {
            opacity: 1;
        }
        #oa3-gantt.success .gantt-bar {
            background: #48f7a0;
        }

        .svg-lines {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            overflow: visible;
        }
    }

    @keyframes oa3-bar-grow-rtl {
        from {
            transform: scaleX(0);
        }
        to {
            transform: scaleX(1);
        }
    }

    @keyframes oa3-beam-travel {
        0% {
            stroke-dashoffset: 500;
            opacity: 1;
        }
        85% {
            opacity: 1;
        }
        100% {
            stroke-dashoffset: 0;
            opacity: 0;
        }
    }

    @keyframes oa3-spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

