                                fireBeam(beamRecv, function () {
                                    execBox.classList.remove(
                                        "active",
                                        "running",
                                        "success",
                                    )
                                    termBox.className =
                                        "term-box active-receive"
                                    typeLines(
                                        seq.responseLines,
                                        110,
                                        function () {
                                            setTimeout(function () {
                                                termBox.className = "term-box"
                                                setTimeout(function () {
                                                    resetExec()
                                                    wait(run, 600)
                                                }, 900)
                                            }, 1800)
                                        },
                                    )
                                })
                            }, 400)
                        })
                    })
                }, 200)
            })
        }

        function wait(fn, ms) {
            setTimeout(function () {
                if (isPaused()) wait(fn, 100)
                else fn()
            }, ms)
        }

        wait(run, 600)
    })()
</script>

