<style>
    .oa-4 {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100%;
        overflow: hidden;
        position: relative;

        .scene-wrapper {
            width: 580px;
            height: 500px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        .scene {
            position: relative;
            width: 620px;
            height: 380px;
            transform: scale(0.9);
            transform-origin: center center;
            flex-shrink: 0;
        }

        .term-box,
        #oa4-execBox {
            position: absolute;
            top: 40px;
            width: 260px;
            height: 300px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .term-box {
            left: 0;
            border: 1.5px solid rgba(255, 255, 255, 0.12);
            background: rgba(0, 0, 0, 0.6);
            transition:
                border-color 0.3s,
                box-shadow 0.3s;
        }
        .term-box.active-send {
            border-color: rgba(124, 111, 255, 0.85);
            box-shadow: 0 0 22px rgba(124, 111, 255, 0.35);
        }
        .term-box.active-receive {
            border-color: rgba(72, 247, 160, 0.75);
            box-shadow: 0 0 22px rgba(72, 247, 160, 0.28);
        }
        #oa4-execBox {
            right: 0;
            border: 1.5px solid rgba(255, 255, 255, 0.1);
            background: rgba(255, 255, 255, 0.025);
            transition:
                border-color 0.3s,
                box-shadow 0.3s;
        }
        #oa4-execBox.active {
            border-color: #631bff;
            box-shadow:
                0 0 28px rgba(99, 27, 255, 0.5),
                inset 0 0 16px rgba(99, 27, 255, 0.12);
        }
        #oa4-execBox.success {
            border-color: rgba(72, 247, 160, 0.8);
            box-shadow:
                0 0 28px rgba(72, 247, 160, 0.4),
                inset 0 0 16px rgba(72, 247, 160, 0.1);
        }

        .term-titlebar,
        .exec-titlebar {
            display: flex;
            align-items: center;
            padding: 8px 12px;
            background: rgba(255, 255, 255, 0.035);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            flex-shrink: 0;
        }
        .term-titlebar {
            gap: 6px;
        }
        .exec-titlebar {
            justify-content: space-between;
            background: rgba(255, 255, 255, 0.03);
        }
        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }
        .dot.r {
            background: #ff5f57;
        }
        .dot.y {
            background: #febc2e;
        }
        .dot.g {
            background: #28c840;
        }
        .term-title {
            font-size: 9px;
            color: rgba(255, 255, 255, 0.28);
            margin-left: 4px;
            letter-spacing: 0.05em;
            font-family: "JetBrains Mono", monospace;
        }
        .exec-title {
            font-size: 9px;
            color: rgba(255, 255, 255, 0.9);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-family: "JetBrains Mono", monospace;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .term-body {
            padding: 10px 12px;
            flex: 1;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 1px;
        }
        .tl {
            font-family: "JetBrains Mono", monospace;
            font-size: 11px;
            line-height: 1.65;
            white-space: pre;
            opacity: 0;
            transition: opacity 0.12s;
        }
        .tl.vis {
            opacity: 1;
        }
        .tl .p {
            color: #7b5fff;
        }
        .tl .k {
            color: #a950ff;
        }
        .tl .a {
            color: rgba(255, 255, 255, 0.6);
        }
        .tl .d {
            color: rgba(255, 255, 255, 0.28);
        }
        .tl .ok {
            color: #48f7a0;
        }
        .tl .inf {
            color: #659ad2;
        }
        .tl .w {
            color: #f7c948;
        }
        .tl .jk {
            color: #a950ff;
        }
        .tl .jv {
            color: #48f7a0;
        }
        .tl .jn {
            color: #f7c948;
        }
        .tl .jb {
            color: #48c3f7;
        }
        .cursor {
            display: inline-block;
            width: 6px;
            height: 10px;
            background: rgba(124, 111, 255, 0.9);
            vertical-align: middle;
            animation: oa4-blink 0.85s step-end infinite;
        }

        .exec-status {
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .exec-status-label {
            font-family: "Segoe UI", sans-serif;
            font-size: 11px;
            font-weight: 600;
            color: transparent;
            letter-spacing: 0.04em;
            transition: color 0.3s;
        }
        .exec-icon-wrap {
            position: relative;
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }
        .exec-icon {
            position: absolute;
            top: 0;
            left: 0;
            width: 16px;
            height: 16px;
            opacity: 0;
            transition: opacity 0.3s;
        }
        #oa4-execBox.running .exec-status-label {
            color: #659ad2;
        }
        #oa4-execBox.running .exec-icon.spin-icon {
            opacity: 1;
            animation: oa4-spin 1s linear infinite;
        }
        #oa4-execBox.success .exec-status-label {
            color: #48f7a0;
        }
        #oa4-execBox.success .exec-icon.check-icon {
            opacity: 1;
        }

        .exec-body {
            padding: 12px;
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .bar-wrap {
            height: 5px;
            border-radius: 3px;
            background: rgba(255, 255, 255, 0.07);
            overflow: hidden;
        }
        .bar {
            height: 100%;
            border-radius: 3px;
            transform: scaleX(0);
            transform-origin: left;
        }
        .bar.run {
            background: #659ad2;
            animation: oa4-bar-grow 1.3s ease-out forwards;
            transition: background 0.4s;
        }
        .bar.done {
            background: #48f7a0;
            transform: scaleX(1);
            transition: background 0.4s;
        }
        .exec-divider {
            height: 1px;
            background: rgba(255, 255, 255, 0.07);
        }
        .exec-logs {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .exec-log {
            font-family: "JetBrains Mono", monospace;
            font-size: 11px;
            line-height: 1.5;
            color: rgba(255, 255, 255, 0.22);
            opacity: 0;
            transform: translateY(3px);
            transition:
                opacity 0.3s,
                transform 0.3s;
            white-space: nowrap;
        }
        .exec-log.show {
            opacity: 1;
            transform: none;
        }
        .exec-log .lt {
            color: rgba(255, 255, 255, 0.15);
        }
        .exec-log .lok {
            color: #48f7a0;
        }
        .exec-log .lin {
            color: #659ad2;
        }

        #oa4-connSvg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            overflow: visible;
        }
        .conn-base {
            fill: none;
            stroke: rgba(255, 255, 255, 0.15);
            stroke-width: 1.5;
            stroke-dasharray: 4 4;
        }
        .beam {
            fill: none;
            stroke-width: 2.5;
            stroke-linecap: round;
            stroke-dasharray: 500;
            stroke-dashoffset: 500;
            opacity: 0;
        }
    }

    @keyframes oa4-blink {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0;
        }
    }

    @keyframes oa4-spin {
        to {
            transform: rotate(360deg);
        }
    }

    @keyframes oa4-bar-grow {
        from {
            transform: scaleX(0);
        }
        to {
            transform: scaleX(1);
        }
    }

    @keyframes oa4-beam-travel {
        0% {
            stroke-dashoffset: 500;
            opacity: 1;
        }
        85% {
            opacity: 1;
        }
        100% {
            stroke-dashoffset: 0;
            opacity: 0;
        }
    }
</style>

