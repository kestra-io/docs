<script is:inline>
    ;(function () {
        const root = document.querySelector(".oa-1")
        const codeEl = root.querySelector("#oa1-code"),
            badge = root.querySelector("#oa1-badge"),
            bico = root.querySelector("#oa1-bico")
        const suggInline = root.querySelector("#oa1-suggInline"),
            acceptBtn = root.querySelector("#oa1-acceptBtn"),
            acceptWordBtn = root.querySelector("#oa1-acceptWordBtn")
        const topoOuter = root.querySelector("#oa1-topoOuter")
        const nStatus = root.querySelector("#oa1-nStatus"),
            nIf = root.querySelector("#oa1-nIf"),
            nLog = root.querySelector("#oa1-nLog")
        const tFrame = root.querySelector("#oa1-tFrame")
        const tLine1 = root.querySelector("#oa1-tLine1"),
            tLine2 = root.querySelector("#oa1-tLine2")

        function isPaused() {
            return !!root.closest(".paused")
        }

        let tid = null
        const after = (fn, ms) => {
            clearTimeout(tid)
            tid = setTimeout(() => {
                if (isPaused()) {
                    after(fn, 100)
                } else {
                    fn()
                }
            }, ms)
        }

        function setBadge(s) {
            if (s === "hide") {
                badge.className = "badge"
                return
            }
            const vis = badge.classList.contains("show")
            const swap =
                vis &&
                ((s === "err" && badge.classList.contains("ok")) ||
                    (s === "ok" && badge.classList.contains("err")))
            if (swap) {
                badge.classList.add("switching")
                setTimeout(() => {
                    badge.classList.remove("switching")
                    badge.className = "badge show " + s
                    ub(s)
                }, 175)
            } else {
                badge.className = "badge show " + s
                ub(s)
            }
        }
        function ub(s) {
            bico.innerHTML =
                s === "ok"
                    ? '<polyline points="20 6 9 17 4 12"/>'
                    : '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>'
        }

        function esc(s) {
            return s
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
        }
        function kw(s) {
            return '<span class="kw">' + esc(s) + "</span>"
        }
        function val(s) {
            return '<span class="val">' + esc(s) + "</span>"
        }
        function url(s) {
            return '<span class="url">' + esc(s) + "</span>"
        }
        function tmpl(s) {
            return '<span class="tmpl">' + esc(s) + "</span>"
        }

        var LINES = [
            {
                raw: "id: health_check",
                html: kw("id") + esc(": health_check"),
            },
            {
                raw: "namespace: company.team",
                html: kw("namespace") + esc(": company.team"),
            },
            { raw: "" },
            { raw: "tasks:", html: kw("tasks:") },
            {
                raw: "  - id: status_check",
                html: esc("  - ") + kw("id") + esc(": status_check"),
            },
            {
                raw: "    type: io.kestra.plugin.core.http.Request",
                html:
                    esc("    ") +
                    kw("type") +
                    esc(": ") +
                    val("io.kestra.plugin.core.http.Request"),
            },
            {
                raw: "    uri: https://kestra.io",
                html:
                    esc("    ") +
                    kw("uri") +
                    esc(": ") +
                    url("https://kestra.io"),
            },
            { raw: "" },
            {
                raw: "  - id: check",
                html: esc("  - ") + kw("id") + esc(": check"),
            },
            {
                raw: "    type: io.kestra.plugin.core.flow.If",
                html:
                    esc("    ") +
                    kw("type") +
                    esc(": ") +
                    val("io.kestra.plugin.core.flow.If"),
            },
            {
                raw: '    condition: "{{ outputs.status_check.code == 200 }}"',
                html:
                    esc("    ") +
                    kw("condition") +
                    esc(': "') +
                    tmpl("{{ outputs.status_check.code == 200 }}") +
                    esc('"'),
            },
            { raw: "    then:", html: esc("    ") + kw("then:") },
            {
                raw: "      - id: log",
                html: esc("      - ") + kw("id") + esc(": log"),
            },
            {
                raw: "        type: io.kestra.plugin.core.log.Log",
                html:
                    esc("        ") +
                    kw("type") +
                    esc(": ") +
                    val("io.kestra.plugin.core.log.Log"),
            },
            {
                raw: '        message: "Status OK"',
                html:
                    esc("        ") +
                    kw("message") +
                    esc(': "') +
                    val("Status OK") +
                    esc('"'),
            },
        ]

        var TYPO_LINE = 5,
            TYPO_PREFIX = "    type: io.kestra.plugin.core.http.Reque",
            TYPO_WRONG = "ts",
            TYPO_CORRECT = "st"

        var TOPO1_LINE = 6
        var SUGG_LINE = 9
        var TOPO3_LINE = 14

        function sliceHtml(h, n) {
            var rem = n
            var d = document.createElement("div")
            d.innerHTML = h
            var out = ""
            for (var node of d.childNodes) {
                if (rem <= 0) break
                if (node.nodeType === 3) {
                    var t = node.textContent.slice(0, rem)
                    out += esc(t)
                    rem -= t.length
                } else {
                    var t2 = node.textContent,
                        take = Math.min(t2.length, rem)
                    out +=
                        '<span class="' +
                        node.className +
                        '">' +
                        esc(t2.slice(0, take)) +
                        "</span>"
                    rem -= take
                }
            }
            return out
        }

        var committed = []
        function render(partial, cursor) {
            var h = ""
            for (var l of committed) h += l + "\n"
            if (partial !== undefined) h += partial
            if (cursor) h += '<span class="cursor"></span>'
            codeEl.innerHTML = h
        }
        function delay(ch) {
            if (!ch) return 50
            if (ch === ".") return 30 + Math.random() * 15
            if (ch === ":") return 35 + Math.random() * 15
            if (ch === " ") return 18 + Math.random() * 10
            return 22 + Math.random() * 18
        }

        var li = 0,
            ci = 0,
            topoPhase = 0

        function showPhase1() {
            if (topoPhase >= 1) return
            topoPhase = 1
            topoOuter.classList.add("visible")
            nStatus.setAttribute("transform", "translate(200,100)")
            nStatus.classList.remove("hidden")
        }

        function showPhase2() {
            if (topoPhase >= 2) return
            topoPhase = 2
            nStatus.setAttribute("transform", "translate(93,72)")
            setTimeout(function () {
                tFrame.classList.add("on")
            }, 350)
            setTimeout(function () {
                nIf.classList.remove("hidden")
            }, 450)
            setTimeout(function () {
                tLine1.classList.add("on")
            }, 700)
        }

        function showPhase3() {
            if (topoPhase >= 3) return
            topoPhase = 3
            setTimeout(function () {
                nLog.classList.remove("hidden")
            }, 200)
            setTimeout(function () {
                tLine2.classList.add("on")
            }, 500)
        }

        function resetTopo() {
            topoPhase = 0
            topoOuter.classList.remove("visible")
            nStatus.classList.add("hidden")
            nStatus.setAttribute("transform", "translate(200,120)")
            nIf.classList.add("hidden")
            nLog.classList.add("hidden")
            tFrame.classList.remove("on")
            tLine1.classList.remove("on")
            tLine2.classList.remove("on")
        }

        function reset() {
            clearTimeout(tid)
            committed = []
            li = 0
            ci = 0
            suggInline.style.display = "none"
            setBadge("hide")
            render("", false)
            resetTopo()
            after(start, 400)
        }
        function start() {
            setBadge("ok")
            after(typeNext, 80)
        }

        function typeNext() {
            if (li >= LINES.length) {
                allDone()
                return
            }
            var L = LINES[li]
            if (L.raw === "") {
                committed.push("")
                li++
                ci = 0
                after(typeNext, 75 + Math.random() * 35)
                return
            }
            if (li === TYPO_LINE && ci === 0) {
                after(function () {
                    typo(0, 0)
                }, 60)
                return
            }
            if (ci < L.raw.length) {
                ci++
                render(sliceHtml(L.html, ci), true)
                after(typeNext, delay(L.raw[ci - 1]))
            } else {
                committed.push(L.html)
                var done = li
                li++
                ci = 0
                if (done === TOPO1_LINE) {
                    render("", false)
                    after(function () {
                        showPhase1()
                        after(typeNext, 500)
                    }, 350)
                    return
                }
                if (done === SUGG_LINE) {
                    render("", false)
                    after(showSuggestion, 480)
                    return
                }
                after(typeNext, 60 + Math.random() * 25)
            }
        }

        function typo(stage, idx) {
            var L = LINES[TYPO_LINE]
            switch (stage) {
                case 0:
                    if (idx < TYPO_PREFIX.length) {
                        render(sliceHtml(L.html, idx + 1), true)
                        after(function () {
                            typo(0, idx + 1)
                        }, delay(TYPO_PREFIX[idx]))
                    } else
                        after(function () {
                            typo(1, 0)
                        }, 90)
                    break
                case 1:
                    if (idx < TYPO_WRONG.length) {
                        render(
                            sliceHtml(L.html, TYPO_PREFIX.length) +
                                '<span class="err-char">' +
                                esc(TYPO_WRONG.slice(0, idx + 1)) +
                                "</span>",
                            true,
                        )
                        after(function () {
                            typo(1, idx + 1)
                        }, 100)
                    } else {
                        setBadge("err")
                        after(function () {
                            typo(2, TYPO_WRONG.length)
                        }, 680)
                    }
                    break
                case 2:
                    if (idx > 0) {
                        var w = TYPO_WRONG.slice(0, idx - 1)
                        render(
                            sliceHtml(L.html, TYPO_PREFIX.length) +
                                (w
                                    ? '<span class="err-char">' +
                                      esc(w) +
                                      "</span>"
                                    : ""),
                            true,
                        )
                        after(function () {
                            typo(2, idx - 1)
                        }, 80)
                    } else {
                        setBadge("ok")
                        after(function () {
                            typo(3, 0)
                        }, 140)
                    }
                    break
                case 3:
                    if (idx < TYPO_CORRECT.length) {
                        render(
                            sliceHtml(L.html, TYPO_PREFIX.length + idx + 1),
                            true,
                        )
                        after(function () {
                            typo(3, idx + 1)
                        }, delay(TYPO_CORRECT[idx]))
                    } else {
                        ci = TYPO_PREFIX.length + TYPO_CORRECT.length
                        after(typeNext, 65)
                    }
                    break
            }
        }

        function showSuggestion() {
            render(
                '<span id="oa1-ghostCond" class="cmt-to-kw">    condition:</span>',
                true,
            )
            suggInline.style.display = "block"
            after(doAccept, 2000)
        }
        function doAccept() {
            clearTimeout(tid)
            suggInline.style.display = "none"
            var g = root.querySelector("#oa1-ghostCond")
            if (g) g.classList.add("resolved")
            showPhase2()
            after(function () {
                li = 10
                ci = "    condition:".length
                render(kw("    condition") + esc(":"), false)
                after(typeNext, 80)
            }, 420)
        }
        acceptBtn.addEventListener("click", function () {
            clearTimeout(tid)
            doAccept()
        })
        acceptWordBtn.addEventListener("click", function () {
            clearTimeout(tid)
            doAccept()
        })

        function allDone() {
            render("", false)
            showPhase3()
            after(function () {
                topoOuter.classList.remove("visible")
                after(reset, 700)
            }, 3500)
        }

        reset()
    })()
</script>

