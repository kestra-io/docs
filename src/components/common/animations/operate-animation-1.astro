<style>
    .oa-1 {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100%;

        .scene {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .glow-wrap {
            position: relative;
            padding: 4px;
            border-radius: 14px;
            border: 1px solid rgba(113, 139, 254, 0.4);
            z-index: 2;
        }
        .anim-card {
            position: relative;
            background: #fff;
            border-radius: 10px;
            border: 1px solid #718bfe;
            width: 456px;
            padding: 20px 32px 24px;
            box-shadow: 0 4px 32px rgba(0, 0, 0, 0.5);
        }
        .badge {
            position: absolute;
            top: 14px;
            right: 14px;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transform: scale(0.5);
            transition:
                opacity 0.25s ease,
                transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .badge.show {
            opacity: 1;
            transform: scale(1);
        }
        .badge.ok {
            background: #22c55e;
        }
        .badge.err {
            background: #ef4444;
        }
        .badge svg {
            width: 16px;
            height: 16px;
            stroke: white;
            stroke-width: 2.8;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }
        .badge.switching {
            animation: oa1-badgeFlip 0.35s ease forwards;
        }

        .code {
            font-family: "SF Mono", "Fira Code", "Consolas", monospace;
            font-size: 12.5px;
            line-height: 1.9;
            color: #131316;
            min-height: 220px;
            white-space: pre;
        }
        .cursor {
            display: inline-block;
            width: 2px;
            height: 13px;
            background: #631bff;
            vertical-align: middle;
            animation: oa1-blink 0.65s step-end infinite;
        }
        .err-char {
            color: #ef4444;
            text-decoration: underline wavy #ef4444;
            background: rgba(239, 68, 68, 0.08);
            border-radius: 2px;
        }
        .kw {
            color: #631bff;
        }
        .val {
            color: #131316;
        }
        .url {
            color: #131316;
            text-decoration: underline;
        }
        .cmt {
            color: #a5a4aa;
            font-style: italic;
        }
        .cmt-to-kw {
            color: #a5a4aa;
            font-style: italic;
            transition: color 0.35s ease;
        }
        .cmt-to-kw.resolved {
            color: #631bff;
            font-style: normal;
        }
        .tmpl {
            color: #dd5f00;
        }

        .sugg-inline {
            display: none;
            margin-top: 4px;
        }
        .sugg-pill {
            display: inline-flex;
            align-items: center;
            border: 1.5px solid #c8c7ce;
            border-radius: 999px;
            background: #fff;
            font-family: -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 11px;
            color: #131316;
            overflow: hidden;
            box-shadow: 0 1px 6px rgba(0, 0, 0, 0.09);
            white-space: nowrap;
            margin-left: 28px;
        }
        .pill-nav {
            display: flex;
            align-items: center;
            gap: 2px;
            padding: 5px 10px;
            border-right: 1.5px solid #c8c7ce;
        }
        .pill-nav button {
            background: none;
            border: none;
            cursor: pointer;
            padding: 0 2px;
            display: flex;
            align-items: center;
        }
        .pill-nav button svg {
            width: 10px;
            height: 10px;
            stroke: #131316;
            stroke-width: 2.5;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }
        .pill-counter {
            font-size: 11px;
            font-weight: 500;
            padding: 0 2px;
        }
        .pill-action {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 5px 12px;
            font-size: 11px;
            color: #131316;
            cursor: pointer;
            border: none;
            background: none;
            font-family: inherit;
            transition: background 0.12s;
        }
        .pill-action:hover {
            background: #f3f3f5;
        }
        .pill-action + .pill-action {
            border-left: 1.5px solid #c8c7ce;
        }
        .pill-action.selected {
            background: #ede9ff;
            color: #631bff;
            font-weight: 600;
        }
        .pill-action.selected .pill-key {
            background: #631bff;
            color: #fff;
        }
        .pill-key {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #e8e8ea;
            border-radius: 4px;
            font-size: 10px;
            padding: 1px 5px;
            color: #444;
            min-width: 22px;
        }
        .pill-arrow {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #e8e8ea;
            border-radius: 4px;
            width: 20px;
            height: 18px;
        }
        .pill-arrow svg {
            width: 9px;
            height: 9px;
            stroke: #444;
            stroke-width: 2.5;
            fill: none;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .topo-outer {
            width: 464px;
            overflow: hidden;
            height: 0;
            transition: height 0.65s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            z-index: 1;
            transform-origin: top center;
        }
        .topo-outer.visible {
            height: 160px;
        }
        .topo-outer.hiding {
            height: 0;
        }
        .topo-svg {
            width: 100%;
            height: 160px;
            display: block;
            overflow: visible;
        }

        .t-line {
            fill: none;
            stroke: rgba(255, 255, 255, 0.45);
            stroke-width: 1.5;
            stroke-dasharray: 5 4;
            opacity: 0;
            transition: opacity 0.4s ease;
        }
        .t-line.on {
            opacity: 1;
            animation: oa1-dashFlow 0.9s linear infinite;
        }

        .t-node {
            transition:
                transform 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.5s ease;
        }
        .t-node.hidden {
            opacity: 0;
            pointer-events: none;
        }

        .t-frame {
            fill: rgba(89, 188, 230, 0.05);
            stroke: #59bce6;
            stroke-width: 1;
            opacity: 0;
            transition: opacity 0.5s ease;
        }
        .t-frame.on {
            opacity: 1;
        }
        .t-frame-label {
            font-family: -apple-system, sans-serif;
            font-size: 11px;
            fill: #59bce6;
            opacity: 0;
            transition: opacity 0.5s ease;
        }
        .t-frame-label.on {
            opacity: 1;
        }
    }

    @keyframes oa1-badgeFlip {
        0% {
            transform: scale(1) rotate(0deg);
        }
        40% {
            transform: scale(0) rotate(90deg);
        }
        60% {
            transform: scale(0) rotate(-90deg);
        }
        100% {
            transform: scale(1) rotate(0deg);
        }
    }
    @keyframes oa1-blink {
        50% {
            opacity: 0;
        }
    }
    @keyframes oa1-dashFlow {
        to {
            stroke-dashoffset: -18;
        }
    }
</style>

