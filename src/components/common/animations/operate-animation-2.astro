 16.8557 31.1172 18.9399 29.58 20.4772C28.0428 22.0144 25.9585 22.8791 23.7845 22.8815ZM23.7845 7.65296C22.3939 7.65296 21.0344 8.06534 19.8781 8.83796C18.7218 9.61057 17.8206 10.7087 17.2884 11.9935C16.7562 13.2783 16.617 14.6921 16.8883 16.0561C17.1596 17.42 17.8293 18.6729 18.8126 19.6562C19.796 20.6396 21.0488 21.3092 22.4128 21.5805C23.7767 21.8519 25.1905 21.7126 26.4753 21.1804C27.7601 20.6482 28.8583 19.747 29.6309 18.5907C30.4035 17.4344 30.8159 16.075 30.8159 14.6843C30.8138 12.8201 30.0724 11.0329 28.7542 9.71468C27.436 8.39649 25.6487 7.65503 23.7845 7.65296Z" fill="#389826"/><path d="M33.7806 39.4332C37.987 39.4332 41.3968 36.0233 41.3968 31.817C41.3968 27.6107 37.987 24.2008 33.7806 24.2008C29.5743 24.2008 26.1644 27.6107 26.1644 31.817C26.1644 36.0233 29.5743 39.4332 33.7806 39.4332Z" fill="#AA79C1"/><path d="M33.7807 40.0155C32.1589 40.0155 30.5735 39.5345 29.225 38.6335C27.8765 37.7324 26.8256 36.4517 26.205 34.9533C25.5844 33.4549 25.4221 31.8062 25.7386 30.2155C26.0551 28.6249 26.8362 27.1638 27.983 26.0171C29.1299 24.8704 30.5911 24.0896 32.1818 23.7733C33.7725 23.4571 35.4212 23.6197 36.9195 24.2405C38.4178 24.8613 39.6983 25.9125 40.5992 27.2611C41.5 28.6097 41.9807 30.1952 41.9805 31.817C41.9777 33.9908 41.1129 36.0747 39.5757 37.6116C38.0385 39.1486 35.9545 40.0131 33.7807 40.0155ZM33.7807 24.7844C32.39 24.7844 31.0306 25.1967 29.8743 25.9694C28.718 26.742 27.8168 27.8401 27.2846 29.1249C26.7524 30.4097 26.6132 31.8235 26.8845 33.1875C27.1558 34.5514 27.8254 35.8043 28.8088 36.7876C29.7921 37.771 31.045 38.4407 32.409 38.712C33.7729 38.9833 35.1867 38.844 36.4715 38.3118C37.7563 37.7796 38.8544 36.8784 39.6271 35.7221C40.3997 34.5658 40.812 33.2064 40.812 31.8157C40.8096 29.9517 40.068 28.1648 38.7499 26.8469C37.4317 25.529 35.6447 24.7864 33.7807 24.7844Z" fill="#9558B2"/></svg>',
            },
            {
                id: "cpp",
                label: "C++",
                color: "#00599C",
                glowColor: "rgba(0,89,156,0.6)",
                beamColor: "#659AD2",
                svg: '<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M38.5204 31.9158C38.7542 31.5108 38.8995 31.0545 38.8995 30.6447L38.8995 16.4201C38.8995 16.0103 38.7544 15.5541 38.5205 15.1491L24 23.5325L38.5204 31.9158Z" fill="#00599C"/><path d="M25.2903 39.9918L37.6092 32.8796C37.9641 32.6747 38.2866 32.3209 38.5204 31.9158L24 23.5325L9.4796 31.9159C9.71342 32.3209 10.036 32.6748 10.3908 32.8796L22.7097 39.9918C23.4193 40.4016 24.5807 40.4016 25.2903 39.9918Z" fill="#004482"/><path d="M38.5205 15.1491C38.2866 14.744 37.964 14.3901 37.6092 14.1852L25.2903 7.07296C24.5807 6.66318 23.4193 6.66318 22.7097 7.07296L10.3908 14.1852C9.68109 14.5949 9.10049 15.6006 9.10049 16.4201L9.10049 30.6447C9.10049 31.0545 9.24569 31.5108 9.4796 31.9158L24 23.5325L38.5205 15.1491Z" fill="#659AD2"/><path d="M24 33.4655C18.5229 33.4655 14.067 29.0095 14.067 23.5325C14.067 18.0554 18.5229 13.5994 24 13.5994C27.5342 13.5994 30.8303 15.5013 32.6019 18.5628L28.3031 21.0504C27.4165 19.518 25.7675 18.5659 24 18.5659C21.2614 18.5659 19.0335 20.7939 19.0335 23.5325C19.0335 26.2709 21.2614 28.499 24 28.499C25.7677 28.499 27.4167 27.5469 28.3034 26.0142L32.6022 28.5017C30.8306 31.5635 27.5344 33.4655 24 33.4655Z" fill="white"/><path d="M33.933 22.9806L32.8293 22.9806L32.8293 21.8769L31.7258 21.8769L31.7258 22.9806L30.622 22.9806L30.622 24.0842L31.7258 24.0842L31.7258 25.188L32.8293 25.188L32.8293 24.0842L33.933 24.0842L33.933 22.9806Z" fill="white"/><path d="M38.0718 22.9806L36.968 22.9806L36.968 21.8769L35.8645 21.8769L35.8645 22.9806L34.7608 22.9806L34.7608 24.0842L35.8645 24.0842L35.8645 25.188L36.968 25.188L36.968 24.0842L38.0718 24.0842L38.0718 22.9806Z" fill="white"/></svg>',
            },
        ]

        var scene = root.querySelector("#oa2-scene")
        var svgEl = root.querySelector("#oa2-connector-svg")

        var totalW = LANGS.length * CARD_W + (LANGS.length - 1) * 16
        var startX = (SW - totalW) / 2

        function cardCX(i) {
            return startX + i * (CARD_W + 16) + CARD_W / 2
        }

        function kestraPoint(angle) {
            return {
                x: KESTRA_CX + KESTRA_R * Math.sin(angle),
                y: KESTRA_CY - KESTRA_R * Math.cos(angle),
            }
        }

        function angleToCard(i) {
            var dx = cardCX(i) - KESTRA_CX
            var dy = CARD_BOTTOM - KESTRA_CY
            return Math.atan2(dx, -dy)
        }

        var kestraBottom = { x: KESTRA_CX, y: KESTRA_CY + KESTRA_R }

        LANGS.forEach(function (l, i) {
            var card = document.createElement("div")
            card.className = "lang-card"
            card.id = "oa2-card-" + l.id
            card.style.left = startX + i * (CARD_W + 16) + "px"
            card.style.top = CARD_Y + "px"
            card.innerHTML =
                '<div class="glow" style="background:' +
                l.glowColor +
                '"></div>' +
                l.svg
            scene.appendChild(card)
        })

        var kestraWrap = document.createElement("div")
        kestraWrap.id = "oa2-kestra"
        kestraWrap.className = "kestra-wrap"
        kestraWrap.style.cssText =
            "top:" +
            (KESTRA_CY - KESTRA_R) +
            "px;width:" +
            KESTRA_R * 2 +
            "px;height:" +
            KESTRA_R * 2 +
            "px;border-radius:50%;"
        kestraWrap.innerHTML =
            '\
  <div class="kestra-glow"></div>\
  <div class="kestra-ring"></div>\
  <div class="kestra-inner">\
    <svg width="46" height="46" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">\
      <path d="M23.2073 19.1959C24.1832 18.22 25.7655 18.22 26.7415 19.1959L30.7532 23.2077C31.7291 24.1836 31.7291 25.7659 30.7532 26.7418L26.7415 30.7536C25.7655 31.7295 24.1832 31.7295 23.2073 30.7536L19.1956 26.7418C18.2196 25.7659 18.2196 24.1836 19.1956 23.2077L23.2073 19.1959Z" fill="#A950FF"/>\
      <path d="M41.6846 19.164C42.643 18.2055 44.197 18.2055 45.1555 19.164L49.2305 23.2389C50.1889 24.1974 50.1889 25.7514 49.2305 26.7099L45.1555 30.7848C44.197 31.7433 42.643 31.7433 41.6846 30.7848L37.6096 26.7099C36.6511 25.7514 36.6511 24.1974 37.6096 23.2389L41.6846 19.164Z" fill="#A950FF"/>\
      <path d="M23.2389 0.718862C24.1974 -0.23962 25.7514 -0.239621 26.7099 0.71886L30.7848 4.7938C31.7433 5.75228 31.7433 7.30628 30.7848 8.26476L26.7099 12.3397C25.7514 13.2982 24.1974 13.2982 23.2389 12.3397L19.164 8.26477C18.2055 7.30629 18.2055 5.75228 19.164 4.7938L23.2389 0.718862Z" fill="#E9C1FF"/>\
      <path d="M21.5313 13.985C22.5072 14.9609 22.5072 16.5433 21.5313 17.5192L17.5196 21.5309C16.5436 22.5068 14.9613 22.5069 13.9854 21.5309L9.97367 17.5192C8.99773 16.5433 8.99773 14.9609 9.97367 13.985L13.9854 9.9733C14.9613 8.99736 16.5436 8.99736 17.5196 9.9733L21.5313 13.985Z" fill="#CD88FF"/>\
      <path d="M12.3397 23.2389C13.2982 24.1974 13.2982 25.7514 12.3397 26.7099L8.26476 30.7848C7.30628 31.7433 5.75228 31.7433 4.79379 30.7848L0.718861 26.7099C-0.23962 25.7514 -0.239621 24.1974 0.718861 23.2389L4.7938 19.164C5.75228 18.2055 7.30629 18.2055 8.26477 19.164L12.3397 23.2389Z" fill="#A950FF"/>\
      <path d="M39.9762 13.985C40.9521 14.9609 40.9521 16.5433 39.9762 17.5192L35.9645 21.5309C34.9886 22.5068 33.4062 22.5069 32.4303 21.5309L28.4186 17.5192C27.4426 16.5433 27.4426 14.9609 28.4186 13.985L32.4303 9.9733C33.4062 8.99736 34.9886 8.99736 35.9645 9.9733L39.9762 13.985Z" fill="#CD88FF"/>\
      <path d="M28.9225 40.3319C31.1028 42.5123 31.1028 46.0473 28.9225 48.2276C26.7422 50.408 23.2071 50.408 21.0268 48.2276C18.8465 46.0473 18.8465 42.5123 21.0268 40.3319C23.2072 38.1516 26.7422 38.1516 28.9225 40.3319Z" fill="#F62E76"/>\
    </svg>\
  </div>\
  <svg class="refresh-icon" id="oa2-refresh-icon" viewBox="0 0 24 24" fill="none">\
    <path d="M12 4C9.33 4 7 5.34 5.56 7.36L3 4.81V11H9.19L6.41 8.22C7.5 6.86 9.15 6 11 6C14.31 6 17 8.69 17 12H19C19 7.58 15.42 4 12 4ZM12 18C8.69 18 6 15.31 6 12H4C4 16.42 7.58 20 12 20C14.67 20 17 18.66 18.44 16.64L21 19.19V13H14.81L17.59 15.78C16.5 17.14 14.85 18 13 18H12Z" fill="#631BFF"/>\
  </svg>'
        scene.appendChild(kestraWrap)

        var refreshIcon = kestraWrap.querySelector(".refresh-icon")
        refreshIcon.style.left = KESTRA_R * 2 + 8 + "px"
        refreshIcon.style.top = KESTRA_R - 11 + "px"

        var successArea = document.createElement("div")
        successArea.className = "success-area"
        successArea.id = "oa2-success-area"
        successArea.style.top = SUCCESS_Y - 11 + "px"
        successArea.innerHTML =
            '\
  <div class="success-check">\
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">\
      <path d="M2 7L5.5 10.5L12 4" stroke="#06F0B1" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>\
    </svg>\
  </div>\
  <span class="success-label" id="oa2-success-label">Success</span>'
        scene.appendChild(successArea)

        var beamPaths = []
        var defs = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "defs",
        )
        svgEl.appendChild(defs)

        LANGS.forEach(function (l, i) {
            var cx = cardCX(i),
                cy = CARD_BOTTOM
            var angle = angleToCard(i)
            var kPt = kestraPoint(angle)
            var midY = (cy + kPt.y) / 2
            var pathD =
                "M " +
                cx +
                " " +
                cy +
                " C " +
                cx +
                " " +
                midY +
                ", " +
                kPt.x +
                " " +
                midY +
                ", " +
                kPt.x +
                " " +
                kPt.y

            var base = document.createElementNS(
                "http://www.w3.org/2000/svg",
                "path",
            )
            base.setAttribute("d", pathD)
            base.setAttribute("stroke", "rgba(255,255,255,0.12)")
            base.setAttribute("stroke-width", "1.5")
            base.setAttribute("stroke-dasharray", "3 3")
            base.setAttribute("fill", "none")
            svgEl.appendChild(base)

            var gradId = "oa2-beam-grad-" + i
            var grad = document.createElementNS(
                "http://www.w3.org/2000/svg",
                "linearGradient",
            )
            grad.setAttribute("id", gradId)
            grad.setAttribute("gradientUnits", "userSpaceOnUse")
            grad.setAttribute("x1", cx)
            grad.setAttribute("y1", cy)
            grad.setAttribute("x2", kPt.x)
            grad.setAttribute("y2", kPt.y)
            var s1 = document.createElementNS(
                "http://www.w3.org/2000/svg",
                "stop",
            )
            s1.setAttribute("offset", "0%")
            s1.setAttribute("stop-color", l.beamColor)
            var s2 = document.createElementNS(
                "http://www.w3.org/2000/svg",
                "stop",
            )
            s2.setAttribute("offset", "100%")
            s2.setAttribute("stop-color", "#631BFF")
            grad.appendChild(s1)
            grad.appendChild(s2)
            defs.appendChild(grad)

            var beam = document.createElementNS(
                "http://www.w3.org/2000/svg",
                "path",
            )
            beam.setAttribute("d", pathD)
            beam.setAttribute("stroke", "url(#" + gradId + ")")
            beam.setAttribute("stroke-width", "2.5")
            beam.setAttribute("fill", "none")
            beam.setAttribute("stroke-linecap", "round")
            beam.setAttribute("stroke-dasharray", "300")
            beam.setAttribute("stroke-dashoffset", "300")
            beam.style.opacity = "0"
            svgEl.appendChild(beam)
            beamPaths.push(beam)
        })

        var successLineLen = SUCCESS_Y - kestraBottom.y - 22
        var successLine = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "line",
        )
        successLine.setAttribute("x1", KESTRA_CX)
        successLine.setAttribute("y1", kestraBottom.y)
        successLine.setAttribute("x2", KESTRA_CX)
        successLine.setAttribute("y2", SUCCESS_Y - 22)
        successLine.setAttribute("stroke", "#631BFF")
        successLine.setAttribute("stroke-width", "1.5")
        successLine.setAttribute("stroke-dasharray", successLineLen)
        successLine.setAttribute("stroke-dashoffset", successLineLen)
        successLine.style.opacity = "0"
        svgEl.appendChild(successLine)

        var kestra = root.querySelector("#oa2-kestra")
        var rIcon = root.querySelector("#oa2-refresh-icon")
        var sucArea = root.querySelector("#oa2-success-area")
        var sucLabel = root.querySelector("#oa2-success-label")

        var currentIdx = -1
        var tids = []
        function q(fn, ms) {
            var t = setTimeout(function () {
                if (isPaused()) {
                    q(fn, 100)
                } else {
                    fn()
                }
            }, ms)
            tids.push(t)
        }
        function clearAll() {
            for (var i = 0; i < tids.length; i++) {
                clearTimeout(tids[i])
            }
            tids = []
        }

        function resetLang(i) {
            if (i < 0) return
            var card = root.querySelector("#oa2-card-" + LANGS[i].id)
            card.classList.remove("active")
            card.style.borderColor = ""
            card.style.boxShadow = ""
            var b = beamPaths[i]
            b.style.animation = "none"
            b.style.opacity = "0"
            b.setAttribute("stroke-dashoffset", "300")
        }

        function resetKestra() {
            kestra.classList.remove("active")
            rIcon.classList.remove("spinning")
            rIcon.style.opacity = "0"
            sucArea.classList.remove("show")
            successLine.style.opacity = "0"
            successLine.setAttribute("stroke-dashoffset", successLineLen)
        }

        function activateLang(i) {
            var l = LANGS[i]
            var card = root.querySelector("#oa2-card-" + l.id)
            var beam = beamPaths[i]

            card.classList.add("active")
            card.style.borderColor = l.color
            card.style.boxShadow =
                "0 0 16px " + l.glowColor + ", inset 0 0 6px " + l.glowColor

            q(function () {
                beam.style.opacity = "1"
                beam.setAttribute("stroke-dashoffset", "300")
                beam.offsetHeight
                beam.style.animation = "none"
                beam.offsetHeight
                beam.style.animation = "oa2-beam-travel 0.75s ease-in forwards"
                beam.addEventListener(
                    "animationend",
                    function () {
                        beam.style.animation = "none"
                        beam.setAttribute("stroke-dashoffset", "0")
                        beam.style.opacity = "1"
                    },
                    { once: true },
                )
            }, 300)

            q(function () {
                kestra.classList.add("active")
                rIcon.style.opacity = "1"
                rIcon.classList.add("spinning")
            }, 900)

            q(function () {
                successLine.style.opacity = "1"
                successLine.style.transition = "none"
                successLine.setAttribute("stroke-dashoffset", successLineLen)
                successLine.offsetHeight
                successLine.style.transition = "stroke-dashoffset 0.5s ease-out"
                successLine.setAttribute("stroke-dashoffset", "0")
            }, 1550)

            q(function () {
                rIcon.classList.remove("spinning")
                rIcon.style.opacity = "0"
                sucLabel.textContent = l.label + " — Success"
                sucArea.classList.add("show")
            }, 2000)
        }

        var HOLD = 3000
        var PAUSE = 500

        function runCycle() {
            function next() {
                var prev = currentIdx
                currentIdx = (currentIdx + 1) % LANGS.length
                if (prev >= 0) {
                    resetLang(prev)
                    resetKestra()
                }
                q(
                    function () {
                        activateLang(currentIdx)
                        q(next, HOLD)
                    },
                    prev >= 0 ? PAUSE : 0,
                )
            }
            next()
        }

        setTimeout(runCycle, 500)
    })()
</script>

