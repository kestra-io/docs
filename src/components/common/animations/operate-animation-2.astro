<style>
    .oa-2 {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100%;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        overflow: hidden;

        .scene-wrapper {
            width: 580px;
            height: 500px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .scene {
            position: relative;
            width: 680px;
            height: 560px;
            transform: scale(0.85);
            transform-origin: center center;
            flex-shrink: 0;
        }

        .lang-card {
            position: absolute;
            width: 76px;
            height: 76px;
            border-radius: 12px;
            border: 1.5px solid rgba(255, 255, 255, 0.18);
            background: rgba(255, 255, 255, 0.04);
            display: flex;
            align-items: center;
            justify-content: center;
            transition:
                border-color 0.3s,
                box-shadow 0.3s;
        }

        .lang-card .glow {
            position: absolute;
            inset: -14px;
            border-radius: 22px;
            opacity: 0;
            filter: blur(20px);
            transition: opacity 0.4s ease;
            pointer-events: none;
        }

        .lang-card svg {
            position: relative;
            z-index: 1;
        }
        .lang-card.active .glow {
            opacity: 0.6;
        }

        .kestra-wrap {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
        }

        .kestra-ring {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            border: 1.5px dashed rgba(255, 255, 255, 0.22);
            transition:
                border-color 0.3s,
                box-shadow 0.3s,
                border-style 0.1s;
        }

        .kestra-glow {
            position: absolute;
            inset: -24px;
            border-radius: 50%;
            background: radial-gradient(
                circle,
                rgba(99, 27, 255, 0.75) 0%,
                transparent 70%
            );
            opacity: 0;
            transition: opacity 0.4s;
            pointer-events: none;
        }

        .kestra-inner {
            position: relative;
            width: 100%;
            height: 100%;
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .refresh-icon {
            position: absolute;
            width: 22px;
            height: 22px;
            opacity: 0;
            transition: opacity 0.3s;
            transform-origin: center;
        }

        .kestra-wrap.active .kestra-ring {
            border-color: #631bff;
            border-style: solid;
            box-shadow:
                0 0 22px rgba(99, 27, 255, 0.8),
                inset 0 0 12px rgba(99, 27, 255, 0.3);
        }
        .kestra-wrap.active .kestra-glow {
            opacity: 1;
        }
        .kestra-wrap.active .refresh-icon {
            opacity: 1;
        }

        .refresh-icon.spinning {
            animation: oa2-spin 1.1s linear infinite;
        }

        .success-area {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            gap: 8px;
            opacity: 0;
            transition: opacity 0.4s;
            white-space: nowrap;
        }
        .success-area.show {
            opacity: 1;
        }

        .success-check {
            width: 22px;
            height: 22px;
            background: #030307;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .success-label {
            color: #fff;
            font-family: "JetBrains Mono", monospace;
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 0.04em;
            opacity: 0.85;
        }
    }

    @keyframes oa2-beam-travel {
        0% {
            stroke-dashoffset: 300;
            opacity: 1;
        }
        85% {
            opacity: 1;
        }
        100% {
            stroke-dashoffset: 0;
            opacity: 0;
        }
    }

    @keyframes oa2-line-draw {
        from {
            stroke-dashoffset: 120;
        }
        to {
            stroke-dashoffset: 0;
        }
    }

    @keyframes oa2-spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="oa-2">
    <div class="scene-wrapper">
        <div class="scene" id="oa2-scene">
