<style is:global>
    .scene {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .glow-wrap {
        position: relative;
        padding: 4px;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.55);
        z-index: 2;
        transition:
            opacity 0.6s ease,
            transform 0.6s ease,
            filter 0.6s ease;
    }

    .glow-wrap.disappear {
        animation: disappearAnim 0.9s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    @keyframes disappearAnim {
        0% {
            opacity: 1;
            transform: scale(1) translateY(0);
            filter: blur(0px);
        }
        30% {
            opacity: 1;
            transform: scale(1.03) translateY(-4px);
            filter: blur(0px);
        }
        100% {
            opacity: 0;
            transform: scale(0.92) translateY(12px);
            filter: blur(6px);
        }
    }

    .glow-wrap.appear {
        animation: appearAnim 0.7s cubic-bezier(0.2, 0, 0, 1) forwards;
    }

    @keyframes appearAnim {
        0% {
            opacity: 0;
            transform: scale(0.94) translateY(10px);
            filter: blur(6px);
        }
        100% {
            opacity: 1;
            transform: scale(1) translateY(0);
            filter: blur(0px);
        }
    }

    .copilot-card {
        position: relative;
        background: #fff;
        border-radius: 10px;
        border: 1px solid #718bfe;
        width: 500px;
        box-shadow: 0 4px 32px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }

    .panel {
        width: 100%;
        transition: none;
    }

    #copilotPanel {
        padding: 0;
        display: flex;
        flex-direction: column;
    }

    .copilot-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 18px 12px;
        border-bottom: 1px solid #ecebef;
    }

    .copilot-icon {
        width: 32px;
        height: 32px;
        flex-shrink: 0;
    }

    .copilot-title {
        font-size: 15px;
        font-weight: 700;
        color: #131316;
        letter-spacing: -0.01em;
    }

    .copilot-subtitle {
        font-size: 10.5px;
        color: #9797a6;
        margin-top: 1px;
    }

    .input-wrap {
        padding: 12px 14px 10px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .input-area {
        position: relative;
        border: 1px solid #ecebef;
        border-radius: 8px;
        background: #fff;
        transition:
            border-color 0.25s ease,
            box-shadow 0.25s ease;
    }

    .input-area.focused {
        border-color: #631bff;
        box-shadow: 0 0 0 3px rgba(99, 27, 255, 0.12);
    }

    .input-inner {
        padding: 10px 12px 36px;
        font-size: 15px;
        font-weight: 400;
        color: #131316;
        line-height: 1.55;
        min-height: 70px;
    }

    .input-placeholder {
        color: #b0b3ba;
        font-style: normal;
    }

    .input-typing {
        display: none;
    }

    .input-bottom-bar {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 6px 8px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-top: 1px solid #f2f2f5;
    }

    .input-icons-left {
        display: flex;
        gap: 2px;
        align-items: center;
    }

    .input-icon-btn {
        width: 26px;
        height: 26px;
        border-radius: 6px;
        border: none;
        background: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9797a6;
    }

    .input-icon-btn:hover {
        background: #f5f5f8;
    }

    .input-send-btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        background: #8405ff;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.1s ease;
    }

    .input-send-btn.clicking {
        transform: scale(0.88);
    }

    .type-cursor {
        display: inline-block;
        width: 2px;
        height: 13px;
        background: #631bff;
        vertical-align: middle;
        animation: blink 0.65s step-end infinite;
        margin-left: 1px;
    }

    @keyframes blink {
        50% {
            opacity: 0;
        }
    }

    .submit-row {
        padding: 0 14px 14px;
        display: flex;
        justify-content: center;
    }

    .submit-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        background: #631bff;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 11px 0;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        width: 100%;
        transition:
            transform 0.1s ease,
            box-shadow 0.15s ease;
        box-shadow: 0 2px 12px rgba(99, 27, 255, 0.4);
        letter-spacing: -0.01em;
    }

    .submit-btn.clicking {
        transform: scale(0.95);
        box-shadow: 0 1px 4px rgba(99, 27, 255, 0.2);
    }

    .submit-btn svg {
        width: 14px;
        height: 14px;
    }

    .cursor-dot {
        position: absolute;
        width: 28px;
        height: 28px;
        pointer-events: none;
        z-index: 100;
        transition: none;
        display: none;
        filter: drop-shadow(0 0 3px rgba(180, 170, 255, 0.5))
            drop-shadow(0 1px 4px rgba(0, 0, 0, 0.5));
    }

    .cursor-dot svg {
        width: 28px;
        height: 28px;
    }

    .loading-overlay {
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 32px;
        gap: 14px;
    }

    .loading-spinner {
        width: 28px;
        height: 28px;
        border: 3px solid rgba(99, 27, 255, 0.15);
        border-top-color: #631bff;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .loading-text {
        font-size: 12px;
        color: #9797a6;
        animation: pulse 1.2s ease-in-out infinite;
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 0.6;
        }
        50% {
            opacity: 1;
        }
    }

    #codePanel {
        display: none;
    }

    .code-header {
        background: #f8f8fa;
        border-bottom: 1px solid #e1e3e5;
        padding: 10px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-radius: 10px 10px 0 0;
    }

    .code-tabs {
        display: flex;
        gap: 2px;
    }

    .code-tab {
        padding: 4px 12px;
        font-size: 11px;
        border-radius: 6px;
        color: #9797a6;
        cursor: pointer;
        font-weight: 500;
    }

    .code-tab.active {
        background: #ecedf2;
        color: #131316;
    }

    .code-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .code-action-btn {
        background: none;
        border: 1px solid #e1e3e5;
        color: #6b6b80;
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 10px;
        cursor: pointer;
        font-family: inherit;
    }

    .code-action-btn:last-child {
        background: rgba(99, 27, 255, 0.08);
        color: #631bff;
        border-color: rgba(99, 27, 255, 0.25);
    }

    .code-body {
        background: #fff;
        padding: 16px 20px 20px;
        font-family: "SF Mono", "Fira Code", "Consolas", monospace;
        font-size: 11.5px;
        line-height: 1.6;
        color: #1e1e2e;
        text-align: left;
        height: 240px;
        overflow-y: auto;
        overflow-x: hidden;
        white-space: pre;
        border-radius: 0 0 10px 10px;
        position: relative;
        scrollbar-width: thin;
        scrollbar-color: #d0d0dc #fff;
    }

    .code-body::-webkit-scrollbar {
        width: 6px;
    }

    .code-body::-webkit-scrollbar-track {
        background: #f8f8fa;
    }

    .code-body::-webkit-scrollbar-thumb {
        background: #d0d0dc;
        border-radius: 3px;
    }

    .code-body::-webkit-scrollbar-thumb:hover {
        background: #b8b8c8;
    }

    .code-cursor {
        display: inline-block;
        width: 2px;
        height: 12px;
        background: #631bff;
        vertical-align: middle;
        animation: blink 0.65s step-end infinite;
    }

    .sy-key {
        color: #7c3aed;
        font-weight: 500;
    }

    .sy-val {
        color: #0284c7;
    }

    .sy-str {
        color: #059669;
    }

    .sy-cmt {
        color: #94a3b8;
        font-style: italic;
    }

    .sy-trigger {
        color: #7c3aed;
        font-weight: 500;
    }

    .sy-new {
        background: rgba(99, 27, 255, 0.08);
        border-radius: 2px;
    }

    .trigger-lines {
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .trigger-lines.visible {
        opacity: 1;
    }

    .trigger-line-added {
        display: block;
        background: rgba(22, 163, 74, 0.08);
        border-left: 2px solid #16a34a;
        padding-left: 6px;
        margin-left: -20px;
        padding-right: 20px;
        animation: highlightFade 2.5s ease forwards;
    }

    @keyframes highlightFade {
        0% {
            background: rgba(22, 163, 74, 0.15);
        }
        100% {
            background: rgba(22, 163, 74, 0.06);
        }
    }

    .panel-fade-out {
        animation: fadeOut 0.35s ease forwards;
    }

    .panel-fade-in {
        animation: fadeIn 0.4s ease forwards;
    }

    @keyframes fadeOut {
        to {
            opacity: 0;
            transform: translateY(-8px);
        }
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .model-selector {
        display: flex;
        align-items: center;
        gap: 3px;
        padding: 3px 7px;
        border-radius: 5px;
        border: 1px solid #e8e8ee;
        background: #f8f8fa;
        cursor: pointer;
        font-size: 10px;
        font-weight: 500;
        color: #5a5a70;
        white-space: nowrap;
        transition: background 0.15s;
    }

    .model-selector:hover {
        background: #f0f0f5;
    }

    .model-selector-text {
        line-height: 1;
    }
</style>

