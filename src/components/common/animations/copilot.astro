<script is:inline>
    const PROMPT_TEXT = "Add a trigger to run the flow every day at 9 AM"

    const BASE_YAML_LINES = [
        {
            raw: "id: eland_854830",
            html: '<span class="sy-key">id</span>: eland_854830',
        },
        {
            raw: "namespace: company.team",
            html: '<span class="sy-key">namespace</span>: company.team',
        },
        { raw: "" },
        { raw: "tasks:", html: '<span class="sy-key">tasks</span>:' },
        {
            raw: "  - id: fetch_weather_data",
            html: '  - <span class="sy-key">id</span>: fetch_weather_data',
        },
        {
            raw: "    type: io.kestra.plugin.scripts.python.Script",
            html: '    <span class="sy-key">type</span>: <span class="sy-val">io.kestra.plugin.scripts.python.Script</span>',
        },
        {
            raw: "    description: Fetch current weather data for New York City",
            html: '    <span class="sy-key">description</span>: <span class="sy-str">Fetch current weather data for New York City</span>',
        },
        {
            raw: "    dependencies:",
            html: '    <span class="sy-key">dependencies</span>:',
        },
        {
            raw: "      - requests",
            html: '      - <span class="sy-str">requests</span>',
        },
        {
            raw: "    script: |",
            html: '    <span class="sy-key">script</span>: |',
        },
        {
            raw: "      import requests",
            html: '      <span class="sy-key">import</span> requests',
        },
        { raw: "" },
        {
            raw: '      CITY_NAME = "New York"',
            html: '      <span class="sy-val">CITY_NAME</span> = <span class="sy-str">"New York"</span>',
        },
        {
            raw: '      API_KEY = "YOUR_OPENWEATHERMAP_API_KEY"',
            html: '      <span class="sy-val">API_KEY</span> = <span class="sy-str">"YOUR_OPENWEATHERMAP_API_KEY"</span> <span class="sy-cmt"># Replace with your actual API key</span>',
        },
        {
            raw: '      WEATHER_API_URL = f"http://api.openweathermap.org/..."',
            html: '      <span class="sy-val">WEATHER_API_URL</span> = <span class="sy-str">f"http://api.openweathermap.org/data/2.5/weather?..."</span>',
        },
        { raw: "" },
        {
            raw: "      response = requests.get(WEATHER_API_URL)",
            html: '      response = requests.get(<span class="sy-val">WEATHER_API_URL</span>)',
        },
        {
            raw: "      weather_data = response.json()",
            html: "      weather_data = response.json()",
        },
        { raw: "" },
        {
            raw: "      if response.status_code == 200:",
            html: '      <span class="sy-key">if</span> response.status_code == <span class="sy-str">200</span>:',
        },
        {
            raw: '          temperature = weather_data["main"]["temp"]',
            html: '          temperature = weather_data[<span class="sy-str">"main"</span>][<span class="sy-str">"temp"</span>]',
        },
        {
            raw: '          print(f"Current weather: {temperature}°C")',
            html: '          print(<span class="sy-str">f"Current weather: {temperature}°C, {description}"</span>)',
        },
        { raw: "      else:", html: '      <span class="sy-key">else</span>:' },
        {
            raw: "          print(f\"Error: {weather_data['message']}\")",
            html: '          print(<span class="sy-str">f"Error: {weather_data[\'message\']}"</span>)',
        },
    ]

    const TRIGGER_LINES = [
        { raw: "", html: "" },
        { raw: "triggers:", html: '<span class="sy-trigger">triggers</span>:' },
        {
            raw: "  - id: daily_9am_schedule",
            html: '  - <span class="sy-key">id</span>: <span class="sy-val">daily_9am_schedule</span>',
        },
        {
            raw: "    type: io.kestra.plugin.core.trigger.Schedule",
            html: '    <span class="sy-key">type</span>: <span class="sy-val">io.kestra.plugin.core.trigger.Schedule</span>',
        },
        {
            raw: '    cron: "0 9 * * *"',
            html: '    <span class="sy-key">cron</span>: <span class="sy-str">"0 9 * * *"</span>',
        },
    ]

{
    let tid = null
    const copilotCard = document.querySelector(".copilot-card")
    const after = (fn, ms) => {
        clearTimeout(tid)
        tid = setTimeout(async () => {
            await waitForVisible()
            fn()
        }, ms)
    }

    const copilotPanel = copilotCard.querySelector("#copilotPanel")
    const inputArea = copilotCard.querySelector("#inputArea")
    const inputPH = copilotCard.querySelector("#inputPlaceholder")
    const inputTyping = copilotCard.querySelector("#inputTyping")
    const typedText = copilotCard.querySelector("#typedText")
    const submitBtn = copilotCard.querySelector("#submitBtn")
    const loadingOv = copilotCard.querySelector("#loadingOverlay")
    const codePanel = copilotCard.querySelector("#codePanel")
    const codeBody = copilotCard.querySelector("#codeBody")
    const cursorDot = copilotCard.querySelector("#cursorDot")

    let cursorAnim = null

    async function waitForVisible() {
        while (copilotCard.closest(".paused")) {
            await new Promise((r) => setTimeout(r, 100))
        }
    }

    function getCardRect(el) {
        const card = copilotCard.getBoundingClientRect()
        const er = el.getBoundingClientRect()
        return {
            x: er.left - card.left + er.width / 2,
            y: er.top - card.top + er.height / 2,
        }
    }

    function moveCursorTo(el, duration, callback) {
        const pos = getCardRect(el)
        const startX = parseFloat(cursorDot.style.left) || 80
        const startY = parseFloat(cursorDot.style.top) || 60
        const steps = Math.round(duration / 16)
        let step = 0

        clearInterval(cursorAnim)
        cursorAnim = setInterval(async () => {
            if (copilotCard.closest(".paused")) return

            step++
            const t = step / steps
            const ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t
            cursorDot.style.left = startX + (pos.x - startX) * ease + "px"
            cursorDot.style.top = startY + (pos.y - startY) * ease + "px"
            if (step >= steps) {
                clearInterval(cursorAnim)
                if (callback) {
                    await waitForVisible()
                    callback()
                }
            }
        }, 16)
    }

    function showCursor(x, y) {
        cursorDot.style.display = "block"
        cursorDot.style.left = x + "px"
        cursorDot.style.top = y + "px"
    }

    function hideCursor() {
        cursorDot.style.display = "none"
    }

    function typeText(target, text, i, callback) {
        if (i > text.length) {
            if (callback) {
                ;(async () => {
                    await waitForVisible()
                    callback()
                })()
            }
            return
        }
        if (copilotCard.closest(".paused")) {
            setTimeout(() => typeText(target, text, i, callback), 100)
            return
        }
        target.textContent = text.slice(0, i)
        const delay = 28 + Math.random() * 30
        setTimeout(() => typeText(target, text, i + 1, callback), delay)
    }

    let committedLines = []

    let _currentNode = null
    let _cursorNode = null

    function rebuildDOM() {
        codeBody.innerHTML = ""
        _currentNode = null
        _cursorNode = null
        for (const l of committedLines) {
            const span = document.createElement("span")
            span.innerHTML = (l || "") + "\n"
            codeBody.appendChild(span)
        }
    }

    function renderCode(partial, showCsr) {
        rebuildDOM()
        if (partial) {
            _currentNode = document.createElement("span")
            _currentNode.innerHTML = partial
            codeBody.appendChild(_currentNode)
        }
        if (showCsr) {
            _cursorNode = document.createElement("span")
            _cursorNode.className = "code-cursor"
            codeBody.appendChild(_cursorNode)
        }
    }

    function updateCurrentNode(html, showCsr) {
        if (!_currentNode) {
            _currentNode = document.createElement("span")
            codeBody.appendChild(_currentNode)
        }
        _currentNode.innerHTML = html
        if (showCsr) {
            if (!_cursorNode) {
                _cursorNode = document.createElement("span")
                _cursorNode.className = "code-cursor"
                codeBody.appendChild(_cursorNode)
            }
        } else {
            if (_cursorNode) {
                _cursorNode.remove()
                _cursorNode = null
            }
        }
    }

    function sliceHtml(htmlStr, n) {
        let rem = n
        const d = document.createElement("div")
        d.innerHTML = htmlStr
        let out = ""
        for (const node of d.childNodes) {
            if (rem <= 0) break
            if (node.nodeType === 3) {
                const t = node.textContent.slice(0, rem)
                out += t
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                rem -= t.length
            } else {
                const t = node.textContent
                const take = Math.min(t.length, rem)
                out += `<span class="${node.className}">${t.slice(0, take).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")}</span>`
                rem -= take
            }
        }
        return out
    }

    function typeNextLine() {
        committedLines = BASE_YAML_LINES.map((l) => l.html)
        rebuildDOM()
        codeBody.scrollTop = codeBody.scrollHeight
        after(insertTrigger, 600)
    }

    function smoothScrollTo(target, duration, callback) {
        const start = codeBody.scrollTop
        const dist = target - start
        const t0 = performance.now()
        function tick(now) {
            if (copilotCard.closest(".paused")) {
                requestAnimationFrame(tick)
                return
            }
            const elapsed = now - t0
            const progress = Math.min(elapsed / duration, 1)
            const ease =
                progress < 0.5
                    ? 4 * progress * progress * progress
                    : 1 - Math.pow(-2 * progress + 2, 3) / 2
            codeBody.scrollTop = start + dist * ease
            if (progress < 1) requestAnimationFrame(tick)
            else if (callback) {
                ;(async () => {
                    await waitForVisible()
                    callback()
                })()
            }
        }
        requestAnimationFrame(tick)
    }

    function insertTrigger() {
        const placeholders = []
        for (const L of TRIGGER_LINES) {
            const ph = document.createElement("span")
            ph.style.cssText =
                "display:block;visibility:hidden;white-space:pre;"
            ph.textContent = L.raw || " "
            codeBody.appendChild(ph)
            placeholders.push(ph)
        }

        const targetScroll = codeBody.scrollHeight - codeBody.clientHeight / 2
        smoothScrollTo(targetScroll, 650, () => {
            placeholders.forEach((ph) => ph.remove())

            const lineNodes = TRIGGER_LINES.map((L) => {
                const span = document.createElement("span")
                if (L.raw === "") {
                    span.innerHTML = "\n"
                } else {
                    span.className = "trigger-line-added"
                    span.style.visibility = "hidden"
                    span.innerHTML = L.html + "\n"
                }
                codeBody.appendChild(span)
                return span
            })

            _cursorNode = document.createElement("span")
            _cursorNode.className = "code-cursor"

            let ti = 0
            function typeTriggerLine() {
                if (ti >= TRIGGER_LINES.length) {
                    if (_cursorNode.parentNode) _cursorNode.remove()
                    after(clickApplyThenRestart, 700)
                    return
                }
                const L = TRIGGER_LINES[ti]
                const node = lineNodes[ti]
                ti++

                if (L.raw === "") {
                    after(typeTriggerLine, 40)
                    return
                }

                node.style.visibility = "visible"
                node.innerHTML = ""
                node.appendChild(_cursorNode)

                const rawLen = L.raw.length
                let ci = 1
                function step() {
                    if (copilotCard.closest(".paused")) {
                        setTimeout(step, 100)
                        return
                    }
                    if (ci <= rawLen) {
                        node.innerHTML = sliceHtml(L.html, ci)
                        node.innerHTML += "\n"
                        node.appendChild(_cursorNode)
                        const ch = L.raw[ci - 1] || ""
                        const delay = ch === " " ? 14 : 18 + Math.random() * 16
                        ci++
                        setTimeout(step, delay)
                    } else {
                        node.innerHTML = L.html + "\n"
                        after(typeTriggerLine, 50)
                    }
                }
                step()
            }
            typeTriggerLine()
        })
    }

    function showCopilot(immediate) {
        codePanel.style.display = "none"
        copilotPanel.style.display = "flex"
        if (!immediate) copilotPanel.classList.add("panel-fade-in")
        setTimeout(() => copilotPanel.classList.remove("panel-fade-in"), 400)
        inputArea.classList.remove("focused")
        inputPH.style.display = "block"
        inputTyping.style.display = "none"
        typedText.textContent = ""
        loadingOv.style.display = "none"
        submitBtn.classList.remove("clicking")
    }

    function showCode() {
        copilotPanel.classList.add("panel-fade-out")
        setTimeout(() => {
            copilotPanel.style.display = "none"
            copilotPanel.classList.remove("panel-fade-out")
            codePanel.style.display = "block"
            codePanel.classList.add("panel-fade-in")
            setTimeout(() => codePanel.classList.remove("panel-fade-in"), 400)
            committedLines = []
            renderCode("", false)
            after(typeNextLine, 200)
        }, 350)
    }

    function clickApplyThenRestart() {
        const applyBtn = copilotCard.querySelector("#applyBtn")
        const cardRect = copilotCard.getBoundingClientRect()
        const applyRect = applyBtn.getBoundingClientRect()
        showCursor(applyRect.left - cardRect.left - 60, 20)
        moveCursorTo(applyBtn, 600, () => {
            applyBtn.style.transform = "scale(0.93)"
            applyBtn.style.background = "rgba(99,27,255,0.2)"
            after(() => {
                applyBtn.style.transform = ""
                hideCursor()
                const glowWrap = copilotCard.closest(".glow-wrap")
                glowWrap.classList.add("disappear")
                after(() => {
                    glowWrap.classList.remove("disappear")
                    restart()
                }, 950)
            }, 160)
        })
    }

    function restart() {
        hideCursor()
        const applyBtn = copilotCard.querySelector("#applyBtn")
        applyBtn.style.background = "rgba(99,27,255,0.08)"
        applyBtn.style.transform = ""
        const glowWrap = copilotCard.closest(".glow-wrap")
        glowWrap.classList.add("appear")
        setTimeout(() => glowWrap.classList.remove("appear"), 750)
        showCopilot(false)
        after(startCopilotAnim, 900)
    }

    function startCopilotAnim() {
        showCursor(40, 30)
        after(() => {
            moveCursorTo(inputArea, 700, () => {
                inputArea.classList.add("focused")
                after(() => {
                    inputPH.style.display = "none"
                    inputTyping.style.display = "block"
                    typeText(typedText, PROMPT_TEXT, 0, () => {
                        after(() => {
                            moveCursorTo(submitBtn, 600, () => {
                                submitBtn.classList.add("clicking")
                                after(() => {
                                    submitBtn.classList.remove("clicking")
                                    inputArea.classList.remove("focused")
                                    loadingOv.style.display = "flex"
                                    hideCursor()
                                    after(() => {
                                        showCode()
                                    }, 1800)
                                }, 180)
                            })
                        }, 400)
                    })
                }, 300)
            })
        }, 500)
    }

    showCopilot(true)
    after(startCopilotAnim, 900)
}
</script>
