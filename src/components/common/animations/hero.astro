        item.innerHTML =
            '<div class="topo-icn" style="background:' +
            t.bg +
            '">' +
            t.icon +
            "</div>" +
            '<div class="topo-lbl"><span class="topo-lbl-id">' +
            t.label +
            '</span><span class="topo-lbl-type">' +
            t.type +
            "</span></div>" +
            '<div class="topo-rt">' +
            rtHTML +
            "</div>"
        var cn = document.createElement("div")
        cn.className = "topo-cn"
        cn.innerHTML =
            '<div class="topo-dt"></div><div class="topo-dt"></div><div class="topo-dt"></div><div class="topo-pt"></div>'
        wrap.appendChild(item)
        wrap.appendChild(cn)
        return { el: wrap, itemEl: item, cnEl: cn }
    }

    for (var i = 0; i < TOTAL + 1; i++) {
        var item = mkItem(TASKS[taskCursor++ % TASKS.length])
        items.push(item)
        inner?.appendChild(item.el)
    }

    var SCENE_CY = (814 - 86) / 2 + 80
    var baseOffset = SCENE_CY - ACTIVE_I * ITEM_H - ITEM_H / 2

    function setY(y: number, animate: boolean) {
        if (!inner) return
        inner.style.transition = animate
            ? "transform " + ANIM_MS + "ms cubic-bezier(0.4,0,0.2,1)"
            : "none"
        inner.style.transform = "translateY(" + y + "px)"
    }
    setY(baseOffset, false)

    function updateActive() {
        items.forEach(function (it, i) {
            var dist = Math.abs(i - ACTIVE_I)
            var op = Math.max(
                0,
                1 - Math.max(0, dist - 1) / (VISIBLE / 2 + 0.5),
            ).toString()
            it.el.style.opacity = op
            it.itemEl.classList.toggle("is-active", i === ACTIVE_I)
            it.cnEl.classList.toggle("is-active", i === ACTIVE_I)
        })
    }
    updateActive()

    function advance() {
        baseOffset -= ITEM_H
        setY(baseOffset, true)
        setTimeout(function () {
            var first = items.shift()
            first?.el.remove()
            var newItem = mkItem(TASKS[taskCursor++ % TASKS.length])
            items.push(newItem)
            inner?.appendChild(newItem.el)
            baseOffset += ITEM_H
            setY(baseOffset, false)
            updateActive()
        }, ANIM_MS + 16)
    }
    setInterval(advance, STEP_MS)
</script>
