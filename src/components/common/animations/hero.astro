---
/* make this component inherit the css class specified in the parent */
const { class: parentClass, ...rest } = Astro.props
---

<div class={`topo-scene ${parentClass}`} {...rest}>
    <div class="topo-flow">
        <div class="topo-flow-inner" id="flowInner"></div>
    </div>
</div>

<style is:global>
    .topo-scene {
        position: relative;
        width: 570px;
        height: 814px;
        overflow: visible;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .topo-flow {
        position: relative;
        transform: matrix(0.978148, 0.207912, -0.669131, 0.743145, 0, 0)
            scale(1.28);
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .topo-flow-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        will-change: transform;
    }

    /* renamed from .card → .topo-item to avoid Bootstrap conflicts */
    .topo-item {
        width: 340px;
        height: 58px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        padding: 0 16px;
        gap: 12px;
        position: relative;
        flex-shrink: 0;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.018);
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.35);
        transition:
            border-color 0.6s ease,
            box-shadow 0.6s ease,
            opacity 0.6s ease,
            transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        transform: scale(1) translateY(0);
    }
    .topo-item.is-active {
        transform: scale(1.07) translate(-3px, -3px);
        border-color: rgba(180, 140, 255, 0.7);
        background: rgba(144, 65, 255, 0.1);
        box-shadow:
            0 0 0 1px rgba(144, 65, 255, 0.35),
            0 0 32px rgba(144, 65, 255, 0.45),
            0 0 80px rgba(144, 65, 255, 0.18),
            inset 0 0 20px rgba(144, 65, 255, 0.08),
            6px 6px 0 rgba(0, 0, 0, 0.6),
            8px 8px 16px rgba(0, 0, 0, 0.5);
    }
    .topo-item.is-trigger {
        background: rgba(8, 233, 149, 0.025);
        border-color: rgba(8, 233, 149, 0.18);
    }
    .topo-item.is-trigger.is-active {
        border-color: #08e995;
        background: rgba(8, 233, 149, 0.07);
        box-shadow:
            0 0 0 1px rgba(8, 233, 149, 0.5),
            0 0 32px rgba(8, 233, 149, 0.4),
            0 0 80px rgba(8, 233, 149, 0.15),
            inset 0 0 20px rgba(8, 233, 149, 0.06),
            6px 6px 0 rgba(0, 0, 0, 0.6),
            8px 8px 16px rgba(0, 0, 0, 0.5);
    }

    .topo-badge {
        position: absolute;
        top: -9px;
        left: 14px;
        font-size: 9px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #08e995;
        background: #0d0d10;
        padding: 1px 8px;
        border-radius: 6px;
        border: 1px solid rgba(8, 233, 149, 0.2);
    }
    .topo-icn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
    }
    .topo-icn::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 50%;
        background: linear-gradient(
            to bottom,
            rgba(255, 255, 255, 0.12),
            transparent
        );
        border-radius: 8px 8px 0 0;
        pointer-events: none;
    }
    .topo-icn svg {
        width: 24px;
        height: 24px;
    }
    .topo-lbl {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1px;
    }
    .topo-lbl-id {
        font-size: 12px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.4);
        letter-spacing: 0.01em;
        transition: color 0.6s ease;
    }
    .topo-lbl-type {
        font-size: 8px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.25);
        letter-spacing: 0.02em;
        transition: color 0.6s ease;
    }
    .topo-item.is-active .topo-lbl-id {
        color: rgba(255, 255, 255, 0.9);
    }
    .topo-item.is-active .topo-lbl-type {
        color: rgba(255, 255, 255, 0.3);
    }
    .topo-rt {
        display: flex;
        align-items: center;
        min-width: 20px;
    }
    .topo-chk svg {
        width: 18px;
        height: 18px;
    }
    .topo-chk .chk-circle {
        transition:
            fill 0.4s ease,
            stroke 0.4s ease;
    }
    .topo-item.is-active .topo-chk .chk-circle {
        fill: rgba(8, 233, 149, 0.08);
        stroke: #08e995;
    }
    .topo-chk .cp {
        stroke-dasharray: 20;
        stroke-dashoffset: 20;
        transition: stroke-dashoffset 0.5s 0.1s ease;
    }
    .topo-item.is-active .topo-chk .cp {
        stroke-dashoffset: 0;
    }
    .topo-blt {
        opacity: 0;
        transition: opacity 0.4s ease;
    }
    .topo-item.is-active .topo-blt {
        opacity: 1;
    }
    .topo-blt svg {
        width: 15px;
        height: 15px;
    }
    .topo-cn {
        height: 30px;
        width: 340px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        position: relative;
    }
    .topo-dt {
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
        transition: background 0.6s ease;
    }
    .topo-cn.is-active .topo-dt {
        background: rgba(144, 65, 255, 0.5);
    }
    .topo-pt {
        position: absolute;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #9041ff;
        box-shadow: 0 0 8px rgba(144, 65, 255, 0.9);
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        opacity: 0;
        pointer-events: none;
    }
    .topo-cn.is-active .topo-pt {
        animation: ptSlide 1s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }
    @keyframes ptSlide {
        0% {
            top: 2px;
            opacity: 0;
        }
        8% {
            opacity: 1;
        }
        88% {
            opacity: 0.9;
        }
        100% {
            top: 26px;
            opacity: 0;
        }
    }
</style>

