---
import { $fetchApi } from "~/utils/fetch"
import { type PluginMetadata } from "@kestra-io/ui-libs"
import { fetchTotalPluginsCount } from "~/utils/plugins/pluginCount"

import Link from "~/components/common/Link.astro"
import TaskIcon from "~/components/common/TaskIcon.astro"

const totalPlugins = await fetchTotalPluginsCount()

const pluginMetadata = await $fetchApi<PluginMetadata[]>("/plugins/metadata")

const filteredPlugins = pluginMetadata
    .filter(
        (r) =>
            r.artifactId &&
            !["core", "plugin-kestra", "plugin-debezium"].includes(
                r.artifactId,
            ) &&
            !r.artifactId.startsWith("plugin-ee") &&
            !r.artifactId.startsWith("secret-") &&
            !r.artifactId.startsWith("storage-"),
    )
    .map((plugin) => ({
        ...plugin,
        link:
            `/plugins/${plugin.artifactId}` +
            (`plugin-${plugin.name}` !== plugin.artifactId
                ? "/" + plugin.name
                : ""),
    }))
    .sort(() => 0.5 - Math.random())

const rows = [
    {
        items: filteredPlugins.slice(0, 20),
        cls: "row-1",
    },
    {
        items: filteredPlugins.slice(20, 40),
        cls: "row-2",
    },
]
---

<section class="plugins">
    <div class="container">
        <div class="content-wrapper">
            <div class="text-block">
                <h2 data-usal="fade-r">
                    <slot name="title">
                        <span class="highlight">{totalPlugins}+ Plugins</span>
                        <br /> That Integrate With Your Stack
                    </slot>
                </h2>
                <p data-usal="fade-l">
                    <slot name="description">
                        Connect with third-party systems, data sources, and
                        applications.
                        <br />
                        And if you require a custom integration, our platform makes it
                        easy to build custom plugins.
                    </slot>
                </p>
            </div>
            <slot name="cta">
                <Link
                    data-usal="zoomin"
                    href="/plugins"
                    class="btn btn-secondary"
                >
                    See all plugins
                </Link>
            </slot>
        </div>
    </div>

    <div class="carousel">
        {
            rows.map((row) => (
                <div class={`carousel-row ${row.cls}`}>
                    <div class="carousel-track">
                        {[...row.items, ...row.items].map((plugin) => (
                            <a href={plugin.link} class="plugin-logo">
                                <TaskIcon cls={plugin.group} />
                            </a>
                        ))}
                    </div>
                </div>
            ))
        }
    </div>
</section>

<style lang="scss">
    @import "~/assets/styles/variable";

    section.plugins {
        padding: 6.25rem 0;
        display: flex;
        flex-direction: column;
        gap: 4.5rem;
        background: linear-gradient(
            180deg,
            var(--ks-background-secondary) 0%,
            var(--ks-background-body) 100%
        );
        overflow: visible;

        .container {
            padding: 0 1rem;

            .content-wrapper {
                display: flex;
                justify-content: space-between;
                align-items: center;
                text-align: left;
                width: 100%;

                @include media-breakpoint-down(md) {
                    flex-direction: column;
                    gap: $rem-2;
                }

                :global(.link) {
                    white-space: nowrap;
                }

                .text-block {
                    max-width: 893px;

                    h2 {
                        margin-bottom: $rem-1;
                    }
                    p {
                        margin: 0;
                    }
                }
            }
        }

        .carousel {
            width: 100%;
            position: relative;
            display: flex;
            flex-direction: column;
            overflow: clip;
            padding-top: 50px;
            margin-top: -50px;
            touch-action: pan-y;

            $mask: linear-gradient(
                to right,
                transparent,
                $black 100px,
                $black calc(100% - 100px),
                transparent
            );
            mask-image: $mask;
            -webkit-mask-image: $mask;
            pointer-events: none;
            cursor: default;

            &::before,
            &::after {
                content: "";
                position: absolute;
                top: 0;
                height: 100%;
                width: 100px;
                z-index: 20;
                pointer-events: none;
            }

            &::before {
                left: 0;
                background: linear-gradient(
                    to right,
                    var(--ks-background-body),
                    transparent
                );
                $mask-left: linear-gradient(to right, $black, transparent);
                -webkit-mask-image: $mask-left;
                mask-image: $mask-left;
            }

            &::after {
                right: 0;
                background: linear-gradient(
                    to left,
                    var(--ks-background-body),
                    transparent
                );
                $mask-right: linear-gradient(to left, $black, transparent);
                -webkit-mask-image: $mask-right;
                mask-image: $mask-right;
            }

            .carousel-row {
                display: flex;
                align-items: center;
                position: relative;
                z-index: 1;

                &:hover {
                    z-index: 10;
                }

                .carousel-track {
                    display: flex;
                    gap: 10px;
                    width: max-content;
                    will-change: transform;
                    pointer-events: none;
                }

                &.row-1 .carousel-track {
                    animation: scroll-left 50s linear infinite;
                    padding-bottom: 0.5rem;
                }
                &.row-2 .carousel-track {
                    animation: scroll-right 50s linear infinite;
                }
            }

            .plugin-logo {
                width: 79px;
                height: 79px;
                background: var(--ks-background-primary);
                border-radius: 12px;
                border: 1px solid var(--ks-border-primary);
                box-shadow: 0px 1.61px 3.21px 0px var(--ks-shadows-light);
                padding: 12px;
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                position: relative;
                pointer-events: auto;
                touch-action: pan-y;
                overscroll-behavior-y: auto;
                transition: all 0.2s ease;

                @include media-breakpoint-down(sm) {
                    width: 55px;
                    height: 55px;
                }

                &:hover {
                    color: var(--ks-content-primary);
                    z-index: 10;
                }
            }
        }
    }

    @keyframes scroll-left {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    @keyframes scroll-right {
        0% {
            transform: translateX(-50%);
        }
        100% {
            transform: translateX(0);
        }
    }
</style>