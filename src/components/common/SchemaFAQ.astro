---
interface FaqItem {
    question: string
    answer: string
}

interface Props {
    items?: FaqItem[]
}

const { items = [] } = Astro.props

function stripHtml(html: string): string {
    return html
        .replace(/<[^>]+>/g, "")
        .replace(/&amp;/g, "&")
        .replace(/&lt;/g, "<")
        .replace(/&gt;/g, ">")
        .replace(/&quot;/g, '"')
        .replace(/&#39;/g, "'")
        .trim()
}

const schema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": items.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
            "@type": "Answer",
            "text": stripHtml(item.answer),
        },
    })),
}
---

{
    items.length > 0 && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    )
}
