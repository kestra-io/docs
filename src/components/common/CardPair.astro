---
interface Props {
    isKestra?: boolean;
    logo?: string;
    logoAlt?: string;
    shadowColor?: string;
    maxWidth?: string;
}

const {
    isKestra = false,
    logo,
    logoAlt = "logo",
    shadowColor,
    maxWidth = "554px",
} = Astro.props as Props;
---

<div class:list={["comparison-item", isKestra ? "kestra" : "competitor"]}>
    {logo && (
        <div
            class="logo-wrapper"
            set:html={logo}
            role="img"
            aria-label={logoAlt}
        />
    )}
    <slot />
</div>

<style lang="scss" define:vars={{ competitorShadowColor: shadowColor, maxWidth }}>
    @import "~/assets/styles/variable";

    .comparison-item {
        flex: 1;
        @include media-breakpoint-up(xl) {
            max-width: var(--maxWidth);
        }
        padding: $rem-2;
        @include media-breakpoint-down(md) {
            padding: $rem-1;
        }
        border: $block-border;
        border-radius: 0 0 $border-radius-lg $border-radius-lg;
        display: flex;
        flex-direction: column;
        gap: 12px;
        color: var(--ks-content-primary);
        background-color: var(--ks-background-secondary);

        html.light & {
            background-color: $white;
        }

        &.kestra {
            box-shadow: 0px 4px 0px 0px var(--ks-border-active) inset;
        }

        &.competitor {
            box-shadow: 0px 4px 0px 0px var(--competitorShadowColor) inset;
        }
    }
</style>
