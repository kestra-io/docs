---
import { fetchPluginIcon } from "~/utils/pluginIcon"
const { cls } = Astro.props

const IconStr = await fetchPluginIcon(cls)
---

<div
    class="icon-wrapper"
    data-tooltip={cls.split(".").pop()}
    set:html={IconStr}
/>

<style lang="scss">
    .icon-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100%;
        position: relative;
        touch-action: pan-y;
        pointer-events: auto;

        :global(svg) {
            max-width: 100%;
            max-height: 100%;
            display: block;
        }

        &[data-tooltip]:hover::after {
            content: attr(data-tooltip);
            position: absolute;
            bottom: calc(100% + 16px);
            left: 50%;
            transform: translateX(-50%);
            background: var(--ks-background-body);
            border: 1px solid var(--ks-border-secondary);
            border-radius: 8px;
            color: var(--ks-content-primary);
            font-size: $font-size-xs;
            padding: 0.25rem 0.5rem;
            white-space: nowrap;
            z-index: 1000;
            pointer-events: none;
        }
    }
</style>
