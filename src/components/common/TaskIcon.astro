---
const { cls, class: className, ...rest } = Astro.props
---

<div
    class:list={["icon-wrapper", className ?? ""]}
    data-tooltip={cls.split(".").pop()}
>
    <img
        data-theme-responsive
        src={`/icons/${cls}.svg`}
        alt={cls.split(".").pop() + " icon"}
        width="32"
        height="32"
        loading="lazy"
        decoding="async"
        onerror="const w=this.closest('.icon-wrapper');const p=w&&w.parentElement;((p&&(p.classList.contains('icon')||p.classList.contains('box')))?p:w||this).style.display='none'"
        {...rest}
    />
</div>

<style lang="scss">
    .icon-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100%;
        position: relative;
        touch-action: pan-y;
        pointer-events: auto;
        aspect-ratio: 1 / 1;

        img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            aspect-ratio: 1 / 1;
        }

        &[data-tooltip]:hover::after {
            content: attr(data-tooltip);
            position: absolute;
            bottom: calc(100% + 16px);
            left: 50%;
            transform: translateX(-50%);
            background: var(--ks-background-body);
            border: 1px solid var(--ks-border-secondary);
            border-radius: 8px;
            color: var(--ks-content-primary);
            font-size: $font-size-xs;
            padding: 0.25rem 0.5rem;
            white-space: nowrap;
            z-index: 1000;
            pointer-events: none;
        }
    }
</style>

<script>
    /**
     * Upon loading a document, find all the [data-theme-responsive] images
     * and replace their source with white if the html element has the class "dark", otherwise replace it with black
     */
    const updateThemeIcons = () => {
        const isDarkMode = document.documentElement.classList.contains("dark")
        const themeIcons = document.querySelectorAll(
            "img[data-theme-responsive]",
        )

        themeIcons.forEach((icon) => {
            const src = icon.getAttribute("src")
            if (src) {
                const newSrc = src.replace(
                    /(-white|-black)?\.svg$/,
                    isDarkMode ? "-white.svg" : "-black.svg",
                )
                icon.setAttribute("src", newSrc)
            }
        })
    }
    updateThemeIcons()

    // when classes change on the html element, update the icons
    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            if (mutation.attributeName === "class") {
                updateThemeIcons()
            }
        })
    })
    observer.observe(document.documentElement, { attributes: true })
</script>
