---
import { fetchPluginIcon } from "~/utils/pluginIcon"
const { cls } = Astro.props

const IconStr = await fetchPluginIcon(cls)
---

<div
    class="icon-wrapper"
    data-tooltip={cls.split(".").pop()}
    set:html={IconStr}
/>

<style lang="scss">
    .icon-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100%;

        @include task-icon-wrapper;
    }
</style>
