---
import { fetchTotalPluginsCount } from "~/utils/plugins/pluginCount"
import { fetchPluginIcon } from "~/utils/pluginIcon"
import GradientCard from "~/components/card/GradientCard.vue"
import { $fetchApi } from "~/utils/fetch"
import { type PluginMetadata } from "@kestra-io/ui-libs"

const totalPlugins = await fetchTotalPluginsCount()
const pluginMetadata = await $fetchApi<PluginMetadata[]>("/plugins/metadata")

const filteredPlugins = pluginMetadata
    .filter(
        (r) =>
            r.artifactId &&
            r.artifactId !== "core" &&
            r.artifactId !== "plugin-kestra" &&
            r.artifactId !== "plugin-debezium" &&
            !r.artifactId.startsWith("plugin-ee") &&
            !r.artifactId.startsWith("secret-") &&
            !r.artifactId.startsWith("storage-"),
    )
    .sort(() => 0.5 - Math.random())
    .slice(0, 20)

const plugins = await Promise.all(
    filteredPlugins.map(async (plugin) => {
        const icon = await fetchPluginIcon(plugin.group)
        return {
            title: plugin.title,
            name: plugin.name,
            artifactId: plugin.artifactId,
            link:
                `/plugins/${plugin.artifactId}` +
                (`plugin-${plugin.name}` != plugin.artifactId
                    ? "/" + plugin.name
                    : ""),
            icon,
        }
    }),
)
---

<GradientCard class="container card-block">
    <div class="plugin-text">
        <h2>
            <span>{totalPlugins}+</span> Plugins<br />That Integrate With<br
            />Your <span> Stack </span>
        </h2>
        <h2 class="mobile">
            Integrate With<br />Your <span>Stack</span>
        </h2>
        <p>
            Connect with third-party systems, data sources, and applications.
            And if you require a custom integration, our platform makes it easy
            to build custom plugins.
        </p>
        <a href="/plugins" class="btn btn-md btn-primary">See All Plugins</a>
    </div>
    <div class="plugin-logos-grid">
        {
            plugins.map((plugin) => (
                <a href={plugin.link} set:html={plugin.icon} />
            ))
        }
    </div>
</GradientCard>

<style lang="scss">
    @import "~/assets/styles/variable";

    section {
        display: flex;
        place-content: center;
        background: var(--ks-background-secondary);
        padding: $rem-2 0.5rem;
    }

    .card-block {
        position: relative;
        z-index: 1;
        margin-block: 4rem;
        background: var(--ks-background-primary);
        border: $block-border;

        @include media-breakpoint-up(xl) {
            padding: 4rem;
            display: flex;
            flex-direction: row-reverse;
            gap: 4rem;
            align-items: center;
        }
    }

    .plugin-logos-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        flex: 1;
        min-width: 0;
        margin: clamp(1rem, 3vw, 2rem);

        @include media-breakpoint-up(xl) {
            margin: 0;
        }

        a {
            aspect-ratio: 1 / 1;
            padding: clamp(0.6rem, 1vw, 0.8rem);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            transition: none;

            &:nth-child(even) {
                background: var(--ks-background-secondary);
                box-shadow: inset 1px 1px 1px var(--ks-border-primary);
            }

            &:hover {
                background: inherit;
                color: inherit;
                &:nth-child(even) {
                    background: var(--ks-background-secondary);
                }
            }
        }

        :global(svg) {
            width: 60px;
            height: 60px;
            transition: transform 0.2s;
        }

        a:hover :global(svg) {
            transform: scale(1.1);
        }
    }

    .plugin-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        place-items: center;
        gap: 1rem;
        max-width: 450px;
        margin: 2rem auto;
        text-align: center;

        @include media-breakpoint-up(xl) {
            margin: 0;
        }

        h2 {
            display: none;
            font-size: 3rem;
            font-weight: 600;
            color: var(--ks-content-primary);

            @include media-breakpoint-up(xl) {
                display: block;
            }

            &.mobile {
                display: block;

                @include media-breakpoint-up(xl) {
                    display: none;
                }
            }

            span {
                background: linear-gradient(90deg, #7c2eea, #658af9) text;
                -webkit-text-fill-color: transparent;
            }
        }

        p {
            color: var(--ks-content-secondary);
        }

        .btn {
            margin: 1rem;
            border-radius: $border-radius-lg;
        }
    }
</style>

