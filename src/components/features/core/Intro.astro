---

---

<section class="core-head">
    <div class="background"></div>
    <div class="background bottom"></div>
    <div class="container">
        <div class="content">
            <h1 data-usal="fade-u">
                <span class="highlight">Standardize</span> Production Workflows,
                <br class="d-none d-lg-block" />
                Across Every Team and Stack
            </h1>
            <p data-usal="fade-u">
                One orchestration layer for data, infrastructure, and AI.
                <br class="d-none d-lg-block" />
                Git-native, API-first, and plugin-powered.
            </p>
        </div>
        <div class="d-flex align-items-center gap-3 cta" data-usal="zoomin">
            <a
                href="/docs/getting-started/quickstart#start-kestra"
                class="btn btn-lg btn-primary"
            >
                Get Started
            </a>
            <a href="/blueprints" class="btn btn-lg btn-secondary">
                Browse Blueprints
            </a>
        </div>
    </div>
</section>

<style lang="scss">
    .core-head {
        position: relative;
        padding: 130px 0;
        width: 100%;

        @include media-breakpoint-down(sm) {
            padding: 4rem 1rem;
        }

        .background {
            position: fixed;
            inset: 0;
            z-index: -1;
            background: #212125
                url("data:image/svg+xml;base64,")
                no-repeat top center / 1720px auto;
            pointer-events: none;

            &.bottom {
                position: absolute;
                background: transparent
                    url("data:image/svg+xml;base64,")
                    no-repeat bottom center / 1720px auto;
            }
        }

        .container {
            display: flex;
            flex-direction: column;
            gap: 4rem;
            align-items: center;

            @include media-breakpoint-down(sm) {
                gap: 2rem;
            }

            .content {
                text-align: center;
                color: $white;

                h1 {
                    font-weight: 500;
                    font-size: 2rem;

                    @include media-breakpoint-up(md) {
                        font-size: 2.5rem;
                    }

                    @include media-breakpoint-up(lg) {
                        font-size: 3.5rem;
                        line-height: 63px;
                    }
                }

                span.highlight {
                    color: #718bfe;
                }

                p {
                    margin-top: 1rem;

                    @include media-breakpoint-up(md) {
                        font-size: $font-size-lg;
                        line-height: 28px;
                    }
                }
            }

            .cta {
                a {
                    border-radius: $border-radius-lg;
                }

                @include media-breakpoint-down(sm) {
                    flex-direction: column;
                    padding-bottom: 0;
                    width: 100%;

                    a {
                        width: 100%;
                    }
                }

                html.light & {
                    .btn-secondary {
                        background-color: transparent;
                        color: $white !important;
                        border-color: $white !important;

                        &:hover {
                            background: $white !important;
                            color: $black !important;
                        }
                    }
                }
            }
        }
    }
</style>

