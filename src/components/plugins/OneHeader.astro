---
import MDCParserAndRenderer from "~/components/MDCParserAndRenderer.astro"
import KestraIcon from "../icons/KestraIcon.vue"

interface Props {
    headingTitle: string
    currentPageIcon?: string
    headingDescription?: string
}

const { headingTitle, currentPageIcon, headingDescription } = Astro.props
---

<h4 class="py-0 title">
    {
        currentPageIcon && (
            <div class="pageIcon">
                <img
                    src={currentPageIcon}
                    alt={headingTitle}
                    width={80}
                    height={80}
                    class="page-icon"
                />
            </div>
        )
    }
    <div class="title-content d-flex flex-column justify-space-between w-100">
        <div class="d-flex align-items-center flex-wrap gap-3">
            <h1 class="mb-0">{headingTitle}</h1>
            <div class="certified-tag">
                <KestraIcon />
                <span>Certified</span>
            </div>
        </div>
        {
            headingDescription && (
                <div class="bd-content">
                    <MDCParserAndRenderer content={headingDescription} />
                </div>
            )
        }
    </div>
</h4>

<style lang="scss">
    .pageIcon {
        min-width: 104px;
        height: 104px;
        border-radius: 14px;
        background: $white;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 5;
        overflow: visible;
        border: 1.73px solid var(--ks-border-primary);
    }

    .title {
        margin-top: 1rem;
        display: flex;
        align-items: start;
        gap: 1rem;

        @include media-breakpoint-down(lg) {
            display: grid;
            grid-template-columns: 104px 1fr;
            column-gap: 1rem;
            row-gap: 0.875rem;
            align-items: start;

            .pageIcon {
                margin-right: 0;
            }
        }
    }

    .bd-content {
        color: var(--ks-content-secondary);
        max-width: 650px;
        margin: 0.5rem 0;
        line-height: 1.5;
        font-size: $font-size-md;
        font-weight: normal;

        @media screen and (max-width: 1100px) {
            display: -webkit-box;
            -webkit-box-orient: vertical;
            line-clamp: 4;
            -webkit-line-clamp: 4;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: normal;
        }
    }

    .certified-tag {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 2.5rem;
        gap: 0.25rem;
        padding: 0.125rem 0.5rem;
        border: 1px solid var(--ks-border-alert-info);
        background: var(--ks-background-alert-info);
        color: var(--ks-content-alert-info);
        font-size: $font-size-xs;
        white-space: nowrap;

        :global(.kestra-icon) {
            position: relative;
            top: -1px;
        }
    }
</style>
