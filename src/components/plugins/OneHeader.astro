---
import MDCParserAndRenderer from "~/components/MDCParserAndRenderer.astro"
import KestraIcon from "../icons/KestraIcon.vue"
import type { Plugin } from "~/utils/plugins/plugin"

interface Props {
    headingTitle: string
    rootPlugin?: Plugin
    currentPageIcon?: string
    headingDescription?: string
}

const { headingTitle, rootPlugin, currentPageIcon, headingDescription } =
    Astro.props
---

<h4 class="py-0 title">
    {
        currentPageIcon && (
            <div class="pageIcon">
                <img
                    src={currentPageIcon}
                    alt={headingTitle}
                    width={80}
                    height={80}
                    class="page-icon"
                />
            </div>
        )
    }
    <div class="title-content">
        <h1 class="mb-0">{headingTitle}</h1>
        <div class="title-certified">
            <div class="certified-tag">
                <KestraIcon />
                Certified
            </div>
            {
                rootPlugin?.license && (
                    <div class="certified-tag enterprise">
                        Enterprise Edition
                    </div>
                )
            }
        </div>
        {
            headingDescription && (
                <div class="bd-content">
                    <MDCParserAndRenderer content={headingDescription} />
                </div>
            )
        }
    </div>
</h4>

<style lang="scss">
    .pageIcon {
        min-width: 104px;
        height: 104px;
        border-radius: 14px;
        background: $white;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 5;
        overflow: visible;
        border: 1.73px solid var(--ks-border-primary);
    }

    .title-content {
        display: flex;
        flex-direction: column;
        width: 100%;
        gap: 0.5rem;
    }

    .title-certified {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .title {
        margin-top: 1rem;
        display: flex;
        align-items: start;
        gap: 1rem;

        @include media-breakpoint-down(sm) {
            display: grid;
            grid-template-columns: 104px 1fr;
            column-gap: 1rem;
            row-gap: 0.875rem;
            align-items: start;

            .pageIcon {
                margin-right: 0;
            }
        }
    }

    .bd-content {
        color: var(--ks-content-secondary);
        max-width: 650px;
        margin: 0.5rem 0;
        line-height: 1.5;
        font-size: $font-size-md;
        font-weight: normal;

        @media screen and (max-width: 1100px) {
            display: -webkit-box;
            -webkit-box-orient: vertical;
            line-clamp: 4;
            -webkit-line-clamp: 4;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: normal;
        }
    }

    .certified-tag {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 2.5rem;
        gap: 0.25rem;
        padding: 0 0.5rem;
        height: 22px;
        background: var(--ks-background-alert-info);
        color: var(--ks-content-alert-info);
        font-size: $font-size-xs;
        white-space: nowrap;

        :global(.kestra-icon) {
            position: relative;
            top: -1px;
        }
    }

    .enterprise {
        background: var(--ks-background-tag-EE);
        color: var(--ks-content-tag-EE);
    }
</style>
