---
import Section from "~/components/layout/Section.astro"

const personas = [
    {
        tag: "Data leaders",
        tagColor: "green",
        description:
            "You're on Airflow 2 and have to make a call: upgrade, migrate, or modernize. You want a clear, defensible framework before you commit budget and roadmap time.",
    },
    {
        tag: "VP of Engineering",
        tagColor: "blue",
        description:
            "You're balancing migration effort vs. platform debt. You need to understand how the switching cost compares to the ongoing cost of Airflow 2's operational quirks and the Airflow 3 upgrade.",
    },
    {
        tag: "Platform engineers",
        tagColor: "purple",
        description:
            "You'll live with the decision day-to-day. You want to know what actually changes in your deploy pipeline, observability stack, and on-call rotation — beyond the release notes.",
    },
]
---

<Section class="who-this-is-for" title="Who this is for">
    <div class="cards">
        {
            personas.map((p) => (
                <div class="persona-card" data-usal="zoomin">
                    <div class={`persona-tag persona-tag--${p.tagColor}`}>
                        {p.tag}
                    </div>
                    <p class="persona-description">{p.description}</p>
                </div>
            ))
        }
    </div>
</Section>

<style lang="scss">
    .who-this-is-for {
        background-color: var(--ks-background-body);
        border-bottom: none !important;

        :global(h2) {
            font-size: 2rem;
            font-weight: 600;
            margin-bottom: 2rem;
            color: var(--ks-content-primary);

            @include media-breakpoint-up(md) {
                font-size: 2.25rem;
            }
        }
    }

    .cards {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        max-width: 1200px;
        margin: 0 auto;

        @include media-breakpoint-up(md) {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .persona-card {
        background: var(--ks-background-primary);
        border: 1px solid var(--ks-border-secondary);
        border-radius: 8px;
        box-shadow: 2px 3px 16px 0 var(--ks-shadows-light);
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;

        @include media-breakpoint-down(md) {
            padding: 1.5rem;
        }
    }

    .persona-tag {
        display: inline-flex;
        align-self: flex-start;
        font-size: $font-size-sm;
        font-weight: 600;
        padding: 0.375rem 0.75rem;
        border-radius: 999px;
        line-height: 1;

        &--green {
            background-color: rgba(34, 197, 94, 0.12);
            color: #16a34a;

            :global(html.dark) & {
                color: #4ade80;
            }
        }

        &--blue {
            background-color: rgba(59, 130, 246, 0.12);
            color: #2563eb;

            :global(html.dark) & {
                color: #60a5fa;
            }
        }

        &--purple {
            background-color: rgba(159, 79, 237, 0.12);
            color: #7c3aed;

            :global(html.dark) & {
                color: #c084fc;
            }
        }
    }

    .persona-description {
        color: var(--ks-content-secondary);
        font-size: $font-size-sm;
        line-height: 1.5;
        margin: 0;
    }
</style>
