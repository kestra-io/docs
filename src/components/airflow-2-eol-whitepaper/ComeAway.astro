---
const iconChanged = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13 3C10.6131 3 8.32387 3.94821 6.63604 5.63604C4.94821 7.32387 4 9.61305 4 12H1L4.89 15.89L4.96 16.03L9 12H6C6 10.1435 6.7375 8.36301 8.05025 7.05025C9.36301 5.7375 11.1435 5 13 5C14.8565 5 16.637 5.7375 17.9497 7.05025C19.2625 8.36301 20 10.1435 20 12C20 13.8565 19.2625 15.637 17.9497 16.9497C16.637 18.2625 14.8565 19 13 19C11.07 19 9.32 18.21 8.06 16.94L6.64 18.36C8.27 20 10.5 21 13 21C15.3869 21 17.6761 20.0518 19.364 18.364C21.0518 16.6761 22 14.3869 22 12C22 9.61305 21.0518 7.32387 19.364 5.63604C17.6761 3.94821 15.3869 3 13 3Z" fill="#8465FF"/></svg>`
const iconFork = `<svg width="18" height="17" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 0V8.5L3 5.5L6 9C7 10 7 11 7 11V17H11V10C11 10 11 9 10.47 8C9.94 7 9 6 9 6L6 2.58L8.5 0M15 0L10.54 4.47L11 5C11 5 11.93 6 12.47 7C12.68 7.4 12.8 7.79 12.87 8.13L18 3" fill="#8465FF"/></svg>`
const iconChart = `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3.5 18.5L9.5 12.5L13.5 16.5L22 6.92L20.59 5.5L13.5 13.5L9.5 9.5L2 17L3.5 18.5Z" fill="#8465FF"/></svg>`

const cards = [
    {
        icon: iconChanged,
        title: "What changed in Airflow 3",
        description:
            "Airflow 3 is a big rewrite. Schedules, executors, versioning, backfills, and UI all moved — we cover what's new, what broke, and what's just renamed so you don't get surprised mid-migration.",
    },
    {
        icon: iconFork,
        title: "The old and the new fork in the road",
        description:
            "Code that ran fine in Airflow 2 doesn't always port cleanly. Different DAG shapes, executors, and deployment models lead you to one of two forks: an in-place upgrade or a re-platform decision.",
    },
    {
        icon: iconChart,
        title: "A platform migration path",
        description:
            "Whether you're moving incrementally, running both in parallel, or rebuilding on a declarative orchestrator, we walk through concrete migration paths and the trade-offs of each.",
    },
]
---

<section class="come-away">
    <div class="container">
        <h2 data-usal="fade-r">What you'll come away with</h2>
        <div class="cards">
            {
                cards.map((card, i) => (
                    <div
                        class="come-card"
                        data-usal={i % 2 === 0 ? "fade" : "zoomin"}
                    >
                        <div
                            class="come-icon"
                            set:html={card.icon}
                            aria-hidden="true"
                        />
                        <h6 class="come-title">{card.title}</h6>
                        <p class="come-description">{card.description}</p>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style lang="scss">
    .come-away {
        background: var(--ks-background-secondary);
        border-bottom: 1px solid var(--ks-border-secondary);
        padding: 4rem 0.75rem;

        @include media-breakpoint-up(lg) {
            padding: 5rem 0.75rem;
        }
    }

    .container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2.5rem;
    }

    h2 {
        font-size: 2rem;
        font-weight: 600;
        line-height: 1.2;
        text-align: center;
        color: var(--ks-content-primary);
        margin: 0;

        @include media-breakpoint-up(md) {
            font-size: 2.25rem;
        }
    }

    .cards {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
        width: 100%;

        @include media-breakpoint-up(md) {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .come-card {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
        padding: 2rem;
        border-radius: 8px;
        border: 1px solid var(--ks-border-secondary);
        background: var(--ks-background-primary);
        box-shadow: 2px 3px 16px 0 var(--ks-shadows-light);
    }

    .come-icon {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
        margin-bottom: 0.25rem;
        background: none;

        :global(svg) {
            width: 24px;
            height: 24px;
            display: block;
        }
    }

    .come-title {
        font-size: 1rem;
        font-weight: 600;
        line-height: 1.5;
        color: var(--ks-content-primary);
        margin: 0;
    }

    .come-description {
        font-size: 0.875rem;
        line-height: 1.571;
        color: var(--ks-content-secondary);
        margin: 0;
    }
</style>
