---
import { Image } from "astro:assets"
import Link from "~/components/common/Link.astro"
import shapesImage from "./assets/cta-shapes.png"
---

<section class="final-cta">
    <div class="container">
        <div class="cta-outer-frame" data-usal="zoomin">
            <div class="cta-inner-card">
                <div class="cta-visual">
                    <Image
                        src={shapesImage}
                        alt=""
                        loading="lazy"
                        class="cta-visual-img"
                    />
                </div>
                <div class="cta-body">
                    <h2 class="cta-title">Ready to explore your options?</h2>
                    <p class="cta-description">
                        Talk to our team about what migration looks like, or
                        start building with Kestra for free.
                    </p>
                    <div class="cta-actions">
                        <Link href="/demo" class="btn btn-primary">
                            Book a Demo
                        </Link>
                        <Link href="/docs" class="btn btn-secondary">
                            Read the Docs
                        </Link>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style lang="scss">
    .final-cta {
        padding: 4rem 1rem;
        background-color: var(--ks-background-body);
        border-bottom: 1px solid var(--ks-border-secondary);

        @include media-breakpoint-up(lg) {
            padding: 5rem 1rem;
        }
    }

    .cta-outer-frame {
        border: 1px solid var(--ks-border-primary);
        border-radius: 13px;
        padding: 6px;
    }

    .cta-inner-card {
        background: var(--ks-background-secondary);
        border-radius: 9px;
        overflow: hidden;
        display: flex;
        flex-direction: column;

        @include media-breakpoint-up(md) {
            flex-direction: row;
            align-items: stretch;
            min-height: 460px;
        }
    }

    .cta-visual {
        flex: 0 0 auto;
        min-height: 220px;
        overflow: hidden;

        @include media-breakpoint-up(md) {
            width: 45%;
            min-height: unset;
        }

        @include media-breakpoint-up(lg) {
            width: 50%;
        }
    }

    .cta-visual-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
    }

    .cta-body {
        flex: 1 1 auto;
        padding: 2.5rem 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        gap: 1.25rem;

        @include media-breakpoint-up(lg) {
            padding: 3rem 4rem 3rem 3rem;
        }
    }

    .cta-title {
        font-size: 1.75rem;
        font-weight: 600;
        line-height: 1.2;
        margin: 0;
        color: var(--ks-content-primary);

        @include media-breakpoint-up(md) {
            font-size: 2rem;
        }
    }

    .cta-description {
        font-size: 1rem;
        line-height: 1.5;
        color: var(--ks-content-secondary);
        margin: 0;
        max-width: 420px;
    }

    .cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 0.5rem;

        :global(.btn) {
            min-width: 160px;
        }
    }
</style>
