---
import NavSideBar from "~/components/docs/NavSideBar.vue"
import Layout from "~/components/layout.astro"
import { buildDocsNavigation } from "~/utils/buildDocsNavigation"
import Breadcrumb from "~/components/layout/Breadcrumb.vue"
import { generatePageNames, recursivePages } from "~/utils/navigation"
import squaredGrid from "~/assets/squared-grid.svg"

const navigation = await buildDocsNavigation()

const pageList = recursivePages(navigation[0])
const pageNames = generatePageNames(navigation[0])

interface Props {
    title?: string
    description?: string
    activeStem: string
    pageTitle?: string
    isHomePage?: boolean
    image?: string
}

const props = Astro.props as Props

// TechArticle JSON-LD: emit on every /docs/* page (including the index) so that
// Google can surface documentation rich results and AI search engines can
// attribute citations back to a canonical headline + publisher.
const techArticleSchema = {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "@id": Astro.url.href,
    "headline": props.pageTitle ?? props.title ?? "Kestra Documentation",
    "url": Astro.url.href,
    "inLanguage": "en",
    ...(props.description ? { description: props.description } : {}),
    "isPartOf": {
        "@type": "WebSite",
        "@id": "https://kestra.io/#website",
    },
    "about": {
        "@type": "SoftwareApplication",
        "@id": "https://kestra.io/#software",
    },
    "author": { "@id": "https://kestra.io/#organization" },
    "publisher": { "@id": "https://kestra.io/#organization" },
}
---

<Layout title={props.title} description={props.description} image={props.image}>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(techArticleSchema)} />
    </Fragment>
    <link rel="preload" as="image" href={squaredGrid.src} />
    <div
        style={{
            backgroundImage: `url(${squaredGrid.src})`,
            backgroundRepeat: "no-repeat",
            backgroundPosition: "top center",
            backgroundSize: "1400px auto",
        }}
        class:list={[
            "container-fluid",
            "bd-gutter",
            "bd-layout",
            "type-docs",
            { homepage: props.isHomePage },
        ]}
    >
        <NavSideBar
            type="docs"
            navigation={navigation}
            slug={props.activeStem}
            client:idle
            transition:persist
        />
        <article
            class:list={[
                "bd-main",
                "order-1",
                "docs",
                { homepage: props.isHomePage },
            ]}
        >
            <div class="bd-title">
                <Breadcrumb
                    slug={props.activeStem}
                    pageList={pageList}
                    pageNames={pageNames}
                    pageTitle={props.pageTitle}
                />
                <slot name="title" />
            </div>
            <slot name="headings" />

            <div class="layout-docs">
                <div class="bd-content">
                    <blockquote class="llms-directive">For the complete documentation index, see <a href="/llms.txt">llms.txt</a>. For a full content snapshot, see <a href="/llms-full.txt">llms-full.txt</a>. Append <code>.md</code> to any <code>kestra.io/docs/*</code> URL for plain Markdown.</blockquote>
                    <slot />
                </div>
            </div>
        </article>
    </div>
</Layout>

<style lang="scss">
    .container-fluid {
        background-color: var(--ks-background-body);
        gap: calc($spacer * 4);
        padding-left: 1rem;
        padding-right: 1rem;
        max-width: 1520px;
        width: 100%;
        overflow: clip !important;
        z-index: 10;

        @include media-breakpoint-down(md) {
            gap: calc($spacer * 2);
            padding-left: 0.75rem;
            padding-right: 0.75rem;
        }

        @include media-breakpoint-down(sm) {
            gap: $spacer;
            padding-left: 0.5rem;
            padding-right: 0.5rem;
        }

        .bd-title {
            h1 {
                word-wrap: break-word;
                overflow-wrap: break-word;

                @include media-breakpoint-down(md) {
                    max-width: 100%;
                }
            }

            @include media-breakpoint-up(lg) {
                margin-top: 4rem;
            }

            @include media-breakpoint-down(md) {
                margin-top: 2rem;
            }
        }

        .bd-content {
            margin: 0 auto 2em auto;
            box-sizing: border-box;
            width: auto;

            @include media-breakpoint-down(xl) {
                margin-left: -2rem;
                padding-left: 2.5rem;
                padding-right: 0.5rem;
            }
        }

        .title {
            font-size: $h2-font-size;
            line-height: 3.25rem;
            margin: 0 auto;
            max-width: 100%;
            word-wrap: break-word;
            overflow-wrap: break-word;
            margin-bottom: 0;

            @include media-breakpoint-down(md) {
                font-size: $h3-font-size;
                line-height: 2.5rem;
            }
        }
    }

    .llms-directive {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    :global(.medium-zoom-image) {
        max-width: 100%;
        max-height: 100%;
    }
</style>
