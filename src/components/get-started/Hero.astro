---
import DeclarativeIcon from "~/components/home/assets/hero/declarative.svg"
import AnyLangIcon from "~/components/home/assets/hero/any-lang.svg"
import ApiFirstIcon from "~/components/home/assets/hero/api-first.svg"
import PluginsIcon from "~/components/home/assets/hero/plugin.svg"
import LockInIcon from "~/components/home/assets/hero/lock-in.svg"
import SelfHostedIcon from "~/components/home/assets/hero/self-hosted.svg"
import CloudIcon from "~/components/home/assets/hero/cloud.svg"
import { Image } from "astro:assets"

const dockerCommand = `docker run --pull=always -it -p 8080:8080 --user=root \\
  --name kestra --restart=always \\
  -v kestra_data:/app/storage \\
  -v /var/run/docker.sock:/var/run/docker.sock \\
  kestra/kestra:latest server local`

const TAGS = [
    { label: "Declarative", icon: DeclarativeIcon },
    { label: "Any Language", icon: AnyLangIcon },
    { label: "1200+ Plugins", icon: PluginsIcon },
    { label: "API-First", icon: ApiFirstIcon },
    { label: "No Lock-in", icon: LockInIcon },
    { label: "Self-Hosted", icon: SelfHostedIcon },
    { label: "Cloud", icon: CloudIcon },
]
---

<section class="hero-section">
    <div class="container">
        <div class="hero-content">
            <h1 data-usal="fade-r">
                Stop Writing Glue Code.<br />
                <span class="gradient">Start Orchestrating.</span>
            </h1>

            <p class="subtitle" data-usal="fade-l">
                One YAML file. Any language. 1200+ integrations. Your first workflow runs in under 2 minutes.
            </p>

            <div class="tags" data-usal="fade-r">
                {TAGS.map((tag) => (
                    <span>
                        <Image src={tag.icon} alt={tag.label} width={18} height={18} />
                        {tag.label}
                    </span>
                ))}
            </div>

            <div class="hero-command" data-usal="fade-up">
                <div class="command-label">
                    <span class="dot dot-red"></span>
                    <span class="dot dot-yellow"></span>
                    <span class="dot dot-green"></span>
                    <span class="command-hint">Run this. That's it.</span>
                </div>
                <pre class="command-code"><code>{dockerCommand}</code></pre>
            </div>

            <div class="hero-ctas" data-usal="zoomin">
                <a href="/docs/tutorial" class="btn btn-primary btn-lg">
                    Read the docs
                </a>
                <a href="/demo" class="btn btn-secondary btn-lg">
                    Book a Demo
                </a>
            </div>
        </div>
    </div>
</section>

<style lang="scss">
    .hero-section {
        position: relative;
        padding: 8rem 1rem 5rem;
        overflow: hidden;
        background:
            linear-gradient(106.32deg, #000000 28.36%, #0f1a2e 79.51%);

        @include media-breakpoint-down(md) {
            padding: 6rem 1rem 4rem;
        }

        &::before {
            content: "";
            position: absolute;
            top: 0;
            right: 30%;
            background: radial-gradient(
                circle,
                #581fd38f 0%,
                rgba(88, 31, 211, 0) 70%
            );
            width: 659px;
            height: 629px;
            pointer-events: none;
            z-index: 0;
        }

        .hero-content {
            position: relative;
            z-index: 1;
            max-width: 820px;
            margin: 0 auto;
            text-align: center;
            color: $white;

            h1 {
                font-size: $font-size-4xl;
                font-weight: 600;
                line-height: 1.15;
                margin-bottom: 1.25rem;
                letter-spacing: -0.02em;

                @include media-breakpoint-up(md) {
                    font-size: 3.5rem;
                }
            }

            .gradient {
                background: linear-gradient(90deg, var(--ks-content-link-inverse), var(--ks-content-color-highlight-inverse));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            .subtitle {
                font-size: $font-size-lg;
                line-height: 1.6;
                opacity: 0.8;
                margin-bottom: 1.75rem;
                max-width: 600px;
                margin-left: auto;
                margin-right: auto;

                @include media-breakpoint-down(md) {
                    font-size: $font-size-md;
                }
            }

            .tags {
                display: flex;
                flex-wrap: wrap;
                justify-content: center;
                gap: 0.5rem;
                margin-bottom: 2.5rem;

                span {
                    display: inline-flex;
                    align-items: center;
                    gap: 0.4rem;
                    border: 1px solid rgba(255, 255, 255, 0.15);
                    padding: 0.4rem 0.85rem;
                    border-radius: 9999px;
                    color: rgba(255, 255, 255, 0.7);
                    font-size: $font-size-xs;
                    white-space: nowrap;
                    background: rgba(255, 255, 255, 0.04);
                    transition: all 0.2s ease;

                    :global(img) {
                        width: 16px;
                        height: 16px;
                        object-fit: contain;
                        filter: brightness(0) invert(1) opacity(0.6);
                    }

                    &:hover {
                        border-color: rgba(255, 255, 255, 0.35);
                        color: $white;
                        background: rgba(255, 255, 255, 0.08);

                        :global(img) {
                            filter: brightness(0) invert(1) opacity(1);
                        }
                    }
                }
            }

            .hero-command {
                background: rgba(0, 0, 0, 0.5);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: $border-radius-lg;
                overflow: hidden;
                margin-bottom: 2.5rem;
                text-align: left;
                backdrop-filter: blur(8px);

                .command-label {
                    display: flex;
                    align-items: center;
                    gap: 0.4rem;
                    padding: 0.6rem 1rem;
                    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                    background: rgba(255, 255, 255, 0.03);

                    .dot {
                        width: 10px;
                        height: 10px;
                        border-radius: 50%;

                        &.dot-red { background: #ff5f56; }
                        &.dot-yellow { background: #ffbd2e; }
                        &.dot-green { background: #27c93f; }
                    }

                    .command-hint {
                        font-family: var(--bs-font-monospace);
                        font-size: $font-size-xs;
                        color: rgba(255, 255, 255, 0.3);
                        margin-left: 0.5rem;
                    }
                }

                .command-code {
                    margin: 0;
                    padding: 1.25rem 1.5rem;
                    background: transparent;
                    overflow-x: auto;

                    code {
                        font-family: var(--bs-font-monospace);
                        font-size: $font-size-sm;
                        color: var(--ks-content-color-highlight-inverse);
                        line-height: 1.7;
                        white-space: pre;
                    }
                }
            }

            .hero-ctas {
                display: flex;
                justify-content: center;
                gap: 1rem;
                flex-direction: column;

                @include media-breakpoint-up(md) {
                    flex-direction: row;
                }
            }
        }
    }
</style>
