---
import { Icon } from "astro-icon/components"

const FEATURES = [
    {
        icon: "mdi:file-document-outline",
        title: "Declarative YAML",
        description:
            "Define workflows as code. Version control, code review, and reuse — built in from day one.",
    },
    {
        icon: "mdi:code-tags",
        title: "Any Language",
        description:
            "Python, Bash, Node.js, Go, SQL — use what you already know. No framework wrappers, no refactoring.",
    },
    {
        icon: "mdi:puzzle-outline",
        title: "1200+ Plugins",
        description:
            "Connect to databases, cloud services, APIs, and SaaS tools. No custom integrations required.",
    },
    {
        icon: "mdi:api",
        title: "API-First",
        description:
            "Trigger, manage, and monitor workflows programmatically. Everything in the UI is available via API.",
    },
    {
        icon: "mdi:lightning-bolt-outline",
        title: "Event-Driven",
        description:
            "React to file changes, messages, webhooks, and database events in real time. Or schedule with cron.",
    },
    {
        icon: "mdi:shield-check-outline",
        title: "Production-Ready",
        description:
            "SOC 2 Type II certified. SSO, RBAC, audit logs, multi-tenancy. From startup to enterprise.",
    },
]
---

<section class="differentiators">
    <div class="container">
        <p class="overline" data-usal="fade-r">Why Kestra</p>
        <h2 data-usal="fade-l">
            Built Different. <span class="highlight">On Purpose.</span>
        </h2>
        <p class="lead" data-usal="fade-r">
            Not another Airflow clone. Kestra was designed from scratch for teams that need
            orchestration without the overhead.
        </p>

        <div class="features-grid" data-usal="fade-up">
            {
                FEATURES.map((feature) => (
                    <div class="feature-item" data-usal="fade-up">
                        <div class="icon-wrapper">
                            <Icon name={feature.icon} />
                        </div>
                        <h5>{feature.title}</h5>
                        <p>{feature.description}</p>
                    </div>
                ))
            }
        </div>

        <div class="section-cta" data-usal="fade-up">
            <p>Want to see Kestra with your actual use case?</p>
            <a href="/demo" class="btn btn-primary btn-lg">Book a Demo</a>
        </div>
    </div>
</section>

<style lang="scss">
    .differentiators {
        padding: $rem-4 0;
        background-color: var(--ks-background-primary);
        border-top: $block-border;
        border-bottom: $block-border;

        @include media-breakpoint-down(lg) {
            padding: $spacer * 2 0.75rem;
        }

        .container {
            text-align: center;
        }

        .overline {
            font-size: $font-size-sm;
            text-transform: uppercase;
            color: var(--ks-content-secondary);
            font-family: var(--bs-font-monospace);
            font-weight: 600;
            letter-spacing: 0.05em;
            margin-bottom: 0.75rem;
        }

        h2 {
            font-weight: 500;
            margin-bottom: 1rem;
        }

        .lead {
            color: var(--ks-content-secondary);
            font-size: $font-size-lg;
            max-width: 600px;
            margin: 0 auto 3rem;
        }

        .features-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.5rem 1rem;

            @include media-breakpoint-up(md) {
                grid-template-columns: repeat(2, 1fr);
            }

            @include media-breakpoint-up(lg) {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .section-cta {
            margin-top: 3rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;

            p {
                color: var(--ks-content-secondary);
                font-size: $font-size-md;
                margin: 0;
            }
        }

        .feature-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 1rem 0.75rem;

            .icon-wrapper {
                width: 44px;
                height: 44px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 10px;
                background: var(--ks-background-secondary);
                border: $block-border;
                margin-bottom: 0.75rem;

                :global(svg) {
                    font-size: 1.25rem;
                    color: var(--ks-content-link);
                }
            }

            h5 {
                font-weight: 600;
                margin-bottom: 0.35rem;
                font-size: $font-size-md;
            }

            p {
                color: var(--ks-content-secondary);
                font-size: $font-size-sm;
                margin-bottom: 0;
                max-width: 280px;
            }
        }
    }
</style>
