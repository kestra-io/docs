---
import BrandedHero from "~/components/common/BrandedHero.astro"

interface Props {
    title: string
    description: string
    cta: {
        label: string
        href: string
    }
    secondaryCta?: {
        label: string
        href: string
    }
    toolName: string
    toolIcon: string
    toolColor?: string
}

const {
    title,
    description,
    cta,
    secondaryCta,
    toolName,
    toolIcon,
    toolColor,
} = Astro.props as Props
---

<BrandedHero
    {title}
    {description}
    {cta}
    {secondaryCta}
    secondaryIcon={toolIcon}
    secondaryLabel={toolName}
    highlightTerm={toolName}
    themeColor={toolColor}
    animatePictos={true}
>
    <div class="flow" slot="between" aria-hidden="true">
        <div class="flow-arrow flow-arrow--out">
            <span class="flow-line" />
            <span class="flow-line-bright" />
        </div>
        <div class="flow-arrow flow-arrow--back">
            <span class="flow-line" />
            <span class="flow-line-bright" />
        </div>
    </div>
</BrandedHero>

<style lang="scss">
    .flow {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.6rem;
        width: 90px;
        flex-shrink: 0;

        @include media-breakpoint-down(md) {
            width: 48px;
            gap: 0.35rem;
        }
    }

    .flow-arrow {
        position: relative;
        width: 100%;
        height: 14px;

        &--out {
            --flow-color: #8b5cf6;
        }

        &--back {
            --flow-color: var(
                --tool-color,
                var(--ks-content-color-highlight)
            );
        }
    }

    .flow-line {
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--flow-color);
        opacity: 0.22;
        transform: translateY(-50%);
        border-radius: 999px;
    }

    .flow-line-bright {
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--flow-color);
        box-shadow:
            0 0 6px var(--flow-color),
            0 0 14px var(--flow-color);
        border-radius: 999px;
        transform: translateY(-50%) scaleX(0);
        opacity: 0;
    }

    .flow-arrow--out .flow-line-bright {
        transform-origin: left center;
        animation: line-fill-out 4.5s ease-in-out infinite;
    }

    .flow-arrow--back .flow-line-bright {
        transform-origin: right center;
        animation: line-fill-back 4.5s ease-in-out infinite;
    }

    @keyframes line-fill-out {
        0% {
            transform: translateY(-50%) scaleX(0);
            opacity: 0;
        }
        6% {
            opacity: 0.9;
        }
        44% {
            transform: translateY(-50%) scaleX(1);
            opacity: 1;
        }
        50% {
            transform: translateY(-50%) scaleX(1);
            opacity: 0;
        }
        51%, 100% {
            transform: translateY(-50%) scaleX(0);
            opacity: 0;
        }
    }

    @keyframes line-fill-back {
        0%, 50% {
            transform: translateY(-50%) scaleX(0);
            opacity: 0;
        }
        56% {
            opacity: 0.9;
        }
        94% {
            transform: translateY(-50%) scaleX(1);
            opacity: 1;
        }
        100% {
            transform: translateY(-50%) scaleX(1);
            opacity: 0;
        }
    }
</style>
