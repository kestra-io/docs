---
import { Icon } from "astro-icon/components"
import TaskIcon from "~/components/common/TaskIcon.vue"

interface Step {
    node: string
    label?: string
    gate?: boolean
    pluginClass?: string
}

interface Props {
    flow: Step[]
}

const { flow } = Astro.props as Props
---

<div class="uc-flow-pad">
    <div
        class="uc-task-flow"
        data-total={flow.length}
        style={`--total-tasks: ${flow.length}`}
    >
        {
            flow.map((step, stepIdx) => (
                <>
                    <div
                        class="uc-task-cell"
                        style={`--step-index: ${stepIdx}`}
                    >
                        <div
                            class:list={["uc-task", { "is-gate": step.gate }]}
                            data-step={stepIdx}
                        >
                            <div class="uc-task-icon">
                                {step.pluginClass ? (
                                    <TaskIcon cls={step.pluginClass} />
                                ) : (
                                    <Icon
                                        name="mdi:hexagon-outline"
                                        width={20}
                                        height={20}
                                    />
                                )}
                            </div>
                            <div class="uc-task-meta">
                                <div class="uc-task-name">{step.node}</div>
                                {step.label && (
                                    <div class="uc-task-label">
                                        {step.label}
                                    </div>
                                )}
                            </div>
                            <div class="uc-task-status">
                                <Icon
                                    name="mdi:circle-outline"
                                    class="status status-pending"
                                    width={18}
                                    height={18}
                                />
                                <Icon
                                    name="mdi:loading"
                                    class="status status-running"
                                    width={18}
                                    height={18}
                                />
                                <Icon
                                    name="mdi:check-circle"
                                    class="status status-validated"
                                    width={18}
                                    height={18}
                                />
                            </div>
                        </div>
                    </div>
                    {stepIdx < flow.length - 1 && (
                        <div
                            class="uc-task-arrow-cell"
                            style={`--step-index: ${stepIdx}`}
                        >
                            <div class="uc-task-arrow" data-step={stepIdx}>
                                <Icon
                                    name="mdi:chevron-down"
                                    width={16}
                                    height={16}
                                />
                            </div>
                        </div>
                    )}
                </>
            ))
        }
    </div>
</div>

<style lang="scss">
    @use "sass:math";

    .uc-flow-pad {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2.5rem 2rem;

        @include media-breakpoint-down(xl) {
            padding: 2rem 1.5rem;
        }
    }

    .uc-task-flow {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 0.5rem;
        width: 100%;
        max-width: 360px;

        --total-tasks: 5;
        --slot: 1.2s;
        --cycle: calc((var(--total-tasks) + 2) * var(--slot));
    }

    .uc-task-cell {
        opacity: 1;
        transform: translateY(0) scaleY(1);
        transform-origin: top center;
        transition:
            opacity 0.45s ease-out,
            transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .uc-task {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 0.875rem;
        padding: 0.75rem 1rem;
        background: rgba(255, 255, 255, 0.96);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 0.625rem;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);

        animation-duration: var(--cycle);
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
        animation-fill-mode: both;
        animation-play-state: running;

        &.is-gate {
            background: rgba(255, 235, 226, 0.96);
            border-color: rgba(255, 139, 97, 0.55);
        }
    }

    .uc-task-icon {
        width: 2.125rem;
        height: 2.125rem;
        padding: 0.375rem;
        background: $white;
        border: $block-border;
        border-radius: $border-radius;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .uc-task-meta {
        min-width: 0;
    }

    .uc-task-name {
        font-family: $font-family-sans-serif;
        font-size: 0.78rem;
        font-weight: 600;
        color: #131316;
        line-height: 1.2;
    }

    .uc-task-label {
        font-family: $font-family-sans-serif;
        font-size: 0.66rem;
        font-weight: 400;
        color: #6b6a73;
        line-height: 1.2;
        margin-top: 2px;
    }

    .uc-task-status {
        position: relative;
        width: 18px;
        height: 18px;
        flex-shrink: 0;
    }

    .uc-task-status .status {
        position: absolute;
        inset: 0;
        width: 18px;
        height: 18px;
        opacity: 0;
        animation-duration: var(--cycle);
        animation-timing-function: linear;
        animation-iteration-count: infinite;
        animation-fill-mode: both;
        animation-play-state: running;
    }

    .uc-task-status .status-pending {
        color: #a5a4aa;
    }

    .uc-task-status .status-running {
        color: #8c4bff;
        animation-duration: var(--cycle), 0.9s;
        animation-timing-function: linear, linear;
        animation-iteration-count: infinite, infinite;
        animation-fill-mode: both, both;
    }

    .uc-task-status .status-validated {
        color: #22c55e;
    }

    .uc-task-arrow-cell {
        opacity: 1;
        transform: scaleY(1) translateY(0);
        transform-origin: top center;
        transition:
            opacity 0.4s ease-out,
            transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .uc-task-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255, 255, 255, 0.7);
        height: 14px;
        filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.35));

        animation-duration: var(--cycle);
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
        animation-fill-mode: both;
        animation-play-state: running;
    }

    :global(.split-badge-card.is-folded) {
        .uc-task,
        .uc-task-arrow,
        .uc-task-status .status {
            animation-play-state: paused;
        }
    }

    @keyframes uc-spin {
        to { transform: rotate(360deg); }
    }

    $max-tasks: 8;
    @for $total from 1 through $max-tasks {
        @for $i from 0 through ($total - 1) {
            $slot: math.div(100, $total + 2);
            $start: $slot * $i;
            $end: $slot * ($i + 1);
            $onset: math.div($slot, 4);
            $hold-end: $slot * ($total + 1);

            @keyframes uc-pending-#{$total}-#{$i} {
                0% { opacity: 1; }
                @if $i > 0 {
                    #{$start - $onset}% { opacity: 1; }
                }
                #{$start + $onset}% { opacity: 0; }
                #{$hold-end}% { opacity: 0; }
                #{$hold-end + $onset}% { opacity: 1; }
                100% { opacity: 1; }
            }

            @keyframes uc-running-#{$total}-#{$i} {
                0% { opacity: 0; }
                @if $i > 0 {
                    #{$start - $onset}% { opacity: 0; }
                }
                #{$start + $onset}% { opacity: 1; }
                #{$end - $onset}% { opacity: 1; }
                #{$end + $onset}% { opacity: 0; }
                100% { opacity: 0; }
            }

            @keyframes uc-validated-#{$total}-#{$i} {
                0% { opacity: 0; }
                #{$end - $onset}% { opacity: 0; }
                #{$end + $onset}% { opacity: 1; }
                #{$hold-end}% { opacity: 1; }
                #{$hold-end + $onset}% { opacity: 0; }
                100% { opacity: 0; }
            }

            @keyframes uc-task-active-#{$total}-#{$i} {
                0% {
                    transform: translateX(0) scale(1);
                    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
                }
                @if $i > 0 {
                    #{$start - $onset}% {
                        transform: translateX(0) scale(1);
                        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
                    }
                }
                #{$start + $onset}% {
                    transform: translateX(5px) scale(1.02);
                    box-shadow: 0 14px 36px rgba(140, 75, 255, 0.55);
                }
                #{$end - $onset}% {
                    transform: translateX(5px) scale(1.02);
                    box-shadow: 0 14px 36px rgba(140, 75, 255, 0.55);
                }
                #{$end + $onset}% {
                    transform: translateX(0) scale(1);
                    box-shadow: 0 10px 26px rgba(34, 197, 94, 0.28);
                }
                #{$hold-end}% {
                    transform: translateX(0) scale(1);
                    box-shadow: 0 10px 26px rgba(34, 197, 94, 0.28);
                }
                #{$hold-end + $onset}% {
                    transform: translateX(0) scale(1);
                    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
                }
                100% {
                    transform: translateX(0) scale(1);
                    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
                }
            }

            @keyframes uc-arrow-active-#{$total}-#{$i} {
                0% {
                    color: rgba(255, 255, 255, 0.7);
                    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.35));
                    transform: translateY(-2px) scale(0.9);
                }
                @if $i > 0 {
                    #{$start - $onset}% {
                        color: rgba(255, 255, 255, 0.7);
                        filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.35));
                        transform: translateY(-2px) scale(0.9);
                    }
                }
                #{$start + $onset}% {
                    color: #fff;
                    filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.8));
                    transform: translateY(1px) scale(1.05);
                }
                #{$end - $onset}% {
                    color: #fff;
                    filter: drop-shadow(0 0 14px rgba(255, 255, 255, 0.95));
                    transform: translateY(3px) scale(1.2);
                }
                #{$end}% {
                    color: #fff;
                    filter: drop-shadow(0 0 16px rgba(255, 255, 255, 1));
                    transform: translateY(5px) scale(1.25);
                }
                #{$end + $onset}% {
                    color: rgba(255, 255, 255, 0.9);
                    filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.6));
                    transform: translateY(0) scale(1);
                }
                #{$end + 2 * $onset}% {
                    color: rgba(255, 255, 255, 0.7);
                    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.35));
                    transform: translateY(-2px) scale(0.9);
                }
                100% {
                    color: rgba(255, 255, 255, 0.7);
                    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.35));
                    transform: translateY(-2px) scale(0.9);
                }
            }

            .uc-task-flow[data-total="#{$total}"] {
                .uc-task[data-step="#{$i}"] {
                    animation-name: uc-task-active-#{$total}-#{$i};
                    animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);

                    .status-pending {
                        animation-name: uc-pending-#{$total}-#{$i};
                    }
                    .status-running {
                        animation-name: uc-running-#{$total}-#{$i}, uc-spin;
                    }
                    .status-validated {
                        animation-name: uc-validated-#{$total}-#{$i};
                    }
                }

                .uc-task-arrow[data-step="#{$i}"] {
                    animation-name: uc-arrow-active-#{$total}-#{$i};
                    animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
                }
            }
        }
    }
</style>
