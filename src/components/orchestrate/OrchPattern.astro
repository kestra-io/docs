---
import { Icon } from "astro-icon/components"
import TaskIcon from "~/components/common/TaskIcon.vue"
import Snippets from "~/components/common/Snippets.vue"

interface FlowNode {
    label: string
    sublabel?: string
    pluginClass?: string
    icon?: string
}

interface FlowDiagram {
    source: FlowNode
    workflow: { label: string; sublabel?: string }
    tools: FlowNode[]
    outcome: FlowNode
}

interface BlueprintItem {
    name: string
    title: string
    description: string
    code: string
    plugins: string[]
    href?: string
    flowDiagram?: FlowDiagram
}

interface Props {
    nutshell?: string
    blueprints: BlueprintItem[]
    toolColor?: string
}

const { nutshell, blueprints, toolColor } = Astro.props as Props
const sectionStyle = toolColor ? `--tool-color: ${toolColor};` : undefined

const tabs = blueprints.filter((bp) => bp.flowDiagram)
const hasTabs = tabs.length > 0
const hasContent = Boolean(nutshell) || hasTabs
---

{
    hasContent && (
        <section class="orch-pattern" style={sectionStyle}>
            <div class="container">
                <div class="wrapper">
                    {nutshell && (
                        <div class="wrapper__head">
                            <p class="nutshell" set:html={nutshell} />
                        </div>
                    )}

                    {hasTabs && (
                        <div class="orch-tabs" data-orch-tabs>
                            <div class="orch-tabs__bar" role="tablist">
                                {tabs.map((bp, idx) => (
                                    <button
                                        type="button"
                                        class:list={["orch-tabs__tab", { active: idx === 0 }]}
                                        role="tab"
                                        data-tab-target={idx}
                                        aria-selected={idx === 0}
                                    >
                                        {bp.name}
                                    </button>
                                ))}
                            </div>

                            {tabs.map((bp, idx) => (
                                <div
                                    class:list={["orch-tabs__panel", { active: idx === 0 }]}
                                    role="tabpanel"
                                    data-tab-content={idx}
                                >
                                    <div class="panel-row">
                                        <div class="panel-topology">
                                            <div class="topology">
                                                <div class="topology-row">
                                                    <span class="topology-eyebrow">
                                                        Trigger
                                                    </span>
                                                    <div class="node node-trigger">
                                                        <div class="node-icon">
                                                            {bp.flowDiagram!.source.pluginClass ? (
                                                                <TaskIcon cls={bp.flowDiagram!.source.pluginClass} />
                                                            ) : (
                                                                <Icon
                                                                    name={bp.flowDiagram!.source.icon || "mdi:lightning-bolt-outline"}
                                                                    width={20}
                                                                    height={20}
                                                                />
                                                            )}
                                                        </div>
                                                        <div class="node-text">
                                                            <div class="node-label">
                                                                {bp.flowDiagram!.source.label}
                                                            </div>
                                                            {bp.flowDiagram!.source.sublabel && (
                                                                <div class="node-sublabel">
                                                                    {bp.flowDiagram!.source.sublabel}
                                                                </div>
                                                            )}
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="topology-rail" aria-hidden="true">
                                                    <span class="rail-track">
                                                        <span class="rail-fill rail-fill-1" />
                                                    </span>
                                                </div>

                                                <div class="topology-row">
                                                    <span class="topology-eyebrow">
                                                        Flow
                                                    </span>
                                                    <div class="node node-flow">
                                                        <div class="node-icon node-icon-flow">
                                                            <Icon
                                                                name="mdi:lightning-bolt"
                                                                class="ks-spark"
                                                                width={20}
                                                                height={20}
                                                            />
                                                        </div>
                                                        <div class="node-text">
                                                            <div class="node-label">
                                                                {bp.flowDiagram!.workflow.label}
                                                            </div>
                                                            {bp.flowDiagram!.workflow.sublabel && (
                                                                <div class="node-sublabel">
                                                                    {bp.flowDiagram!.workflow.sublabel}
                                                                </div>
                                                            )}
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="topology-rail" aria-hidden="true">
                                                    <span class="rail-track">
                                                        <span class="rail-fill rail-fill-2" />
                                                    </span>
                                                </div>

                                                <div class="topology-row">
                                                    <span class="topology-eyebrow">
                                                        Tasks
                                                    </span>
                                                    <div class="tools-cluster node-tasks">
                                                        {bp.flowDiagram!.tools.map((tool) => (
                                                            <div class="tool-pill">
                                                                <div class="tool-icon">
                                                                    {tool.pluginClass ? (
                                                                        <TaskIcon cls={tool.pluginClass} />
                                                                    ) : (
                                                                        <Icon
                                                                            name={tool.icon || "mdi:hexagon-outline"}
                                                                            width={14}
                                                                            height={14}
                                                                        />
                                                                    )}
                                                                </div>
                                                                <span class="tool-label">
                                                                    {tool.label}
                                                                </span>
                                                            </div>
                                                        ))}
                                                    </div>
                                                </div>

                                                <div class="topology-rail" aria-hidden="true">
                                                    <span class="rail-track">
                                                        <span class="rail-fill rail-fill-3" />
                                                    </span>
                                                </div>

                                                <div class="topology-row">
                                                    <span class="topology-eyebrow">
                                                        Outcome
                                                    </span>
                                                    <div class="node node-outcome">
                                                        <div class="node-icon">
                                                            {bp.flowDiagram!.outcome.pluginClass ? (
                                                                <TaskIcon cls={bp.flowDiagram!.outcome.pluginClass} />
                                                            ) : (
                                                                <Icon
                                                                    name={bp.flowDiagram!.outcome.icon || "mdi:check-circle-outline"}
                                                                    width={20}
                                                                    height={20}
                                                                />
                                                            )}
                                                        </div>
                                                        <div class="node-text">
                                                            <div class="node-label">
                                                                {bp.flowDiagram!.outcome.label}
                                                            </div>
                                                            {bp.flowDiagram!.outcome.sublabel && (
                                                                <div class="node-sublabel">
                                                                    {bp.flowDiagram!.outcome.sublabel}
                                                                </div>
                                                            )}
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="panel-code">
                                            <div class="code-head">
                                                <span class="code-caption">{bp.title}</span>
                                                {bp.href && (
                                                    <a class="code-link" href={bp.href}>
                                                        Open blueprint
                                                        <Icon name="mdi:chevron-right" width={14} height={14} />
                                                    </a>
                                                )}
                                            </div>
                                            <Snippets client:idle code={bp.code} lang="yaml" />
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    )}
                </div>
            </div>
        </section>
    )
}

<script>
    function wireOrchTabs() {
        for (const root of document.querySelectorAll<HTMLElement>(
            "[data-orch-tabs]",
        )) {
            if (root.dataset.wired === "true") continue
            root.dataset.wired = "true"
            root.addEventListener("click", (e) => {
                const btn = (e.target as Element).closest(
                    ".orch-tabs__tab",
                ) as HTMLElement | null
                if (!btn) return
                const target = btn.dataset.tabTarget
                if (target == null) return
                for (const el of root.querySelectorAll(
                    ".orch-tabs__tab, .orch-tabs__panel",
                )) {
                    el.classList.remove("active")
                    if (el.matches(".orch-tabs__tab")) {
                        el.setAttribute("aria-selected", "false")
                    }
                }
                btn.classList.add("active")
                btn.setAttribute("aria-selected", "true")
                root.querySelector(
                    `.orch-tabs__panel[data-tab-content="${target}"]`,
                )?.classList.add("active")
            })
        }
    }

    document.addEventListener("astro:page-load", wireOrchTabs)
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", wireOrchTabs)
    } else {
        wireOrchTabs()
    }
</script>

<style lang="scss">
    .orch-pattern {
        background: var(--ks-background-body);
        padding: 2.5rem 1rem 3rem;

        @include media-breakpoint-up(md) {
            padding: 3rem 1.5rem 4rem;
        }
    }

    .container {
        max-width: 1180px;
        margin: 0 auto;
    }

    .wrapper {
        border: 1px solid var(--ks-border-primary);
        border-radius: 0.875rem;
        background: var(--ks-background-primary);
        box-shadow: 2px 3px 16px 0 var(--ks-shadows-light);
        overflow: hidden;
    }

    .wrapper__head {
        padding: 1.75rem 2rem 1.5rem;
        border-bottom: 1px solid var(--ks-border-secondary);
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--ks-content-color-highlight) 4%, var(--ks-background-primary)),
            var(--ks-background-primary) 60%
        );

        @include media-breakpoint-down(md) {
            padding: 1.25rem 1.25rem 1rem;
        }
    }

    .nutshell {
        max-width: 880px;
        margin: 0 auto;
        text-align: center;
        font-size: 1.0625rem;
        line-height: 1.65;
        color: var(--ks-content-primary);

        :global(a) {
            color: var(--ks-content-color-highlight);
            text-decoration: underline;
            text-underline-offset: 3px;
            text-decoration-thickness: 1px;
            text-decoration-color: color-mix(
                in srgb,
                var(--ks-content-color-highlight) 40%,
                transparent
            );
            transition: text-decoration-color 0.18s ease;

            &:hover {
                text-decoration-color: var(--ks-content-color-highlight);
            }
        }
    }

    .orch-tabs__bar {
        display: flex;
        flex-direction: row;
        overflow-x: auto;
        scrollbar-width: thin;
        background: var(--ks-background-secondary);
        border-bottom: 1px solid var(--ks-border-secondary);
    }

    .orch-tabs__tab {
        flex: 1 1 0;
        padding: 0.9rem 1.25rem;
        border: 0;
        border-bottom: 2px solid transparent;
        background: transparent;
        color: var(--ks-content-secondary);
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        text-align: center;
        transition:
            color 0.18s ease,
            background 0.18s ease,
            border-color 0.18s ease;

        &:hover {
            color: var(--ks-content-primary);
            background: color-mix(
                in srgb,
                var(--ks-content-color-highlight) 4%,
                transparent
            );
        }

        &.active {
            color: var(--ks-content-primary);
            background: var(--ks-background-primary);
            border-bottom-color: var(--ks-content-color-highlight);
        }

        & + & {
            border-left: 1px solid var(--ks-border-secondary);
        }
    }

    .orch-tabs__panel {
        display: none;

        &.active {
            display: block;
        }
    }

    .panel-row {
        display: flex;
        flex-direction: row;
        align-items: stretch;

        @include media-breakpoint-down(lg) {
            flex-direction: column;
        }
    }

    .panel-topology {
        flex: 0 0 42%;
        padding: 1.75rem 1.5rem;
        background: var(--ks-background-secondary);
        border-right: 1px solid var(--ks-border-secondary);

        @include media-breakpoint-down(lg) {
            flex: 1 1 auto;
            border-right: none;
            border-bottom: 1px solid var(--ks-border-secondary);
        }

        @include media-breakpoint-down(md) {
            padding: 1.25rem 1rem;
        }
    }

    .panel-code {
        flex: 1 1 0;
        padding: 1.5rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        background: var(--ks-background-primary);
        min-width: 0;

        @include media-breakpoint-down(md) {
            padding: 1.25rem 1rem;
        }
    }

    .topology {
        display: flex;
        flex-direction: column;
    }

    .topology-row {
        display: grid;
        grid-template-columns: 4.25rem 1fr;
        align-items: center;
        gap: 0.875rem;

        @include media-breakpoint-down(md) {
            grid-template-columns: 3.5rem 1fr;
            gap: 0.625rem;
        }
    }

    .topology-eyebrow {
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--ks-content-secondary);
        text-align: right;
        padding-right: 0.25rem;
    }

    .topology-rail {
        display: grid;
        grid-template-columns: 4.25rem 1fr;
        gap: 0.875rem;
        padding: 0.4rem 0;
        align-items: center;

        @include media-breakpoint-down(md) {
            grid-template-columns: 3.5rem 1fr;
            gap: 0.625rem;
        }
    }

    .rail-track {
        grid-column: 2;
        margin-left: 1rem;
        position: relative;
        display: inline-block;
        width: 2px;
        height: 32px;
        background: color-mix(
            in srgb,
            var(--ks-content-color-highlight) 14%,
            var(--ks-border-secondary)
        );
        border-radius: 2px;
        overflow: hidden;
    }

    .rail-fill {
        position: absolute;
        left: -1px;
        right: -1px;
        top: 0;
        height: 70%;
        background: linear-gradient(
            to bottom,
            transparent 0%,
            color-mix(in srgb, var(--ks-content-color-highlight) 30%, transparent)
                25%,
            var(--ks-content-color-highlight) 50%,
            color-mix(in srgb, var(--ks-content-color-highlight) 30%, transparent)
                75%,
            transparent 100%
        );
        filter: drop-shadow(
            0 0 4px
                color-mix(
                    in srgb,
                    var(--ks-content-color-highlight) 70%,
                    transparent
                )
        );
        border-radius: 2px;
        transform: translateY(-110%);
        opacity: 0;
    }

    .node {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 0.9rem;
        background: var(--ks-background-primary);
        border: 1px solid var(--ks-border-secondary);
        border-radius: 0.625rem;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
        transition: box-shadow 0.2s ease;
    }

    .node-flow {
        border-color: color-mix(
            in srgb,
            var(--ks-content-color-highlight) 30%,
            var(--ks-border-secondary)
        );
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--ks-content-color-highlight) 5%, var(--ks-background-primary)),
            var(--ks-background-primary)
        );
    }

    .node-outcome {
        border-color: color-mix(
            in srgb,
            var(--tool-color, var(--ks-content-color-highlight)) 35%,
            var(--ks-border-secondary)
        );
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--tool-color, var(--ks-content-color-highlight)) 5%, var(--ks-background-primary)),
            var(--ks-background-primary)
        );

        .node-icon {
            color: var(--tool-color, var(--ks-content-color-highlight));
        }
    }

    .node-icon {
        width: 2rem;
        height: 2rem;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--ks-background-body);
        border: 1px solid var(--ks-border-secondary);
        border-radius: 0.5rem;
        padding: 0.3rem;
    }

    .node-icon-flow {
        background: color-mix(
            in srgb,
            var(--ks-content-color-highlight) 10%,
            var(--ks-background-body)
        );
        border-color: color-mix(
            in srgb,
            var(--ks-content-color-highlight) 25%,
            var(--ks-border-secondary)
        );

        .ks-spark {
            color: var(--ks-content-color-highlight);
        }
    }

    .node-text {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .node-label {
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1.2;
        color: var(--ks-content-primary);
    }

    .node-sublabel {
        font-size: 0.72rem;
        line-height: 1.25;
        color: var(--ks-content-secondary);
    }

    .tools-cluster {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        align-content: center;
        padding: 0.6rem;
        background: var(--ks-background-primary);
        border: 1px solid var(--ks-border-secondary);
        border-radius: 0.625rem;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
        transition: box-shadow 0.2s ease;
    }

    .tool-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.3rem 0.55rem;
        background: var(--ks-background-body);
        border: 1px solid var(--ks-border-secondary);
        border-radius: 0.375rem;
        font-size: 0.72rem;
        font-weight: 500;
        color: var(--ks-content-primary);
        line-height: 1;
    }

    .tool-icon {
        width: 1.05rem;
        height: 1.05rem;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tool-label {
        white-space: nowrap;
    }

    .code-head {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        flex-wrap: wrap;
    }

    .code-caption {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--ks-content-primary);
        flex: 1;
        min-width: 0;
        line-height: 1.35;
    }

    .code-link {
        display: inline-flex;
        align-items: center;
        gap: 0.125rem;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--ks-content-color-highlight);
        text-decoration: none;
        white-space: nowrap;

        &:hover {
            text-decoration: underline;
            text-underline-offset: 3px;
        }
    }

    /* ---------- animations ---------- */

    $cycle: 8s;
    $ease: cubic-bezier(0.65, 0, 0.35, 1);

    @keyframes orch-pulse {
        0%, 3% {
            border-color: var(--ks-border-secondary);
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
            transform: translateY(0);
        }
        6%, 9% {
            border-color: color-mix(
                in srgb,
                var(--ks-content-color-highlight) 55%,
                var(--ks-border-secondary)
            );
            box-shadow:
                0 0 0 4px
                    color-mix(
                        in srgb,
                        var(--ks-content-color-highlight) 14%,
                        transparent
                    ),
                0 10px 26px
                    color-mix(
                        in srgb,
                        var(--ks-content-color-highlight) 32%,
                        transparent
                    );
            transform: translateY(-1px);
        }
        13%, 100% {
            border-color: var(--ks-border-secondary);
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
            transform: translateY(0);
        }
    }

    @keyframes orch-pulse-flow {
        0%, 3% {
            border-color: color-mix(
                in srgb,
                var(--ks-content-color-highlight) 30%,
                var(--ks-border-secondary)
            );
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
            transform: translateY(0);
        }
        6%, 9% {
            border-color: color-mix(
                in srgb,
                var(--ks-content-color-highlight) 70%,
                var(--ks-border-secondary)
            );
            box-shadow:
                0 0 0 4px
                    color-mix(
                        in srgb,
                        var(--ks-content-color-highlight) 16%,
                        transparent
                    ),
                0 12px 30px
                    color-mix(
                        in srgb,
                        var(--ks-content-color-highlight) 36%,
                        transparent
                    );
            transform: translateY(-1px);
        }
        13%, 100% {
            border-color: color-mix(
                in srgb,
                var(--ks-content-color-highlight) 30%,
                var(--ks-border-secondary)
            );
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
            transform: translateY(0);
        }
    }

    @keyframes orch-pulse-outcome {
        0%, 3% {
            border-color: color-mix(
                in srgb,
                var(--tool-color, var(--ks-content-color-highlight)) 35%,
                var(--ks-border-secondary)
            );
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
            transform: translateY(0);
        }
        6%, 9% {
            border-color: color-mix(
                in srgb,
                var(--tool-color, var(--ks-content-color-highlight)) 75%,
                var(--ks-border-secondary)
            );
            box-shadow:
                0 0 0 4px
                    color-mix(
                        in srgb,
                        var(--tool-color, var(--ks-content-color-highlight)) 16%,
                        transparent
                    ),
                0 12px 30px
                    color-mix(
                        in srgb,
                        var(--tool-color, var(--ks-content-color-highlight)) 38%,
                        transparent
                    );
            transform: translateY(-1px);
        }
        13%, 100% {
            border-color: color-mix(
                in srgb,
                var(--tool-color, var(--ks-content-color-highlight)) 35%,
                var(--ks-border-secondary)
            );
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
            transform: translateY(0);
        }
    }

    @keyframes orch-rail-comet {
        0%, 4% {
            transform: translateY(-110%);
            opacity: 0;
        }
        8% {
            transform: translateY(-110%);
            opacity: 1;
        }
        22% {
            transform: translateY(110%);
            opacity: 1;
        }
        26%, 100% {
            transform: translateY(110%);
            opacity: 0;
        }
    }

    .node-trigger {
        animation: orch-pulse $cycle $ease infinite;
        animation-delay: 0s;
    }
    .rail-fill-1 {
        animation: orch-rail-comet $cycle $ease infinite;
        animation-delay: 0.8s;
    }
    .node-flow {
        animation: orch-pulse-flow $cycle $ease infinite;
        animation-delay: 1.6s;
    }
    .rail-fill-2 {
        animation: orch-rail-comet $cycle $ease infinite;
        animation-delay: 2.4s;
    }
    .node-tasks {
        animation: orch-pulse $cycle $ease infinite;
        animation-delay: 3.2s;
    }
    .rail-fill-3 {
        animation: orch-rail-comet $cycle $ease infinite;
        animation-delay: 4s;
    }
    .node-outcome {
        animation: orch-pulse-outcome $cycle $ease infinite;
        animation-delay: 4.8s;
    }

    @media (prefers-reduced-motion: reduce) {
        .node-trigger,
        .node-flow,
        .node-tasks,
        .node-outcome,
        .rail-fill {
            animation: none !important;
        }
        .rail-fill {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
