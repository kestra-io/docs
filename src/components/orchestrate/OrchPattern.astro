---
import { Icon } from "astro-icon/components"
import TaskIcon from "~/components/common/TaskIcon.vue"
import Snippets from "~/components/common/Snippets.vue"

interface FlowNode {
    label: string
    sublabel?: string
    pluginClass?: string
    icon?: string
}

interface FlowDiagram {
    source: FlowNode
    workflow: { label: string; sublabel?: string }
    tools: FlowNode[]
    outcome: FlowNode
}

interface BlueprintItem {
    name: string
    title: string
    description: string
    code: string
    plugins: string[]
    href?: string
    flowDiagram?: FlowDiagram
}

interface Props {
    nutshell?: string
    blueprints: BlueprintItem[]
    toolColor?: string
}

const { nutshell, blueprints, toolColor } = Astro.props as Props
const sectionStyle = toolColor ? `--tool-color: ${toolColor};` : undefined

const tabs = blueprints.filter((bp) => bp.flowDiagram)
const hasTabs = tabs.length > 0
---

<section class="orch-pattern" style={sectionStyle}>
    <div class="container">
        <div class="wrapper">
            {nutshell && (
                <div class="wrapper__head">
                    <p class="nutshell" set:html={nutshell} />
                </div>
            )}

            {hasTabs && (
                <div class="orch-tabs" data-orch-tabs>
                            <div class="orch-tabs__bar" role="tablist">
                                {tabs.map((bp, idx) => (
                                    <button
                                        type="button"
                                        class:list={["orch-tabs__tab", { active: idx === 0 }]}
                                        role="tab"
                                        data-tab-target={idx}
                                        aria-selected={idx === 0}
                                    >
                                        {bp.name}
                                    </button>
                                ))}
                            </div>

                            {tabs.map((bp, idx) => (
                                <div
                                    class:list={["orch-tabs__panel", { active: idx === 0 }]}
                                    role="tabpanel"
                                    data-tab-content={idx}
                                >
                                    <div class="panel-row">
                                        <div class="panel-topology">
                                            <div class="topology">
                                                <div class="topology-group group-flow">
                                                    <span class="topology-tag tag-flow">Flow</span>
                                                    <div class="node">
                                                        <div class="node-icon node-icon-flow">
                                                            <Icon
                                                                name="mdi:lightning-bolt"
                                                                width={20}
                                                                height={20}
                                                            />
                                                        </div>
                                                        <div class="node-text">
                                                            <div class="node-label">
                                                                {bp.flowDiagram!.workflow.label}
                                                            </div>
                                                            {bp.flowDiagram!.workflow.sublabel && (
                                                                <div class="node-sublabel">
                                                                    {bp.flowDiagram!.workflow.sublabel}
                                                                </div>
                                                            )}
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="topology-rail topology-rail--bi" aria-hidden="true">
                                                    <span class="rail-track">
                                                        <Icon name="mdi:menu-up" class="rail-arrow rail-arrow--up" width={14} height={14} />
                                                        <Icon name="mdi:menu-down" class="rail-arrow rail-arrow--down" width={14} height={14} />
                                                    </span>
                                                </div>

                                                <div class="topology-group group-trigger">
                                                    <span class="topology-tag tag-trigger">Triggers</span>
                                                    <div class="node">
                                                        <div class="node-icon">
                                                            {bp.flowDiagram!.source.pluginClass ? (
                                                                <TaskIcon cls={bp.flowDiagram!.source.pluginClass} />
                                                            ) : (
                                                                <Icon
                                                                    name={bp.flowDiagram!.source.icon || "mdi:lightning-bolt-outline"}
                                                                    width={20}
                                                                    height={20}
                                                                />
                                                            )}
                                                        </div>
                                                        <div class="node-text">
                                                            <div class="node-label">
                                                                {bp.flowDiagram!.source.label}
                                                            </div>
                                                            {bp.flowDiagram!.source.sublabel && (
                                                                <div class="node-sublabel">
                                                                    {bp.flowDiagram!.source.sublabel}
                                                                </div>
                                                            )}
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="topology-rail" aria-hidden="true">
                                                    <span class="rail-track">
                                                        <Icon name="mdi:menu-down" class="rail-arrow rail-arrow--down" width={14} height={14} />
                                                    </span>
                                                </div>

                                                <div class="topology-group group-tasks">
                                                    <span class="topology-tag tag-tasks">Tasks</span>
                                                    <div class="tools-cluster">
                                                        {bp.flowDiagram!.tools.map((tool) => (
                                                            <div class="tool-pill">
                                                                <div class="tool-icon">
                                                                    {tool.pluginClass ? (
                                                                        <TaskIcon cls={tool.pluginClass} />
                                                                    ) : (
                                                                        <Icon
                                                                            name={tool.icon || "mdi:hexagon-outline"}
                                                                            width={14}
                                                                            height={14}
                                                                        />
                                                                    )}
                                                                </div>
                                                                <span class="tool-label">
                                                                    {tool.label}
                                                                </span>
                                                            </div>
                                                        ))}
                                                    </div>
                                                </div>

                                                <div class="topology-rail" aria-hidden="true">
                                                    <span class="rail-track">
                                                        <Icon name="mdi:menu-down" class="rail-arrow rail-arrow--down" width={14} height={14} />
                                                    </span>
                                                </div>

                                                <div class="topology-group group-outcome">
                                                    <span class="topology-tag tag-outcome">Outcome</span>
                                                    <div class="node node-outcome">
                                                        <div class="node-icon">
                                                            {bp.flowDiagram!.outcome.pluginClass ? (
                                                                <TaskIcon cls={bp.flowDiagram!.outcome.pluginClass} />
                                                            ) : (
                                                                <Icon
                                                                    name={bp.flowDiagram!.outcome.icon || "mdi:check-circle-outline"}
                                                                    width={20}
                                                                    height={20}
                                                                />
                                                            )}
                                                        </div>
                                                        <div class="node-text">
                                                            <div class="node-label">
                                                                {bp.flowDiagram!.outcome.label}
                                                            </div>
                                                            {bp.flowDiagram!.outcome.sublabel && (
                                                                <div class="node-sublabel">
                                                                    {bp.flowDiagram!.outcome.sublabel}
                                                                </div>
                                                            )}
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="topology-rail" aria-hidden="true">
                                                    <span class="rail-track">
                                                        <Icon name="mdi:menu-down" class="rail-arrow rail-arrow--down" width={14} height={14} />
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="panel-code">
                                            <div class="code-head">
                                                <span class="code-caption">{bp.title}</span>
                                                {bp.href && (
                                                    <a class="code-link" href={bp.href}>
                                                        Open blueprint
                                                        <Icon name="mdi:chevron-right" width={14} height={14} />
                                                    </a>
                                                )}
                                            </div>
                                            <Snippets client:idle code={bp.code} lang="yaml" />
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    )}
        </div>
    </div>
</section>

<script>
    function wireOrchTabs() {
        for (const root of document.querySelectorAll<HTMLElement>(
            "[data-orch-tabs]",
        )) {
            if (root.dataset.wired === "true") continue
            root.dataset.wired = "true"
            root.addEventListener("click", (e) => {
                const btn = (e.target as Element).closest(
                    ".orch-tabs__tab",
                ) as HTMLElement | null
                if (!btn) return
                const target = btn.dataset.tabTarget
                if (target == null) return
                for (const el of root.querySelectorAll(
                    ".orch-tabs__tab, .orch-tabs__panel",
                )) {
                    el.classList.remove("active")
                    if (el.matches(".orch-tabs__tab")) {
                        el.setAttribute("aria-selected", "false")
                    }
                }
                btn.classList.add("active")
                btn.setAttribute("aria-selected", "true")
                root.querySelector(
                    `.orch-tabs__panel[data-tab-content="${target}"]`,
                )?.classList.add("active")
            })
        }
    }

    document.addEventListener("astro:page-load", wireOrchTabs)
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", wireOrchTabs)
    } else {
        wireOrchTabs()
    }
</script>

<style lang="scss">
    .orch-pattern {
        background: var(--ks-background-body);
        padding: 2.5rem 1rem 3rem;

        @include media-breakpoint-up(md) {
            padding: 3rem 1.5rem 4rem;
        }
    }

    .container {
        max-width: 1180px;
        margin: 0 auto;
    }

    .wrapper {
        border: 1px solid var(--ks-border-primary);
        border-radius: 0.875rem;
        background: var(--ks-background-primary);
        box-shadow: 2px 3px 16px 0 var(--ks-shadows-light);
        overflow: hidden;
    }

    .wrapper__head {
        padding: 1.75rem 2rem 1.5rem;
        border-bottom: 1px solid var(--ks-border-secondary);
        background: linear-gradient(
            135deg,
            color-mix(in srgb, var(--ks-content-color-highlight) 4%, var(--ks-background-primary)),
            var(--ks-background-primary) 60%
        );

        @include media-breakpoint-down(md) {
            padding: 1.25rem 1.25rem 1rem;
        }
    }

    .nutshell {
        max-width: 880px;
        margin: 0 auto;
        text-align: center;
        font-size: 1.0625rem;
        line-height: 1.65;
        color: var(--ks-content-primary);

        :global(a) {
            color: var(--ks-content-color-highlight);
            text-decoration: underline;
            text-underline-offset: 3px;
            text-decoration-thickness: 1px;
            text-decoration-color: color-mix(
                in srgb,
                var(--ks-content-color-highlight) 40%,
                transparent
            );
            transition: text-decoration-color 0.18s ease;

            &:hover {
                text-decoration-color: var(--ks-content-color-highlight);
            }
        }
    }

    .orch-tabs__bar {
        display: flex;
        flex-direction: row;
        overflow-x: auto;
        scrollbar-width: thin;
        background: var(--ks-background-secondary);
        border-bottom: 1px solid var(--ks-border-secondary);
    }

    .orch-tabs__tab {
        flex: 1 1 0;
        padding: 0.9rem 1.25rem;
        border: 0;
        border-bottom: 2px solid transparent;
        background: transparent;
        color: var(--ks-content-secondary);
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        text-align: center;
        transition:
            color 0.18s ease,
            background 0.18s ease,
            border-color 0.18s ease;

        &:hover {
            color: var(--ks-content-primary);
            background: color-mix(
                in srgb,
                var(--ks-content-color-highlight) 4%,
                transparent
            );
        }

        &.active {
            color: var(--ks-content-primary);
            background: var(--ks-background-primary);
            border-bottom-color: var(--ks-content-color-highlight);
        }

        & + & {
            border-left: 1px solid var(--ks-border-secondary);
        }
    }

    .orch-tabs__panel {
        display: none;

        &.active {
            display: block;
        }
    }

    .panel-row {
        display: flex;
        flex-direction: row;
        align-items: stretch;

        @include media-breakpoint-down(lg) {
            flex-direction: column;
        }
    }

    .panel-topology {
        flex: 0 0 42%;
        padding: 1.75rem 1.25rem;
        background: #0e0d1a;
        background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.06) 1px, transparent 0);
        background-size: 14px 14px;
        border-right: 1px solid var(--ks-border-secondary);

        @include media-breakpoint-down(lg) {
            flex: 1 1 auto;
            border-right: none;
            border-bottom: 1px solid var(--ks-border-secondary);
        }

        @include media-breakpoint-down(md) {
            padding: 1.25rem 1rem;
        }
    }

    .panel-code {
        flex: 1 1 0;
        padding: 1.5rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        background: var(--ks-background-primary);
        min-width: 0;

        @include media-breakpoint-down(md) {
            padding: 1.25rem 1rem;
        }
    }

    .topology {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .topology-group {
        position: relative;
        width: 100%;
        min-height: 6.75rem;
        padding: 2.5rem 0.85rem 1rem;
        border: 1px solid;
        border-radius: 0.875rem;
        background: rgba(255, 255, 255, 0.02);
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .group-flow {
        --group-color: #8405ff;
        border-color: var(--group-color);
        background: rgba(132, 5, 255, 0.05);
    }

    .group-trigger {
        --group-color: #02be8a;
        border-color: var(--group-color);
        background: rgba(2, 190, 138, 0.05);
    }

    .group-tasks {
        --group-color: #1761fd;
        border-color: var(--group-color);
        background: rgba(23, 97, 253, 0.05);
    }

    .group-outcome {
        --group-color: var(--tool-color, #8405ff);
        border-color: var(--group-color);
        background: color-mix(in srgb, var(--group-color) 5%, transparent);
    }

    .topology-tag {
        position: absolute;
        top: 0.75rem;
        left: 0.85rem;
        display: inline-flex;
        align-items: center;
        padding: 0.2rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.6875rem;
        font-weight: 700;
        line-height: 1;
        color: #ffffff;
        white-space: nowrap;
    }

    .tag-flow { background: #8405ff; }
    .tag-trigger { background: #02be8a; }
    .tag-tasks { background: #1761fd; }
    .tag-outcome { background: var(--tool-color, #8405ff); }

    .topology-rail {
        display: flex;
        justify-content: center;
        padding: 0.9rem 0;
    }

    .rail-track {
        position: relative;
        display: block;
        box-sizing: content-box;
        width: 14px;
        height: 56px;
        padding: 10px 0;
        background-image: linear-gradient(
            to bottom,
            #9A8EB4 50%,
            transparent 50%
        );
        background-size: 2px 7px;
        background-position: center top;
        background-repeat: repeat-y;
        background-origin: content-box;
        background-clip: content-box;
        animation: rail-flow 0.25s linear infinite;

        &::before {
            content: "";
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #9A8EB4;
        }
    }

    .topology-rail--bi .rail-track::before {
        display: none;
    }

    .rail-arrow {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        color: #9A8EB4;
    }

    .rail-arrow--down { bottom: 0; }
    .rail-arrow--up { top: 0; }

    @keyframes rail-flow {
        from { background-position: center 0; }
        to { background-position: center 7px; }
    }

    @media (prefers-reduced-motion: reduce) {
        .rail-track { animation: none !important; }
    }

    .node {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.7rem 0.85rem;
        background: rgba(154, 142, 180, 0.22);
        border: 1px solid rgba(154, 142, 180, 0.35);
        border-radius: 0.625rem;
    }

    .node-icon {
        width: 2rem;
        height: 2rem;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #2b1c5c, #1a1235);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.5rem;
        padding: 0.3rem;
        color: #ffffff;
    }

    .node-icon-flow {
        background: linear-gradient(135deg, color-mix(in srgb, var(--group-color) 60%, #1a1235), #1a1235);
        border-color: color-mix(in srgb, var(--group-color) 35%, transparent);
    }

    .node-outcome .node-icon {
        background: linear-gradient(135deg, color-mix(in srgb, var(--group-color) 55%, #1a1235), #1a1235);
        border-color: color-mix(in srgb, var(--group-color) 35%, transparent);
        color: #ffffff;
    }

    .node-text {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .node-label {
        font-size: 0.85rem;
        font-weight: 600;
        line-height: 1.2;
        color: rgba(255, 255, 255, 0.95);
    }

    .node-sublabel {
        font-size: 0.72rem;
        line-height: 1.25;
        color: rgba(255, 255, 255, 0.55);
    }

    .tools-cluster {
        display: flex;
        flex-wrap: wrap;
        gap: 0.375rem;
        align-content: center;
        padding: 0.5rem;
        background: rgba(154, 142, 180, 0.22);
        border: 1px solid rgba(154, 142, 180, 0.35);
        border-radius: 0.625rem;
    }

    .tool-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.3rem 0.55rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.375rem;
        font-size: 0.72rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.9);
        line-height: 1;
    }

    .tool-icon {
        width: 1.05rem;
        height: 1.05rem;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255, 255, 255, 0.85);
    }

    .tool-label {
        white-space: nowrap;
    }

    .code-head {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        flex-wrap: wrap;
    }

    .code-caption {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--ks-content-primary);
        flex: 1;
        min-width: 0;
        line-height: 1.35;
    }

    .code-link {
        display: inline-flex;
        align-items: center;
        gap: 0.125rem;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--ks-content-color-highlight);
        text-decoration: none;
        white-space: nowrap;

        &:hover {
            text-decoration: underline;
            text-underline-offset: 3px;
        }
    }

    $cycle: 12s;
    $ease: ease-in-out;

    @keyframes group-pulse {
        0%, 4%, 18%, 100% {
            box-shadow: 0 0 0 0 transparent;
        }
        9%, 13% {
            box-shadow:
                0 0 0 4px color-mix(in srgb, var(--group-color) 22%, transparent),
                0 10px 30px color-mix(in srgb, var(--group-color) 32%, transparent);
        }
    }

    .group-flow { animation: group-pulse $cycle $ease infinite; animation-delay: 0s; }
    .group-trigger { animation: group-pulse $cycle $ease infinite; animation-delay: 3s; }
    .group-tasks { animation: group-pulse $cycle $ease infinite; animation-delay: 6s; }
    .group-outcome { animation: group-pulse $cycle $ease infinite; animation-delay: 9s; }

    @media (prefers-reduced-motion: reduce) {
        .group-flow,
        .group-trigger,
        .group-tasks,
        .group-outcome {
            animation: none !important;
        }
    }
</style>
