---
import { Image } from "astro:assets"

interface Props {
    cards: {
        title: string
        description: string
        image: ImageMetadata
        reverse?: boolean
    }[]
}

const { cards } = Astro.props
---

<section class="section-card">
    <div class="container">
        <h2 data-usal="fade-u delay-0 duration-400 ease-out">
            <slot name="title" />
        </h2>

        <div class="cards-wrapper mt-4">
            {
                cards.map((card, index) => (
                    <div
                        class="cards"
                        data-usal={`fade duration-400 delay-${50 + index * 50} ease-out`}
                    >
                        <div
                            class:list={[
                                "inner-card",
                                { reverse: card.reverse },
                            ]}
                        >
                            <div
                                class="content-card"
                                data-usal={`fade-u duration-350 delay-${100 + index * 50} ease-out`}
                            >
                                <h3 set:html={card.title} />
                                <p set:html={card.description} />
                            </div>

                            <div class="img-card">
                                <Image
                                    src={card.image}
                                    alt={card.title}
                                    class="img-fluid"
                                />
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style lang="scss">
    .section-card {
        background: var(--ks-background-body);
        padding: $rem-3 $rem-1;

        @include media-breakpoint-up(md) {
            padding: $rem-4 0;
        }

        .container {
            padding: 0;

            h2 {
                margin-bottom: $rem-3;

                @include media-breakpoint-up(md) {
                    text-align: left;
                }

                :global(.gradient) {
                    color: var(--ks-content-color-highlight);
                }

                :global(.indent) {
                    display: block;
                    text-align: center;

                    @include media-breakpoint-up(md) {
                        margin-left: $rem-4;
                        text-align: left;
                    }
                }
            }

            h3 {
                margin: 0;
            }

            .cards-wrapper {
                display: flex;
                flex-direction: column;
                gap: 1.625rem;

                @include media-breakpoint-only(md) {
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                }

                .cards {
                    border: 1px solid var(--ks-border-primary);
                    padding: 0.375rem;
                    border-radius: 0.8125rem;

                    .inner-card {
                        background: var(--ks-background-secondary);
                        border-radius: $border-radius-lg;
                        display: flex;
                        flex-direction: column-reverse;
                        align-items: center;
                        justify-content: space-between;
                        overflow: hidden;

                        @include media-breakpoint-up(lg) {
                            flex-direction: row;
                            padding-left: $rem-2;
                            gap: 2.5rem;

                            &.reverse {
                                flex-direction: row-reverse;
                                padding: 0 $rem-2 0 0;
                            }
                        }

                        @include media-breakpoint-up(xl) {
                            gap: 64px;
                        }

                        .content-card {
                            display: flex;
                            flex-direction: column;
                            gap: 0.5rem;
                            padding-bottom: 1rem;
                            padding: 1rem 0.5rem;

                            @include media-breakpoint-down(lg) {
                                padding: 1rem;
                                h3 {
                                    font-size: $h4-font-size;
                                }
                            }

                            @include media-breakpoint-up(lg) {
                                width: 500px;
                                height: auto;
                            }

                            @include media-breakpoint-up(xl) {
                                width: 400px;
                                height: 212px;
                                gap: 16px;
                            }
                        }

                        .img-card {
                            width: 100%;
                            height: 100%;
                            margin-bottom: 1rem;
                            display: flex;
                            overflow: hidden;

                            img {
                                width: calc(100% + 4px);
                                height: calc(100% + 4px);
                                margin: -2px;
                                object-fit: cover;
                                display: block;
                            }

                            @include media-breakpoint-up(md) {
                                img {
                                    min-width: 100%;
                                    height: 240px;
                                }
                            }

                            @include media-breakpoint-up(lg) {
                                width: auto;
                                margin-bottom: 0;

                                img {
                                    width: calc(500px + 4px);
                                    height: calc(333px + 4px);
                                    margin: -2px;
                                    object-fit: cover;
                                }
                            }

                            @include media-breakpoint-up(xl) {
                                width: auto;
                                margin-bottom: 0;

                                img {
                                    width: calc(600px + 4px);
                                    height: calc(400px + 4px);
                                    margin: -2px;
                                    object-fit: cover;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
</style>
