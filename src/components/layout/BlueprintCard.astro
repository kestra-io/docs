---
import { Icon } from "astro-icon/components"
import TaskIcon from "~/components/common/TaskIcon.astro"
import { capitalize } from "~/utils/plugins/pluginUtils"
import { visibleTags, SOLUTIONS_TAG } from "~/utils/blueprints/visibleTags"
import { tagIconFor } from "~/utils/blueprints/tagIcon"

const { blueprint, tags = [], href } = Astro.props

const MAX_ICONS = 6
const allTasks = blueprint.includedTasks ?? []
const visibleTasks = allTasks.slice(0, MAX_ICONS)
const extraCount = Math.max(0, allTasks.length - MAX_ICONS)

const capitalizedTitle = capitalize(blueprint?.title ?? "")

const solutionsTagId = tags?.find((t: any) => t.name === SOLUTIONS_TAG)?.id
const isSolutions = Boolean(
    solutionsTagId && blueprint.tags?.includes(solutionsTagId),
)

const tagsList = tags?.length
    ? visibleTags(tags)
          .filter((t: any) => blueprint.tags?.includes(t.id))
          .map((t: any) => t.name)
    : (blueprint.tags ?? [])
---

<a
    href={href}
    class:list={["blueprint", { "has-solutions-badge": isSolutions }]}
>
    {
        isSolutions && (
            <span
                class="solutions-badge"
                title="Built by the Kestra Solutions Engineering team"
            >
                <Icon name="mdi:shield-check-outline" class="badge-icon" />
                Kestra SE
            </span>
        )
    }
    <h6 class="title">
        {capitalizedTitle}
    </h6>
    {
        blueprint.shortDescription && (
            <p class="description">{blueprint.shortDescription}</p>
        )
    }
    <div class="task-icons">
        {
            visibleTasks.map((cls: string) => (
                <div class="icon">
                    <TaskIcon cls={cls} />
                </div>
            ))
        }
        {extraCount > 0 && <span class="extra-count">+{extraCount}</span>}
    </div>
    <div class="footer">
        <hr />
        <div class="bottom-row">
            {
                tagsList.length > 0 && (
                    <div class="tag-list">
                        {tagsList.map((tag: string) => (
                            <span class="category-tag">
                                <Icon name={tagIconFor(tag)} class="tag-icon" />
                                {tag}
                            </span>
                        ))}
                    </div>
                )
            }
        </div>
    </div>
</a>

<style lang="scss">
    @use "/src/components/blueprints/_blueprintCard.scss" as blueprintCard;

    .blueprint {
        @include blueprintCard.blueprint-card-base;

        position: relative;

        .solutions-badge {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            padding: 0.125rem 0.5rem;
            border-radius: 2rem;
            font-size: $font-size-xs;
            font-weight: 600;
            background: var(--ks-background-tag-category);
            color: var(--ks-content-tag-category);

            .badge-icon {
                width: 0.875rem;
                height: 0.875rem;
            }
        }

        &.has-solutions-badge .title {
            padding-right: 6rem;
        }

        transition: all 0.4s ease-out;
        scroll-snap-align: start;
        scroll-margin-left: 1em;
        @include media-breakpoint-up(md) {
            scroll-margin-left: 2em;
        }
        &:hover {
            color: var(--ks-content-primary);
        }
        .task-icons {
            .icon {
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 4px;
            }
            .extra-count {
                flex-shrink: 0;
                font-size: $font-size-xs !important;
                font-weight: 600;
                color: var(--ks-content-secondary);
            }
        }
    }
</style>
