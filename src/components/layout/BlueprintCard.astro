---
import { Icon } from "astro-icon/components"
import TaskIcon from "~/components/common/TaskIcon.astro"
import { capitalize } from "~/utils/plugins/pluginUtils"
import { visibleTags } from "~/utils/blueprints/visibleTags"
import { tagIconFor } from "~/utils/blueprints/tagIcon"
import {
    blueprintHasSubtag,
    CUSTOMER_SUCCESS_SUBTAG,
    CUSTOMER_SUCCESS_LABEL,
} from "~/utils/blueprints/subtags"

const { blueprint, tags = [], href } = Astro.props

const MAX_ICONS = 6
const allTasks = (blueprint.includedTasks ?? []).filter(
    (cls: string) => !cls.startsWith("io.kestra.plugin.ee.assets."),
)
const visibleTasks = allTasks.slice(0, MAX_ICONS)
const extraCount = Math.max(0, allTasks.length - MAX_ICONS)

const capitalizedTitle = capitalize(blueprint?.title ?? "")

const isCustomerSuccess = blueprintHasSubtag(blueprint, CUSTOMER_SUCCESS_SUBTAG)

const usesEE = (blueprint.includedTasks ?? []).some((cls: string) =>
    cls.startsWith("io.kestra.plugin.ee."),
)

const tagsList = tags?.length
    ? visibleTags(tags)
          .filter((t: any) => blueprint.tags?.includes(t.id))
          .map((t: any) => t.name)
    : (blueprint.tags ?? [])
---

<a href={href} class="blueprint">
    {
        isCustomerSuccess && (
            <span class="cs-badge" title={CUSTOMER_SUCCESS_LABEL}>
                <Icon name="mdi:star" class="cs-badge-icon" />
                {CUSTOMER_SUCCESS_LABEL}
            </span>
        )
    }
    <h6 class="title">
        {capitalizedTitle}
    </h6>
    {
        blueprint.shortDescription && (
            <p class="description">{blueprint.shortDescription}</p>
        )
    }
    <div class="task-icons">
        {
            visibleTasks.map((cls: string) => (
                <div class="icon">
                    <TaskIcon cls={cls} />
                </div>
            ))
        }
        {extraCount > 0 && <span class="extra-count">+{extraCount}</span>}
    </div>
    <div class="footer">
        <hr />
        <div class="bottom-row">
            {
                tagsList.length > 0 && (
                    <div class="tag-list">
                        {tagsList.map((tag: string) => (
                            <span class="category-tag">
                                <Icon name={tagIconFor(tag)} class="tag-icon" />
                                {tag}
                            </span>
                        ))}
                    </div>
                )
            }
            {
                usesEE && (
                    <span
                        class="ee-tag"
                        title="Uses an Enterprise Edition plugin"
                    >
                        Enterprise Edition
                    </span>
                )
            }
        </div>
    </div>
</a>

<style lang="scss">
    @use "/src/components/blueprints/_blueprintCard.scss" as blueprintCard;

    .blueprint {
        @include blueprintCard.blueprint-card-base;

        .cs-badge {
            display: inline-flex;
            align-self: flex-start;
            align-items: center;
            gap: 0.3125rem;
            margin-bottom: 0.5rem;
            font-size: 0.6875rem;
            font-weight: 600;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            white-space: nowrap;
            color: var(--ks-content-tertiary);

            .cs-badge-icon {
                width: 0.75rem;
                height: 0.75rem;
                flex-shrink: 0;
                color: #f5c518;
            }
        }

        transition: all 0.4s ease-out;
        scroll-snap-align: start;
        scroll-margin-left: 1em;
        @include media-breakpoint-up(md) {
            scroll-margin-left: 2em;
        }
        &:hover {
            color: var(--ks-content-primary);
        }
        .task-icons {
            .icon {
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 4px;
            }
            .extra-count {
                flex-shrink: 0;
                font-size: $font-size-xs !important;
                font-weight: 600;
                color: var(--ks-content-secondary);
            }
        }
    }
</style>
