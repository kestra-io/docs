---
import Layout from "~/components/layout.astro"
import Meeting from "~/components/demo/Meeting.vue"
import headerBackground from "../components/demo/assets/header-background.png"
import Logos from "~/components/demo/Logos.astro"

const title = "Book a Demo"
const description = "Discuss your Orchestration Strategy"
---

<Layout title={title} description={description}>
    <div class="demo">
        <div class="demo-left">
            <h1>Discuss your <span>Orchestration</span> Strategy</h1>
            <p class="subtitle">Your Architecture is Unique.</p>
            <p class="subtitle">Your Challenges are Specific.</p>
            <ul class="list">
                <li>
                    <b>Your Pains:</b> Are you struggling with unreliable pipelines,
                    legacy fatigue, or lack of visibility?
                </li>
                <li>
                    <b>Your Needs:</b> We’ll discuss your requirements for security,
                    scale, and language agnostic support.
                </li>
                <li>
                    <b>The Resolution:</b> See exactly how Kestra’s architecture resolves
                    these friction points in your stack.
                </li>
            </ul>
            <p class="shadow-card">
                Get a clear understanding of how Kestra fits your platform and a
                roadmap to solve your current orchestration headaches.
            </p>
        </div>
        <Meeting
            routePath="/demo"
            headerBackground={headerBackground}
            client:idle
        />
    </div>
    <Logos />
</Layout>

<style lang="scss">
    @import "~/assets/styles/variable";
    .demo {
        display: flex;
        flex-direction: column;
        font-size: 0.9rem;
        @include media-breakpoint-up(lg) {
            flex-direction: row;
            max-width: 1200px;
            margin: 0 auto;
        }
    }
    h1 {
        margin: 2rem 0;
        span {
            // force a return before this element and not after it
            &:before {
                content: "\A";
                white-space: pre;
            }
            color: var(--ks-content-color-highlight);
        }
    }

    .demo-left {
        flex: 1;
        padding: 2rem;
    }

    .subtitle {
        font-size: 1rem;
        margin: 0;
    }

    .list {
        list-style-type: disc;
        padding-left: 1.5rem;
        margin: 2rem 0;
        li {
            margin-bottom: 1.5rem;
        }
    }

    .shadow-card {
        background-color: var(--ks-background-primary);
        color: var(--ks-content-primary);
        padding: 1rem 1.5rem;
        border-radius: 0.5rem;
        box-shadow: 0px 0px 15px var(--ks-shadows-light);
    }
</style>
