---
export const prerender = false
import Layout from "~/components/layout.astro"
import FooterContact from "~/components/layout/FooterContact.astro"
import { type AshbyJobPosting, fetchJob } from "~/utils/careers.ts"
import HeaderDetails from "~/components/careers/HeaderDetails.astro"

const { id1, id2, id3, id4, id5 } = Astro.params

const uid = [id1, id2, id3, id4, id5].join("-")

if (!uid) {
    return Astro.redirect("/careers")
}

const page: AshbyJobPosting = await fetchJob(uid)

if (!page) {
    return new Response(null, {
        status: 404,
        statusText: "Not found",
    })
}

const title = page.title
---

<Layout title={title} noindex>
    <HeaderDetails title={page.title} />

    <section>
        <div class="container">
            <div
                id="ashby_embed"
                data-uid={uid}
                class="application-form-embed-container"
                data-tab="application"
                data-noChrome="true"
            >
            </div>
        </div>
    </section>

    <FooterContact
        title="See all open positions"
        purple={{
            text: "Careers page",
            href: "/careers",
        }}
        dark={null}
    />
</Layout>

<script is:inline>
    window.__Ashby = {
        settings: {
            autoScroll: false,
            autoLoad: true,
            verboseLogging: false,
        },
    }

    function init() {
        const jobPostingId = document.getElementById("ashby_embed").dataset.uid

        window.__Ashby.iFrame().load({
            jobPostingId
        });
    }

    document.addEventListener('astro:page-load', init);
</script>

<script is:inline id="ashby-script" src="https://jobs.ashbyhq.com/kestra/embed?version=2"></script>


<script is:inline>


</script>


<style lang="scss" scoped>
    #ashby_embed {
        background: white;
        padding: 0 1rem;
    }
</style>
