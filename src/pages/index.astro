---
import Layout from "~/components/layout.astro"
import Hero from "~/components/home/Hero.astro"
import LogoBar from "~/components/home/LogoBar.astro"
import Comparison from "~/components/home/Comparison.astro"
import AdoptBanner from "~/components/home/AdoptBanner.astro"
import FeatureCards from "~/components/home/FeatureCards.astro"
import PlatformOverview from "~/components/home/PlatformOverview.astro"
import UseCaseGrid from "~/components/home/UseCaseGrid.astro"
import Integrations from "~/components/home/Integrations.astro"
import Testimonial from "~/components/home/Testimonial.astro"
import DeploySection from "~/components/home/DeploySection.astro"
import Blueprints from "~/components/home/Blueprints.astro"
import CTA from "~/components/common/CTA.astro"
import { $fetchApi } from "~/utils/fetch"

const blueprints = await $fetchApi<{ results: Blueprint[] }>(
    "/blueprints/versions/latest?page=1&size=20",
)
---

<Layout headerTheme="darkHeader">
    <div class="home-page">
        <Hero />
        <LogoBar />
        <Comparison />
        <AdoptBanner />
        <FeatureCards />
        <PlatformOverview />
        <UseCaseGrid />
        <Integrations />
        <Testimonial />
        <DeploySection />
        <Blueprints />
        <CTA />
    </div>
</Layout>

<style lang="scss">
    .home-page {
        background-color: #0a0b0d;
        margin-top: -2rem;
    }
</style>
