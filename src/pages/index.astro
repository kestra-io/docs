---
import Layout from "~/components/layout.astro"
import SchemaSoftwareApplication from "~/components/common/SchemaSoftwareApplication.astro"
import Hero from "~/components/home/Hero.astro"
import Comparison from "~/components/home/Comparison.astro"
import Stacked from "~/components/common/Stacked.astro"
import PlatformOverview from "~/components/home/PlatformOverview.astro"
import UseCaseGrid from "~/components/home/UseCaseGrid.astro"
import Testimonial from "~/components/home/Testimonial.astro"
import Blueprints from "~/components/home/Blueprints.astro"
import ClosingCTA from "~/components/home/ClosingCTA.astro"
import EarlyAdopterBanner from "~/components/early-adopter-program/EarlyAdopterBanner.astro"
import GetStarted from "~/components/common/GetStarted.astro"
import PluginsBlock from "~/components/common/PluginsBlock.astro"
import { fetchTotalPluginsCount } from "~/utils/plugins/pluginCount"

const totalPlugins = await fetchTotalPluginsCount()
---

<Layout headerTheme="darkHeader">
    <Fragment slot="head">
        <SchemaSoftwareApplication
            url="https://kestra.io"
        />
    </Fragment>
    <div class="home-page">
        <Hero />
        <Comparison />
        <Stacked>
            <h2 slot="title" id="adopt">
                Adopt Once.<br />
                <span>Standardize Everywhere.</span>
            </h2>

            <div slot="description"></div>
        </Stacked>
        <PlatformOverview />
        <UseCaseGrid />
        <PluginsBlock>
            <span slot="title">
                Work With Your Stack, <br />
                Not the Other Way Around.
            </span>
            <span slot="description">
                Kestra integrates with your existing cloud, data,
                infrastructure, and SaaS tools. <br />With {totalPlugins}+ plugins, you
                can orchestrate everything without building custom glue code.
            </span>
        </PluginsBlock>
        <Testimonial />
        <GetStarted>
            <h2 slot="heading" id="get-started">
                Deploy Anywhere. Keep Everything Governed.
            </h2>
        </GetStarted>
        <Blueprints />
        <ClosingCTA />
        <EarlyAdopterBanner />
    </div>
</Layout>

<style lang="scss">
    /* since the home page will mostly follow its own theme,
     * we need to define some of the colors here. */
    .home-page {
        --hp-background-dark: #0a0b0d;
        --hp-content-dark: #ffffff;
        --hp-content-primary: #131316;
        --hp-background-secondary: #f7f7f7;
        --hp-content-secondary: #3b3a41;
        --hp-content-secondary-inverse: #cccbce;
        --hp-background-tertiary: #7f7f86;
        --hp-content-tertiary: #94a3b8;
        --hp-border-primary: #f1f1f1;
        --hp-border-secondary: #cccbce;
        --hp-content-color-highlight: #631bff;
        --hp-background-purple-light: #f1efff;
        --hp-grid-size: 68px;
        background-color: var(--hp-background-dark);
        color: var(--hp-content-dark);
        overflow: clip;
    }

    h2 {
        font-size: 2rem;
        text-align: center;
        margin-bottom: 2rem;
        margin-inline: auto;
        @include media-breakpoint-up(md) {
            width: 700px;
        }
    }

    h2#adopt {
        color: var(--ks-content-primary);
        span {
            color: var(--ks-content-color-highlight);
        }
    }

    h2#get-started {
        color: var(--ks-content-primary-inverse);
    }
</style>

