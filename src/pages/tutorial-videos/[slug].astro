---
export const prerender = false
import Layout from "~/components/layout.astro"
import FooterContact from "~/components/layout/FooterContact.astro"
import TutorialsList from "~/components/videos/TutorialsList.vue"
import { getCollection } from "astro:content"
import TutorialsListTabs from "~/components/videos/TutorialsListTabs.vue"

const categories = new Map([
    ["all", "All videos"],
    ["deep-dive", "Deep Dive Tutorials"],
    ["quick-start", "Quick Start Tutorials"],
    ["feature-highlight", "Feature Highlight"],
])

const { slug } = Astro.params

const currentCategory = slug ? (categories.get(slug) ?? "") : ""

const PageURL = new URL(Astro.request.url)

const itemsPerPageStr = PageURL.searchParams.get("size")
const itemsPerPage = itemsPerPageStr ? parseInt(itemsPerPageStr) : 24

const pageStr = PageURL.searchParams.get("page")
const page = pageStr ? parseInt(pageStr) : 1

const currentCategoryFilter = slug === "all" ? "" : currentCategory

const allVideos = await getCollection("tutorialVideos")

const sortedVideos = allVideos.sort(
    (a, b) =>
        b.data.publicationDate.getTime() - a.data.publicationDate.getTime(),
)

const filteredVideos = currentCategoryFilter
    ? sortedVideos.filter((v) => v.data.category === currentCategoryFilter)
    : sortedVideos

const total = filteredVideos.length
const start = (page - 1) * itemsPerPage
const results = filteredVideos.slice(start, start + itemsPerPage).map((v) => ({
    ...v.data,
    publicationDate: v.data.publicationDate.toISOString(),
}))

const tutorialVideo = { results, total }

const title = `Video Tutorials: ${currentCategory}`
const description = `Get started with our Video Tutorials: ${currentCategory}`
---

<Layout title={title} description={description}>
    <section class="header" transition:persist>
        <div class="container">
            <h1 data-usal="fade-left title">Video Tutorials</h1>
            <p data-usal="fade-r">Get started with our video tutorials</p>
        </div>
        <form class="container">
            <label for="email">Subscribe to updates</label>
            <input
                type="email"
                id="email"
                placeholder="Enter your email"
                required
            />
            <button type="submit">Subscribe</button>
        </form>
    </section>
    <section>
        <div class="container">
            <TutorialsListTabs
                categories={categories}
                current-category={currentCategory}
            />
            <TutorialsList
                currentUrl={Astro.request.url}
                {...{
                    tutorialVideo,
                    page,
                    itemsPerPage,
                    currentCategory,
                    categories,
                }}
                client:visible
            />
        </div>
    </section>
    <FooterContact title="Get Started" />
</Layout>

<style lang="scss">
    .header {
        padding-top: 6rem;
        background-color: var(--ks-background-secondary);
        background: url("~/components/videos/assets/another-grid.svg") no-repeat
            bottom center;
    }
    h1 {
        color: var(--ks-content-primary);
        margin-bottom: 0.5rem;
    }
    p {
        color: var(--ks-content-secondary);
        margin-bottom: 2rem;
    }

    form {
        padding: 1rem 0.5rem 4rem;
        label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--ks-content-primary);
        }
        button {
            background: var(--ks-background-body);
            color: var(--ks-content-primary);
            border-radius: 3px;
            border: 1px solid var(--ks-content-primary);
        }
    }
</style>
