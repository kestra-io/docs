---
import Layout from "~/components/layout.astro"

import Hero from "~/components/enterprise/Hero.vue"
import Quotes from "~/components/common/Quotes.vue"
import SeeHow from "~/components/common/SeeHow.astro"
import ScrollSpy from "~/components/enterprise/Scroll.vue"
import Success from "~/components/enterprise/Success.astro"
import PluginsBlock from "~/components/common/PluginsBlock.astro"
import Capabilities from "~/components/enterprise/Capabilities.vue"
import StatsHeader from "~/components/enterprise/StatsHeader.astro"

import graviteeLogo from "~/contents/customer-stories/25/logo.svg?raw"
import leroyMerlinLogo from "~/contents/customer-stories/14/logo.svg?raw"
import fortune500Logo from "~/components/enterprise/assets/fortune500.svg?raw"

const title = "Get More Out of Your Data With the Enterprise Edition"
const description =
    "Get full access of all the Open source features and unlock the full potential with Enterprise only features"

const CUSTOMER_QUOTES = [
    {
        quote: "Our goal is for Kestra to become the go-to solution across the organization whenever data wrangling and complex pipeline orchestration are needed.",
        author: "Rémi Sultan — AI/ML Lead",
        smallLogoSvg: graviteeLogo,
        kpis: [
            {
                name: "less maintenance",
                value: "50%",
            },
            {
                name: "Customer training needed",
                value: "0",
            },
            {
                name: "Engineers to build the product",
                value: "2",
            },
        ],
        storyLink:
            "/use-cases/stories/25-when-your-api-writes-its-own-docs-with-kestra",
    },
    {
        quote: "We eliminated the high cost and risk of VMware vRA. What used to take 6 months now takes 6 days with Kestra!",
        author: "Principal Hosting",
        smallLogoSvg: fortune500Logo,
        kpis: [
            {
                name: "Isolated automation platforms",
                value: "4+1",
            },
            {
                name: "faster time to deliver",
                value: "30x",
            },
            {
                name: "In licensing cost VS Aria Automation",
                value: "-90%",
            },
        ],
        storyLink:
            "/use-cases/stories/27-securing-hybrid-cloud-automation-across-it-ot-with-kestra",
    },
    {
        quote: "Kestra is the unifying layer for our data and workflows. You can start small, but then there is no limit to the possibilities and scalability of such an open architecture.",
        author: "Julien Henrion — Head of Data Engineering",
        smallLogoSvg: leroyMerlinLogo,
        kpis: [
            {
                name: "In Data Production",
                value: "+900%",
            },
            {
                name: "active users",
                value: "+250",
            },
            {
                name: "workflows Created",
                value: "+5000",
            },
        ],
        storyLink:
            "/use-cases/stories/14-datamesh-at-scale-increased-its-data-production-by-900",
    },
]

const STATS = [
    {
        category: "PRODUCTIVITY",
        value: "10x",
        label: "Faster Workflow Completion",
    },
    {
        category: "PROFITABILITY",
        value: "75%",
        label: "Reduction in Operational costs",
    },
    {
        category: "EFFICIENCY",
        value: "80%",
        label: "Boost in Team Efficiency",
    },
    {
        category: "TIME TO MARKET",
        value: "5x",
        label: "Deployment Speed",
    },
]
---

<Layout {title} {description} headerTheme="lightHero">
    <Hero client:load />
    <div class="enterprise">
        <ScrollSpy client:load />
    </div>
    <Success />
    <Capabilities />
    <StatsHeader stats={STATS} />
    <PluginsBlock />
    <Quotes quotes={CUSTOMER_QUOTES} client:load />
    <SeeHow
        cta={{
            text: "Let's Talk",
            href: "/demo",
        }}
    >
        <Fragment slot="title">Ready to Scale Your Workflows</Fragment>
        Teams replace vRO, Rundeck, Cron, Jenkins, and manual scripts with Kestra
    </SeeHow>
</Layout>

<style lang="scss">
    .enterprise {
        overflow: clip;

        :global(.card-grid-section) {
            background: var(--ks-background-secondary);
        }
    }
</style>
