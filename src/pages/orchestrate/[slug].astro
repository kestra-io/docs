</style>

<script>
    document.addEventListener("astro:page-load", () => {
        for (const container of document.querySelectorAll(".orch-build .inner")) {
            container.addEventListener("click", (e) => {
                const tab = (e.target as Element).closest(".header-tab") as HTMLElement
                if (!tab) return
                const target = (container as Element).querySelector(
                    `[data-tab-content="${tab.dataset.tabTarget}"]`,
                )
                if (!target) return

                for (const el of container.querySelectorAll(".header-tab, .content")) {
                    el.classList.remove("active")
                }
                tab.classList.add("active")
                target.classList.add("active")
            })
        }

        const observer = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    const card = entry.target as HTMLElement
                    card.classList.toggle("is-folded", !entry.isIntersecting)
                }
            },
            { threshold: 0.15 },
        )
        for (const card of document.querySelectorAll(".uc-card")) {
            observer.observe(card as HTMLElement)
        }
    })
</script>
