            h3 {
                margin: 0;
                font-size: $font-size-lg;
                font-weight: 600;
                color: var(--ks-content-primary);
                line-height: 1.3;
            }

            p {
                margin: 0;
                color: var(--ks-content-secondary);
                font-size: $font-size-sm;
                line-height: 1.55;
            }
        }
    }

    /* ===== Comparison table overrides ===== */
    .orch-compare {
