---
import { getCollection } from "astro:content"

import Layout from "~/components/layout.astro"
import SchemaFAQ from "~/components/common/SchemaFAQ.astro"
import Faq from "~/components/common/Faq.vue"
import Quotes from "~/components/common/Quotes.vue"
import SeeHow from "~/components/common/SeeHow.astro"
import Link from "~/components/common/Link.astro"
import BlogList from "~/components/common/BlogList.astro"
import BlueprintTabs from "~/components/common/BlueprintTabs.astro"
import CardGrid from "~/components/card/CardGrid.astro"
import SplitBadgeCard from "~/components/card/SplitBadgeCard.astro"
import FeatureGrid from "~/components/versus/FeatureGrid.astro"

import Hero from "~/components/orchestrate/Hero.astro"
import UseCaseFlow from "~/components/orchestrate/UseCaseFlow.astro"

import { fetchPluginIcon } from "~/utils/pluginIcon"
import { optimizeSvgIcon } from "~/utils/svgo"

import GorgiasLogo from "~/contents/customer-stories/gorgias-using-declarative-data-engineering-orchestration-with-kestra/logo.svg?raw"
import RiversideLogo from "~/components/orchestrate/assets/riverside.svg?raw"
import SlackLogo from "~/components/orchestrate/assets/slack.svg?raw"
import FoundationDataLogo from "~/components/orchestrate/assets/foundation-data.svg?raw"
import RedditLogo from "~/components/orchestrate/assets/reddit.svg?raw"
import CreditAgricoleLogo from "~/components/orchestrate/assets/credit-agricole.svg?raw"
import SophtLogo from "~/components/orchestrate/assets/sopht.svg?raw"
import BsiLogo from "~/components/orchestrate/assets/bsi.svg?raw"
import CenshareLogo from "~/components/orchestrate/assets/censhare.svg?raw"
import WestBendLogo from "~/components/orchestrate/assets/west-bend.svg?raw"

const versusLogoModules = import.meta.glob<string>(
    "../../components/versus/assets/*.svg",
    { query: "?raw", import: "default", eager: true },
)

function getVersusLogo(filename: string): string {
    const key = Object.keys(versusLogoModules).find((k) =>
        k.endsWith(`/${filename}.svg`),
    )
    return key ? versusLogoModules[key] : ""
}

const LOGO_MAP: Record<string, string> = {
    gorgias: optimizeSvgIcon(GorgiasLogo, "gorgias-orch-logo"),
    riverside: optimizeSvgIcon(RiversideLogo, "riverside-orch-logo"),
    slack: optimizeSvgIcon(SlackLogo, "slack-orch-logo"),
    "foundation-data": optimizeSvgIcon(FoundationDataLogo, "foundation-data-orch-logo"),
    reddit: optimizeSvgIcon(RedditLogo, "reddit-orch-logo"),
    "credit-agricole": optimizeSvgIcon(CreditAgricoleLogo, "credit-agricole-orch-logo"),
    sopht: optimizeSvgIcon(SophtLogo, "sopht-orch-logo"),
    bsi: optimizeSvgIcon(BsiLogo, "bsi-orch-logo"),
    censhare: optimizeSvgIcon(CenshareLogo, "censhare-orch-logo"),
    "west-bend": optimizeSvgIcon(WestBendLogo, "west-bend-orch-logo"),
}

export async function getStaticPaths() {
    const entries = await getCollection("orchestration")
    return entries.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }))
}

const { entry } = Astro.props
const {
    title,
    description,
    tool,
    hero,
    pillars,
    useCases,
    quotes,
    blueprints,
    comparison,
    faq,
    seeHow,
} = entry.data

let pluginIcon = ""
try {
    pluginIcon = await fetchPluginIcon(tool.pluginClass)
} catch (e) {
    console.warn(`Could not fetch plugin icon for ${tool.pluginClass}`, e)
}

const pluginParts = tool.pluginClass.split(".")
const pluginDocsUrl =
    pluginParts.length > 3 ? `/plugins/plugin-${pluginParts[3]}` : null

const toolKeyword = tool.name.toLowerCase().split(" ")[0]
const allBlogs = await getCollection("blogs")
const relatedBlogs = allBlogs
    .filter(
        (b) =>
            b.id.toLowerCase().includes(toolKeyword) ||
            b.data.title.toLowerCase().includes(toolKeyword),
    )
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .slice(0, 4)
    .map((b) => ({
        path: `/blogs/${b.id}`,
        image: b.data.image,
        title: b.data.title,
        date: b.data.date.toISOString(),
        category: b.data.category,
    }))

const competitorLogos: string[] = await Promise.all(
    comparison.competitors.map(async (c) => {
        if (c.logoAsset) {
            return getVersusLogo(c.logoAsset)
        }
        if (c.pluginClass) {
            try {
                return await fetchPluginIcon(c.pluginClass)
            } catch (e) {
                console.warn(`Could not fetch logo for ${c.name}`, e)
                return ""
            }
        }
        return ""
    }),
)

const quoteItems = quotes.map((q) => ({
    quote: q.quote,
    author: q.author,
    storyLink: q.storyLink,
    sourceUrl: q.sourceUrl,
    sourceLabel: q.sourceLabel,
    kpis: q.kpis,
    smallLogoSvg: q.logoFile ? LOGO_MAP[q.logoFile] : undefined,
}))

const competitorKeys = comparison.competitors.map((_: any, i: number) => `comp${i}`)
const comparisonTableData = comparison.rows.map((row) => {
    const obj: Record<string, string> = {
        feature: row.feature,
        kestra: row.kestra,
    }
    row.values.forEach((v, i) => {
        obj[`comp${i}`] = v
    })
    return obj
})
---

<Layout title={title} description={description}>
    <SchemaFAQ items={faq} slot="head" />

    <Hero
        title={hero.title}
        description={hero.description}
        cta={hero.cta}
        secondaryCta={hero.secondaryCta}
        toolName={tool.name}
        toolIcon={pluginIcon}
        toolColor={tool.color}
    />

    <CardGrid title={pillars.title} subtitle={pillars.subtitle} items={pillars.items} />

    <section class="orch-usecases">
        <div class="orch-usecases__head">
            <h2>{useCases.title}</h2>
            {useCases.subtitle && <p>{useCases.subtitle}</p>}
        </div>
        <div class="orch-usecases__container">
            {
                useCases.items.map((uc) => (
                    <SplitBadgeCard
                        badge={uc.badge}
                        badgeIcon={uc.badgeIcon}
                        title={uc.title}
                        description={uc.description}
                        items={uc.items}
                        signal={uc.signal}
                    >
                        <UseCaseFlow slot="right" flow={uc.flow} />
                    </SplitBadgeCard>
                ))
            }
        </div>
    </section>

    <Quotes quotes={quoteItems} client:load />

    <BlueprintTabs
        title={blueprints.title}
        lead={blueprints.lead}
        items={blueprints.items}
    />

    <div class="orch-compare">
        <FeatureGrid
            featureGrid={{
                title: comparison.title,
                tableData: comparisonTableData,
            }}
            columns={competitorKeys}
        >
            <Fragment slot="firstCol">Capability</Fragment>
            <Fragment slot="more">
                {
                    comparison.competitors.map((c, i) => (
                        <th>
                            <div class="th-competitor">
                                {competitorLogos[i] && (
                                    <div
                                        class="th-logo"
                                        set:html={competitorLogos[i]}
                                        role="img"
                                        aria-label={c.name}
                                    />
                                )}
                                <span class="th-name">{c.name}</span>
                            </div>
                        </th>
                    ))
                }
            </Fragment>
        </FeatureGrid>
    </div>

    <Faq
        items={faq}
        title={`${tool.name} & Kestra: common questions`}
        client:visible
    />

    {
        (pluginDocsUrl || relatedBlogs.length > 0) && (
            <section class="orch-resources">
                <div class="container">
                    <div class="orch-resources__grid">
                        {pluginDocsUrl && (
                            <aside class="docs-card">
                                <span class="docs-card__eyebrow">
                                    Documentation
                                </span>
                                <h3>
                                    Wire {tool.name} into your workflows
                                </h3>
                                <p>
                                    Every {tool.name} task, trigger, and
                                    configuration option, with copy-ready
                                    YAML examples.
                                </p>
                                <Link href={pluginDocsUrl}>
                                    Explore the {tool.name} plugin docs
                                </Link>
                            </aside>
                        )}
                        {relatedBlogs.length > 0 && (
                            <div class="blogs-card">
                                <BlogList
                                    posts={relatedBlogs}
                                    title={`Read more about ${tool.name} + Kestra`}
                                />
                            </div>
                        )}
                    </div>
                </div>
            </section>
        )
    }

    <SeeHow
        cta={seeHow.cta
            ? { text: seeHow.cta.label, href: seeHow.cta.href }
            : { text: "Book a Demo", href: "/demo" }}
    >
        <Fragment slot="title">{seeHow.title}</Fragment>
        {seeHow.description}
    </SeeHow>
</Layout>

<style lang="scss">
    .orch-usecases {
        width: 100%;
        padding: 3rem 2rem;
        background: var(--ks-background-primary)
            url("~/assets/landing/infrastructure/grid.svg") no-repeat top;

        @include media-breakpoint-down(md) {
            padding: 1rem 0.75rem;
        }

        @include media-breakpoint-up(xl) {
            padding: 5.4375rem 120px;
        }

        &__head {
            max-width: 760px;
            margin: 0 auto 3rem;
            text-align: center;

            h2 {
                color: var(--ks-content-primary);
                margin-bottom: 1rem;
            }

            p {
                color: var(--ks-content-secondary);
                font-size: $font-size-lg;
                line-height: 1.6;
                margin: 0;
            }
        }

        &__container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2rem;
        }
    }

    .orch-compare {
        :global(table) {
            table-layout: auto !important;
        }

        :global(th),
        :global(td) {
            width: auto !important;
            padding: 1rem 1.25rem !important;
        }

        :global(.th-competitor) {
            display: inline-flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 0.375rem;
        }

        :global(.th-name) {
            font-size: $font-size-sm;
            font-weight: 600;
            color: var(--ks-content-primary);
            line-height: 1;
        }

        :global(.th-logo) {
            display: inline-flex;
            align-items: center;
            justify-content: flex-start;
            max-height: 40px;
            max-width: 140px;
            overflow: hidden;
        }

        :global(.th-logo svg) {
            width: auto !important;
            height: 32px !important;
            max-width: 140px !important;
            max-height: 32px !important;
        }

        :global(.check-icon) {
            color: #22c55e !important;
        }
    }

    .orch-resources {
        background: var(--ks-background-body);
        padding: $rem-4 $rem-1;

        .container {
            max-width: 1180px;
            margin: 0 auto;
            padding: 0;
        }

        &__grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
            align-items: start;

            @include media-breakpoint-up(md) {
                grid-template-columns: minmax(0, 22rem) minmax(0, 1fr);
                gap: 3rem;
            }
        }

        .docs-card {
            position: relative;
            padding: 1.75rem;
            border-radius: 0.75rem;
            border: $block-border;
            background: var(--ks-background-primary);
            box-shadow: 2px 3px 16px 0 var(--ks-shadows-light);
            display: flex;
            flex-direction: column;
            gap: 0.6rem;

            &::before {
                content: "";
                position: absolute;
                inset: 0;
                border-radius: inherit;
                pointer-events: none;
                background: radial-gradient(
                    120% 80% at 100% 0%,
                    color-mix(
                        in srgb,
                        var(--tool-color, var(--ks-content-color-highlight))
                            18%,
                        transparent
                    ),
                    transparent 60%
                );
                z-index: 0;
            }

            > * {
                position: relative;
                z-index: 1;
            }

            &__eyebrow {
                width: fit-content;
                padding: 0.375rem 1.125rem;
                border-radius: 2.5rem;
                border: 1px solid var(--ks-border-active);
                display: inline-flex;
                align-items: center;
                font-size: $font-size-xs;
                color: var(--ks-content-color-highlight);
            }

            h3 {
                margin: 0;
                font-size: $font-size-lg;
                font-weight: 600;
                color: var(--ks-content-primary);
                line-height: 1.3;
            }

            p {
                margin: 0;
                color: var(--ks-content-secondary);
                font-size: $font-size-sm;
                line-height: 1.55;
            }
        }
    }
</style>
