---
import { getCollection } from "astro:content"
import Layout from "~/components/layout.astro"
import Faq from "~/components/common/Faq.vue"
import SchemaFAQ from "~/components/common/SchemaFAQ.astro"
import GetStarted from "~/components/common/GetStarted.astro"
import kestraIcon from "~/components/versus/assets/ks-icon.svg?raw"
import { fetchPluginIcon } from "~/utils/pluginIcon"
import { fetchTotalPluginsCount } from "~/utils/plugins/pluginCount"

const totalPlugins = await fetchTotalPluginsCount()

const CATEGORY_MAP: Record<string, string> = {
    ansible: "Infrastructure",
    argocd: "Infrastructure",
    aws: "Cloud",
    cloudflare: "Cloud",
    docker: "Infrastructure",
    git: "Infrastructure",
    "github-actions": "Infrastructure",
    kubernetes: "Infrastructure",
    netbox: "Infrastructure",
    nutanix: "Infrastructure",
    opa: "Infrastructure",
    proxmox: "Infrastructure",
    servicenow: "Business",
    slack: "Business",
    terraform: "Infrastructure",
    vmware: "Infrastructure",
    "dbt-cloud": "Data",
    "dbt-core": "Data",
}

const orchestrationEntries = await getCollection("orchestration")

const entries = await Promise.all(
    orchestrationEntries
        .sort((a, b) => a.data.tool.name.localeCompare(b.data.tool.name))
        .map(async (entry) => {
            let icon = ""
            try {
                icon = await fetchPluginIcon(entry.data.tool.pluginClass)
            } catch (e) {
                console.warn(
                    `Could not fetch plugin icon for ${entry.data.tool.pluginClass}`,
                    e,
                )
            }
            return {
                path: `/orchestration/${entry.id}`,
                toolName: entry.data.tool.name,
                category: CATEGORY_MAP[entry.id] ?? "Other",
                icon,
                shortDescription: entry.data.description,
                color: entry.data.tool.color ?? "#8465FF",
            }
        }),
)

const CATEGORY_ORDER = [
    "Infrastructure",
    "Cloud",
    "Data",
    "Business",
    "AI",
    "Alerting",
    "Core",
]
const presentCategories = [...new Set(entries.map((e) => e.category))].sort(
    (a, b) => {
        const ai = CATEGORY_ORDER.indexOf(a)
        const bi = CATEGORY_ORDER.indexOf(b)
        if (ai === -1 && bi === -1) return a.localeCompare(b)
        if (ai === -1) return 1
        if (bi === -1) return -1
        return ai - bi
    },
)

const faqItems = [
    {
        question: "What does Kestra orchestrate?",
        answer: `Kestra wraps the tools you already run with a unified orchestration layer: event-driven triggers, approval gates, retries, and cross-stack execution history. Today the catalog covers infrastructure (Terraform, Ansible, VMware, Nutanix, Proxmox, Docker, Argo CD) and data (dbt Cloud, dbt Core). The same pattern extends to ${totalPlugins}+ plugins across the wider stack.`,
    },
    {
        question: "How does Kestra fit alongside the tool I already use?",
        answer: "Kestra does not replace the tool. Terraform still provisions infrastructure, Ansible still configures hosts, dbt still runs models, Argo CD still reconciles Kubernetes. Kestra runs above them: when each one fires, what runs before, who approves promotion to prod, and where the audit trail lives. Each integration page shows the exact pattern for that tool.",
    },
    {
        question: "Can one Kestra flow chain multiple of these tools?",
        answer: "Yes. A common pattern: Terraform provisions the cluster, Ansible configures the nodes, Argo CD deploys the app. All three run as sequential tasks in one flow with outputs flowing forward and per-step retries on the step that fails. See the <a href='/orchestration/terraform'>Terraform</a>, <a href='/orchestration/ansible'>Ansible</a>, and <a href='/orchestration/argocd'>Argo CD</a> pages for the full chain.",
    },
    {
        question: "Is Kestra open source?",
        answer: "Yes. Kestra's core is fully open source under the Apache 2.0 license. You can self-host on Docker or Kubernetes, run air-gapped, or use the managed Cloud version. Enterprise adds RBAC, audit logs, SSO, Apps for self-service forms, and worker isolation.",
    },
    {
        question: "Where does Kestra fit for data orchestration?",
        answer: "Kestra triggers dbt Cloud or dbt Core jobs the moment upstream data lands (Fivetran completion, S3 file, Kafka event), coordinates Hightouch reverse-ETL downstream, and gives you one execution history across the whole pipeline. See the <a href='/orchestration/dbt-cloud'>dbt Cloud</a> and <a href='/orchestration/dbt-core'>dbt Core</a> pages for the full pattern.",
    },
    {
        question: "How do I get started?",
        answer: "Start Kestra locally in under a minute with Docker, or try the managed Cloud version for free. Visit the <a href='/docs/quickstart'>quickstart guide</a> to launch your first workflow, or <a href='/demo'>book a demo</a> to see how Kestra fits your team's stack.",
    },
]
---

<Layout
    title="Orchestrate your stack with Kestra"
    description="One orchestrator across infrastructure and data: Terraform, Ansible, VMware, Nutanix, Proxmox, Docker, Argo CD, dbt Cloud, and dbt Core. Event-driven, declarative, self-hosted."
>
    <section class="header-container">
        <div class="header container">
            <div class="hero-logos">
                <div class="hero-picto ks" set:html={kestraIcon} />
                <div class="hero-plus" aria-hidden="true">
                    <svg
                        width="22"
                        height="22"
                        viewBox="0 0 22 22"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            d="M11 3v16M3 11h16"
                            stroke="#8465FF"
                            stroke-width="2.5"
                            stroke-linecap="round"
                        ></path>
                    </svg>
                </div>
                <div class="hero-carousel" id="hero-carousel">
                    {
                        entries.map((entry, i) => (
                            <div
                                class:list={[
                                    "carousel-item",
                                    { active: i === 0 },
                                ]}
                                set:html={entry.icon}
                                data-name={entry.toolName}
                                data-color={entry.color}
                            />
                        ))
                    }
                </div>
            </div>
            <h1>
                Orchestrate <span
                    id="hero-name"
                    style={`color: ${entries[0].color}`}
                    >{entries[0].toolName}</span
                > with Kestra
            </h1>
            <p>
                One orchestrator across your infrastructure and data stack. Event-driven
                triggers, approval gates, per-step retries, cross-tool chains.
            </p>
            <div class="search-wrapper">
                <input
                    type="search"
                    placeholder="Search tools..."
                    id="orch-search"
                />
                <svg
                    class="search-icon"
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    ><path
                        d="M7.333 12.667A5.333 5.333 0 1 0 7.333 2a5.333 5.333 0 0 0 0 10.667ZM14 14l-2.9-2.9"
                        stroke="currentColor"
                        stroke-width="1.333"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path></svg
                >
            </div>
        </div>
    </section>

    <section class="listing">
        <div class="container">
            <div class="toggle" id="orch-toggle">
                <button class="toggle-btn active" data-category=""
                    >All tools</button
                >
                {
                    presentCategories.map((cat) => (
                        <button class="toggle-btn" data-category={cat}>
                            {cat}
                        </button>
                    ))
                }
            </div>
            <div class="grid" id="orch-grid">
                {
                    entries.map((entry) => (
                        <a
                            href={entry.path}
                            class="card"
                            data-name={entry.toolName}
                            data-category={entry.category}
                        >
                            <div class="pictos">
                                <div class="picto ks" set:html={kestraIcon} />
                                <div class="plus" aria-hidden="true">
                                    <svg
                                        width="16"
                                        height="16"
                                        viewBox="0 0 22 22"
                                        fill="none"
                                        xmlns="http://www.w3.org/2000/svg"
                                    >
                                        <path
                                            d="M11 3v16M3 11h16"
                                            stroke="#8465FF"
                                            stroke-width="2.5"
                                            stroke-linecap="round"
                                        />
                                    </svg>
                                </div>
                                <div class="picto" set:html={entry.icon} />
                            </div>
                            <p class="name">
                                Orchestrate {entry.toolName} with Kestra
                            </p>
                            <span class="cat-tag">{entry.category}</span>
                            <p class="desc">{entry.shortDescription}</p>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>

    <GetStarted>
        <Fragment slot="heading">
            <h2
                style="color: var(--ks-content-primary-inverse); text-align: center;"
            >
                Ready to orchestrate your stack?
            </h2>
            <div
                style="display: flex; justify-content: center; margin-top: 1.5rem; margin-bottom: 4rem;"
            >
                <a
                    href="/demo"
                    class="btn btn-primary"
                    style="color: white !important;">Book a Demo</a
                >
            </div>
        </Fragment>
    </GetStarted>

    <SchemaFAQ items={faqItems} slot="head" />
    <Faq items={faqItems} title="Frequently Asked Questions" client:visible />
</Layout>

<script is:inline>
    ;(function () {
        if (window.__orchCarouselTimer)
            clearInterval(window.__orchCarouselTimer)

        function init() {
            var toggle = document.getElementById("orch-toggle")
            var grid = document.getElementById("orch-grid")
            var search = document.getElementById("orch-search")
            var activeCategory = ""

            function applyFilters() {
                if (!grid) return
                var q = ((search && search.value) || "").toLowerCase().trim()
                var cards = grid.querySelectorAll(".card")
                for (var i = 0; i < cards.length; i++) {
                    var card = cards[i]
                    var name = (
                        card.getAttribute("data-name") || ""
                    ).toLowerCase()
                    var category = card.getAttribute("data-category") || ""
                    var matchesSearch = !q || name.indexOf(q) !== -1
                    var matchesCat =
                        !activeCategory || category === activeCategory
                    card.style.display =
                        matchesSearch && matchesCat ? "" : "none"
                }
            }

            if (toggle) {
                toggle.addEventListener("click", function (e) {
                    var btn = e.target.closest(".toggle-btn")
                    if (!btn) return
                    var btns = toggle.querySelectorAll(".toggle-btn")
                    for (var i = 0; i < btns.length; i++)
                        btns[i].classList.remove("active")
                    btn.classList.add("active")
                    activeCategory = btn.getAttribute("data-category") || ""
                    applyFilters()
                })
            }

            if (search) {
                search.addEventListener("input", applyFilters)
            }

            var carousel = document.getElementById("hero-carousel")
            var heroName = document.getElementById("hero-name")
            if (carousel && heroName) {
                var items = carousel.querySelectorAll(".carousel-item")
                var current = 0
                var total = items.length

                function updateHeroName(item) {
                    heroName.textContent = item.getAttribute("data-name") || ""
                    var color = item.getAttribute("data-color") || "#8465FF"
                    heroName.style.color = color
                }

                window.__orchCarouselTimer = setInterval(function () {
                    items[current].classList.remove("active")
                    heroName.style.opacity = "0"
                    setTimeout(function () {
                        current = (current + 1) % total
                        items[current].classList.add("active")
                        updateHeroName(items[current])
                        heroName.style.opacity = "1"
                    }, 400)
                }, 2800)
            }
        }

        if (!window.__orchInitDone) {
            window.__orchInitDone = true
            document.addEventListener("astro:page-load", init)
            document.addEventListener("visibilitychange", function () {
                if (!document.hidden) init()
            })
        }
        init()
    })()
</script>

<style lang="scss">
    .header-container {
        background: url("~/assets/squared-grid.svg") no-repeat top center /
            1400px auto;
        padding-inline: 1rem;

        .header {
            max-width: 1180px;
            margin: 0 auto;
            padding-top: 4rem;
            padding-bottom: 1rem;

            .hero-logos {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                margin-bottom: 1.5rem;

                .hero-picto {
                    width: 64px;
                    height: 64px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    border: 1px solid #f1f1f1;
                    border-radius: 12px;
                    padding: 8px;
                    background: #f7f7f7;

                    :global(svg) {
                        max-width: 100%;
                        max-height: 100%;
                        width: auto;
                        height: auto;
                    }

                    &.ks {
                        padding: 4px;
                        overflow: hidden;

                        :global(svg) {
                            width: 100%;
                            height: 100%;
                        }
                    }
                }

                .hero-plus {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    width: 22px;

                    svg {
                        display: block;
                    }
                }

                .hero-carousel {
                    position: relative;
                    width: 64px;
                    height: 64px;
                    border: 1px solid #f1f1f1;
                    border-radius: 12px;
                    padding: 8px;
                    background: #f7f7f7;
                    overflow: hidden;

                    .carousel-item {
                        position: absolute;
                        inset: 8px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        opacity: 0;
                        transform: translateY(6px);
                        transition:
                            opacity 0.4s ease,
                            transform 0.4s ease;
                        pointer-events: none;

                        :global(svg) {
                            max-width: 100%;
                            max-height: 100%;
                            width: auto;
                            height: auto;
                        }

                        &.active {
                            opacity: 1;
                            transform: translateY(0);
                            pointer-events: auto;
                        }
                    }
                }
            }

            h1 {
                font-weight: 600;
                color: var(--ks-content-primary);
                margin-bottom: 0.5rem;

                span {
                    color: var(--ks-border-active);
                    transition: opacity 0.4s ease;
                }
            }

            p {
                color: var(--ks-content-secondary);
                margin-bottom: 1.5rem;
                max-width: 640px;
            }

            .search-wrapper {
                position: relative;
                max-width: 450px;

                input {
                    width: 100%;
                    padding: 0.75rem 2.75rem 0.75rem 1rem;
                    border: 1px solid var(--ks-border-secondary);
                    border-radius: 8px;
                    font-size: $font-size-sm;
                    background-color: var(--ks-background-input);
                    color: var(--ks-content-primary);
                    outline: none;

                    &::placeholder {
                        color: var(--ks-content-tertiary);
                    }

                    &:focus {
                        border-color: var(--ks-border-active);
                    }
                }

                .search-icon {
                    position: absolute;
                    right: 0.875rem;
                    top: 50%;
                    transform: translateY(-50%);
                    color: var(--ks-content-tertiary);
                    pointer-events: none;
                }
            }
        }
    }

    .listing {
        padding: $rem-2 1rem $rem-6;
        background: var(--ks-background-body);

        .container {
            max-width: 1180px;
            margin: 0 auto;
            padding: 0;
        }
    }

    .toggle {
        display: flex;
        gap: 0;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--ks-border-secondary);
        width: fit-content;
    }

    .toggle-btn {
        font-size: $font-size-sm;
        color: var(--ks-content-secondary);
        background: transparent;
        padding: 0.75rem 1.25rem;
        border: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.2s;

        &:hover {
            color: var(--ks-content-primary);
        }

        &.active {
            color: var(--ks-content-primary);
            border-bottom-color: var(--ks-content-primary);
        }
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;

        @include media-breakpoint-up(md) {
            grid-template-columns: repeat(2, 1fr);
        }

        @include media-breakpoint-up(xl) {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .card {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 24px;
        border: 1px solid var(--ks-border-secondary);
        border-radius: 8px;
        text-decoration: none;
        background: var(--ks-background-primary);
        box-shadow: 2px 3px 16px 0px var(--ks-shadows-light);
        transition: all 0.2s ease;

        html.light & {
            background: $white;
        }

        &:hover {
            border-color: var(--ks-border-active);
        }
    }

    .pictos {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .picto {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--ks-border-primary);
        border-radius: 8px;
        padding: 8px;
        background: $white;
        flex-shrink: 0;

        :global(svg) {
            max-width: 100%;
            max-height: 100%;
            width: auto;
            height: auto;
        }

        &.ks {
            padding: 5px;
            overflow: hidden;

            :global(svg) {
                width: 100%;
                height: 100%;
            }
        }
    }

    .plus {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 16px;

        svg {
            display: block;
        }
    }

    .name {
        color: var(--ks-content-primary);
        font-weight: 600;
        font-size: $font-size-md;
        line-height: 24px;
        margin: 0;
    }

    .desc {
        color: var(--ks-content-secondary);
        font-size: $font-size-sm;
        line-height: 20px;
        margin: 0;
        min-height: 60px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .cat-tag {
        align-self: flex-start;
        font-size: $font-size-xs;
        line-height: 16px;
        padding: 2px 8px;
        border-radius: 40px;
        white-space: nowrap;
        font-weight: 600;
        background: var(--ks-background-tag-category);
        color: var(--ks-content-tag-category);
    }
</style>
