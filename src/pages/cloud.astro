---
import Layout from "~/components/layout.astro"
import Quotes from "~/components/common/Quotes.vue"
import CardGrid from "~/components/card/CardGrid.astro"
import SeeHow from "~/components/common/SeeHow.astro"
import Header from "~/components/cloud/Header.astro"
import RunningOrNew from "~/components/cloud/RunningOrNew.astro"
import { optimizeSvgIcon } from "~/utils/svgo"

import USCCALogo from "~/assets/quotes-companies/USCCA.svg?raw"
import ExtracadabraLogo from "~/assets/quotes-companies/Extracadabra.svg?raw"
import Yol1Logo from "~/assets/quotes-companies/Yol1.svg?raw"
import FoundationLogo from "~/components/cloud/assets/foundation-direct-logo.svg?raw"
import ctaImg from "~/components/cloud/assets/cta-end.png"

const title = "Kestra Cloud Early Adopter Program"
const description =
    "Be among the first to experience Kestra Cloud with exclusive access before general availability"

const platformSubtitle =
    'Run your declarative flows, event-driven triggers, language-agnostic tasks with <a href="/plugins">1,700+ plugins</a> and let us handle the provisioning, scaling, upgrades and security.'

const platformCards = [
    {
        icon: "mdi:cloud-check-outline",
        title: "Fully managed & operated",
        description:
            "Upgrades, scaling, backups and uptime handled by our team.",
    },
    {
        icon: "mdi:shield-check-outline",
        title: "SSO & audit logs",
        description: "Enterprise auth and a full audit trail from day one.",
    },
    {
        icon: "mdi:face-agent",
        title: "Human support that ships",
        description: "A direct line to the team and a real say in the roadmap.",
        badge: "Early-adopter only",
    },
    {
        icon: "mdi:key-outline",
        title: "Secret manager",
        description: "Encrypted secrets, scoped by namespace, managed for you.",
    },
    {
        icon: "mdi:account-cog-outline",
        title: "Unlimited users & custom roles",
        description:
            "Fine-grained RBAC: invite your whole team, scope every permission.",
    },
    {
        icon: "mdi:layers-outline",
        title: "Apps for your whole team",
        description:
            "Let non-technical teammates run flows themselves through a custom UI.",
        badge: "Early-adopter only",
    },
    {
        icon: "mdi:auto-fix",
        title: "AI Copilot",
        description:
            "Generate flows from plain English, on a fully managed Kestra.",
        badge: "Early-adopter only",
    },
    {
        icon: "mdi:lightning-bolt-outline",
        title: "Event-driven triggers",
        description:
            "Webhooks and schedules start executions for you, no poller and no extra server.",
    },
    {
        icon: "mdi:server-outline",
        title: "Remote / BYO task runners",
        description:
            "Run tasks on your own AWS, GCP or Azure. Your data stays on your infra.",
    },
]

const quotes = [
    {
        quote: "We didn't have centralized orchestration. That's where Kestra plays the most important role: all the fragmented production pipelines orchestrated through it.",
        author: "Shilpa Pauly — Data Engineer, USCCA",
        smallLogoSvg: optimizeSvgIcon(USCCALogo, "uscca-quote-logo"),
    },
    {
        quote: "Everyone in the company can create a flow very easily. That's why everyone at Extracadabra said yes to Kestra Cloud.",
        author: "Louis Raverdy — Lead Data Engineer, Extracadabra",
        smallLogoSvg: optimizeSvgIcon(
            ExtracadabraLogo,
            "extracadabra-quote-logo",
        ),
    },
    {
        quote: "The aha moment is more than the tool; it's the people. Kestra took care of us as we matter to them. We've really become Kestra fans.",
        author: "Felipe E. Vildoso Castillo — Head of Data & Analytics, Yol1",
        smallLogoSvg: optimizeSvgIcon(Yol1Logo, "yol1-quote-logo"),
    },
    {
        quote: "Kestra Cloud has been a pivotal part of giving us flexibility and scalability we need to pull off complex processes we do at Foundation Direct.",
        author: "Michael Heidner — SVP of Analytics and Business Intelligence, Foundation Data",
        smallLogoSvg: optimizeSvgIcon(FoundationLogo, "foundation-quote-logo"),
    },
]
---

<Layout {title} {description}>
    <Header />
    <Quotes {quotes} client:load />
    <CardGrid
        title="The Kestra platform, run for you."
        subtitle={platformSubtitle}
        items={platformCards}
    />
    <RunningOrNew />
    <SeeHow
        imgSrc={ctaImg}
        cta={{ text: "Request early access", href: "#get-access" }}
    >
        <Fragment slot="title">Ready to let us run Kestra for you?</Fragment>
    </SeeHow>
</Layout>
