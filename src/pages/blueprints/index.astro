---
export const prerender = false

import { Icon } from "astro-icon/components"
import { $fetchApiCached } from "~/utils/fetch"
import Layout from "~/components/layout.astro"
import Faq from "~/components/common/Faq.vue"
import SeeHow from "~/components/common/SeeHow.astro"
import { blueprintFaqItems } from "~/utils/blueprints/faq"
import BlueprintCard from "~/components/layout/BlueprintCard.astro"
import BlueprintLists from "~/components/blueprints/BlueprintLists.vue"
import TokenSearch from "~/components/blueprints/TokenSearch.vue"
import { visibleTags } from "~/utils/blueprints/visibleTags"
import { splitTagsByAxis, PATTERN_TAGS } from "~/utils/blueprints/useCaseTags"
import { categoryTileMetaFor } from "~/utils/blueprints/categoryMeta"
import { fetchTotalBlueprintsCount } from "~/utils/blueprints/blueprintCount"
import { fetchFullCatalog } from "~/utils/blueprints/catalog"
import {
    SUB_CATEGORIES,
    blueprintInSubCategory,
    type SubCategory,
} from "~/utils/blueprints/subCategories"
import {
    buildToolIndex,
    buildCoreToolIndex,
    blueprintUsesTool,
} from "~/utils/blueprints/toolIndex"

const GETTING_STARTED_IDS = [
    "hello-world",
    "data-engineering-pipeline",
    "business-automation",
    "business-processes",
    "infrastructure-automation",
    "microservices-and-apis",
]
const POPULAR_IDS = [
    "ai-model-router",
    "ai-github-pr-review",
    "kubernetes-vault-rotation-restart",
    "terraform-approval-plan-apply",
    "kafka-realtime-record-processing",
    "dbt-git-docker-duckdb",
    "snowflake-incremental-merge-upsert",
    "ai-slack-chatbot-with-memory",
]
const FEATURED_IDS: string[] = []

async function fetchBlueprintsByIds(ids: string[]): Promise<Blueprint[]> {
    const results = await Promise.all(
        ids.map((blueprintId) =>
            $fetchApiCached<Blueprint>(
                `/blueprints/${blueprintId}/versions/latest`,
            ).catch(() => null),
        ),
    )
    return results.filter((b): b is Blueprint => b !== null)
}

const page = Astro.url.searchParams.get("page") ?? 1
const size = Astro.url.searchParams.get("size") ?? 24
const q = Astro.url.searchParams.get("q") ?? undefined
const sort = Astro.url.searchParams.get("sort") ?? "A-Z"
const tagsSelected = Astro.url.searchParams.get("tags") ?? undefined
const toolsSelected = Astro.url.searchParams.get("tools") ?? undefined
const toolNames = toolsSelected
    ? toolsSelected
          .split(",")
          .map((t) => t.trim())
          .filter(Boolean)
    : []

const tags = await $fetchApiCached<BlueprintTag[]>(
    `/blueprints/versions/latest/tags`,
)
const { categoryTags, patternTags } = splitTagsByAxis(visibleTags(tags))

async function fetchTagCount(tagId?: string): Promise<number> {
    if (!tagId) return 0
    return $fetchApiCached<{ total: number }>(
        `/blueprints/versions/latest?tags=${tagId}&size=1`,
    )
        .then((r) => r?.total ?? 0)
        .catch(() => 0)
}

const [
    gettingStartedBlueprints,
    popularBlueprints,
    featuredBlueprints,
    fullCatalog,
    headlineCount,
    categoryCounts,
    patternCounts,
] = await Promise.all([
    fetchBlueprintsByIds(GETTING_STARTED_IDS),
    fetchBlueprintsByIds(POPULAR_IDS),
    fetchBlueprintsByIds(FEATURED_IDS),
    fetchFullCatalog(),
    fetchTotalBlueprintsCount(),
    Promise.all(categoryTags.map((tag) => fetchTagCount(tag.id))),
    Promise.all(patternTags.map((tag) => fetchTagCount(tag.id))),
])

const recentlyAddedBlueprints = fullCatalog
    .slice()
    .filter((b) => !/n8n|zapier/i.test(`${b.id} ${b.title}`))
    .sort(
        (a, b) =>
            new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime(),
    )
    .slice(0, 8)

const toolIndex = buildToolIndex(fullCatalog)
const coreToolIndex = buildCoreToolIndex(fullCatalog)

const hasActiveFilters = Boolean(q || tagsSelected || toolNames.length)

const tagNames = tagsSelected
    ? tagsSelected
          .split(",")
          .map((t) => t.trim())
          .filter(Boolean)
    : []
const tagIdsForFilter = tagNames
    .map(
        (name) =>
            tags.find((tag) => tag.name.toLowerCase() === name.toLowerCase())
                ?.id,
    )
    .filter((tagId): tagId is string => Boolean(tagId))
const ALL_SUB_CATEGORIES = Object.values(SUB_CATEGORIES).flat()
const fallbackSubCategories = tagNames
    .filter(
        (name) =>
            !tags.some((tag) => tag.name.toLowerCase() === name.toLowerCase()),
    )
    .map((name) =>
        ALL_SUB_CATEGORIES.find(
            (sc) => sc.name.toLowerCase() === name.toLowerCase(),
        ),
    )
    .filter((sc): sc is SubCategory => Boolean(sc))

let blueprintsData: Blueprint[] = []
let total = 0

const groupedByCategory = toolNames.length > 0 && tagNames.length === 0
let toolGroups: {
    name: string
    slug?: string
    icon: string
    total: number
    blueprints: Blueprint[]
}[] = []

if (
    toolNames.length > 0 ||
    tagIdsForFilter.length > 1 ||
    fallbackSubCategories.length > 0
) {
    const selectedTools = toolNames
        .map((name) =>
            [...toolIndex, ...coreToolIndex].find((t) => t.name === name),
        )
        .filter((t): t is (typeof toolIndex)[number] => t !== undefined)

    const qLower = q?.toLowerCase()
    const filtered = fullCatalog.filter((b) => {
        if (!tagIdsForFilter.every((tagId) => b.tags?.includes(tagId))) {
            return false
        }
        if (
            !fallbackSubCategories.every((sc) => blueprintInSubCategory(sc, b))
        ) {
            return false
        }
        if (!selectedTools.every((t) => blueprintUsesTool(b, t.pluginClass))) {
            return false
        }
        if (qLower) {
            const haystack =
                `${b.title} ${b.shortDescription ?? ""} ${b.description ?? ""}`.toLowerCase()
            if (!haystack.includes(qLower)) return false
        }
        return true
    })

    total = filtered.length
    blueprintsData = filtered.slice(
        (Number(page) - 1) * Number(size),
        Number(page) * Number(size),
    )

    if (groupedByCategory) {
        toolGroups = categoryTags
            .map((ct) => {
                const meta = categoryTileMetaFor(ct.name)
                const inCategory = filtered.filter((b) =>
                    b.tags?.includes(ct.id ?? ""),
                )
                return {
                    name: ct.name,
                    slug: meta?.slug,
                    icon: meta?.icon ?? "mdi:tag-outline",
                    total: inCategory.length,
                    blueprints: inCategory.slice(0, 6),
                }
            })
            .filter((g) => g.total > 0)
    }
} else if (hasActiveFilters) {
    const data = (await $fetchApiCached<{
        results: Blueprint[]
        total: number
    }>(
        `/blueprints/versions/latest?size=${size}&page=${page}` +
            (tagIdsForFilter.length ? `&tags=${tagIdsForFilter[0]}` : "") +
            (q ? `&q=${encodeURIComponent(q)}` : ""),
    )) ?? { results: [], total: 0 }
    blueprintsData = data.results ?? []
    total = data.total ?? 0
}

const blueprints = blueprintsData.sort((a, b) => {
    if (sort === "A-Z") {
        return a.title.localeCompare(b.title)
    } else if (sort === "Z-A") {
        return b.title.localeCompare(a.title)
    }
    return 0
})

const categoryNames = categoryTags.map((t) => t.name).sort()
const categoryList =
    categoryNames.length > 1
        ? `${categoryNames.slice(0, -1).join(", ")}, and ${categoryNames[categoryNames.length - 1]}`
        : (categoryNames[0] ?? "")

const ITEMS = blueprintFaqItems(categoryList)

const title = "Blueprints"
const description = "Get started with our library of workflows ready to use"
---

<Layout {title} {description}>
    <section class="bp-hero">
        <div class="container-xxl">
            <div class="hero-card">
                <h1>{headlineCount}+ Blueprints, ready to build.</h1>
                <p>
                    The first step is always the hardest. Search or browse to
                    kick-start your next flow.
                </p>
                <div class="bp-hero-search">
                    <TokenSearch
                        {q}
                        {tagsSelected}
                        tools={toolsSelected}
                        {toolIndex}
                        {coreToolIndex}
                        client:idle
                    />
                    <div class="quick-filters">
                        {
                            categoryTags.map((tag) => {
                                const meta = categoryTileMetaFor(tag.name)
                                return (
                                    <a
                                        href={`/blueprints/${meta?.slug}`}
                                        class="quick-filter"
                                    >
                                        <Icon
                                            name={
                                                meta?.icon ?? "mdi:tag-outline"
                                            }
                                            class="quick-filter-icon"
                                        />
                                        {tag.name}
                                    </a>
                                )
                            })
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    {
        !hasActiveFilters && gettingStartedBlueprints.length > 0 && (
            <section class="bp-row">
                <div class="container-xxl">
                    <h2>Getting Started</h2>
                    <p>New to Kestra? Start with these six core patterns.</p>
                    <div class="row g-3">
                        {gettingStartedBlueprints
                            .slice(0, 6)
                            .map((blueprint) => (
                                <div class="col-md-6 col-xl-4">
                                    <BlueprintCard
                                        {blueprint}
                                        {tags}
                                        href={`/blueprints/${blueprint.id}`}
                                    />
                                </div>
                            ))}
                    </div>
                </div>
            </section>
        )
    }

    {
        !hasActiveFilters && popularBlueprints.length > 0 && (
            <section class="bp-row">
                <div class="container-xxl">
                    <h2>Popular</h2>
                    <p>
                        Community favorites: AI agents, Kubernetes, Terraform,
                        Kafka, dbt, and Snowflake at work.
                    </p>
                    <div class="row g-3">
                        {popularBlueprints.slice(0, 6).map((blueprint) => (
                            <div class="col-md-6 col-xl-4">
                                <BlueprintCard
                                    {blueprint}
                                    {tags}
                                    href={`/blueprints/${blueprint.id}`}
                                />
                            </div>
                        ))}
                    </div>
                </div>
            </section>
        )
    }

    {
        !hasActiveFilters && featuredBlueprints.length > 0 && (
            <section class="bp-row">
                <div class="container-xxl">
                    <h2>Featured</h2>
                    <p>Hand-picked blueprints worth a closer look.</p>
                    <div class="row g-3">
                        {featuredBlueprints.slice(0, 6).map((blueprint) => (
                            <div class="col-md-6 col-xl-4">
                                <BlueprintCard
                                    {blueprint}
                                    {tags}
                                    href={`/blueprints/${blueprint.id}`}
                                />
                            </div>
                        ))}
                    </div>
                </div>
            </section>
        )
    }

    {
        !hasActiveFilters && recentlyAddedBlueprints.length > 0 && (
            <section class="bp-row">
                <div class="container-xxl">
                    <h2>Recently Added</h2>
                    <p>The newest blueprints in the catalog.</p>
                    <div class="row g-3">
                        {recentlyAddedBlueprints
                            .slice(0, 6)
                            .map((blueprint) => (
                                <div class="col-md-6 col-xl-4">
                                    <BlueprintCard
                                        {blueprint}
                                        {tags}
                                        href={`/blueprints/${blueprint.id}`}
                                    />
                                </div>
                            ))}
                    </div>
                </div>
            </section>
        )
    }

    {
        !hasActiveFilters && (
            <section class="bp-row bp-categories">
                <div class="container-xxl">
                    <h2>Browse by category</h2>
                    <p>
                        Find blueprints by domain: what part of your stack they
                        touch.
                    </p>
                    <div class="category-tiles">
                        {categoryTags.map((tag, i) => {
                            const meta = categoryTileMetaFor(tag.name)
                            return (
                                <a
                                    href={`/blueprints/${meta?.slug}`}
                                    class="category-tile"
                                >
                                    <Icon
                                        name={meta?.icon ?? "mdi:tag-outline"}
                                        class="tile-icon"
                                    />
                                    <span class="tile-name">{tag.name}</span>
                                    {meta && (
                                        <p class="tile-blurb">{meta.blurb}</p>
                                    )}
                                    <span class="tile-count">
                                        {categoryCounts[i]}+ blueprints
                                    </span>
                                </a>
                            )
                        })}
                    </div>
                </div>
            </section>
        )
    }

    {
        !hasActiveFilters && patternTags.length > 0 && (
            <section class="bp-row bp-categories bp-patterns">
                <div class="container-xxl">
                    <h2>Browse by pattern</h2>
                    <p>
                        Find blueprints by what they do, across every category.
                    </p>
                    <div class="category-tiles">
                        {patternTags.map((tag, i) => {
                            const pattern = PATTERN_TAGS.find(
                                (p) => p.name === tag.name,
                            )
                            return (
                                pattern && (
                                    <a
                                        href={`/blueprints/patterns/${pattern.slug}`}
                                        class="category-tile"
                                    >
                                        <Icon
                                            name={pattern.icon}
                                            class="tile-icon"
                                        />
                                        <span class="tile-name">
                                            {tag.name}
                                        </span>
                                        <p class="tile-blurb">
                                            {pattern.description}
                                        </p>
                                        <span class="tile-count">
                                            {patternCounts[i]}+ blueprints
                                        </span>
                                    </a>
                                )
                            )
                        })}
                    </div>
                </div>
            </section>
        )
    }

    {
        groupedByCategory && (
            <section class="bp-row tool-results">
                <div class="container-xxl">
                    <p class="fw-bold results-count">
                        {total} blueprints using {toolNames.join(" + ")}
                    </p>
                    {toolGroups.length > 0 ? (
                        toolGroups.map((group) => (
                            <div class="tool-group">
                                <div class="tool-group-head">
                                    <h2>
                                        <Icon
                                            name={group.icon}
                                            class="group-icon"
                                        />
                                        {group.name}
                                    </h2>
                                    {group.total > group.blueprints.length && (
                                        <a
                                            href={`/blueprints?tools=${encodeURIComponent(toolNames.join(","))}&tags=${encodeURIComponent(group.name)}`}
                                            class="see-more"
                                        >
                                            See all {group.total} in{" "}
                                            {group.name}
                                            <Icon
                                                name="mdi:chevron-right"
                                                class="see-more-icon"
                                            />
                                        </a>
                                    )}
                                </div>
                                <div class="row g-3">
                                    {group.blueprints.map((blueprint) => (
                                        <div class="col-md-6 col-xl-4">
                                            <BlueprintCard
                                                {blueprint}
                                                {tags}
                                                href={`/blueprints/${blueprint.id}`}
                                            />
                                        </div>
                                    ))}
                                </div>
                            </div>
                        ))
                    ) : (
                        <div class="col-12 text-center py-5">
                            <h4>No blueprints found for this search.</h4>
                            <p>
                                Try a different term, or remove a filter chip
                                from the search bar.
                            </p>
                            <a href="/blueprints" class="btn btn-primary">
                                Clear all filters
                            </a>
                        </div>
                    )}
                </div>
            </section>
        )
    }

    {
        hasActiveFilters && !groupedByCategory && (
            <BlueprintLists
                {q}
                {tags}
                {total}
                {blueprints}
                sortBy={sort}
                currentPage={Number(page)}
                itemsPerPage={Number(size)}
                currentUrl={Astro.request.url}
                {tagsSelected}
                client:idle
            >
                <div class="row g-3">
                    {blueprints.length > 0 ? (
                        blueprints.map((blueprint) => (
                            <div class="col-md-6 col-xl-4">
                                <BlueprintCard
                                    {blueprint}
                                    {tags}
                                    href={`/blueprints/${blueprint.id}`}
                                />
                            </div>
                        ))
                    ) : (
                        <div class="col-12 text-center py-5">
                            <h4>No blueprints found for this search.</h4>
                            <p>
                                Try a different term, or remove a filter chip
                                from the search bar.
                            </p>
                            <a href="/blueprints" class="btn btn-primary">
                                Clear all filters
                            </a>
                        </div>
                    )}
                </div>
            </BlueprintLists>
        )
    }
    {
        !hasActiveFilters && (
            <SeeHow
                cta={{
                    text: "Get Started",
                    href: "/get-started",
                }}
            >
                <Fragment slot="title">
                    Ready to orchestrate your stack?
                </Fragment>
                Copy a blueprint, adapt it to your stack, and ship your first
                flow in minutes.
            </SeeHow>
        )
    }
    {!hasActiveFilters && <Faq items={ITEMS} client:visible />}
</Layout>

<style lang="scss">
    :global(section.faq) {
        background: var(--ks-background-secondary);
    }

    .text-center {
        p {
            color: var(--ks-content-tertiary);
        }
    }

    .tool-results {
        .results-count {
            color: var(--ks-content-primary);
            margin-bottom: 1.5rem;
        }

        .tool-group {
            margin-bottom: 2.5rem;

            &:last-child {
                margin-bottom: 0;
            }
        }

        .tool-group-head {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1rem;

            h2 {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                margin: 0;
                font-size: $font-size-xl;
                color: var(--ks-content-primary);

                .group-icon {
                    width: 1.375rem;
                    height: 1.375rem;
                    color: var(--ks-content-link);
                }
            }
        }

        .see-more {
            display: inline-flex;
            align-items: center;
            gap: 0.125rem;
            flex-shrink: 0;
            font-size: $font-size-sm;
            font-weight: 600;
            color: var(--ks-content-link);
            text-decoration: none;
            white-space: nowrap;

            .see-more-icon {
                width: 1.125rem;
                height: 1.125rem;
            }

            &:hover {
                text-decoration: underline;
                text-underline-offset: 3px;
            }
        }
    }

    .bp-hero {
        padding: $rem-2 $rem-1 $rem-1;

        .hero-card {
            padding: 4rem 2.625rem;
            background: url("~/components/blueprints/assets/bar-bg.png")
                center / cover no-repeat;
            border-radius: $border-radius-lg;
            color: $white;

            @include media-breakpoint-down(lg) {
                padding: 2rem 1.5rem;
            }
        }

        h1 {
            margin-bottom: 0.5rem;
            color: $white;
        }

        p {
            color: var(--ks-content-tertiary);
            font-size: $font-size-lg;
            margin-bottom: 0;
        }

        .bp-hero-search {
            margin-top: 1.5rem;
            max-width: 640px;

            .quick-filters {
                display: flex;
                flex-wrap: nowrap;
                gap: 0.5rem;
                margin-top: 1rem;
                overflow-x: auto;
                scrollbar-width: none;

                &::-webkit-scrollbar {
                    display: none;
                }
            }

            .quick-filter {
                display: inline-flex;
                align-items: center;
                gap: 0.375rem;
                padding: 0.375rem 1rem;
                border-radius: 2rem;
                border: 1px solid rgba(255, 255, 255, 0.25);
                color: rgba(255, 255, 255, 0.85);
                font-size: $font-size-sm;
                font-weight: 600;
                white-space: nowrap;
                flex-shrink: 0;
                text-decoration: none;
                transition: all 0.2s ease;

                .quick-filter-icon {
                    font-size: 1rem;
                    width: 1rem;
                    height: 1rem;
                }

                &:hover {
                    border-color: rgba(255, 255, 255, 0.6);
                    color: $white;
                }
            }
        }
    }

    .bp-row {
        padding: $rem-1 0 $rem-2;

        .container-xxl {
            padding-inline: $rem-1;
        }

        h2 {
            margin-bottom: 0.25rem;
            color: var(--ks-content-primary);
        }

        p {
            color: var(--ks-content-secondary);
            margin-bottom: 1rem;
        }
    }

    .bp-categories {
        .category-tiles {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 1rem;
        }

        .category-tile {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
            padding: 1.5rem;
            border-radius: $border-radius-lg;
            border: 1px solid var(--ks-border-secondary);
            background: var(--ks-background-primary);
            box-shadow: 2px 3px 16px 0 var(--ks-shadows-light);
            text-decoration: none;
            transition: all 0.2s ease;

            .tile-icon {
                font-size: 1.75rem;
                width: 1.75rem;
                height: 1.75rem;
                color: var(--ks-content-link);
            }

            .tile-name {
                font-weight: 700;
                font-size: $font-size-md;
                color: var(--ks-content-primary);
            }

            .tile-blurb {
                margin: 0;
                font-size: $font-size-sm;
                line-height: 1.4;
                color: var(--ks-content-secondary);
            }

            .tile-count {
                margin-top: auto;
                padding-top: 0.5rem;
                font-size: $font-size-xs;
                font-weight: 600;
                color: var(--ks-content-tertiary);
            }

            &:hover {
                border-color: var(--ks-border-active);
                box-shadow: 2px 6px 20px 0 var(--ks-shadows-light);
                transform: translateY(-2px);
            }
        }
    }
</style>
