---
export const prerender = false
import { $fetchApi } from "~/utils/fetch"
import Layout from "~/components/layout.astro"
import Header from "~/components/blueprints/Header.astro"
import Detail from "~/components/blueprints/Detail.vue"
import Related from "~/components/blueprints/Related.astro"
import SeeHow from "~/components/common/SeeHow.astro"

const { id } = Astro.params

let pageData: Blueprint

try {
    pageData = await $fetchApi<Blueprint>(`/blueprints/${id}/versions/latest`)
} catch (e) {
    return Astro.redirect("/404")
}

const graph = await $fetchApi(`/blueprints/${id}/versions/latest/graph`)
const tags = await $fetchApi<BlueprintTag[]>(`/blueprints/versions/latest/tags`)

let relatedRows: { id: string; title: string; blueprints: Blueprint[] }[] = []

if (pageData.tags && pageData.tags.length > 0) {
    const selectedTagIds = pageData.tags.slice(0, 2)

    for (const tagId of selectedTagIds) {
        const tag = tags.find((t) => t.id === tagId)
        if (!tag) continue

        const data = await $fetchApi<{ results: Blueprint[] }>(
            `/blueprints/versions/latest?tags=${tagId}&size=10`,
        )

        if (data && data.results.length > 0) {
            const rowBlueprints = data.results
                .filter((b) => b.id !== pageData.id)
                .sort(() => Math.random() - 0.5)
                .slice(0, 6)

            if (rowBlueprints.length > 0) {
                relatedRows.push({
                    id: tagId,
                    title: `More <span class="highlight">${tag.name}</span> Blueprints`,
                    blueprints: rowBlueprints,
                })
            }
        }
    }
}

const title = pageData.title
const description = pageData.metaDescription
---

<Layout title={title} description={description}>
    <Header page={pageData} slug={id} tags={tags} />
    <Detail
        client:only
        page={pageData}
        description={pageData.description}
        flow={pageData.flow}
        graph={graph}
    />
    {
        relatedRows.map((row) => (
            <Related
                id={row.id}
                title={row.title}
                relatedBlueprints={row.blueprints}
                tags={tags}
            />
        ))
    }
    <SeeHow
        cta={{
            text: "Get started",
            href: "/docs/quickstart#start-kestra",
        }}
    >
        <Fragment slot="title">New to Kestra?</Fragment>
        Use blueprints to kickstart your first workflows.
    </SeeHow>
</Layout>

<style lang="scss">
    :global(.content p) {
        white-space: nowrap;
        margin-bottom: 2rem;
    }
</style>
