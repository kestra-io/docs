---
import Layout from "~/components/layout.astro"
import Faq from "~/components/common/Faq.vue"
import SeeHow from "~/components/common/SeeHow.astro"
import CardGrid from "~/components/card/CardGrid.astro"

import Intro from "~/components/write-for-us/Intro.astro"
import WriteSection from "~/components/write-for-us/Write.astro"
import Process from "~/components/write-for-us/Process.astro"

import seeHowImg from "~/components/write-for-us/assets/img-bottom-CTA.webp"
import Send from "vue-material-design-icons/Send.vue"

const title = "Write for the Kestra Community"
const description =
"If you are a software engineer, or tech enthusiast passionate about orchestration, scheduling, and workflow automation, we at Kestra are inviting you to share your knowledge and insights by writing for us."

const FORM_URL = "https://share-eu1.hsforms.com/1HWgyBQh8RP6pEZVFW51rOAg7f8j"

const DRAFTS = [
    {
        icon: "mdi:head-dots-horizontal-outline",
        title: "Showcase your expertise",
        description:
            "Writing sharpens your ability to convey complex technical ideas clearly and effectively. If " +
            "your draft shows potential, our team will assist you to refine it, making your message more impactful.",
    },
    {
        icon: "mdi:face-recognition",
        title: "Gain Recognition",
        description:
            "We value our contributors and promote their articles across our social media channels and " +
            "newsletter, offering you a platform to reach a broad audience in the tech community.",
    },
    {
        icon: "mdi:currency-usd",
        title: "Get Compensated",
        description:
            "Your expertise is precious, and we believe in rewarding our contributors. We offer competitive " +
            "compensation for original articles, videos and tutorials.",
    },
]

const FAQS = [
    {
        question: "Compensation",
        answer:
            "Original articles are compensated at a competitive rate (exact amount to be specified), " +
            "payable upon publication.",
    },
    {
        question: "Cross-Posting",
        answer:
            "You can cross-post your article on other platforms, provided a canonical link to the " +
            "Kestra site is included.",
    },
]
---

<Layout {title} {description} headerTheme="lightText">
    <div class="write-for-us">
        <Intro />
        <CardGrid
            title="Why Submit a <span class='highlight'>Draft</span> ?"
            items={DRAFTS}
            align="left"
        />
        <WriteSection />
        <Process />
        <Faq items={FAQS} client:visible />
        <SeeHow imgSrc={seeHowImg}>
            <Fragment slot="title">Start Writing For Kestra</Fragment>
            Ready to share your technical knowledge? Join our community of writers
            and get rewarded for your contributions.
            <Fragment slot="footer">
                <a
                    href={FORM_URL}
                    class="btn btn-primary"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Submit a Draft
                    <Send class="ms-1" />
                </a>
                <a
                    href="/slack"
                    class="btn btn-secondary"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Join us on Slack
                </a>
            </Fragment>
        </SeeHow>
    </div>
</Layout>

<style lang="scss">
    .write-for-us {
        :global(.card-grid-section) {
            background: var(--ks-background-secondary);
        }
    }
</style>
