const BUILD_TABS = [
    {
        name: "Per-tenant customer onboarding",
        title: "Onboard a customer end to end. One flow, every client, every plan.",
        description:
            "Stand up a new tenant in one execution: provision infrastructure with Terraform, deploy default flows for the customer's namespace, seed baseline data, and notify Customer Success. Same flow shape runs for tenant one and tenant five hundred. Replayable, observable, audit-ready.",
        code: `id: onboard-tenant
namespace: company.delivery.tenants

inputs:
  - id: tenant_id
    type: STRING
    displayName: Tenant identifier
  - id: plan
    type: SELECT
    values: [starter, growth, enterprise]
  - id: region
    type: STRING
    defaults: eu-west-1

tasks:
  - id: provision_infra
    type: io.kestra.plugin.terraform.cli.TerraformCLI
    inputFiles:
      main.tf: "{{ read('infra/tenant.tf') }}"
    commands:
      - terraform init
      - terraform apply -auto-approve -var tenant_id={{ inputs.tenant_id }} -var plan={{ inputs.plan }} -var region={{ inputs.region }}

  - id: deploy_default_flows
    type: io.kestra.plugin.core.flow.Subflow
    namespace: company.delivery.flows
    flowId: deploy-tenant-flows
    inputs:
      tenant_id: "{{ inputs.tenant_id }}"
      plan: "{{ inputs.plan }}"

  - id: seed_baseline_data
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://tenant-{{ inputs.tenant_id }}.internal:5432/app"
    username: "{{ secret('TENANT_PG_USER') }}"
    password: "{{ secret('TENANT_PG_PASSWORD') }}"
    sql: |
      INSERT INTO settings (tenant_id, plan, region, onboarded_at)
      VALUES ('{{ inputs.tenant_id }}', '{{ inputs.plan }}', '{{ inputs.region }}', NOW());

  - id: notify_cs
    type: io.kestra.plugin.notifications.slack.SlackIncomingWebhook
    url: "{{ secret('CS_SLACK_WEBHOOK') }}"
    messageText: |
      Tenant {{ inputs.tenant_id }} onboarded on the {{ inputs.plan }} plan in {{ inputs.region }}.
      Execution {{ execution.id }} ready in the audit log.`,
        plugins: [
            { cls: "io.kestra.plugin.terraform.cli.TerraformCLI" },
            { cls: "io.kestra.plugin.core.flow.Subflow" },
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.notifications.slack.SlackIncomingWebhook" },
        ],
        href: "/blueprints",
    },
    {
        name: "Environment-as-a-Service",
        title: "Provision, deploy, validate, hand off. Environments go from days to hours.",
        description:
            "Click a button, get a finished environment. Provision the VMs in parallel, install the application stack, run the regression suite, and only release when validation is green. The pattern platform teams at large software vendors use to make integration environments a self-service product instead of a multi-day ticket.",
        code: `id: provision-integration-environment
namespace: company.platform.environments

inputs:
  - id: environment_name
    type: STRING
  - id: vm_count
    type: INT
    defaults: 1
  - id: with_validation
    type: BOOLEAN
    defaults: true

tasks:
  - id: provision_vms
    type: io.kestra.plugin.core.flow.ForEach
    values: "{{ range(1, inputs.vm_count + 1) }}"
    tasks:
      - id: provision_vm
        type: io.kestra.plugin.scripts.shell.Commands
        commands:
          - /opt/scripts/provision-vm.sh --env {{ inputs.environment_name }} --idx {{ taskrun.value }}

  - id: install_app_stack
    type: io.kestra.plugin.core.flow.Subflow
    namespace: company.platform.deploy
    flowId: install-application-stack
    inputs:
      environment: "{{ inputs.environment_name }}"

  - id: validate
    type: io.kestra.plugin.core.flow.If
    condition: "{{ inputs.with_validation }}"
    then:
      - id: run_regression
        type: io.kestra.plugin.core.flow.Parallel
        tasks:
          - id: smoke_tests
            type: io.kestra.plugin.scripts.shell.Commands
            commands:
              - pytest tests/smoke --env {{ inputs.environment_name }}
          - id: integration_tests
            type: io.kestra.plugin.scripts.shell.Commands
            commands:
              - pytest tests/integration --env {{ inputs.environment_name }}

  - id: handover_to_user
    type: io.kestra.plugin.core.http.Request
    uri: "https://portal.internal/environments/{{ inputs.environment_name }}/ready"
    method: POST`,
        plugins: [
            { cls: "io.kestra.plugin.core.flow.ForEach" },
            { cls: "io.kestra.plugin.scripts.shell.Commands" },
            { cls: "io.kestra.plugin.core.flow.Subflow" },
            { cls: "io.kestra.plugin.core.flow.Parallel" },
        ],
        href: "/blueprints",
    },
    {
        name: "AI-assisted client deliverable",
        title: "AI extraction with a human in the loop. Inside your product, on your audit trail.",
        description:
            "Receive a client request, extract context with Python and an LLM, query the engagement history, generate a draft, pause for reviewer approval, then deliver. Models, prompts, and customer data stay inside your environment. Every model output and human decision captured in the immutable audit log.",
        code: `id: ai-assisted-deliverable
namespace: company.delivery.ai

triggers:
  - id: client_request
    type: io.kestra.plugin.core.trigger.Webhook
    key: "client-request"

inputs:
  - id: client_id
    type: STRING
  - id: source_doc
    type: FILE

tasks:
  - id: extract_context
    type: io.kestra.plugin.scripts.python.Commands
    inputFiles:
      doc: "{{ inputs.source_doc }}"
    commands:
      - python extract.py --doc doc --client {{ inputs.client_id }}

  - id: query_history
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://history-db:5432/engagements"
    username: "{{ secret('HISTORY_DB_USER') }}"
    password: "{{ secret('HISTORY_DB_PASSWORD') }}"
    fetchType: STORE
    sql: "SELECT context, decisions FROM engagement WHERE client = '{{ inputs.client_id }}' ORDER BY ts DESC LIMIT 50"

  - id: generate_draft
    type: io.kestra.plugin.core.http.Request
    uri: "https://llm.internal/v1/generate"
    method: POST
    contentType: application/json
    headers:
      Authorization: "Bearer {{ secret('LLM_API_TOKEN') }}"
    body: |
      {
        "client": "{{ inputs.client_id }}",
        "context": {{ outputs.extract_context.vars.summary | toJson }}
      }

  - id: human_review
    type: io.kestra.plugin.core.flow.Pause
    description: |
      Reviewer must approve the AI draft for client {{ inputs.client_id }} before delivery.

  - id: deliver
    type: io.kestra.plugin.core.http.Request
    uri: "https://portal.internal/clients/{{ inputs.client_id }}/deliveries"
    method: POST`,
        plugins: [
            { cls: "io.kestra.plugin.core.trigger.Webhook" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.core.http.Request" },
        ],
        href: "/blueprints",
    },
    {
        name: "Multi-tenant data pipeline",
        title: "Per-tenant data pipeline with namespace isolation and zero blast radius.",
        description:
            "Each customer owns its namespace, secrets, and runtime. The same flow shape runs per tenant: extract from the tenant database, transform with dbt, aggregate on Databricks, publish to the tenant bucket. Zero blast radius across customers, full audit per execution. The pattern modern SaaS teams use to scale from 5 to 500 customers without scaling the platform team.",
        code: `id: tenant-data-pipeline
namespace: company.data.tenants.acme

triggers:
  - id: hourly
    type: io.kestra.plugin.core.trigger.Schedule
    cron: "0 * * * *"

tasks:
  - id: extract_source
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://source-acme.internal:5432/data"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    fetchType: STORE
    sql: "SELECT * FROM events WHERE updated_at > NOW() - INTERVAL '1 hour'"

  - id: transform_with_dbt
    type: io.kestra.plugin.dbt.cli.Build
    projectDir: "./dbt"
    commands:
      - dbt build --target acme

  - id: aggregate_on_databricks
    type: io.kestra.plugin.databricks.job.CreateJob
    host: "{{ secret('DATABRICKS_HOST') }}"
    authentication:
      token: "{{ secret('DATABRICKS_TOKEN') }}"
    jobTasks:
      - taskKey: aggregate
        notebookTask:
          notebookPath: "/tenants/acme/aggregate"
        existingClusterId: "{{ secret('DATABRICKS_CLUSTER_ID') }}"

  - id: publish_to_tenant_bucket
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "tenant-acme-out"
    key: "{{ execution.startDate | date('yyyy/MM/dd/HH') }}/output.parquet"
    from: "{{ outputs.transform_with_dbt.outputFiles.results }}"`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.dbt.cli.Build" },
            { cls: "io.kestra.plugin.databricks.job.CreateJob" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
]

