---
import { $fetchApiCached } from "~/utils/fetch"

import Layout from "~/components/layout.astro"
import SeeHow from "~/components/common/SeeHow.astro"
import CardGrid from "~/components/card/CardGrid.astro"
import TopHero from "~/components/layout/TopHero.astro"
import BlueprintsGrid from "~/components/common/BlueprintsGrid.astro"
import Capabilities from "~/components/use-cases/Capabilities.astro"

import heroFront from "~/assets/use-cases/platform/hero-front.svg"
import continuousIntegration from "~/assets/use-cases/capabilities/continuous-integration.svg"
import provisioningDeployment from "~/assets/use-cases/capabilities/provisioning-deployment.svg"
import disasterRecovery from "~/assets/use-cases/capabilities/disaster-recovery.svg"
import infrastructureMonitoring from "~/assets/use-cases/capabilities/infrastructure-monitoring.svg"

const title = "Orchestrate your Infrastructure with Kestra"
const description =
    "Automate, Scale, Provision and Optimize Your Infrastructure with Kestra"

const response = await $fetchApiCached<{ results: Blueprint[] }>(
    "/blueprints/versions/latest?tags=infrastructure&page=1&size=20",
)
const blueprints = response.results

const CAPABILITIES = [
    {
        title: "Continuous Integration/Continuous Deployment (CI/CD)",
        description:
            "Streamline your CI/CD pipelines by integrating with tools like GitHub Actions and Jenkins.",
        image: continuousIntegration,
        pageHref: "/use-cases/ci-cd",
    },
    {
        title: "Provisioning and Deployment",
        description:
            "Automate the setup and deployment of infrastructure components, reducing manual effort and errors.",
        image: provisioningDeployment,
        pageHref: "/use-cases/provisioning-and-deployment",
    },
    {
        title: "Disaster Recovery",
        description:
            "Automate backup and recovery processes to ensure your infrastructure can quickly recover from failures.",
        image: disasterRecovery,
        pageHref: "/use-cases/disaster-recovery",
    },
    {
        title: "Infrastructure Monitoring",
        description:
            "Automate monitoring and alerting processes, ensuring your infrastructure is always performing optimally.",
        image: infrastructureMonitoring,
        pageHref: "/use-cases/monitoring",
    },
]

const ITEMS = [
    {
        number: "01",
        title: "Comprehensive Integration",
        description:
            "Your Unified Infrastructure Control Plane. From Terraform to Python, manage every tool and script in a single, governed environment.",
    },
    {
        number: "02",
        title: "Scalability",
        description:
            "Run tasks safely inside air-gapped networks, VPCs, and private data centers, or in the cloud of your choice.",
    },
    {
        number: "03",
        title: "Automate Infrastructure Tasks",
        description:
            "Automatically capture full run history, task logs, approvals, and evidence bundles for instant compliance.",
    },
    {
        number: "04",
        title: "Manage Docker and Kubernetes",
        description:
            "Manage infrastructure directly from a self service catalog. Kestra provisions the server, syncs the records, and resolves the ticket request automatically.",
    },
    {
        number: "05",
        title: "Infrastructure as Code (IaC) with Ansible and Terraform",
        description:
            "Reuse your existing scripts, Terraform modules, Ansible roles, alongside VMware, NetApp or any other tool your already use.",
    },
    {
        number: "06",
        title: "Scalable Workload Management",
        description:
            "Keep your scripts lightweight. Offload inputs, secrets, retries, and backoff logic to Kestra, so your code focuses purely on the business logic.",
    },
    {
        number: "07",
        title: "Event-Driven Workflows",
        description:
            "Manage cloud, IT, and OT automation from one platform. Execute tasks securely inside your VPCs or private networks securely on the edge.",
    },
    {
        number: "08",
        title: "Enhanced Security and Compliance",
        description:
            "Workflows live in your codebase, move through CI/CD pipelines, and can be instantly rolled back if a deployment fails.",
    },
]
---

<Layout {title} {description} headerTheme="lightText">
    <TopHero
        title="Kestra for <br /> Platform Engineers"
        {description}
        image={heroFront}
    />
    <CardGrid
        title="Built for the Way Infrastructure Teams Work"
        subtitle="Kestra tackles the challenges platform engineers face by automating infrastructure orchestration, enhancing scalability, and ensuring seamless integrations."
        items={ITEMS}
    />

    <BlueprintsGrid
        title='Explore <span class="highlight">Infrastructure</span> blueprints'
        {blueprints}
        link={{
            href: "/blueprints?tags=infrastructure",
            text: "View more Infrastructure Blueprints",
        }}
    />

    <Capabilities
        title="for Platform Orchestration"
        capabilities={CAPABILITIES}
    />

    <SeeHow>
        <Fragment slot="title"> Scale With Kestra Enterprise Edition </Fragment>
        Built for Enterprises and SMBs, with strong governance, enterprise-grade security,
        seamless scalability, and dedicated enterprise support backed by SLAs.
    </SeeHow>
</Layout>
