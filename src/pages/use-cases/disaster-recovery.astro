---
import Layout from "~/components/layout.astro"
import DetailsHero from "~/components/use-cases/DetailsHero.vue"
import Alternation from "~/components/features/shared/Alternation.astro"
import Section from "~/components/layout/Section.vue"
import Enterprise from "~/components/use-cases/Enterprise.vue"
import Cards from "~/components/use-cases/Cards.astro"
import Capabilities from "~/components/use-cases/Capabilities.astro"
import FooterContact from "~/components/layout/FooterContact.astro"
import AlertCircle from "vue-material-design-icons/AlertCircle.vue"
import ChartAreaspline from "vue-material-design-icons/ChartAreaspline.vue"
import CloudRefreshVariant from "vue-material-design-icons/CloudRefreshVariant.vue"
import Cogs from "vue-material-design-icons/Cogs.vue"
import TimerCogOutline from "vue-material-design-icons/TimerCogOutline.vue"
import continuousIntegration from "~/assets/use-cases/capabilities/continuous-integration.svg"
import provisioningDeployment from "~/assets/use-cases/capabilities/provisioning-deployment.svg"
import infrastructureMonitoring from "~/assets/use-cases/capabilities/infrastructure-monitoring.svg"

const TITLE = "Disaster Recovery with Kestra"
const DESCRIPTION =
    "Automate disaster recovery processes, secure your data, and ensure business continuity with Kestra."

const MAIN_CONTENT = [
    {
        title: "Automated Backup",
        image: {
            src: "/landing/usecases/disaster-recovery/automated-backup.svg",
            width: 568,
            height: 420,
            alt: "Automated Backup",
        },
        description:
            "Kestra enables automated backup processes, ensuring that your data is regularly and securely backed up. This minimizes data loss and facilitates quick recovery in the event of a disaster.",
        content: `
                    <ul>
                        <li>
                            Scheduled Backups:
                            <span>Automate regular backups of critical data and infrastructure components, ensuring that you always have up-to-date copies available.</span>
                        </li>
                        <li>
                            Secure Storage:
                            <span>Store backups securely in the cloud or on-premises, ensuring data protection and compliance with regulatory requirements.</span>
                        </li>
                    </ul>
                  `,
    },
    {
        title: "Leverage API Integrations",
        image: {
            src: "/landing/usecases/disaster-recovery/leverage-integrations.svg",
            width: 568,
            height: 420,
            alt: "Leverage API Integrations",
        },
        description:
            "Kestra integrates with various APIs, enabling you to automate and manage disaster recovery processes efficiently. Utilize API capabilities to trigger backups, initiate failover procedures, and streamline recovery workflows.",
        content: `
                    <ul>
                        <li>
                            API-Driven Automation:
                            <span>
                               Use APIs to automate disaster recovery tasks, from triggering backups to initiating failover and restoration processes.
                            </span>
                        </li>
                        <li>
                            Custom Recovery Workflows:
                            <span>
                                Build custom disaster recovery workflows using Kestra's API capabilities, ensuring they meet your specific needs and requirements.
                            </span>
                        </li>
                    </ul>
                `,
    },
    {
        title: "Automated Failover and Restoration",
        image: {
            src: "/landing/usecases/databases/quick-recovery.svg",
            width: 604,
            height: 477,
            alt: "Automated Failover and Restoration",
        },
        description:
            "Kestra's automation capabilities enable you to set up workflows that automatically trigger failover and restoration processes, reducing downtime and ensuring business continuity.",
        content: `
                    <ul>
                        <li>
                            Automated Failover:
                            <span>
                                Configure automated failover processes to switch to backup systems seamlessly, ensuring minimal disruption during a disaster.
                            </span>
                        </li>
                        <li>
                            Quick Restoration:
                            <span>
                                 Automate the restoration of data and services to ensure a swift recovery and return to normal operations.
                            </span>
                        </li>
                    </ul>
                `,
    },
]

const CAPABILITIES = [
    {
        title: "Continuous Integration/Continuous Deployment (CI/CD)",
        description:
            "Streamline your CI/CD pipelines by integrating with tools like GitHub Actions and Jenkins.",
        image: continuousIntegration,
        pageHref: "/use-cases/ci-cd",
    },
    {
        title: "Provisioning and Deployment",
        description:
            "Automate the setup and deployment of infrastructure components, reducing manual effort and errors.",
        image: provisioningDeployment,
        pageHref: "/use-cases/provisioning-and-deployment",
    },
    {
        title: "Infrastructure Monitoring",
        description:
            "Automate monitoring and alerting processes, ensuring your infrastructure is always performing optimally.",
        image: infrastructureMonitoring,
        pageHref: "/use-cases/monitoring",
    },
]

const CARDS_DATA = [
    {
        icon: Cogs,
        cardInfo: {
            title: "Minimize Data Loss",
            description:
                "Regular automated backups ensure that your data is always protected and recoverable.",
        },
    },
    {
        icon: AlertCircle,
        cardInfo: {
            title: "Reduce Downtime",
            description:
                "Automated failover and restoration processes minimize downtime and ensure business continuity.",
        },
    },
    {
        icon: TimerCogOutline,
        cardInfo: {
            title: "Data Security",
            description:
                "Secure backup storage and automated recovery processes",
        },
    },
    {
        icon: ChartAreaspline,
        cardInfo: {
            title: "Scalability",
            description:
                "Easily scale your infrastructure to meet growing demands without compromising performance or reliability.",
        },
    },
    {
        icon: CloudRefreshVariant,
        cardInfo: {
            title: "Increase Efficiency",
            description:
                "Automate disaster recovery workflows, reducing manual intervention.",
        },
    },
]
---

<Layout title={TITLE} description={DESCRIPTION}>
    <DetailsHero
        client:load
        title="Disaster <span>Recovery</span>"
        description="Automate disaster recovery processes, secure your data, and ensure business continuity."
        image={{
            src: "/landing/usecases/disaster-recovery/header-hero.svg",
        }}
    />

    <Alternation items={MAIN_CONTENT}>
        <Section
            subtitle="Disaster Recovery"
            subtitleBefore="Automate"
            class={"p-0 bg-transparent"}
            baseline="Kestra empower platform engineers to maintain data integrity and ensure quick recovery from failures."
        />
    </Alternation>

    <Enterprise
        title="Orchestrate infrastructure components using Kestra"
        client:visible
    />

    <Cards
        title="<span class='highlight'>Key Benefits</span> of Using Kestra for<br/> Disaster Recovery"
        cards={CARDS_DATA}
    />

    <Capabilities
        title="for Platform Orchestration"
        capabilities={CAPABILITIES}
    />

    <FooterContact
        title="Ready to take your Infrastructure to the next level ?"
    />
</Layout>
