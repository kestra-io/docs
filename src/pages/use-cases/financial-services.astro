            .wrapper {
                border: 1px solid var(--ks-border-primary);
                box-shadow: 2px 3px 16px 0 var(--ks-shadows-light);
                border-radius: 13px;

                @include media-breakpoint-down(xl) { border-radius: 0; }

                .inner {
                    border-radius: $rem-1;
                    background: var(--ks-background-primary-inverse);
                    overflow: clip;

                    @include media-breakpoint-down(xxl) { border-radius: 0; }

                    .header {
                        border-bottom: 1px solid var(--ks-border-secondary-inverse);

                        & > div {
                            padding: 1.1875rem $rem-2;
                            font-size: $font-size-md;
                            color: var(--ks-content-secondary-inverse);
                            text-align: center;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            cursor: pointer;
                            transition: background-color 0.2s, color 0.2s, border-color 0.2s;

                            @include media-breakpoint-down(sm) { font-size: $font-size-sm; }

                            &.active {
                                background: var(--ks-background-secondary-inverse);
                                border-bottom: 2px solid $fs-teal;
                                color: var(--ks-content-primary-inverse);
                                font-weight: 600;
                            }
                        }

                        & .middle-part {
                            border-left: 1px solid var(--ks-border-primary-inverse);
                            border-right: 1px solid var(--ks-border-primary-inverse);
                        }
                    }

                    .content {
                        display: none;
                        flex-direction: row;
                        gap: $rem-2;
                        padding: $rem-2;
                        justify-content: center;

                        &.active { display: flex; }

                        @include media-breakpoint-down(xl) {
                            flex-direction: column;
                            align-items: center;
                        }

                        @include media-breakpoint-down(sm) { padding: $rem-2 $rem-1; }

                        .panel {
                            border-radius: 0.5rem;
                            flex-shrink: 0;

                            &.panel-1 {
                                width: 39.4375rem;

                                @include media-breakpoint-down(xl) { width: 100%; }

                                :global(.code-card) {
                                    border: 1px solid var(--ks-border-secondary-inverse);
                                    background: var(--ks-background-input);
                                    height: 100%;

                                    :global(.code-inner) { transition: max-height 0.3s ease; }
                                    :global(.mdc-renderer pre) { padding: 0 1rem 1rem 1rem; }

                                    &:global(:not(.is-expanded)) {
                                        :global(.code-inner) { max-height: 27.9375rem !important; }
                                    }
                                }
                            }

                            &.panel-2 {
                                position: relative;
                                padding-top: $rem-2;
                                color: var(--ks-content-primary-inverse);
                                width: 27.5625rem;

                                @include media-breakpoint-down(xl) {
                                    width: 100%;
                                    padding-top: 0;
                                }

                                p {
                                    font-size: $font-size-lg;
                                    margin-top: $rem-1;
                                    margin-bottom: $rem-2;
                                }

                                .plugins {
                                    display: flex;
                                    gap: 0.5rem;
                                    flex-wrap: wrap;

                                    .plugin-icon {
                                        width: 2.125rem;
                                        height: 2.125rem;
                                        padding: 0.375rem;
                                        background: $white;
                                        border: $block-border;
                                        border-radius: $border-radius;
                                    }
                                }

                                .goto {
                                    position: absolute;
                                    bottom: 0;
                                    right: 0;
                                    font-weight: 600;

                                    @include media-breakpoint-down(xl) {
                                        position: relative;
                                        margin-top: $rem-3;
                                        float: right;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        &__lead {
            text-align: center;
            color: var(--ks-content-secondary);
            font-size: 1.0625rem;
            margin: 0 auto $rem-2;
            max-width: 44rem;
            padding-inline: $rem-1;
        }
    }

    /* ── ENTERPRISE ── */
    .enterprise {
        padding: 140px 1rem 80px;
        gap: 40px;
        background: var(--ks-background-primary-inverse);
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        overflow: hidden;

        @include media-breakpoint-down(lg) { padding: 4rem 1rem 3rem; }

        &::after {
            content: "";
            position: absolute;
            width: 352.83px;
            height: 343.43px;
            border-radius: 50%;
            background: linear-gradient(179.01deg, $fs-teal 0.85%, $fs-teal-light 62.43%);
            opacity: 0.55;
            transform: rotate(45deg);
            filter: blur(36px);
            z-index: 1;
            top: -250px;
            left: -250px;
        }

        &::before {
            content: "";
            position: absolute;
            width: 120%;
            height: 314px;
            border-radius: 50%;
            background: linear-gradient(90deg, $fs-teal 0%, var(--ks-Color-gradient-1-inverse-2) 100%);
            filter: blur(36px);
            transform: rotate(-13.2074deg);
            z-index: 0;
            top: -210px;
            left: -65%;
            opacity: 0.45;
        }

        &__title {
            color: #fff;
            margin-bottom: 2.5rem;
            text-align: center;

            .highlight { color: $fs-teal-bright; }
        }

        :global(.features-grid) {
            box-shadow: 0 9px 36px 0 var(--ks-shadows-light-inverse);
        }

        // Force readable text + teal icons regardless of light/dark mode toggle
        :global(.feature-icon) {
            color: $fs-teal !important;
        }
        :global(.feature-title) {
            color: #fff !important;
        }
        :global(.feature-desc) {
            color: rgba(255, 255, 255, 0.72) !important;
        }

        .container-xxl { max-width: 1420px; }
    }

    /* Only the CTA slot card is centered — the feature cards keep NoGapGrid's
       default left-aligned layout so icons, titles, and descriptions line up. */
    .enterprise :global(.feature-card--cta) {
        width: 100%;
        padding: 2rem 4rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 1px 1px 0 0 var(--ks-border-secondary-inverse);

        @include media-breakpoint-down(lg) { padding: 2rem; }

        .btn { white-space: nowrap; }
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        for (const container of document.querySelectorAll(".build .inner")) {
            container.addEventListener("click", (e) => {
                const tab = (e.target as Element).closest(".header-tab") as HTMLElement
                const target = tab && (container as Element).querySelector(
                    `[data-tab-content="${tab.dataset.tabTarget}"]`
                )
                if (!target) return

                for (const el of container.querySelectorAll(".header-tab, .content")) {
                    el.classList.remove("active")
                }
                tab.classList.add("active")
                target.classList.add("active")
            })
        }
    })
</script>
