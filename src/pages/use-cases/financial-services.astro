    /* ── BANKING FLOW VISUALIZATION ── */
    $stages: (
        "trigger": ( "bg": #fff3d3, "border": #a87f4f, "label": #b87f00 ),
        "ingest":  ( "bg": #cbe2ff, "border": #6b62f2, "label": #0069c6 ),
        "process": ( "bg": #e3cffe, "border": #bb62f2, "label": #822bfd ),
        "act":     ( "bg": #d3ffe0, "border": #4fa876, "label": #007336 )
    );

    .flow {
        position: relative;
        background: var(--ks-background-secondary);
        padding: 5.5rem 1rem;
        overflow: hidden;

        // Teal radial glow backdrop — visible in light + dark mode
        &::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse 800px 420px at 50% 0%, rgba(20, 184, 166, 0.18) 0%, rgba(20, 184, 166, 0) 70%),
