                                                <TaskIcon cls={plugin.cls} />
                                            </div>
                                        ))}
                                    </div>
                                    <Link class="goto" href={tab.href} data-usal="fade-r">
                                        Explore Blueprints
                                    </Link>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <GoFurther />

        <PluginsBlock>
            <Fragment slot="title">
                Integrates with the <span class="highlight">systems regulated teams</span> already rely on.
            </Fragment>
            <Fragment slot="description">
                Connect core platforms, policy and claims systems, data stacks, messaging layers, case tools,
                and security controls through {totalPlugins}+ plugins. Or build the exact integration your environment requires.
            </Fragment>
        </PluginsBlock>

        <SeeHow cta={{ text: "Book a Demo", href: "/demo" }}>
            <Fragment slot="title">One platform for regulated workflows.</Fragment>
            Modernize legacy systems, connect the tools your teams already use, and add lineage, approvals,
            and auditability across claims, onboarding, payments, reconciliations, reporting, servicing, and risk.
        </SeeHow>

        <Faq items={FAQ} client:visible />
    </div>
</Layout>

<style lang="scss">
    $fs-yellow:        #EAB308;
