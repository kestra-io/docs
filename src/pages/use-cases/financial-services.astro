        label: "TRIGGER",
        items: [
            "API / webhook",
            "Schedule / cutoff / market close",
            "Document arrival / FNOL / intake",
            "File drop / partner feed",
            "Queue / stream event",
            "Core-system change event",
        ],
    },
    {
        id: "ingest",
        label: "INGEST",
        items: [
            "Oracle / DB2 / SQL Server / mainframe",
            "Guidewire / Duck Creek / claims",
            "Snowflake / BigQuery / lakehouse",
            "S3 / ADLS / GCS / SFTP / MQ",
            "CRM / case systems / partner APIs",
            "Payment, ledger & portfolio systems",
        ],
    },
    {
        id: "process",
        label: "PROCESS",
        items: [
            "Rules and validations",
            "dbt / SQL / Python / R / Spark",
