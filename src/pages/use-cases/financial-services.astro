            z-index: 0;
        }

        :global(html.dark) &::before {
            background:
                radial-gradient(ellipse 900px 460px at 50% 0%, rgba(20, 184, 166, 0.28) 0%, rgba(20, 184, 166, 0) 70%),
                radial-gradient(ellipse 900px 420px at 50% 100%, rgba(94, 234, 212, 0.32) 0%, rgba(94, 234, 212, 0) 70%);
        }

        .container-xxl {
            margin: 0 auto;
            position: relative;
            z-index: 1;
