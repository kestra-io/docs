                <p class="build__lead">Production workflows, from claims triage to regulatory reporting. Copy the YAML. Wire it to your stack. Ship it through your CI.</p>
                <div class="wrapper">
                    <div class="inner">
                        <div class="header row g-0">
                            {BUILD_TABS.map((tab, idx) => (
                                <div
                                    class:list={[
                                        "col-6 col-md-3 header-tab",
                                        { active: idx === 0, "middle-part": idx > 0 && idx < BUILD_TABS.length - 1 },
                                    ]}
                                    data-tab-target={idx}
                                >
                                    {tab.name}
                                </div>
                            ))}
                        </div>

                        {BUILD_TABS.map((tab, idx) => (
                            <div class:list={["content", { active: idx === 0 }]} data-tab-content={idx}>
                                <div class="panel panel-1">
                                    <Snippets client:idle code={tab.code} lang="yaml" />
                                </div>
                                <div class="panel panel-2">
                                    <h3 data-usal="fade-r">{tab.title}</h3>
                                    <p data-usal="fade-l">{tab.description}</p>
