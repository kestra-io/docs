            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            color: $fs-yellow-light;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .exec-footer__sep { color: rgba(255, 255, 255, 0.25); }
    }

    .exec-row {
        display: grid;
        grid-template-columns: 20px minmax(130px, 1fr) minmax(150px, 1fr) minmax(90px, auto);
        align-items: center;
        gap: 1rem;
        padding: 6px 8px;
        border-radius: 4px;
        font-family: $font-family-monospace;
        font-size: $font-size-xs;
        transition: background 0.2s;

        &:hover { background: rgba(234, 179, 8, 0.06); }

        @include media-breakpoint-down(sm) {
            grid-template-columns: 20px 1fr auto;
        }

        &__check {
            color: $fs-yellow-bright;
            font-weight: 700;
        }

        &__name {
            color: $white;
            font-weight: 500;
        }

        &__type {
            color: rgba(255, 255, 255, 0.45);

            @include media-breakpoint-down(sm) { display: none; }
        }

        &__result {
            color: $fs-yellow-light;
            text-align: right;
            white-space: nowrap;
        }
    }

    .hero-ctas {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;

        .btn {
            justify-content: center;

            @include media-breakpoint-down(md) {
                width: auto;
                min-width: 200px;
            }
        }
    }

    .hero-logos {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        align-items: center;
        justify-content: center;
        margin-top: 1rem;
        padding-top: 2rem;
        width: 100%;
        max-width: 52rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;

        &__label {
            font-size: $font-size-xs;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.55);
        }

        &__row {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            align-items: center;
            justify-items: center;
            column-gap: 0.5rem;
            row-gap: 1.25rem;
            width: 100%;
            max-width: 48rem;
            margin: 0 auto;

            @include media-breakpoint-down(md) {
                grid-template-columns: repeat(2, 1fr);
                column-gap: 1rem;
                row-gap: 1.25rem;
            }
        }

        &__item {
            width: auto;
            height: auto;
            display: block;
            filter: brightness(0) invert(1);
            opacity: 0.8;
            transition: opacity 0.2s;
            max-width: 100%;

            &:hover { opacity: 1; }

            // Row 1: 4 logos, each spans 3 of 12 cols
            &:nth-child(-n+4) { grid-column: span 3; }
            // Row 2: 3 logos, each spans 4 of 12 cols (3×4=12 centers naturally)
            &:nth-child(n+5)  { grid-column: span 4; }

            @include media-breakpoint-down(md) {
                &:nth-child(-n+4),
                &:nth-child(n+5) { grid-column: auto; }
            }

            // Unified optical sizing across all industry pages:
            // text wordmarks 36px, compact icon+text 42px, stacked
            // vertically icon+text 52–56px. Mobile bumps each by ~4px.
            &:nth-child(1) { max-height: 36px; max-width: 170px; }  // JPMorgan (text)
            &:nth-child(2) { max-height: 42px; max-width: 180px; }  // Crédit Agricole (icon + text)
            &:nth-child(3) { max-height: 36px; max-width: 200px; }  // Bloomberg (text wide)
            &:nth-child(4) { max-height: 56px; max-width: 200px; }  // TotalEnergies (icon + text stacked)
            &:nth-child(5) { max-height: 36px; max-width: 160px; }  // iCapital (text)
            &:nth-child(6) { max-height: 42px; max-width: 170px; }  // Matmut (icon + text)
            &:nth-child(7) { max-height: 36px; max-width: 140px; }  // Gate.io (text)
        }
    }

