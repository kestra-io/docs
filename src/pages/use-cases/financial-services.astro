        smallLogoSvg: optimizeSvgIcon(JPMorganLogo, "jpm-quote-logo"),
        kpis: [
            { value: "Billions", name: "of rows processed" },
            { value: "100+", name: "users empowered" },
            { value: "4,000+", name: "API pulls / week" },
        ],
        storyLink: "/use-cases/stories/orchestrating-cybersecurity-for-100-users-and-billions-of-rows",
    },
]

