        background: #06100f;
        border-radius: 9px;
        overflow: hidden;
        backdrop-filter: blur(12px);
        text-align: left;

        &__header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 12px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
