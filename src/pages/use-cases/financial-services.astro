        @include media-breakpoint-down(sm) {
            position: absolute;
            top: calc(100% + 4px);
            left: 50%;
            height: 58px;
            width: 1.5px;
            transform: translateX(-50%);

            .line { width: 1.5px; height: 100%; }
            .head {
                bottom: -6px;
                left: 50%;
                transform: translateX(-50%) rotate(90deg);
            }
        }
    }

    /* ── WORKLOADS (12 grouped) ── */
    .workloads {
        position: relative;
        padding: 5rem 1rem;
        background: var(--ks-background-body);
        overflow: hidden;

        // Top glow — mirrors the flow section's bottom glow so the two halves
        // combine into a full circle of blur at the section boundary.
        &::after {
            content: "";
            position: absolute;
            top: -420px;
            left: 50%;
            transform: translateX(-50%);
            width: 1800px;
            height: 840px;
            background: radial-gradient(ellipse at center, rgba(94, 234, 212, 0.22) 0%, rgba(94, 234, 212, 0) 70%);
            pointer-events: none;
            z-index: 0;
        }

        :global(html.dark) &::after {
            background: radial-gradient(ellipse at center, rgba(94, 234, 212, 0.32) 0%, rgba(94, 234, 212, 0) 70%);
        }

        // Reversed teal blur at the bottom (replaces the old separator line)
        &::before {
            content: "";
            position: absolute;
            bottom: -220px;
            left: 50%;
            transform: translateX(-50%);
            width: 1100px;
            height: 440px;
            background: radial-gradient(ellipse at center, rgba(20, 184, 166, 0.14) 0%, rgba(20, 184, 166, 0) 70%);
            pointer-events: none;
            z-index: 0;
        }

        :global(html.dark) &::before {
            background: radial-gradient(ellipse at center, rgba(20, 184, 166, 0.22) 0%, rgba(20, 184, 166, 0) 70%);
        }

        > .container {
            position: relative;
            z-index: 1;
        }

        &__head {
            text-align: center;
            max-width: 46rem;
            margin: 0 auto 3rem;

