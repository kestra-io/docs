            font-family: $font-family-monospace;
            font-size: $font-size-xs;
        }

        &__dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: $fs-yellow-bright;
            box-shadow: 0 0 8px $fs-yellow-bright;
            flex-shrink: 0;
        }

        &__title {
            color: $white;
            font-weight: 600;
        }

        &__meta {
            color: rgba(255, 255, 255, 0.45);
