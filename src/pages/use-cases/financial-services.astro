        }

        &__footer {
            margin-top: 2rem;
            color: var(--ks-content-secondary);
            font-weight: 500;
        }

        &__grid {
            width: 100%;
            padding: 2rem 1rem;
            background-color: rgba(20, 184, 166, 0.04);
            background-image: url("data:image/svg+xml,%3csvg width='100%25' height='100%25' xmlns='http://www.w3.org/2000/svg'%3e%3crect width='100%25' height='100%25' fill='none' rx='10' ry='10' stroke='%2314B8A6' stroke-width='1' stroke-dasharray='8%2c 8' stroke-dashoffset='0' stroke-linecap='square'/%3e%3c/svg%3e");
            border-radius: 10px;
        }

        &__steps {
            display: flex;
            justify-content: center;
            align-items: stretch;
            width: 100%;

            @include media-breakpoint-down(xl) {
                display: grid;
                grid-template-columns: repeat(2, auto);
                row-gap: 80px;
                column-gap: 40px;
            }

            @include media-breakpoint-down(sm) {
                grid-template-columns: 1fr;
                row-gap: 60px;
                column-gap: 0;
            }
        }
    }

    .flow-block {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;

        &__content {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            z-index: 1;

            @include media-breakpoint-down(sm) {
                width: 100%;
                max-width: 320px;
                margin-top: 0.5rem;
            }
        }

        &__label {
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            text-transform: uppercase;
