        :global(.tag-icon) {
            width: 12px;
            height: 12px;
            color: $fs-yellow-bright;
            flex-shrink: 0;
        }
    }

    @property --fs-neon-angle {
        syntax: '<angle>';
        inherits: false;
        initial-value: 0deg;
    }

    @keyframes fs-neon-trace {
        to { --fs-neon-angle: 360deg; }
    }

    .exec-panel-wrapper {
        --fs-neon-angle: 0deg;
        border-radius: 10px;
        background: conic-gradient(
            from var(--fs-neon-angle),
            rgba(234, 179, 8, 0.12) 0deg,
            rgba(234, 179, 8, 0.12) 320deg,
            #{$fs-yellow}              340deg,
            $fs-platinum             350deg,
            #{$fs-yellow}              360deg
        );
        padding: 1px;
        box-shadow:
            0 1.214px 10.321px 0 rgba(234, 179, 8, 0.22) inset,
            -6.667px -7.143px 31.334px 3.333px rgba(234, 179, 8, 0.55);
        width: 100%;
        max-width: 640px;
        animation: fs-neon-trace 5s linear infinite;
    }

