---
import { Icon } from "astro-icon/components"
import { Image } from "astro:assets"

import Layout from "~/components/layout.astro"
import Link from "~/components/common/Link.astro"
import Faq from "~/components/common/Faq.vue"
import Quotes from "~/components/common/Quotes.vue"
import Snippets from "~/components/common/Snippets.vue"
import TaskIcon from "~/components/common/TaskIcon.vue"
import NoGapGrid from "~/components/common/NoGapGrid.vue"
import PluginsBlock from "~/components/common/PluginsBlock.astro"
import SeeHow from "~/components/common/SeeHow.astro"
import GoFurther from "~/components/get-started/GoFurther.astro"

import ShieldCheckOutline from "vue-material-design-icons/ShieldCheckOutline.vue"
import AccountGroupOutline from "vue-material-design-icons/AccountGroupOutline.vue"
import FileDocumentCheckOutline from "vue-material-design-icons/FileDocumentCheckOutline.vue"
import CodeTagsCheck from "vue-material-design-icons/CodeTagsCheck.vue"
import Git from "vue-material-design-icons/Git.vue"

import JPMorganLogo from "~/contents/customer-stories/26/logo.svg?raw"
import CreditAgricoleLogo from "~/contents/customer-stories/19/logo.svg?raw"
import JPMorganLogoImg from "~/contents/customer-stories/26/logo.svg"
import CreditAgricoleLogoImg from "~/contents/customer-stories/19/logo.svg"
import BloombergLogoImg from "~/assets/landing/infrastructure/companies/bloomberg.svg"
import { optimizeSvgIcon } from "~/utils/svgo"

// Hero tags — real Kestra capabilities (no invented compliance claims)
const HERO_TAGS = [
    { label: "Air-gapped", icon: "mdi:shield-lock-outline" },
    { label: "Self-hosted", icon: "mdi:server-network-outline" },
    { label: "Open source", icon: "mdi:code-tags" },
    { label: "Four-eyes approval", icon: "mdi:account-supervisor-outline" },
    { label: "Replayable lineage", icon: "mdi:history" },
    { label: "Deploy on any region", icon: "mdi:earth" },
    { label: "1200+ plugins", icon: "mdi:puzzle-outline" },
]

const title = "Kestra for Financial Services"
const description =
    "The orchestration platform for banks that cannot fail. From intraday reconciliation to mission-critical regulatory reporting. JPMorgan Chase, Crédit Agricole, and the world's most heavily regulated financial institutions run their operations on Kestra."

// Banking workflow visualization — Any-style, 4 stages
const FLOW_STAGES = [
    {
        id: "trigger",
        label: "TRIGGER",
        items: ["SWIFT MT940 / MT950", "Kafka / AMQP event", "FedNow / SEPA Instant", "Cron / market open", "Webhook / API"],
    },
    {
        id: "ingest",
        label: "INGEST",
        items: ["Oracle / DB2 core", "Postgres / SQL Server", "Snowflake / BigQuery", "S3 / ADLS / GCS", "SFTP / MQ / mainframe"],
    },
    {
        id: "process",
        label: "PROCESS",
        items: ["dbt transformations", "Python / R scripts", "Trino / Spark / Iceberg", "Four-eyes Pause gate", "Vault / CyberArk secrets"],
    },
    {
        id: "act",
        label: "ACT",
        items: ["Regulator submission", "Fraud / AML product", "ERP / ledger / GL", "Lakehouse / data mart", "ServiceNow / Slack"],
    },
]

// Single JPMorgan quote with story CTA
const quotes = [
    {
        quote:
            "For the first time, our analysts weren't waiting for engineering to catch up. They could define the workflows themselves. That changed everything.",
        author: "Cybersecurity Product Owner, JPMorgan Chase",
        smallLogoSvg: optimizeSvgIcon(JPMorganLogo, "jpm-quote-logo"),
        kpis: [
            { value: "Billions", name: "of rows processed" },
            { value: "100+", name: "users empowered" },
            { value: "4,000+", name: "API pulls / week" },
        ],
        storyLink: "/use-cases/stories/26-orchestrating-cybersecurity-for-100-users-and-billions-of-rows",
    },
]

// 12 workloads grouped by category
const WORKLOAD_CATEGORIES = [
    {
        name: "Core Banking & Modernization",
        items: [
            {
                icon: "mdi:server-network",
                title: "Core Banking CDC & Mainframe Modernization",
                description: "Strangle the mainframe, domain by domain. Stream Debezium from Oracle, DB2, and Teradata to modern lakehouse layers.",
            },
            {
                icon: "mdi:wallet-outline",
                title: "Intraday Liquidity & Cash Positioning",
                description: "Pull positions from custodians, forecast flows, stress funding, and push decisions to the core. Every hour, not every midnight.",
            },
            {
                icon: "mdi:swap-horizontal-bold",
                title: "Intraday Nostro & Cash Reconciliation",
                description: "Match SWIFT MT940/950, correspondent feeds, and internal ledgers in real time. Auto-route breaks with a signed audit trail.",
            },
        ],
    },
    {
        name: "Payments & Transactions",
        items: [
            {
                icon: "mdi:flash-outline",
                title: "RTGS, SEPA Instant & FedNow Settlement",
                description: "Validate, route, settle, and post across card networks and instant rails with idempotency, retries, and strictly enforced SLA guarantees.",
            },
            {
                icon: "mdi:eye-outline",
                title: "AML Transaction Monitoring",
                description: "Correlate transactions against watchlists, sanctions, and behavioural baselines. Generate SARs automatically with full data lineage.",
            },
            {
                icon: "mdi:shield-search",
                title: "Real-Time Fraud Scoring at Scale",
                description: "Fan-in vendor threat-intel, enrich in dbt, score with ML, and route to fraud products. The pattern tier-1 banks run across billions of rows.",
            },
        ],
    },
    {
        name: "Risk, Compliance & Reporting",
        items: [
            {
                icon: "mdi:file-document-check-outline",
                title: "FINREP, COREP & BCBS 239 Submission",
                description: "Pull positions, transform with dbt, gate on four-eyes approval, and submit. Every cutoff fully replayable with transparent lineage.",
            },
            {
                icon: "mdi:chart-line",
                title: "Trade Surveillance & P&L Explain",
                description: "Ingest trade events, compute end-of-day marks, run explain-shift analytics, and fan results to front office, risk, and finance teams.",
            },
            {
                icon: "mdi:brain",
                title: "Model Risk Governance & MLOps",
                description: "Train, validate, deploy, and monitor scorecards and fraud models. Champion/challenger flows gated by strict approval steps.",
            },
        ],
    },
    {
        name: "Operations & Security",
        items: [
            {
                icon: "mdi:account-check-outline",
                title: "KYC & Document Intelligence",
                description: "Orchestrate OCR, LLM extraction, adverse-media screening, and human review into one seamless, declarative onboarding workflow.",
            },
            {
                icon: "mdi:receipt-text-outline",
                title: "Financial Close & Consolidation",
                description: "Orchestrate ERP extracts, journal postings, intercompany eliminations, and multi-entity consolidation to achieve a 3-day close.",
            },
            {
                icon: "mdi:security-network",
                title: "Cybersecurity & Platform Automation",
                description: "Automate certificate management, config tests, vulnerability scans, and incident response via declarative pipelines.",
            },
        ],
    },
]

// Enterprise features (5 for clean 3x2 grid)
const ENTERPRISE_FEATURES = [
    {
        icon: ShieldCheckOutline,
        title: "Air-Gapped & Sovereign Deployment",
        description: "Self-hosted, VPC, or fully air-gapped. EU or US data residency. Segment control plane and workers across restricted zones with zero egress required.",
    },
    {
        icon: Git,
        title: "Immutable, Replayable Execution",
        description: "Every flow is YAML in Git. Every execution frozen in time. Replay any historical cutoff with the exact code, secrets, and inputs, in one click.",
    },
    {
        icon: FileDocumentCheckOutline,
        title: "Four-Eyes Approval Gates",
        description: "Pause any workflow pending human sign-off. Enforce mandatory dual-control for regulatory submissions, model promotions, and production deployments.",
    },
    {
        icon: AccountGroupOutline,
        title: "RBAC & Multi-Tenant Isolation",
        description: "Namespace-scoped RBAC with SSO/SAML/SCIM. Every division owns its secrets and runtime on a shared platform. Zero blast radius.",
    },
    {
        icon: CodeTagsCheck,
        title: "Audit Logs & SIEM Integration",
        description: "Every execution, user action, and resource change recorded. Stream logs directly to Splunk, Elastic, or your preferred SIEM.",
    },
]

// "What engineers build" — 3-tab Build section (ai-automation style)
const BUILD_TABS = [
    {
        name: "Real-time fraud scoring",
        title: "Score vendor threat-intel feeds hourly, at billions-of-rows scale.",
        description:
            "Pull intel, stage in S3, enrich with dbt, score in Trino, page on-call on failure. A production pattern running across billions of cybersecurity records at tier-1 banks.",
        code: `id: fraud-intel-pipeline
namespace: company.risk.fraud

triggers:
  - id: hourly
    type: io.kestra.plugin.core.trigger.Schedule
    cron: "0 * * * *"

tasks:
  - id: pull_vendor_feeds
    type: io.kestra.plugin.core.http.Request
    uri: "https://intel.vendor.example/feeds"
    headers:
      Authorization: "Bearer {{ secret('INTEL_TOKEN') }}"

  - id: stage_to_s3
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "fraud-intel-raw"
    key: "{{ execution.startDate | date('yyyy/MM/dd/HH') }}/feed.json"
    from: "{{ outputs.pull_vendor_feeds.uri }}"

  - id: enrich
    type: io.kestra.plugin.dbt.cli.Build
    projectDir: "./dbt/fraud"
    select: "tag:fraud_intel"

  - id: score
    type: io.kestra.plugin.jdbc.trino.Query
    url: "jdbc:trino://trino.internal:443"
    sql: |
      SELECT tx_id, risk_score
      FROM prod.fraud_scores
      WHERE risk_score > 0.85

errors:
  - id: page_oncall
    type: io.kestra.plugin.pagerduty.PagerDutyExecution
    url: "{{ secret('PD_EVENT_URL') }}"
    routingKey: "{{ secret('PD_ROUTING_KEY') }}"
    eventAction: trigger
    executionId: "{{ execution.id }}"
    payloadSummary: "Fraud pipeline failed: {{ execution.id }}"`,
        plugins: [
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
            { cls: "io.kestra.plugin.dbt.cli.Build" },
            { cls: "io.kestra.plugin.jdbc.trino.Query" },
            { cls: "io.kestra.plugin.pagerduty.PagerDutyExecution" },
        ],
        href: "/blueprints",
    },
    {
        name: "EOD reconciliation",
        title: "Close the books against the core, with a 2-hour SLA and zero silent failures.",
        description:
            "Extract from Oracle, reconcile in Python, assert controls, publish a signed audit bundle. Retries, exception routing, and mail alerts are declarative primitives.",
        code: `id: eod-reconciliation
namespace: company.finance.eod

sla:
  - id: two_hour_window
    type: MAX_DURATION
    duration: PT2H
    behavior: FAIL

tasks:
  - id: extract_core
    type: io.kestra.plugin.jdbc.oracle.Query
    url: "jdbc:oracle:thin:@core-prod:1521/BANK"
    username: "{{ secret('ORACLE_USER') }}"
    password: "{{ secret('ORACLE_PASSWORD') }}"
    fetchType: STORE
    sql: |
      SELECT * FROM ledger.gl_postings
      WHERE trade_date = TO_DATE('{{ execution.startDate | date('yyyy-MM-dd') }}', 'YYYY-MM-DD')

  - id: reconcile
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python reconcile.py --date {{ execution.startDate | date('yyyy-MM-dd') }}

  - id: assert_breaks
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.reconcile.vars.breaks > 0 }}"
    then:
      - id: alert_controls
        type: io.kestra.plugin.email.MailSend
        host: smtp.bank.example
        port: 465
        username: "{{ secret('SMTP_USER') }}"
        password: "{{ secret('SMTP_PASSWORD') }}"
        from: eod-bot@bank.example
        to: finance-controls@bank.example
        subject: "EOD breaks: {{ outputs.reconcile.vars.breaks }} items"
        htmlTextContent: "{{ outputs.reconcile.vars.breaks }} unmatched postings require review."

  - id: publish_bundle
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "finance-audit"
    key: "eod/{{ execution.startDate | date('yyyy/MM/dd') }}/bundle.json"
    from: "{{ outputs.extract_core.uri }}"`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.oracle.Query" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.email.MailSend" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
    {
        name: "Regulatory reporting",
        title: "Submit FINREP with lineage any auditor will sign off on.",
        description:
            "Gather positions, transform with dbt, require four-eyes approval, submit to the regulator. Every cutoff replayable, on demand, years later.",
        code: `id: finrep-quarterly
namespace: company.finance.regulatory

labels:
  regulation: "FINREP"

inputs:
  - id: cutoffDate
    type: DATE
    displayName: Regulatory cutoff date

tasks:
  - id: gather_positions
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://warehouse:5432/finance"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    fetchType: STORE
    sql: |
      SELECT * FROM risk.positions
      WHERE as_of_date = '{{ inputs.cutoffDate }}'

  - id: transform
    type: io.kestra.plugin.dbt.cli.Build
    projectDir: "./dbt/regulatory"
    vars: '{ "cutoff": "{{ inputs.cutoffDate }}" }'

  - id: human_approval
    type: io.kestra.plugin.core.flow.Pause
    description: |
      Reviewer must validate the FINREP template before submission.

  - id: submit
    type: io.kestra.plugin.core.http.Request
    uri: "https://regulator.example/submit"
    method: POST
    contentType: application/xml
    headers:
      Authorization: "Bearer {{ secret('REGULATOR_TOKEN') }}"`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.dbt.cli.Build" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.core.http.Request" },
        ],
        href: "/blueprints",
    },
]

const FAQ = [
    {
        question: "Can Kestra run in an air-gapped or on-prem environment?",
        answer: "Yes. Kestra Enterprise runs fully self-hosted in your private cloud, VPC, or air-gapped datacenter with no egress required. Workers sit on-premise; the control plane can live in a different zone. This is how tier-1 banks deploy us.",
    },
    {
        question: "How does Kestra support SOX, BCBS 239, DORA, and internal audit controls?",
        answer: "Every flow is YAML in Git. Every execution is immutable and replayable. RBAC enforces least privilege per namespace. Audit logs stream to your SIEM. Lineage ships with each run. Four-eyes approval gates are a first-class flow primitive.",
    },
    {
        question: "Does Kestra replace Airflow, Control-M, Autosys, or IBM Workload Automation?",
        answer: "It's designed to. Banks consolidate onto Kestra to replace Cron, Control-M, Autosys, Airflow, and hand-rolled schedulers. One control plane for data, infrastructure, and business workflows, with a plugin ecosystem from mainframe to cloud.",
    },
    {
        question: "How do you handle secrets and credentials for banking systems?",
        answer: "Native integrations with HashiCorp Vault, AWS Secrets Manager, GCP Secret Manager, Azure Key Vault, and CyberArk. Secrets are scoped per namespace, per tenant, per flow, and never written to logs.",
    },
    {
        question: "Can Kestra orchestrate mainframe and legacy systems?",
        answer: "Yes. Plugins for JDBC (DB2, Oracle, Teradata), SFTP/FTPS, JMS/IBM MQ, and shell execution for CICS interfaces. Most banks start by wrapping existing jobs, then modernize incrementally. No big-bang migration required.",
    },
    {
        question: "What about data residency and sovereign cloud?",
        answer: "Deploy per-region with full control over residency. Kestra Cloud runs in EU or US regions — pick the one that fits your jurisdiction, with no cross-region data transfer. For sovereign requirements, self-host on your own infrastructure.",
    },
    {
        question: "Is Kestra open source? What's the licensing model?",
        answer: "Yes. Kestra is Apache 2.0. Enterprise Edition adds SSO, RBAC, multi-tenancy, worker groups, advanced audit, and 24x7 support. Start with OSS. Upgrade when you need enterprise governance.",
    },
]

---

<Layout {title} {description} headerTheme="lightText">
    <div class="financial-services">

        <!-- ── 1. HERO ── -->
        <section class="hero">
            <img src="/hero-grid.svg" alt="" class="hero-bg-grid" aria-hidden="true" />
            <div class="hero-inner">
                <div class="badge-pill" data-usal="zoomin">
                    <Icon name="mdi:bank-outline" />
                    <span>Financial Services</span>
                </div>

                <h1 data-usal="fade-u">
                    The Orchestration Platform<br />
                    <span class="gradient">for Banks That Cannot Fail.</span>
                </h1>

                <p class="subtitle" data-usal="fade-l">
                    Intraday reconciliation. Regulatory reporting. Core-banking modernization.
                    Run your most critical workflows on the same control plane as
                    JPMorgan Chase, Crédit Agricole, and Bloomberg.
                </p>

                <div class="tags" data-usal="fade-l">
                    {HERO_TAGS.map((tag) => (
                        <span class="tag">
                            <Icon name={tag.icon} class="tag-icon" />
                            {tag.label}
                        </span>
                    ))}
                </div>

                <div class="exec-panel-wrapper" data-usal="fade-up">
                    <div class="exec-panel">
                        <div class="exec-panel__header">
                            <span class="exec-panel__dot"></span>
                            <span class="exec-panel__title">weyland-yutani-invest</span>
                            <span class="exec-panel__meta">namespace · company.finance.ops</span>
                            <span class="exec-panel__duration">1.8s</span>
                        </div>

                        <div class="exec-panel__body">
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">open_ticket</span>
                                <span class="exec-row__type">servicenow.Post</span>
                                <span class="exec-row__result">INC0042891</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">fetch_positions</span>
                                <span class="exec-row__type">jdbc.postgresql.Query</span>
                                <span class="exec-row__result">442 rows</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">reconcile</span>
                                <span class="exec-row__type">scripts.python.Commands</span>
                                <span class="exec-row__result">8 breaks</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">manage_position</span>
                                <span class="exec-row__type">jdbc.postgresql.Query</span>
                                <span class="exec-row__result">8 updates</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">human_in_the_loop</span>
                                <span class="exec-row__type">core.flow.Pause</span>
                                <span class="exec-row__result">Approved</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">close_ticket</span>
                                <span class="exec-row__type">servicenow.Patch</span>
                                <span class="exec-row__result">resolved</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">notify_team</span>
                                <span class="exec-row__type">teams.TeamsIncomingWebhook</span>
                                <span class="exec-row__result">finance-ops</span>
                            </div>
                        </div>

                        <div class="exec-panel__footer">
                            <span class="exec-footer__item">Ticket resolved</span>
                            <span class="exec-footer__sep">·</span>
                            <span class="exec-footer__item">Lineage signed</span>
                            <span class="exec-footer__sep">·</span>
                            <span class="exec-footer__item">Audit-ready</span>
                        </div>
                    </div>
                </div>

                <div class="hero-ctas" data-usal="zoomin">
                    <Link href="/demo" class="btn btn-primary btn-lg">Book a Demo</Link>
                </div>

                <div class="hero-logos" data-usal="fade-u">
                    <span class="hero-logos__label">Trusted by leading financial institutions</span>
                    <div class="hero-logos__row">
                        <Image src={JPMorganLogoImg} alt="JPMorgan Chase" class="hero-logos__item" />
                        <Image src={CreditAgricoleLogoImg} alt="Crédit Agricole" class="hero-logos__item" />
                        <Image src={BloombergLogoImg} alt="Bloomberg" class="hero-logos__item" />
                    </div>
                </div>
            </div>
        </section>

        <!-- ── 2. BANKING WORKFLOW VISUALIZATION ── -->
        <section class="flow">
            <div class="container-xxl">
                <h2 class="flow__title text-center">
                    Any <span class="highlight">source</span>. Any <span class="highlight">rail</span>. Any <span class="highlight">regulator</span>.
                </h2>
                <p class="flow__lead">
                    SWIFT messages, FedNow settlements, FINREP submissions, core banking CDC. Kestra orchestrates every step of every banking workload with one declarative model.
                </p>

                <div class="flow__grid">
                    <div class="flow__steps">
                        {FLOW_STAGES.map((stage, idx) => (
                            <div class={`flow-block flow-${idx}`}>
                                <div class="flow-block__content">
                                    <span class={`flow-block__label label-${stage.id}`}>{stage.label}</span>
                                    <div class={`flow-block__card card-${stage.id}`}>
                                        <div class="flow-block__items">
                                            {stage.items.map(item => (
                                                <div class="flow-block__item">{item}</div>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                                {idx < FLOW_STAGES.length - 1 && (
                                    <div class={`flow-arrow arrow-${idx}`}>
                                        <div class="line" />
                                        <Icon name="mdi:play" class="head" width={16} height={16} />
                                    </div>
                                )}
                            </div>
                        ))}
                    </div>
                </div>

                <h5 class="flow__footer text-center">
                    Each step is a declarative YAML task. Swap the source, the rail, or the regulator without touching the rest.
                </h5>
            </div>
        </section>

        <!-- ── 3. 12 WORKLOADS (grouped) ── -->
        <section class="workloads">
            <div class="container">
                <div class="workloads__head">
                    <h2>Built for every banking domain.</h2>
                    <p>The workflows Kestra orchestrates across every division of a modern financial institution, from the core to the regulator.</p>
                </div>
                {WORKLOAD_CATEGORIES.map(cat => (
                    <div class="workloads__group">
                        <h3 class="workloads__category">{cat.name}</h3>
                        <div class="workloads__grid">
                            {cat.items.map(item => (
                                <div class="workload-card">
                                    <Icon name={item.icon} class="workload-card__icon" />
                                    <h4 class="workload-card__title">{item.title}</h4>
                                    <p class="workload-card__desc">{item.description}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- ── 4. CUSTOMER PROOF ── -->
        <Quotes {quotes} client:load />

        <!-- ── 5. ENTERPRISE-GRADE ── -->
        <section class="enterprise">
            <div class="container-xxl">
                <h2 class="enterprise__title" data-usal="fade-r">
                    <span class="highlight">Enterprise-Grade</span> Orchestration, Engineered for Banking.
                </h2>
                <NoGapGrid items={ENTERPRISE_FEATURES}>
                    <div class="feature-card feature-card--cta">
                        <a href="/demo" class="btn btn-secondary" data-usal="zoomin">
                            Book a Demo
                        </a>
                    </div>
                </NoGapGrid>
            </div>
        </section>

        <!-- ── 7. WHAT ENGINEERS BUILD ── -->
        <section class="build">
            <div class="container">
                <h2>What engineers <span class="highlight">build</span> with Kestra</h2>
                <p class="build__lead">Three production patterns running at tier-1 banks today. Copy the YAML. Wire it to your stack. Ship it through your CI.</p>
                <div class="wrapper">
                    <div class="inner">
                        <div class="header row g-0">
                            {BUILD_TABS.map((tab, idx) => (
                                <div
                                    class:list={[
                                        "col-4 header-tab",
                                        { active: idx === 0, "middle-part": idx > 0 && idx < BUILD_TABS.length - 1 },
                                    ]}
                                    data-tab-target={idx}
                                >
                                    {tab.name}
                                </div>
                            ))}
                        </div>

                        {BUILD_TABS.map((tab, idx) => (
                            <div class:list={["content", { active: idx === 0 }]} data-tab-content={idx}>
                                <div class="panel panel-1">
                                    <Snippets client:idle code={tab.code} lang="yaml" />
                                </div>
                                <div class="panel panel-2">
                                    <h3 data-usal="fade-r">{tab.title}</h3>
                                    <p data-usal="fade-l">{tab.description}</p>
                                    <div class="plugins" data-usal="zoomin">
                                        {tab.plugins.map(plugin => (
                                            <div class="plugin-icon">
                                                <TaskIcon cls={plugin.cls} />
                                            </div>
                                        ))}
                                    </div>
                                    <Link class="goto" href={tab.href} data-usal="fade-r">
                                        Explore blueprint library
                                    </Link>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <!-- ── 8b. READY FOR PRODUCTION ── -->
        <GoFurther />

        <!-- ── 9. PLUGINS ── -->
        <PluginsBlock />

        <!-- ── 10. FINAL CTA ── -->
        <SeeHow cta={{ text: "Book a Demo", href: "/demo" }}>
            <Fragment slot="title">One platform, from the front office to the back office.</Fragment>
            Talk to our team about how Kestra fits your stack. Air-gapped deployment, regulatory
            lineage, legacy integration, and the workloads you're running today.
        </SeeHow>

        <!-- ── 11. FAQ ── -->
        <Faq items={FAQ} client:visible />
    </div>
</Layout>

<style lang="scss">
