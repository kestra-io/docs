const ENTERPRISE_FEATURES = [
    {
        icon: ShieldCheckOutline,
        title: "Air-Gapped & Sovereign Deployment",
        description: "Self-hosted, VPC, or fully air-gapped. EU or US data residency. Segment control plane and workers across restricted zones with zero egress required.",
    },
    {
        icon: Git,
        title: "Immutable, Replayable Execution",
        description: "Every flow is YAML in Git. Every execution frozen in time. Replay any historical cutoff with the exact code, secrets, and inputs, in one click.",
    },
    {
        icon: FileDocumentCheckOutline,
        title: "Four-Eyes Approval Gates",
        description: "Pause any workflow pending human sign-off. Enforce mandatory dual-control for regulatory submissions, model promotions, and production deployments.",
    },
    {
        icon: AccountGroupOutline,
        title: "RBAC & Multi-Tenant Isolation",
        description: "Namespace-scoped RBAC with SSO/SAML/SCIM. Every division owns its secrets and runtime on a shared platform. Zero blast radius.",
    },
    {
        icon: CodeTagsCheck,
        title: "Audit Logs & SIEM Integration",
        description: "Every execution, user action, and resource change recorded. Stream logs directly to Splunk, Elastic, or your preferred SIEM.",
    },
]

const BUILD_TABS = [
    {
        name: "Claims triage & payout",
        title: "Triage an FNOL, score for fraud, and pay the customer in minutes, not days.",
        description:
            "A claim lands on the webhook, Kestra parses it, scores for fraud, auto-routes to an adjuster queue, and fires the payout. Every step auditable. Every dispute replayable.",
        code: `id: claims-triage-payout
namespace: company.insurance.claims

inputs:
  - id: claim_payload
    type: JSON
    displayName: FNOL payload (JSON)

tasks:
  - id: persist_claim
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://policy-admin:5432/claims"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    sql: |
      INSERT INTO claims.fnol (policy_id, payload, received_at)
      VALUES (
        '{{ inputs.claim_payload.policy_id }}',
        '{{ inputs.claim_payload | toJson }}',
        NOW()
      ) RETURNING claim_id

  - id: fraud_score
    type: io.kestra.plugin.core.http.Request
    uri: "https://ml.insurance.example/score"
    method: POST
    contentType: application/json
    body: "{{ inputs.claim_payload | toJson }}"
    headers:
      Authorization: "Bearer {{ secret('ML_TOKEN') }}"

  - id: route
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.fraud_score.body.risk > 0.75 }}"
    then:
      - id: adjuster_review
        type: io.kestra.plugin.core.flow.Pause
        description: |
          High-risk claim {{ outputs.persist_claim.row.claim_id }}.
          Four-eyes review required before payout.
    else:
      - id: auto_payout
        type: io.kestra.plugin.core.http.Request
        uri: "https://payments.example/v1/disbursements"
        method: POST
        contentType: application/json
        body: |
          {
            "policy_id": "{{ inputs.claim_payload.policy_id }}",
            "amount": {{ inputs.claim_payload.amount }},
            "currency": "EUR"
          }

  - id: notify_customer
    type: io.kestra.plugin.email.MailSend
    host: smtp.insurer.example
    port: 465
    username: "{{ secret('SMTP_USER') }}"
    password: "{{ secret('SMTP_PASSWORD') }}"
    from: claims@insurer.example
    to: "{{ inputs.claim_payload.customer_email }}"
    subject: "Claim {{ outputs.persist_claim.row.claim_id }} received"
    htmlTextContent: "We've received your claim and will update you shortly."`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.email.MailSend" },
        ],
        href: "/blueprints",
    },
    {
        name: "Customer onboarding & document review",
        title: "Turn a stack of documents into an approved customer, with audit trail.",
        description:
            "Extract data from uploaded documents, screen against sanctions lists, persist the case, pause for compliance review, and activate the account. One flow, KYC-grade evidence, replayable end-to-end.",
        code: `id: customer-onboarding
namespace: company.regulated.onboarding

inputs:
  - id: application
    type: JSON
    displayName: Customer application payload

tasks:
  - id: extract_documents
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python extract.py --application '{{ inputs.application | toJson }}'

  - id: screen_sanctions
    type: io.kestra.plugin.core.http.Request
    uri: "https://sanctions.example/screen"
    method: POST
    contentType: application/json
    body: "{{ inputs.application | toJson }}"
    headers:
      Authorization: "Bearer {{ secret('SCREEN_TOKEN') }}"

  - id: persist_case
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://crm:5432/onboarding"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    sql: |
      INSERT INTO onboarding.cases (applicant, screening, status)
      VALUES (
        '{{ inputs.application.name }}',
        '{{ outputs.screen_sanctions.body | toJson }}',
        'pending_review'
      ) RETURNING case_id

  - id: compliance_review
    type: io.kestra.plugin.core.flow.Pause
    description: |
      Compliance reviewer must approve the KYC decision
      for case {{ outputs.persist_case.row.case_id }}.

  - id: activate_account
    type: io.kestra.plugin.core.http.Request
    uri: "https://core.example/accounts/activate"
    method: POST
    contentType: application/json
    body: |
      { "case_id": "{{ outputs.persist_case.row.case_id }}" }`,
        plugins: [
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
        ],
        href: "/blueprints",
    },
    {
        name: "Reconciliation & exception management",
        title: "Reconcile two sources nightly and route every break to the right team.",
        description:
            "Pull two ledgers, reconcile in Python, and branch on exceptions. Breaks open cases in ServiceNow. Clean runs publish a signed audit bundle. Every step replayable at the same cutoff, years later.",
        code: `id: reconciliation-exceptions
namespace: company.regulated.ops

triggers:
  - id: nightly
    type: io.kestra.plugin.core.trigger.Schedule
    cron: "0 2 * * *"

tasks:
  - id: extract_source_a
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://ledger-a:5432/ledger"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    fetchType: STORE
    sql: "SELECT txn_id, amount FROM postings WHERE trade_date = CURRENT_DATE - 1"

  - id: extract_source_b
    type: io.kestra.plugin.jdbc.oracle.Query
    url: "jdbc:oracle:thin:@ledger-b:1521/LEDGER"
    username: "{{ secret('ORACLE_USER') }}"
    password: "{{ secret('ORACLE_PASSWORD') }}"
    fetchType: STORE
    sql: "SELECT txn_id, amount FROM postings WHERE trade_date = TRUNC(SYSDATE) - 1"

  - id: reconcile
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python reconcile.py --a {{ outputs.extract_source_a.uri }} --b {{ outputs.extract_source_b.uri }}

  - id: route_exceptions
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.reconcile.vars.breaks > 0 }}"
    then:
      - id: open_case
        type: io.kestra.plugin.core.http.Request
        uri: "https://servicenow.example/api/now/table/incident"
        method: POST
        contentType: application/json
        headers:
          Authorization: "Bearer {{ secret('SNOW_TOKEN') }}"
        body: |
          {
            "short_description": "Reconciliation breaks: {{ outputs.reconcile.vars.breaks }}",
            "assignment_group": "ops-controls"
          }

  - id: publish_audit
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "ops-audit"
    key: "recon/{{ execution.startDate | date('yyyy/MM/dd') }}/bundle.json"
    from: "{{ outputs.reconcile.outputFiles.bundle }}"`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.jdbc.oracle.Query" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.core.flow.If" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
    {
        name: "Regulatory reporting & approvals",
        title: "Regulatory submissions with dual control and lineage any auditor will sign off on.",
        description:
            "Gather positions, transform with dbt, require four-eyes approval, submit to the regulator. Every cutoff replayable with signed evidence, on demand, years later. Works for FINREP, COREP, Solvency II, and internal reporting alike.",
        code: `id: regulatory-submission
namespace: company.regulated.reporting

labels:
  regulation: "FINREP / Solvency II"

inputs:
  - id: cutoffDate
    type: DATE
    displayName: Regulatory cutoff date

tasks:
  - id: gather_positions
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://warehouse:5432/finance"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    fetchType: STORE
    sql: |
      SELECT * FROM risk.positions
      WHERE as_of_date = '{{ inputs.cutoffDate }}'

  - id: transform
    type: io.kestra.plugin.dbt.cli.Build
    projectDir: "./dbt/regulatory"
    vars: '{ "cutoff": "{{ inputs.cutoffDate }}" }'

  - id: human_approval
    type: io.kestra.plugin.core.flow.Pause
    description: |
      Reviewer must validate the submission template before filing.

  - id: submit
    type: io.kestra.plugin.core.http.Request
    uri: "https://regulator.example/submit"
    method: POST
    contentType: application/xml
    headers:
      Authorization: "Bearer {{ secret('REGULATOR_TOKEN') }}"`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.dbt.cli.Build" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.core.http.Request" },
        ],
        href: "/blueprints",
    },
]

const FAQ = [
    {
        question: "Can Kestra orchestrate insurance workflows like claims, underwriting, policy admin, billing, and renewals?",
        answer: "Yes. Kestra integrates with Guidewire, Duck Creek, and legacy policy and claims cores via JDBC, HTTP, SFTP, Kafka, and MQ. Orchestrate FNOL intake, fraud scoring, underwriting referrals, policy issuance, billing events, and renewals, all with four-eyes approval gates, document handling, and immutable audit trails.",
    },
    {
        question: "Can Kestra orchestrate banking, payments, and lending workflows without replacing our core systems?",
        answer: "Yes. Kestra sits alongside your core banking, ledger, card, and payment platforms. It connects them to data systems, case tools, partner APIs, and customer-facing services, so you can modernize incrementally without a big-bang migration.",
    },
    {
        question: "How does Kestra support approvals, segregation of duties, and auditability?",
        answer: "Every flow is YAML in Git. Every execution is immutable and replayable. RBAC enforces least privilege per namespace. Audit logs stream to your SIEM. Lineage ships with each run. Four-eyes approval gates are a first-class flow primitive, ready to enforce SOX, BCBS 239, Solvency II, DORA, and internal controls for regulatory submissions, payout approvals, and underwriting decisions.",
    },
    {
        question: "Can Kestra handle document-heavy onboarding and servicing workflows?",
        answer: "Yes. Orchestrate document intake from SFTP, email, web forms, and portals; run OCR and LLM extraction; screen against sanctions and adverse-media lists; pause for human review; and post the decision back to core systems. One declarative flow covers KYC, KYB, claims documents, and servicing paperwork.",
    },
    {
        question: "Does Kestra work with mainframes, SFTP, MQ, and other legacy systems?",
        answer: "Yes. Plugins for JDBC (DB2, Oracle, Teradata, SQL Server), SFTP/FTPS, JMS/IBM MQ, Kafka, and shell execution for CICS interfaces. Most institutions start by wrapping existing jobs, then modernize incrementally. No big-bang migration required.",
    },
    {
        question: "How does Kestra fit alongside Airflow, Control-M, or IBM Workload Automation?",
        answer: "Kestra is designed to replace them. Banks, insurers, lenders, and investment firms consolidate onto Kestra to retire Cron, Control-M, Autosys, Airflow, and hand-rolled schedulers. One control plane for data, infrastructure, and business workflows, with a plugin ecosystem spanning mainframe to cloud.",
    },
    {
        question: "Does Kestra integrate with PagerDuty for incident response?",
        answer: "Yes. The PagerDuty plugin fires events on flow failures, SLA breaches, or any conditional branch. Route by severity, deduplicate with custom keys, and attach the full execution ID so on-call engineers can replay the failing run in one click. Works the same way for claims pipelines, reconciliations, and regulatory submissions.",
    },
    {
        question: "Can Kestra replace VMware Aria Automation or other cloud-automation suites?",
        answer: "Yes. Teams migrate off VMware Aria Automation, Aria Orchestrator, vRealize, and similar cloud-automation suites onto Kestra to unify cloud provisioning, platform automation, and business workflows in one declarative engine. Terraform, Ansible, shell, Python, and native API plugins cover the same provisioning and governance scenarios, with Git-backed flows, RBAC, and audit built in.",
    },
    {
        question: "What deployment options exist for restricted, sovereign, or air-gapped environments?",
        answer: "Kestra Enterprise runs fully self-hosted in your private cloud, VPC, or air-gapped datacenter with no egress required. Workers sit on-premise; the control plane can live in a different zone. Kestra Cloud runs in EU or US regions. Pick the one that fits your jurisdiction, with no cross-region data transfer.",
    },
    {
        question: "How do you handle secrets and credentials for regulated systems?",
        answer: "Native integrations with HashiCorp Vault, AWS Secrets Manager, GCP Secret Manager, Azure Key Vault, and CyberArk. Secrets are scoped per namespace, per tenant, per flow, and never written to logs.",
    },
    {
        question: "Is Kestra open source, and what does the licensing model look like?",
        answer: "Yes. Kestra is Apache 2.0. Enterprise Edition adds SSO, RBAC, multi-tenancy, worker groups, advanced audit, and 24x7 support. Start with OSS. Upgrade when you need enterprise governance.",
    },
    {
        question: "Does Kestra support digital asset and BNPL workflows?",
        answer: "Yes. Orchestrate on-chain events, stablecoin settlement, wallet reconciliation, and buy-now-pay-later authorization alongside SWIFT, SEPA, and card rails. The same declarative model covers traditional and digital asset flows.",
    },
]

---

<Layout {title} {description} headerTheme="lightText">
    <div class="financial-services">

        <section class="hero">
            <img src="/hero-grid.svg" alt="" class="hero-bg-grid" aria-hidden="true" />
            <div class="hero-inner">
                <div class="badge-pill" data-usal="zoomin">
                    <Icon name="mdi:scale-balance" />
                    <span>Financial Services &amp; Insurance</span>
                </div>

                <h1 data-usal="fade-u">
                    One orchestration platform for<br />
                    <span class="gradient">regulated financial workflows.</span>
                </h1>

                <p class="subtitle" data-usal="fade-l">
                    The regulated workflows behind modern financial services and insurance. Claims, onboarding, payments,
                    reporting, risk, and AI, orchestrated from one declarative control plane.
                </p>

                <div class="tags" data-usal="fade-l">
                    {HERO_TAGS.map((tag) => (
                        <span class="tag">
                            <Icon name={tag.icon} class="tag-icon" />
                            {tag.label}
                        </span>
                    ))}
                </div>

                <div class="exec-panel-wrapper" data-usal="fade-up">
                    <div class="exec-panel">
                        <div class="exec-panel__header">
                            <span class="exec-panel__dot"></span>
                            <span class="exec-panel__title">regulated-case-intake</span>
                            <span class="exec-panel__meta">namespace · company.regulated.ops</span>
                            <span class="exec-panel__duration">1.4s</span>
                        </div>

                        <div class="exec-panel__body">
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">receive_request</span>
                                <span class="exec-row__type">core.http.Webhook</span>
                                <span class="exec-row__result">accepted</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">extract_data</span>
                                <span class="exec-row__type">scripts.python.Commands</span>
                                <span class="exec-row__result">12 fields</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">validate_rules</span>
                                <span class="exec-row__type">jdbc.postgresql.Query</span>
                                <span class="exec-row__result">0 exceptions</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
