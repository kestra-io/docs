    .flow-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 2;

        .line {
            background: #000000;
            html.dark & { background: #ffffff; }
        }

        .head {
            position: absolute;
            color: #000000;
            html.dark & { color: #ffffff; }
        }

        @include media-breakpoint-up(xl) {
            width: 90px;

            .line { width: 100%; height: 1.5px; }
            .head {
                right: -4px;
                top: 50%;
                transform: translateY(-50%);
            }
        }

        @include media-breakpoint-between(sm, xl) {
            &.arrow-0, &.arrow-1 {
                position: absolute;
                top: calc(100% + 4px);
                left: 50%;
                height: 72px;
                width: 1.5px;
                transform: translateX(-50%);

                .line { width: 1.5px; height: 100%; }
                .head {
                    bottom: -5px;
                    left: 50%;
                    transform: translateX(-50%) rotate(90deg);
                }
            }
            &.arrow-2 { display: none; }
        }

        @include media-breakpoint-down(sm) {
            position: absolute;
            top: calc(100% + 4px);
            left: 50%;
            height: 58px;
            width: 1.5px;
            transform: translateX(-50%);

            .line { width: 1.5px; height: 100%; }
            .head {
                bottom: -6px;
                left: 50%;
                transform: translateX(-50%) rotate(90deg);
            }
        }
    }

