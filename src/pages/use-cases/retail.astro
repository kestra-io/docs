const title = "Kestra for Retail & Commerce"
const description =
    "Kestra keeps orders, inventory, returns, and customers in sync across OMS, WMS, storefront, POS, and partner APIs. Peak-season ready. Queue-backed. Always replayable. Built for retailers who can't afford silent failures during launch day or Black Friday."

const FLOW_STAGES = [
