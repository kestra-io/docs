        }

        :global(html.dark) &::after {
            background: radial-gradient(ellipse at center, rgba(167, 139, 250, 0.32) 0%, rgba(167, 139, 250, 0) 70%);
        }

        &::before {
            content: "";
            position: absolute;
            bottom: -220px;
            left: 50%;
            transform: translateX(-50%);
            width: 1100px;
            height: 440px;
            background: radial-gradient(ellipse at center, rgba(124, 58, 237, 0.14) 0%, rgba(124, 58, 237, 0) 70%);
            pointer-events: none;
            z-index: 0;
        }

        :global(html.dark) &::before {
            background: radial-gradient(ellipse at center, rgba(124, 58, 237, 0.22) 0%, rgba(124, 58, 237, 0) 70%);
        }

        > .container {
            position: relative;
            z-index: 1;
        }

        &__head {
            text-align: center;
            max-width: 46rem;
            margin: 0 auto 3rem;

            h2 { color: var(--ks-content-primary); margin-bottom: 0.75rem; }
            p { color: var(--ks-content-secondary); font-size: $font-size-lg; margin: 0; }
        }

        &__group {
            max-width: 72rem;
            margin: 0 auto 3rem;

            &:last-child { margin-bottom: 0; }
        }

        &__category {
            font-size: $font-size-sm;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: $rt-purple-deep;
            margin: 0 0 1rem;

            :global(html.dark) & { color: $rt-purple-bright; }
        }

        &__grid {
            display: grid;
            gap: 1rem;
            grid-template-columns: 1fr;

            @include media-breakpoint-up(md) { grid-template-columns: repeat(3, 1fr); }
        }
    }

    .workload-card {
        padding: 1.5rem;
        background: var(--ks-background-primary);
        border: 1px solid var(--ks-border-secondary);
        border-radius: 10px;
        transition: border-color 0.2s, transform 0.2s;

        &:hover {
            border-color: $rt-purple;
            transform: translateY(-2px);
        }

        &__icon {
            font-size: 1.375rem;
            color: $rt-purple-deep;
            margin-bottom: 0.75rem;
            width: 1.375rem;
            height: 1.375rem;

            :global(html.dark) & { color: $rt-purple-bright; }
        }

        &__title {
            font-size: $font-size-md;
            font-weight: 600;
            color: var(--ks-content-primary);
            margin: 0 0 0.5rem;
            line-height: 1.3;
        }

        &__desc {
            font-size: $font-size-sm;
            color: var(--ks-content-secondary);
            line-height: 1.5;
            margin: 0;
        }
    }

    .build {
        padding: 3rem 0 4.5rem;
        background: var(--ks-background-primary);
        border-bottom: $block-border;

        .container {
            max-width: 73.75rem;
            margin: 0 auto;
            padding-inline: 0;

            h2 {
                margin-bottom: 1rem;
                padding-inline: $rem-1;
                text-align: center;

                .highlight { color: $rt-purple; }

                @include media-breakpoint-up(xl) { padding-inline: 0; }
            }

            .wrapper {
                border: 1px solid var(--ks-border-primary);
                box-shadow: 2px 3px 16px 0 var(--ks-shadows-light);
                border-radius: 13px;

                @include media-breakpoint-down(xl) { border-radius: 0; }

                .inner {
                    border-radius: $rem-1;
                    background: var(--ks-background-primary-inverse);
                    overflow: clip;

                    @include media-breakpoint-down(xxl) { border-radius: 0; }

                    .header {
                        border-bottom: 1px solid var(--ks-border-secondary-inverse);

                        & > div {
                            padding: 1.1875rem $rem-2;
                            font-size: $font-size-md;
                            color: var(--ks-content-secondary-inverse);
                            text-align: center;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            cursor: pointer;
                            transition: background-color 0.2s, color 0.2s, border-color 0.2s;

                            @include media-breakpoint-down(sm) { font-size: $font-size-sm; }

                            &.active {
                                background: var(--ks-background-secondary-inverse);
                                border-bottom: 1px solid var(--ks-border-active);
                                color: var(--ks-content-primary-inverse);
                                font-weight: 600;
                            }
                        }

                        & .middle-part {
                            border-left: 1px solid var(--ks-border-primary-inverse);
                            border-right: 1px solid var(--ks-border-primary-inverse);
                        }
                    }

                    .content {
                        display: none;
                        flex-direction: row;
                        gap: $rem-2;
                        padding: $rem-2;
                        justify-content: center;

                        &.active { display: flex; }

                        @include media-breakpoint-down(xl) {
                            flex-direction: column;
                            align-items: center;
                        }

                        @include media-breakpoint-down(sm) { padding: $rem-2 $rem-1; }

                        .panel {
                            border-radius: 0.5rem;
                            flex-shrink: 0;

                            &.panel-1 {
                                width: 39.4375rem;

                                @include media-breakpoint-down(xl) { width: 100%; }

                                :global(.code-card) {
                                    border: 1px solid var(--ks-border-secondary-inverse);
                                    background: var(--ks-background-input);
                                    height: 100%;

                                    :global(.code-inner) { transition: max-height 0.3s ease; }
                                    :global(.mdc-renderer pre) { padding: 0 1rem 1rem 1rem; }

                                    &:global(:not(.is-expanded)) {
                                        :global(.code-inner) { max-height: 27.9375rem !important; }
                                    }
                                }
                            }

                            &.panel-2 {
                                position: relative;
                                padding-top: $rem-2;
                                color: var(--ks-content-primary-inverse);
                                width: 27.5625rem;

                                @include media-breakpoint-down(xl) {
                                    width: 100%;
                                    padding-top: 0;
                                }

                                p {
                                    font-size: $font-size-lg;
                                    margin-top: $rem-1;
                                    margin-bottom: $rem-2;
                                }

                                .plugins {
                                    display: flex;
                                    gap: 0.5rem;
                                    flex-wrap: wrap;

                                    .plugin-icon {
                                        width: 2.125rem;
                                        height: 2.125rem;
                                        padding: 0.375rem;
                                        background: $white;
                                        border: $block-border;
                                        border-radius: $border-radius;
                                    }
                                }

                                .goto {
                                    position: absolute;
                                    bottom: 0;
                                    right: 0;
                                    color: var(--ks-content-link-inverse);
                                    font-weight: 600;

                                    @include media-breakpoint-down(xl) {
                                        position: relative;
                                        margin-top: $rem-3;
                                        float: right;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        &__lead {
            text-align: center;
            color: var(--ks-content-secondary);
            font-size: $font-size-lg;
            margin: 0 auto $rem-2;
            max-width: 44rem;
            padding-inline: $rem-1;
        }
    }

    .enterprise {
        padding: 140px 1rem 80px;
        gap: 40px;
        background: var(--ks-background-primary-inverse);
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        overflow: hidden;

        @include media-breakpoint-down(lg) { padding: 4rem 1rem 3rem; }

        &::after {
            content: "";
            position: absolute;
            width: 352.83px;
            height: 343.43px;
            border-radius: 50%;
            background: linear-gradient(179.01deg, $rt-purple 0.85%, $rt-purple-light 62.43%);
            opacity: 0.55;
            transform: rotate(45deg);
            filter: blur(36px);
            z-index: 1;
            top: -250px;
            left: -250px;
        }

        &::before {
            content: "";
            position: absolute;
            width: 120%;
            height: 314px;
            border-radius: 50%;
            background: linear-gradient(90deg, $rt-purple 0%, var(--ks-Color-gradient-1-inverse-2) 100%);
            filter: blur(36px);
            transform: rotate(-13.2074deg);
            z-index: 0;
            top: -210px;
            left: -65%;
            opacity: 0.45;
        }

        &__title {
            color: #fff;
            margin-bottom: 2.5rem;
            text-align: center;

            .highlight { color: $rt-purple-bright; }
        }

        :global(.features-grid) {
            box-shadow: 0 9px 36px 0 var(--ks-shadows-light-inverse);
        }

        :global(.feature-icon) {
            color: $rt-purple !important;
        }
        :global(.feature-title) {
            color: #fff !important;
        }
        :global(.feature-desc) {
            color: rgba(255, 255, 255, 0.72) !important;
        }

        .container-xxl { max-width: 1420px; }
    }

    .enterprise :global(.feature-card--cta) {
        width: 100%;
        padding: 2rem 4rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 1px 1px 0 0 var(--ks-border-secondary-inverse);

        @include media-breakpoint-down(lg) { padding: 2rem; }

        .btn { white-space: nowrap; }
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        for (const container of document.querySelectorAll(".build .inner")) {
            container.addEventListener("click", (e) => {
                const tab = (e.target as Element).closest(".header-tab") as HTMLElement
                const target = tab && (container as Element).querySelector(
                    `[data-tab-content="${tab.dataset.tabTarget}"]`
                )
                if (!target) return

                for (const el of container.querySelectorAll(".header-tab, .content")) {
                    el.classList.remove("active")
                }
                tab.classList.add("active")
                target.classList.add("active")
            })
        }
    })
</script>
