    },
    {
        id: "ingest",
        label: "INGEST",
        items: [
            "Shopify / Salesforce Commerce",
            "SAP / Oracle / Manhattan",
            "Snowflake / BigQuery / lakehouse",
            "S3 / ADLS / GCS / SFTP",
            "POS / OMS / WMS / PIM",
            "CRM, service & partner APIs",
        ],
    },
    {
        id: "process",
        label: "PROCESS",
        items: [
            "Business rules & validations",
            "dbt / SQL / Python / R / Spark",
            "Exception handling",
            "OCR / LLM document review",
            "Human approval gates",
            "Vault / KMS / policy controls",
        ],
    },
    {
        id: "act",
        label: "ACT",
        items: [
            "Update OMS / WMS / PIM",
            "Create case / task / ticket",
            "Trigger fulfillment / refund",
            "Update pricing / promo / loyalty",
            "Generate report / audit package",
            "Notify teams / downstream platforms",
