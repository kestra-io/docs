            },
        ],
    },
    {
        name: "Customer, Service & Loyalty",
        items: [
            {
                icon: "mdi:face-agent",
                title: "Customer Service & Case Management",
                description: "Route cases across Gorgias, Zendesk, Salesforce Service Cloud, and internal tools. Assemble order, shipment, and refund evidence. Escalate with full context.",
            },
            {
                icon: "mdi:heart-outline",
                title: "Loyalty, CRM & Personalization Data",
                description: "Coordinate customer events across CRM, marketing, analytics, and loyalty platforms. Trigger personalized campaigns from real operational signals, not batch dumps.",
            },
            {
                icon: "mdi:shield-search",
                title: "Fraud, Disputes & Trust Operations",
