    },
    {
        name: "Store, Data & Platform Operations",
        items: [
            {
                icon: "mdi:store-outline",
                title: "Store Operations & Omnichannel Handoffs",
                description: "Orchestrate BOPIS, click-and-collect, ship-from-store, and cross-channel returns. Keep store, e-commerce, and fulfillment systems in one operational loop.",
            },
            {
                icon: "mdi:database-sync-outline",
                title: "Operational Data Workflows",
                description: "Move, transform, and operationalize data across dbt, lakehouse, SQL, Python, and Spark to support live retail operations, not just analytics.",
            },
            {
                icon: "mdi:security-network",
