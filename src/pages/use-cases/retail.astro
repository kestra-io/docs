const ENTERPRISE_FEATURES = [
    {
        icon: ShieldCheckOutline,
        title: "Peak-Season Ready Deployment",
        description: "Self-hosted, VPC, or cloud. Horizontal worker scaling absorbs Black Friday and launch-day spikes without architectural surgery. PCI-friendly segmentation built in.",
    },
    {
        icon: Git,
        title: "Immutable, Replayable Execution",
        description: "Every flow is YAML in Git. Every execution frozen in time. Replay any historical order, price change, or campaign cutover with the exact code, secrets, and inputs.",
    },
    {
        icon: FileDocumentCheckOutline,
        title: "Human-in-the-Loop Controls",
        description: "Pause any workflow pending merchandiser, finance, or ops sign-off. Enforce dual control on price changes, large refunds, promo go-lives, and production rollouts.",
    },
    {
        icon: AccountGroupOutline,
        title: "RBAC & Multi-Tenant Isolation",
        description: "Namespace-scoped RBAC with SSO/SAML/SCIM. Every brand, region, or business line owns its secrets and runtime on a shared platform. Zero blast radius.",
    },
    {
        icon: CodeTagsCheck,
        title: "Audit Logs & Observability",
        description: "Every execution, user action, and resource change recorded. Stream logs directly to Splunk, Elastic, Datadog, or your preferred SIEM for PCI and SOC 2 evidence.",
    },
]

const BUILD_TABS = [
    {
        name: "Order orchestration",
        title: "From webhook to warehouse, with the exceptions routed automatically.",
        description:
            "An order lands on the webhook. Kestra validates it, reserves inventory, triggers fulfillment, and syncs status back to the storefront. Failures open Gorgias cases. Every step auditable.",
        code: `id: order-orchestration
namespace: company.retail.orders

inputs:
  - id: order
    type: JSON
    displayName: Order payload from storefront

tasks:
  - id: persist_order
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://oms:5432/orders"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    sql: |
      INSERT INTO orders.new (payload, received_at, status)
      VALUES ('{{ inputs.order | toJson }}', NOW(), 'received')
      RETURNING order_id

  - id: reserve_inventory
    type: io.kestra.plugin.core.http.Request
    uri: "https://wms.example/api/reserve"
    method: POST
    contentType: application/json
    body: "{{ inputs.order | toJson }}"
    headers:
      Authorization: "Bearer {{ secret('WMS_TOKEN') }}"

  - id: route_fulfillment
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.reserve_inventory.body.in_stock == true }}"
    then:
      - id: dispatch
        type: io.kestra.plugin.core.http.Request
        uri: "https://carriers.example/dispatch"
        method: POST
        contentType: application/json
        body: |
          { "order_id": "{{ outputs.persist_order.row.order_id }}" }
    else:
      - id: backorder_case
        type: io.kestra.plugin.core.http.Request
        uri: "https://api.gorgias.com/api/tickets"
        method: POST
        contentType: application/json
        headers:
          Authorization: "Basic {{ secret('GORGIAS_TOKEN') }}"
        body: |
          {
            "subject": "Backorder — order {{ outputs.persist_order.row.order_id }}",
            "channel": "email"
          }

  - id: notify_customer
    type: io.kestra.plugin.email.MailSend
    host: smtp.retail.example
    port: 465
    username: "{{ secret('SMTP_USER') }}"
    password: "{{ secret('SMTP_PASSWORD') }}"
    from: orders@retail.example
    to: "{{ inputs.order.customer_email }}"
    subject: "Order {{ outputs.persist_order.row.order_id }} confirmed"
    htmlTextContent: "Your order is being prepared."`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.core.flow.If" },
            { cls: "io.kestra.plugin.email.MailSend" },
        ],
        href: "/blueprints",
    },
    {
        name: "Returns & reverse logistics",
        title: "Return, restock, refund. One flow keeps OMS, WMS, and finance aligned.",
        description:
            "Authorize a return, route to the right reverse hub, trigger the refund, and update inventory. Breaks open cases in ServiceNow. Reconciliation bundles land in S3 for finance.",
        code: `id: returns-reverse-logistics
namespace: company.retail.returns

inputs:
  - id: return_request
    type: JSON
    displayName: Return request from storefront

tasks:
  - id: validate_return
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://oms:5432/orders"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    fetchType: FETCH_ONE
    sql: |
      SELECT order_id, total, currency, status
      FROM orders.completed
      WHERE order_id = '{{ inputs.return_request.order_id }}'

  - id: route_hub
    type: io.kestra.plugin.core.http.Request
    uri: "https://wms.example/api/reverse-route"
    method: POST
    contentType: application/json
    body: "{{ inputs.return_request | toJson }}"

  - id: human_review
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.validate_return.row.total > 500 }}"
    then:
      - id: finance_review
        type: io.kestra.plugin.core.flow.Pause
        description: "High-value refund requires finance sign-off."

  - id: issue_refund
    type: io.kestra.plugin.core.http.Request
    uri: "https://payments.example/v1/refunds"
    method: POST
    contentType: application/json
    body: |
      {
        "order_id": "{{ outputs.validate_return.row.order_id }}",
        "amount": {{ outputs.validate_return.row.total }}
      }

  - id: update_inventory
    type: io.kestra.plugin.core.http.Request
    uri: "https://wms.example/api/restock"
    method: POST
    contentType: application/json
    body: "{{ inputs.return_request | toJson }}"

  - id: publish_recon
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "retail-audit"
    key: "returns/{{ execution.startDate | date('yyyy/MM/dd') }}/{{ outputs.validate_return.row.order_id }}.json"
    from: "{{ outputs.route_hub.body }}"`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
    {
        name: "Inventory sync & exceptions",
        title: "Keep stock positions true across stores, marketplaces, and partners.",
        description:
            "Pull stock snapshots from WMS and partners, reconcile in Python, publish to storefronts and marketplaces, and route conflicts to merch ops. Peak-season scale, years of replay.",
        code: `id: inventory-sync
namespace: company.retail.inventory

triggers:
  - id: every_5_min
    type: io.kestra.plugin.core.trigger.Schedule
    cron: "*/5 * * * *"

tasks:
  - id: snapshot_wms
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://wms:5432/wms"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    fetchType: STORE
    sql: "SELECT sku, location, qty FROM wms.stock"

  - id: pull_partners
    type: io.kestra.plugin.core.http.Request
    uri: "https://marketplace.example/api/stock"
    method: GET
    headers:
      Authorization: "Bearer {{ secret('MARKET_TOKEN') }}"

  - id: reconcile
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python reconcile_stock.py --wms {{ outputs.snapshot_wms.uri }} --partner {{ outputs.pull_partners.uri }}

  - id: publish_storefront
    type: io.kestra.plugin.core.http.Request
    uri: "https://shop.example/admin/api/inventory"
    method: POST
    contentType: application/json
    body: "{{ outputs.reconcile.outputFiles.reconciled }}"

  - id: route_conflicts
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.reconcile.vars.conflicts > 0 }}"
    then:
      - id: notify_merch
        type: io.kestra.plugin.notifications.slack.SlackIncomingWebhook
        url: "{{ secret('SLACK_MERCH_URL') }}"
        payload: |
          { "text": "Inventory conflicts: {{ outputs.reconcile.vars.conflicts }}" }`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.core.flow.If" },
            { cls: "io.kestra.plugin.notifications.slack.SlackIncomingWebhook" },
        ],
        href: "/blueprints",
    },
]

const FAQ = [
    {
        question: "Can Kestra orchestrate order, return, and fulfillment workflows without replacing our OMS or WMS?",
        answer: "Yes. Kestra sits alongside Shopify, Salesforce Commerce, SAP Commerce, Oracle Retail, Manhattan, and custom OMS/WMS stacks. It connects them to payments, carriers, partners, and customer-facing systems with declarative flows, retries, and full audit. You modernize incrementally without rebuilding core commerce.",
    },
    {
        question: "Does Kestra handle omnichannel workflows: BOPIS, click-and-collect, ship-from-store, cross-channel returns?",
        answer: "Yes. Orchestrate handoffs across e-commerce, POS, store fulfillment, and reverse logistics. Kestra coordinates inventory reservation, associate notification, customer communication, and finance reconciliation so the same operational workflow spans every channel.",
    },
    {
        question: "Can Kestra scale through Black Friday, product launches, and peak seasons?",
        answer: "Yes. Horizontal worker scaling absorbs traffic spikes without architectural changes. Queue-backed triggers and per-namespace rate controls protect downstream systems. Pre-peak dry runs are replayable against production code, so launch-day behaviour is known before launch day.",
    },
    {
        question: "How does Kestra handle high-value refunds, price changes, and promo go-lives?",
        answer: "Four-eyes Pause tasks are first-class flow primitives. Any refund over a threshold, any price change, any promo go-live can pause for merchandiser, finance, or ops sign-off. Namespace-scoped RBAC enforces segregation of duties; every decision is versioned.",
    },
    {
        question: "Can Kestra power personalization, loyalty, and customer-data workflows?",
        answer: "Yes. Coordinate events across CRM, CDP, marketing, analytics, and loyalty platforms. Trigger personalized campaigns from real operational signals — orders, returns, service cases, store visits — not yesterday's batch dumps. Segment membership changes become actions in seconds, not days.",
    },
    {
        question: "Does Kestra help with fraud, disputes, and chargebacks?",
        answer: "Yes. Screen orders against vendor and internal signals, score with ML, route to manual review, and assemble chargeback evidence automatically. Kestra keeps the full decision trail one click away for dispute teams and acquirers.",
    },
    {
        question: "How does Kestra integrate with CS tools like Gorgias, Zendesk, and Salesforce Service Cloud?",
        answer: "Native HTTP plugins + dedicated integrations for Slack and email mean Gorgias, Zendesk, Intercom, or Service Cloud sit naturally in a flow. Assemble order, shipment, and refund context automatically so agents never open five tabs to resolve one ticket.",
    },
    {
        question: "How is Kestra different from Airflow, Control-M, or custom cron scripts?",
        answer: "Airflow and Control-M were built for batch data pipelines, not event-driven commerce. Kestra is declarative YAML over an event-first engine: webhooks, streams, and schedules are equals, retries and exception routing are built in, and every run is auditable out of the box.",
    },
    {
        question: "What deployment options exist and how are secrets handled?",
        answer: "Self-hosted in your private cloud or VPC, Kestra Cloud in EU or US, or fully air-gapped. Secrets come from Vault, AWS Secrets Manager, Azure Key Vault, GCP Secret Manager, or CyberArk. PCI-friendly segmentation is built in.",
    },
    {
        question: "Is Kestra open source, and what does the licensing model look like?",
        answer: "Kestra is Apache 2.0. Enterprise Edition adds SSO, RBAC, multi-tenancy, worker groups, advanced audit, and 24x7 support. Start with OSS. Upgrade when you need enterprise governance.",
    },
]

---

<Layout {title} {description} headerTheme="lightText">
    <div class="retail">

        <section class="hero">
            <img src="/hero-grid.svg" alt="" class="hero-bg-grid" aria-hidden="true" />
            <div class="hero-inner">
                <div class="badge-pill" data-usal="zoomin">
                    <Icon name="mdi:shopping-outline" />
                    <span>Retail &amp; Commerce</span>
                </div>

                <h1 data-usal="fade-u">
                    Kestra keeps retail operations<br />
                    <span class="gradient">in sync, even on launch day.</span>
                </h1>

                <p class="subtitle" data-usal="fade-l">
                    Retailers use Kestra to move orders, returns, inventory, and customers across OMS, WMS, storefront,
                    POS, and partner APIs without silent failures. Peak-season ready, queue-backed, replayable, and
                    audit-ready from supplier to storefront.
                </p>

                <div class="tags" data-usal="fade-l">
                    {HERO_TAGS.map((tag) => (
                        <span class="tag">
                            <Icon name={tag.icon} class="tag-icon" />
                            {tag.label}
                        </span>
                    ))}
                </div>

                <div class="exec-panel-wrapper" data-usal="fade-up">
                    <div class="exec-panel">
                        <div class="exec-panel__header">
                            <span class="exec-panel__dot"></span>
                            <span class="exec-panel__title">order-orchestration</span>
                            <span class="exec-panel__meta">namespace · company.retail.orders</span>
                            <span class="exec-panel__duration">1.1s</span>
                        </div>

                        <div class="exec-panel__body">
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">receive_order</span>
                                <span class="exec-row__type">core.http.Webhook</span>
                                <span class="exec-row__result">accepted</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">persist_order</span>
                                <span class="exec-row__type">jdbc.postgresql.Query</span>
                                <span class="exec-row__result">order #40821</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">reserve_inventory</span>
                                <span class="exec-row__type">core.http.Request</span>
                                <span class="exec-row__result">in stock</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">dispatch_carrier</span>
                                <span class="exec-row__type">core.http.Request</span>
                                <span class="exec-row__result">tracking #</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">update_storefront</span>
                                <span class="exec-row__type">core.http.Request</span>
                                <span class="exec-row__result">synced</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">notify_customer</span>
                                <span class="exec-row__type">email.MailSend</span>
                                <span class="exec-row__result">sent</span>
                            </div>
                        </div>

                        <div class="exec-panel__footer">
                            <span class="exec-footer__item">Peak-ready</span>
                            <span class="exec-footer__sep">·</span>
                            <span class="exec-footer__item">Replayable</span>
                            <span class="exec-footer__sep">·</span>
                            <span class="exec-footer__item">Exception-routed</span>
                        </div>
                    </div>
                </div>

                <div class="hero-ctas" data-usal="zoomin">
                    <Link href="/demo" class="btn btn-primary btn-lg">Book a Demo</Link>
                </div>

                <div class="hero-logos" data-usal="fade-u">
                    <span class="hero-logos__label">Used by retail, e-commerce, and consumer-goods teams</span>
                    <div class="hero-logos__row">
                        <Image src={LeroyMerlinLogoImg} alt="Leroy Merlin" class="hero-logos__item" />
                        <Image src={AuchanLogoImg} alt="Auchan" class="hero-logos__item" />
                        <Image src={DecathlonLogoImg} alt="Decathlon" class="hero-logos__item" />
                        <Image src={IntersportLogoImg} alt="Intersport" class="hero-logos__item" />
                        <Image src={DiorLogoImg} alt="Dior" class="hero-logos__item" />
                        <Image src={GorgiasLogoImg} alt="Gorgias" class="hero-logos__item" />
                        <Image src={FilaLogoImg} alt="Fila" class="hero-logos__item" />
                    </div>
                </div>
            </div>
        </section>

        <section class="flow">
            <div class="container-xxl">
                <h2 class="flow__title text-center">
                    Any <span class="highlight">system</span>. Any <span class="highlight">workflow</span>. Any <span class="highlight">control model</span>.
                </h2>
                <p class="flow__lead">
                    Order, return, stock change, promo go-live, customer case, or supplier feed. The orchestration job is the same: connect systems, route exceptions, trigger actions, keep the books aligned.
                </p>

                <div class="flow__grid">
                    <div class="flow__steps">
                        {FLOW_STAGES.map((stage, idx) => (
                            <div class={`flow-block flow-${idx}`}>
                                <div class="flow-block__content">
                                    <span class={`flow-block__label label-${stage.id}`}>{stage.label}</span>
                                    <div class={`flow-block__card card-${stage.id}`}>
                                        <div class="flow-block__items">
                                            {stage.items.map(item => (
                                                <div class="flow-block__item">{item}</div>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                                {idx < FLOW_STAGES.length - 1 && (
                                    <div class={`flow-arrow arrow-${idx}`}>
                                        <div class="line" />
                                        <Icon name="mdi:play" class="head" width={16} height={16} />
                                    </div>
                                )}
                            </div>
                        ))}
                    </div>
                </div>

                <h5 class="flow__footer text-center">
                    Each step is a declarative YAML task. Change the source system, workflow step, or destination without rebuilding the whole process.
                </h5>
            </div>
        </section>

        <section class="workloads">
            <div class="container">
                <div class="workloads__head">
                    <h2>Every critical workflow in retail and commerce.</h2>
                    <p>Orders and returns, inventory and pricing, customer and loyalty, store and platform operations. One engine runs them all.</p>
                </div>
                {WORKLOAD_CATEGORIES.map(cat => (
                    <div class="workloads__group">
                        <h3 class="workloads__category">{cat.name}</h3>
                        <div class="workloads__grid">
                            {cat.items.map(item => (
                                <div class="workload-card">
                                    <Icon name={item.icon} class="workload-card__icon" />
                                    <h4 class="workload-card__title">{item.title}</h4>
                                    <p class="workload-card__desc">{item.description}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <Quotes {quotes} client:load />

        <section class="enterprise">
            <div class="container-xxl">
                <h2 class="enterprise__title" data-usal="fade-r">
                    <span class="highlight">Enterprise-Grade</span> Orchestration for Every Retail Workload.
                </h2>
                <NoGapGrid items={ENTERPRISE_FEATURES}>
                    <div class="feature-card feature-card--cta">
                        <a href="/demo" class="btn btn-secondary" data-usal="zoomin">
                            Book a Demo
                        </a>
                    </div>
                </NoGapGrid>
            </div>
        </section>

        <section class="build">
            <div class="container">
                <h2><span class="highlight">Blueprints</span> for retail and commerce.</h2>
                <p class="build__lead">Production workflows, from order orchestration to inventory sync. Copy the YAML. Wire it to your stack. Ship it through your CI.</p>
                <div class="wrapper">
                    <div class="inner">
                        <div class="header row g-0">
                            {BUILD_TABS.map((tab, idx) => (
                                <div
                                    class:list={[
                                        "col-6 col-md-4 header-tab",
                                        { active: idx === 0, "middle-part": idx > 0 && idx < BUILD_TABS.length - 1 },
                                    ]}
                                    data-tab-target={idx}
                                >
                                    {tab.name}
                                </div>
                            ))}
                        </div>

                        {BUILD_TABS.map((tab, idx) => (
                            <div class:list={["content", { active: idx === 0 }]} data-tab-content={idx}>
                                <div class="panel panel-1">
                                    <Snippets client:idle code={tab.code} lang="yaml" />
                                </div>
                                <div class="panel panel-2">
                                    <h3 data-usal="fade-r">{tab.title}</h3>
                                    <p data-usal="fade-l">{tab.description}</p>
                                    <div class="plugins" data-usal="zoomin">
                                        {tab.plugins.map(plugin => (
                                            <div class="plugin-icon">
                                                <TaskIcon cls={plugin.cls} />
                                            </div>
                                        ))}
                                    </div>
                                    <Link class="goto" href={tab.href} data-usal="fade-r">
                                        Explore Blueprints
                                    </Link>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <GoFurther />

        <PluginsBlock>
            <Fragment slot="title">
                Integrates with the <span class="highlight">systems regulated teams</span> already rely on.
            </Fragment>
            <Fragment slot="description">
                Connect core platforms, policy and claims systems, data stacks, messaging layers, case tools,
                and security controls through 1,200+ plugins. Or build the exact integration your environment requires.
            </Fragment>
        </PluginsBlock>

        <SeeHow cta={{ text: "Book a Demo", href: "/demo" }}>
            <Fragment slot="title">One platform for retail and commerce.</Fragment>
            Modernize commerce stacks, connect the tools your teams already use, and add lineage, approvals,
            and observability across orders, returns, inventory, pricing, customer service, and store operations.
        </SeeHow>

        <Faq items={FAQ} client:visible />
    </div>
</Layout>

<style lang="scss">
    $rt-purple:        #7C3AED;
