    {
        question: "What workflow automation platforms do retail and e-commerce companies use?",
        answer: `Common platforms include Informatica, Talend, <a href="/vs/airflow">Apache Airflow</a>, <a href="/vs/azure-data-factory">Azure Data Factory</a>, and custom scripts. Kestra replaces them on one self-hosted open-source engine — connecting SAP, Oracle ERP, Salesforce Commerce, Shopify, Gorgias, and warehouse systems side-by-side, with DataMesh-ready namespace isolation, multi-language support, and no per-connector licensing fees.`,
    },
]

---

<Layout {title} {description} headerTheme="lightText">
    <SchemaFAQ items={FAQ} slot="head" />
    <SchemaService
        slot="head"
        serviceType="Retail and E-Commerce Workflow Automation"
        audienceType="Retail Companies, E-Commerce Businesses, and Supply Chain Teams"
        description={description}
    />
    <div class="retail">

        <section class="hero">
            <img src="/hero-grid.svg" alt="" class="hero-bg-grid" aria-hidden="true" />
            <div class="hero-inner">
                <div class="badge-pill" data-usal="zoomin">
                    <Icon name="mdi:shopping-outline" />
                    <span>Retail &amp; Commerce</span>
                </div>

                <h1 data-usal="fade-u">
                    Retail workflow automation<br />
                    <span class="gradient">and data orchestration at scale.</span>
                </h1>

                <p class="subtitle" data-usal="fade-l">
                    Scale data platforms across teams. Automate approval workflows and operations.
                    Modernize legacy ERP and supply-chain integration. One open-source engine, on infrastructure you control.
                </p>

                <div class="tags" data-usal="fade-l">
                    {HERO_TAGS.map((tag) => (
                        <span class="tag">
                            <Icon name={tag.icon} class="tag-icon" />
                            {tag.label}
                        </span>
                    ))}
                </div>

                <div class="exec-panel-wrapper" data-usal="fade-up">
                    <div class="exec-panel">
                        <div class="exec-panel__header">
                            <span class="exec-panel__dot"></span>
                            <span class="exec-panel__title">domain-data-pipeline</span>
                            <span class="exec-panel__meta">namespace · company.retail.domain_supply</span>
                            <span class="exec-panel__duration">2.1s</span>
                        </div>

                        <div class="exec-panel__body">
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">extract_source</span>
                                <span class="exec-row__type">jdbc.postgresql.Query</span>
                                <span class="exec-row__result">14,322 rows</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">dbt_build</span>
                                <span class="exec-row__type">dbt.cli.Build</span>
                                <span class="exec-row__result">42 models</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">quality_checks</span>
                                <span class="exec-row__type">scripts.python.Commands</span>
                                <span class="exec-row__result">passed</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">merch_approval</span>
                                <span class="exec-row__type">core.flow.Pause</span>
                                <span class="exec-row__result">Approved</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">publish_lakehouse</span>
                                <span class="exec-row__type">aws.s3.Upload</span>
                                <span class="exec-row__result">parquet ok</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">register_catalog</span>
                                <span class="exec-row__type">core.http.Request</span>
                                <span class="exec-row__result">cataloged</span>
                            </div>
                        </div>

                        <div class="exec-panel__footer">
                            <span class="exec-footer__item">Multi-tenant</span>
                            <span class="exec-footer__sep">·</span>
                            <span class="exec-footer__item">Replayable</span>
                            <span class="exec-footer__sep">·</span>
                            <span class="exec-footer__item">Audit-ready</span>
                        </div>
                    </div>
                </div>

                <div class="hero-ctas" data-usal="zoomin">
                    <Link href="/demo" class="btn btn-primary btn-lg">Book a Demo</Link>
                </div>

                <div class="hero-logos" data-usal="fade-u">
                    <span class="hero-logos__label">Trusted by retail, commerce, and consumer-goods teams</span>
                    <div class="hero-logos__row">
                        <a href="/use-cases/stories/datamesh-at-scale-increased-its-data-production-by-900percent" aria-label="Read the Leroy Merlin DataMesh customer story">
                            <Image src={LeroyMerlinLogoImg} alt="Leroy Merlin" class="hero-logos__item hero-logos__item--leroy" />
                        </a>
                        <a href="/use-cases/stories/gorgias-using-declarative-data-engineering-orchestration-with-kestra" aria-label="Read the Gorgias customer story">
                            <Image src={GorgiasLogoImg} alt="Gorgias" class="hero-logos__item hero-logos__item--gorgias" />
                        </a>
                        <Image src={AuchanLogoImg} alt="Auchan" class="hero-logos__item hero-logos__item--auchan" />
                        <Image src={DecathlonLogoImg} alt="Decathlon" class="hero-logos__item hero-logos__item--decathlon" />
                        <Image src={IntersportLogoImg} alt="Intersport" class="hero-logos__item hero-logos__item--intersport" />
                        <Image src={DiorLogoImg} alt="Dior" class="hero-logos__item hero-logos__item--dior" />
                        <Image src={FilaLogoImg} alt="FILA" class="hero-logos__item hero-logos__item--fila" />
                    </div>
                </div>
            </div>
        </section>

        <section class="flow">
            <div class="container-xxl">
                <h2 class="flow__title text-center">
                    How <span class="highlight">retail workflow automation</span> connects ERP, e-commerce, and supply chain.
                </h2>
                <p class="flow__lead">
                    Data pipelines per business domain. Approval workflows in front of merchandising and ops.
                    Supplier file normalization. ERP modernization. Whether you're scaling a DataMesh, automating
                    price-change approvals, or migrating off a legacy integration platform, the engine is the same.
                </p>

                <div class="flow__grid">
                    <div class="flow__steps">
                        {FLOW_STAGES.map((stage, idx) => (
                            <div class={`flow-block flow-${idx}`}>
                                <div class="flow-block__content">
                                    <span class={`flow-block__label label-${stage.id}`}>{stage.label}</span>
                                    <div class={`flow-block__card card-${stage.id}`}>
                                        <div class="flow-block__items">
                                            {stage.items.map(item => (
                                                <div class="flow-block__item">{item}</div>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                                {idx < FLOW_STAGES.length - 1 && (
                                    <div class={`flow-arrow arrow-${idx}`}>
                                        <div class="line" />
                                        <Icon name="mdi:play" class="head" width={16} height={16} />
                                    </div>
                                )}
                            </div>
                        ))}
                    </div>
                </div>

                <h5 class="flow__footer text-center">
                    Each step is a declarative YAML task. Wrap an existing legacy job today. Modernize it in place tomorrow. No rewrite of the whole estate.
                </h5>
            </div>
        </section>

        <section class="workloads">
            <div class="container">
                <div class="workloads__head">
                    <h2>Workflow automation use cases in retail and e-commerce.</h2>
                    <p>Real workloads from real retail and commerce teams. DataMesh at enterprise scale. ERP modernization at global brands. Workflow automation across DIY, fashion, and consumer goods. Customer service context one click away. Mission-critical integration replaced one workflow at a time.</p>
                </div>
                {WORKLOAD_CATEGORIES.map(cat => (
                    <div class="workloads__group">
                        <h3 class="workloads__category">{cat.name}</h3>
                        <div class="workloads__grid">
                            {cat.items.map(item => (
                                <div class="workload-card">
                                    <Icon name={item.icon} class="workload-card__icon" />
                                    <h4 class="workload-card__title">{item.title}</h4>
                                    <p class="workload-card__desc">{item.description}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <Quotes {quotes} client:load />

        <section class="enterprise">
            <div class="container-xxl">
                <h2 class="enterprise__title" data-usal="fade-r">
                    Retail data orchestration requirements: <span class="highlight">DataMesh, RBAC, and scale</span>.
                </h2>
                <NoGapGrid items={ENTERPRISE_FEATURES}>
                    <div class="feature-card feature-card--cta">
                        <a href="/demo" class="btn btn-secondary" data-usal="zoomin">
                            Book a Demo
                        </a>
                    </div>
                </NoGapGrid>
            </div>
        </section>

        <section class="build">
            <div class="container">
                <h2>Retail workflow automation <span class="highlight">examples and blueprints</span>.</h2>
                <p class="build__lead">Real workflows running today inside retail, commerce, and consumer-goods teams. Copy the YAML, adapt to your stack, deploy through your existing CI and approvals.</p>
                <div class="wrapper">
                    <div class="inner">
                        <div class="header row g-0">
                            {BUILD_TABS.map((tab, idx) => (
                                <div
                                    class:list={[
                                        "col-6 col-md-3 header-tab",
                                        { active: idx === 0, "middle-part": idx > 0 && idx < BUILD_TABS.length - 1 },
                                    ]}
                                    data-tab-target={idx}
                                >
                                    {tab.name}
                                </div>
                            ))}
                        </div>

                        {BUILD_TABS.map((tab, idx) => (
                            <div class:list={["content", { active: idx === 0 }]} data-tab-content={idx}>
                                <div class="panel panel-1">
                                    <Snippets client:idle code={tab.code} lang="yaml" />
                                </div>
                                <div class="panel panel-2">
                                    <h3 data-usal="fade-r">{tab.title}</h3>
                                    <p data-usal="fade-l">{tab.description}</p>
                                    <div class="plugins" data-usal="zoomin">
                                        {tab.plugins.map(plugin => (
                                            <div class="plugin-icon">
                                                <TaskIcon cls={plugin.cls} />
                                            </div>
                                        ))}
                                    </div>
                                    <Link class="goto" href={tab.href} data-usal="fade-r">
                                        Explore Blueprints
                                    </Link>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <GoFurther />

        <PluginsBlock>
            <Fragment slot="title">
                Integrates with the <span class="highlight">systems retail teams</span> already run.
            </Fragment>
            <Fragment slot="description">
                Connect OMS, WMS, POS, storefronts, PIM, payment gateways, carriers, CS tools, loyalty platforms,
                and analytics stacks through {totalPlugins}+ plugins. Or build the exact integration your environment requires.
            </Fragment>
        </PluginsBlock>

        <SeeHow cta={{ text: "Book a Demo", href: "/demo" }}>
            <Fragment slot="title">Run retail data and operations on a platform you fully own.</Fragment>
            Self-hosted, EU-ready, and procurement-friendly. Scale data platforms across teams,
            automate business workflows, and modernize legacy integrations incrementally.
            One open-source engine.
        </SeeHow>

        <Faq items={FAQ} client:visible />
    </div>
</Layout>

<style lang="scss">
    // ── Retail palette: brand purple ─────────────────────────────────
    // Distinct from FSI (yellow), Healthcare (green), Public Services
    // (cobalt), Automotive (red). Reads as commerce, brand, premium.
    $rt-purple:        #7C3AED;
    $rt-purple-bright: #A78BFA;
    $rt-purple-light:  #EDE9FE;
    $rt-purple-deep:   #581C87;
    $rt-platinum:      #E8EDF0;

    .retail { overflow: clip; }

    :global(html.dark) .retail {
        .flow,
        .workloads,
        .build,
        .enterprise {
            background: #1C1C20;
        }
        :global(section.quotes-wrapper),
        :global(section.plugin-block),
        :global(.see) {
            background: #1C1C20;
        }
    }

    .hero {
        position: relative;
        overflow: hidden;
        background: #0a0514;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin-top: calc(-1 * var(--top-bar-height, 67px) - var(--announce-height, 0px));
        padding: calc(var(--top-bar-height, 67px) + var(--announce-height, 0px) + 5rem) 1.5rem 6rem;

        @include media-breakpoint-down(md) {
            padding: calc(var(--top-bar-height, 67px) + var(--announce-height, 0px) + 3rem) 1rem 4rem;
        }

        &::after {
            content: "";
            position: absolute;
            bottom: -260px;
            left: 50%;
            transform: translateX(-50%);
            width: 1100px;
            height: 520px;
            background: radial-gradient(ellipse at center, rgba(124, 58, 237, 0.32) 0%, rgba(124, 58, 237, 0) 70%);
            pointer-events: none;
            z-index: 0;
        }
    }

    .hero-bg-grid {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        max-width: 1720px;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        pointer-events: none;
        z-index: 0;
        opacity: 0.5;
    }

    .hero-inner {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        width: 100%;
        max-width: 68rem;
        color: $white;
        text-align: center;

        @include media-breakpoint-down(md) { gap: 1.5rem; }

        h1 {
            color: $white;
            font-weight: 600;
            line-height: 1.1;
            letter-spacing: -0.02em;
            margin: 0;
        }

        .gradient {
            background: linear-gradient(90deg, #{$rt-purple-bright}, #{$rt-purple-light});
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            color: rgba(255, 255, 255, 0.82);
            font-size: $font-size-lg;
            line-height: 1.6;
            max-width: 48rem;
            margin: 0;

            @include media-breakpoint-down(md) { font-size: $font-size-md; }
        }
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 4px 1.125rem;
        gap: 0.5rem;
        border-radius: 2.5rem;
        background: #0a0514;
        position: relative;
        z-index: 1;
        font-size: $font-size-xs;
        font-weight: 600;
        color: $rt-purple-bright;

        &::before {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: 2.5rem;
            padding: 1px;
            background: linear-gradient(90deg, #{$rt-purple} 0%, #{$rt-purple-light} 100%);
            -webkit-mask: linear-gradient($white 0 0) content-box, linear-gradient($white 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            z-index: -1;
        }
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
    }

    .tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 9999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.78);
        font-size: $font-size-xs;
        white-space: nowrap;
        transition: all 0.2s ease;

        &:hover {
            border-color: rgba(167, 139, 250, 0.55);
            background: rgba(124, 58, 237, 0.14);
            color: $white;

            :global(.tag-icon) { color: $rt-purple-light; }
        }

        :global(.tag-icon) {
            width: 12px;
            height: 12px;
            color: $rt-purple-bright;
            flex-shrink: 0;
        }
    }

    @property --rt-neon-angle {
        syntax: '<angle>';
        inherits: false;
        initial-value: 0deg;
    }

    @keyframes rt-neon-trace {
        to { --rt-neon-angle: 360deg; }
    }

    .exec-panel-wrapper {
        --rt-neon-angle: 0deg;
        border-radius: 10px;
        background: conic-gradient(
            from var(--rt-neon-angle),
            rgba(124, 58, 237, 0.16) 0deg,
            rgba(124, 58, 237, 0.16) 320deg,
            #{$rt-purple}              340deg,
            $rt-platinum               350deg,
            #{$rt-purple}              360deg
        );
        padding: 1px;
        box-shadow:
            0 1.214px 10.321px 0 rgba(124, 58, 237, 0.28) inset,
            -6.667px -7.143px 31.334px 3.333px rgba(124, 58, 237, 0.6);
        width: 100%;
        max-width: 640px;
        animation: rt-neon-trace 5s linear infinite;
    }

    .exec-panel {
        background: #110a1d;
        border-radius: 9px;
        overflow: hidden;
        backdrop-filter: blur(12px);
        text-align: left;

        &__header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 12px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(124, 58, 237, 0.08);
            flex-wrap: wrap;
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
        }

        &__dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: $rt-purple-bright;
            box-shadow: 0 0 8px $rt-purple-bright;
            flex-shrink: 0;
        }

        &__title {
            color: $white;
            font-weight: 600;
        }

        &__meta {
            color: rgba(255, 255, 255, 0.45);
            flex: 1;

            @include media-breakpoint-down(sm) { display: none; }
        }

        &__duration {
            color: $rt-purple-light;
            font-weight: 500;
        }

        &__body {
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        &__footer {
            padding: 10px 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(124, 58, 237, 0.06);
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            color: $rt-purple-light;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .exec-footer__sep { color: rgba(255, 255, 255, 0.25); }
    }

    .exec-row {
        display: grid;
        grid-template-columns: 20px minmax(130px, 1fr) minmax(150px, 1fr) minmax(90px, auto);
        align-items: center;
        gap: 1rem;
        padding: 6px 8px;
        border-radius: 4px;
        font-family: $font-family-monospace;
        font-size: $font-size-xs;
        transition: background 0.2s;

        &:hover { background: rgba(124, 58, 237, 0.10); }

        @include media-breakpoint-down(sm) {
            grid-template-columns: 20px 1fr auto;
        }

        &__check {
            color: $rt-purple-bright;
            font-weight: 700;
        }

        &__name {
            color: $white;
            font-weight: 500;
        }

        &__type {
            color: rgba(255, 255, 255, 0.45);

            @include media-breakpoint-down(sm) { display: none; }
        }

        &__result {
            color: $rt-purple-light;
            text-align: right;
            white-space: nowrap;
        }
    }

    .hero-ctas {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;

        .btn {
            justify-content: center;

            @include media-breakpoint-down(md) {
                width: auto;
                min-width: 200px;
            }
        }
    }

    // ── Hero logo strip ──────────────────────────────────────────────
    // 7 logos, 4+3 grid at md+, 2-col stack on mobile. Per-logo
    // sizing tuned to each SVG's aspect ratio.
    .hero-logos {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        align-items: center;
        justify-content: center;
        margin-top: 1rem;
        padding-top: 2rem;
        width: 100%;
        max-width: 56rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;

        &__label {
            font-size: $font-size-xs;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.6);
        }

        &__row {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            align-items: center;
            justify-items: center;
            column-gap: 0.5rem;
            row-gap: 1.5rem;
            width: 100%;

            @include media-breakpoint-down(md) {
                grid-template-columns: repeat(2, 1fr);
                column-gap: 1.5rem;
                row-gap: 1.5rem;
            }
        }

        &__item {
            width: auto;
            height: auto;
            display: block;
            filter: brightness(0) invert(1);
            opacity: 0.85;
            transition: opacity 0.2s;
            object-fit: contain;
            max-width: 100%;

            &:hover { opacity: 1; }

            // Row 1: 4 logos, each spans 3 of 12 cols
            &:nth-child(-n+4) { grid-column: span 3; }
            // Row 2: 3 logos, each spans 4 of 12 cols
            &:nth-child(n+5)  { grid-column: span 4; }

            @include media-breakpoint-down(md) {
                &:nth-child(-n+4),
                &:nth-child(n+5) { grid-column: auto; }
            }

            // Unified optical sizing across all industry pages:
            // text wordmarks 36px, small text 32px, compact icon+text
            // 42px, stacked vertically icon+text 52–56px.
            &--leroy      { max-height: 36px; max-width: 180px; }  // text
            &--gorgias    { max-height: 36px; max-width: 160px; }  // text
            &--auchan     { max-height: 36px; max-width: 140px; }  // text
            &--decathlon  { max-height: 36px; max-width: 180px; }  // text wide
            &--intersport { max-height: 36px; max-width: 180px; }  // text wide
            &--dior       { max-height: 32px; max-width: 110px; }  // small text
            &--fila       { max-height: 32px; max-width: 120px; }  // small text

            @include media-breakpoint-down(md) {
                &--leroy      { max-height: 40px; max-width: 200px; }
                &--gorgias    { max-height: 40px; max-width: 180px; }
                &--auchan     { max-height: 40px; max-width: 160px; }
                &--decathlon  { max-height: 40px; max-width: 200px; }
                &--intersport { max-height: 40px; max-width: 200px; }
                &--dior       { max-height: 36px; max-width: 130px; }
                &--fila       { max-height: 36px; max-width: 140px; }
            }
        }
    }

    $stages: (
        "trigger": ( "bg": #fff3d3, "border": #a87f4f, "label": #b87f00 ),
        "ingest":  ( "bg": #cbe2ff, "border": #6b62f2, "label": #0069c6 ),
        "process": ( "bg": #e3cffe, "border": #bb62f2, "label": #822bfd ),
        "act":     ( "bg": #d3ffe0, "border": #4fa876, "label": #007336 )
    );

    .flow {
        position: relative;
        background: var(--ks-background-secondary);
        padding: 5.5rem 1rem;
        overflow: hidden;

        .container-xxl {
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        &__title {
            margin-bottom: 1rem;
            color: var(--ks-content-primary);

            .highlight {
                background: linear-gradient(90deg, #{$rt-purple}, #{$rt-purple-bright});
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }
        }

        &__lead {
            text-align: center;
            color: var(--ks-content-secondary);
            font-size: $font-size-lg;
            line-height: 1.55;
            max-width: 50rem;
            margin: 0 auto 3rem;
        }

        &__footer {
            margin-top: 2rem;
            color: var(--ks-content-secondary);
            font-weight: 500;
        }

        &__grid {
            width: 100%;
            padding: 2rem 1rem;
            background-color: rgba(124, 58, 237, 0.06);
            background-image: url("data:image/svg+xml,%3csvg width='100%25' height='100%25' xmlns='http://www.w3.org/2000/svg'%3e%3crect width='100%25' height='100%25' fill='none' rx='10' ry='10' stroke='%237C3AED' stroke-width='1' stroke-dasharray='8%2c 8' stroke-dashoffset='0' stroke-linecap='square'/%3e%3c/svg%3e");
            border-radius: 10px;
        }

        &__steps {
            display: flex;
            justify-content: center;
            align-items: stretch;
            width: 100%;

            @include media-breakpoint-down(xl) {
                display: grid;
                grid-template-columns: repeat(2, auto);
                row-gap: 80px;
                column-gap: 40px;
            }

            @include media-breakpoint-down(sm) {
                grid-template-columns: 1fr;
                row-gap: 60px;
                column-gap: 0;
            }
        }
    }

    .flow-block {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;

        &__content {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            z-index: 1;

            @include media-breakpoint-down(sm) {
                width: 100%;
                max-width: 320px;
                margin-top: 0.5rem;
            }
        }

        &__label {
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            text-transform: uppercase;
            font-weight: 700;

            @each $id, $colors in $stages {
                &.label-#{$id} { color: map-get($colors, "label"); }
            }
        }

        &__card {
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            width: 240px;
            min-height: 340px;
            padding: 16px;
            border-radius: 8px;

            @include media-breakpoint-down(lg) {
                width: 220px;
                min-height: 330px;
            }

            @include media-breakpoint-down(sm) {
                width: 100%;
                min-height: auto;
                padding: 24px 16px;
            }

            @each $id, $colors in $stages {
                &.card-#{$id} {
                    background: map-get($colors, "bg");
                    border: 1px solid map-get($colors, "border");
                }
            }
        }

        &__items {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        &__item {
            position: relative;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px;
            background: #ffffff;
            border: 1px solid #333638;
            border-radius: 4px;
            color: #333638;
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            font-weight: 700;
            box-shadow: 4px 4px 0 0 #EBEBEB, 4px 4px 0 1px #333638CC;
        }
    }

    .flow-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 2;

        .line {
            background: #000000;
            html.dark & { background: #ffffff; }
        }

        .head {
            position: absolute;
            color: #000000;
            html.dark & { color: #ffffff; }
        }

        @include media-breakpoint-up(xl) {
            width: 90px;

            .line { width: 100%; height: 1.5px; }
            .head {
                right: -4px;
                top: 50%;
                transform: translateY(-50%);
            }
        }

        @include media-breakpoint-between(sm, xl) {
            &.arrow-0, &.arrow-1 {
                position: absolute;
                top: calc(100% + 4px);
                left: 50%;
                height: 72px;
                width: 1.5px;
                transform: translateX(-50%);

                .line { width: 1.5px; height: 100%; }
                .head {
                    bottom: -5px;
                    left: 50%;
                    transform: translateX(-50%) rotate(90deg);
                }
            }
            &.arrow-2 { display: none; }
        }

        @include media-breakpoint-down(sm) {
            position: absolute;
            top: calc(100% + 4px);
            left: 50%;
            height: 58px;
            width: 1.5px;
            transform: translateX(-50%);

            .line { width: 1.5px; height: 100%; }
            .head {
                bottom: -6px;
                left: 50%;
                transform: translateX(-50%) rotate(90deg);
            }
        }
    }

    .workloads {
        position: relative;
        padding: 5rem 1rem;
        background: var(--ks-background-body);
        overflow: hidden;

        > .container {
            position: relative;
            z-index: 1;
        }

        &__head {
            text-align: center;
            max-width: 46rem;
            margin: 0 auto 3rem;

            h2 { color: var(--ks-content-primary); margin-bottom: 0.75rem; }
            p { color: var(--ks-content-secondary); font-size: $font-size-lg; margin: 0; }
        }

        &__highlight {
            background: linear-gradient(90deg, #{$rt-purple}, #{$rt-purple-bright});
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        &__group {
            max-width: 72rem;
            margin: 0 auto 3rem;

            &:last-child { margin-bottom: 0; }
        }

        &__category {
            font-size: $font-size-sm;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: $rt-purple-deep;
            margin: 0 0 1rem;

            :global(html.dark) & { color: $rt-purple-bright; }
        }

        &__grid {
            display: grid;
            gap: 1rem;
            grid-template-columns: 1fr;

            @include media-breakpoint-up(md) { grid-template-columns: repeat(3, 1fr); }
        }
    }

    .workload-card {
        padding: 1.5rem;
        background: var(--ks-background-primary);
        border: 1px solid var(--ks-border-secondary);
        border-radius: 10px;
        box-shadow: 0 1px 3px 0 var(--ks-shadows-light);
        transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;

        &:hover {
            border-color: $rt-purple;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px 0 var(--ks-shadows-light);
        }

        &__icon {
            font-size: 1.375rem;
            color: $rt-purple;
            margin-bottom: 0.75rem;
            width: 1.375rem;
            height: 1.375rem;

            :global(html.dark) & { color: $rt-purple-bright; }
        }

        &__title {
            font-size: $font-size-md;
            font-weight: 600;
            color: var(--ks-content-primary);
            margin: 0 0 0.5rem;
            line-height: 1.3;
        }

        &__desc {
            font-size: $font-size-sm;
            color: var(--ks-content-secondary);
            line-height: 1.5;
            margin: 0;
        }
    }

    .build {
        padding: 3rem 0 4.5rem;
        background: var(--ks-background-primary);
        border-bottom: $block-border;

        .container {
            max-width: 73.75rem;
            margin: 0 auto;
            padding-inline: 0;

            h2 {
                margin-bottom: 1rem;
                padding-inline: $rem-1;
                text-align: center;

                .highlight {
                    background: linear-gradient(90deg, #{$rt-purple}, #{$rt-purple-bright});
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                    background-clip: text;
                }

                @include media-breakpoint-up(xl) { padding-inline: 0; }
            }

            .wrapper {
                border: 1px solid var(--ks-border-primary);
                box-shadow: 2px 3px 16px 0 var(--ks-shadows-light);
                border-radius: 13px;

                @include media-breakpoint-down(xl) { border-radius: 0; }

                .inner {
                    border-radius: $rem-1;
                    background: var(--ks-background-primary-inverse);
                    overflow: clip;

                    @include media-breakpoint-down(xxl) { border-radius: 0; }

                    .header {
                        border-bottom: 1px solid var(--ks-border-secondary-inverse);

                        & > div {
                            padding: 1.1875rem $rem-2;
                            font-size: $font-size-md;
                            color: var(--ks-content-secondary-inverse);
                            text-align: center;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            cursor: pointer;
                            transition: background-color 0.2s, color 0.2s, border-color 0.2s;

                            @include media-breakpoint-down(sm) { font-size: $font-size-sm; }

                            &.active {
                                background: var(--ks-background-secondary-inverse);
                                border-bottom: 1px solid var(--ks-border-active);
                                color: var(--ks-content-primary-inverse);
                                font-weight: 600;
                            }
                        }

                        & .middle-part {
                            border-left: 1px solid var(--ks-border-primary-inverse);
                            border-right: 1px solid var(--ks-border-primary-inverse);
                        }
                    }

                    .content {
                        display: none;
                        flex-direction: row;
                        gap: $rem-2;
                        padding: $rem-2;
                        justify-content: center;

                        &.active { display: flex; }

                        @include media-breakpoint-down(xl) {
                            flex-direction: column;
                            align-items: center;
                        }

                        @include media-breakpoint-down(sm) { padding: $rem-2 $rem-1; }

                        .panel {
                            border-radius: 0.5rem;
                            flex-shrink: 0;

                            &.panel-1 {
                                width: 39.4375rem;

                                @include media-breakpoint-down(xl) { width: 100%; }

                                :global(.code-card) {
                                    border: 1px solid var(--ks-border-secondary-inverse);
                                    background: var(--ks-background-input);
                                    height: 100%;

                                    :global(.code-inner) { transition: max-height 0.3s ease; }
                                    :global(.mdc-renderer pre) { padding: 0 1rem 1rem 1rem; }

                                    &:global(:not(.is-expanded)) {
                                        :global(.code-inner) { max-height: 27.9375rem !important; }
                                    }
                                }
                            }

                            &.panel-2 {
                                position: relative;
                                padding-top: $rem-2;
                                color: var(--ks-content-primary-inverse);
                                width: 27.5625rem;

                                @include media-breakpoint-down(xl) {
                                    width: 100%;
                                    padding-top: 0;
                                }

                                p {
                                    font-size: $font-size-lg;
                                    margin-top: $rem-1;
                                    margin-bottom: $rem-2;
                                }

                                .plugins {
                                    display: flex;
                                    gap: 0.5rem;
                                    flex-wrap: wrap;

                                    .plugin-icon {
                                        width: 2.125rem;
                                        height: 2.125rem;
                                        padding: 0.375rem;
                                        background: $white;
                                        border: $block-border;
                                        border-radius: $border-radius;
                                    }
                                }

                                .goto {
                                    position: absolute;
                                    bottom: 0;
                                    right: 0;
                                    color: var(--ks-content-link-inverse);
                                    font-weight: 600;

                                    @include media-breakpoint-down(xl) {
                                        position: relative;
                                        margin-top: $rem-3;
                                        float: right;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        &__lead {
            text-align: center;
            color: var(--ks-content-secondary);
            font-size: $font-size-lg;
            margin: 0 auto $rem-2;
            max-width: 44rem;
            padding-inline: $rem-1;
        }
    }

    .enterprise {
        padding: 140px 1rem 80px;
        gap: 40px;
        background: var(--ks-background-primary-inverse);
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        overflow: hidden;

        @include media-breakpoint-down(lg) { padding: 4rem 1rem 3rem; }

        &__title {
            color: #fff;
            margin-bottom: 2.5rem;
            text-align: center;

            .highlight {
                background: linear-gradient(90deg, #{$rt-purple-bright}, #{$rt-purple-light});
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }
        }

        :global(.features-grid) {
            box-shadow: 0 9px 36px 0 var(--ks-shadows-light-inverse);
        }

        :global(.feature-icon) {
            color: $rt-purple !important;
        }
        :global(.feature-title) {
            color: #fff !important;
        }
        :global(.feature-desc) {
            color: rgba(255, 255, 255, 0.72) !important;
        }

        .container-xxl { max-width: 1420px; }
    }

    .enterprise :global(.feature-card--cta) {
        width: 100%;
        padding: 2rem 4rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 1px 1px 0 0 var(--ks-border-secondary-inverse);

        @include media-breakpoint-down(lg) { padding: 2rem; }

        .btn { white-space: nowrap; }
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        for (const container of document.querySelectorAll(".build .inner")) {
            container.addEventListener("click", (e) => {
                const tab = (e.target as Element).closest(".header-tab") as HTMLElement
                const target = tab && (container as Element).querySelector(
                    `[data-tab-content="${tab.dataset.tabTarget}"]`
                )
                if (!target) return

                for (const el of container.querySelectorAll(".header-tab, .content")) {
                    el.classList.remove("active")
                }
                tab.classList.add("active")
                target.classList.add("active")
            })
        }
    })
</script>
