    .hero-logos {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        align-items: center;
        justify-content: center;
        margin-top: 1rem;
        padding-top: 2rem;
        width: 100%;
        max-width: 52rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;

        &__label {
            font-size: $font-size-xs;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.55);
        }

        &__row {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            align-items: center;
            justify-items: center;
            column-gap: 0.5rem;
            row-gap: 1.25rem;
            width: 100%;
            max-width: 48rem;
            margin: 0 auto;

            @include media-breakpoint-down(md) {
                grid-template-columns: repeat(2, 1fr);
                column-gap: 1rem;
                row-gap: 1.25rem;
            }
        }

        &__item {
            width: auto;
            height: auto;
            display: block;
            filter: brightness(0) invert(1);
            opacity: 0.8;
            transition: opacity 0.2s;
            max-width: 100%;

            &:hover { opacity: 1; }

            // Row 1: 4 logos, each spans 3 of 12 cols
            &:nth-child(-n+4) { grid-column: span 3; }
            // Row 2: 3 logos, each spans 4 of 12 cols (3×4=12 centers naturally)
            &:nth-child(n+5)  { grid-column: span 4; }

            @include media-breakpoint-down(md) {
                &:nth-child(-n+4),
                &:nth-child(n+5) { grid-column: auto; }
            }

            // Normalised optical sizing: text-logos ≈ 28–32px tall,
            // icon-centric logos ≈ 40–44px tall so they read at the same weight.
            // Normalised optical sizing: text-logos ≈ 28–32px tall,
            // icon-centric logos ≈ 40–44px tall so they read at the same weight.
            &:nth-child(1) { max-height: 30px; max-width: 150px; }  // Leroy Merlin
            &:nth-child(2) { max-height: 32px; max-width: 150px; }  // Auchan
            &:nth-child(3) { max-height: 28px; max-width: 150px; }  // Decathlon
            &:nth-child(4) { max-height: 36px; max-width: 160px; }  // Intersport
            &:nth-child(5) { max-height: 30px; max-width: 140px; }  // Dior
            &:nth-child(6) { max-height: 32px; max-width: 160px; }  // Gorgias
            &:nth-child(7) { max-height: 28px; max-width: 120px; }  // Fila
        }
    }

    $stages: (
