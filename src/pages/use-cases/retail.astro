]

const WORKLOAD_CATEGORIES = [
    {
        name: "Orders, Fulfillment & Returns",
        items: [
            {
                icon: "mdi:shopping-outline",
                title: "Order Orchestration & Fulfillment",
                description: "Validate carts, reserve inventory, route to warehouses or stores, dispatch carriers, and sync status back to storefronts. One declarative flow across OMS, WMS, and partner APIs.",
            },
            {
                icon: "mdi:keyboard-return",
                title: "Returns & Reverse Logistics",
                description: "Authorize returns, route items to the right reverse hub, issue refunds or replacements, and reconcile inventory. Keep refunds, restock, and finance books in sync.",
            },
            {
                icon: "mdi:truck-delivery-outline",
                title: "Supplier & Partner Coordination",
                description: "Ingest supplier feeds via EDI, API, or SFTP. Validate, route exceptions, update POs, and publish status back. Works across dropship, wholesale, and marketplace partners.",
            },
        ],
    },
    {
        name: "Inventory, Merchandising & Pricing",
        items: [
            {
                icon: "mdi:package-variant",
                title: "Inventory & Stock Sync",
