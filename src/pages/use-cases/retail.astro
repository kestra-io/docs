        --fs-neon-angle: 0deg;
        border-radius: 10px;
        background: conic-gradient(
            from var(--fs-neon-angle),
            rgba(124, 58, 237, 0.12) 0deg,
            rgba(124, 58, 237, 0.12) 320deg,
            #{$rt-purple}              340deg,
            $rt-platinum             350deg,
            #{$rt-purple}              360deg
        );
        padding: 1px;
        box-shadow:
            0 1.214px 10.321px 0 rgba(124, 58, 237, 0.22) inset,
            -6.667px -7.143px 31.334px 3.333px rgba(124, 58, 237, 0.55);
