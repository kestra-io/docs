---
import Layout from "~/components/layout.astro"
import heroFront from "~/assets/use-cases/retail/hero-front.svg"
import CartMinus from "~/assets/use-cases/retail/cart-minus.svg"
import LeroyMerlin from "~/contents/customer-stories/14/logo.svg?raw"
import { optimizeSvgIcon } from "~/utils/svgo"

import Link from "~/components/common/Link.astro"
import Quotes from "~/components/common/Quotes.vue"
import SeeHow from "~/components/common/SeeHow.astro"
import Unlock from "~/components/use-cases/Unlock.vue"
import CardGrid from "~/components/card/CardGrid.astro"
import TopHero from "~/components/layout/TopHero.astro"
import PluginsBlock from "~/components/common/PluginsBlock.astro"

const title = "Kestra for Retail and Consuming goods"
const description =
    "From data pipelines to complex integrations, Kestra empowers retail businesses with an event-driven, language-agnostic orchestration platform that scales as you grow."

const ITEMS = [
    {
        icon: "mdi:stack-overflow",
        title: "Automated Inventory Management",
        description:
            "Eliminate manual tracking to use Kestra to automate your inventory management system.",
    },
    {
        icon: "mdi:star-circle-outline",
        title: "Enhanced Customer Experience",
        description:
            "Orchestrate customer data across CRM, analytics, and marketing tools. Trigger personalized promotions and loyalty workflows automatically.",
    },
    {
        icon: "mdi:shield-check",
        title: "Compliance and Reporting",
        description:
            "Automate end-of-day reports, sales reconciliation, and regulatory reporting processes with built-in scheduling and monitoring.",
    },
    {
        icon: "mdi:truck-delivery-outline",
        title: "Delivery & Fulfillment Orchestration",
        description:
            "Integrate e-commerce systems, payment providers, logistics platforms, and warehouse systems to streamline order processing.",
    },
    {
        icon: "mdi:head-snowflake-outline",
        title: "Predictive Analytics",
        description:
            "Integrate machine learning models into workflows to forecast demand, optimize pricing, and improve operational efficiency.",
    },
]

const quotes = [
    {
        quote: "Kestra is the unifying layer for our data and workflows. You can start small, but then there is no limit to the possibilities and scalability of such an open architecture.",
        author: "Julien Henrion - Head of Data Engineering",
        smallLogoSvg: optimizeSvgIcon(LeroyMerlin, "leroy-merlin-logo"),
        kpis: [
            {
                name: "In Data Production",
                value: "+900%",
            },
            {
                name: "active users",
                value: "+250",
            },
            {
                name: "workflows Created",
                value: "+5000",
            },
        ],
        storyLink:
            "/use-cases/stories/14-datamesh-at-scale-increased-its-data-production-by-900percent",
    },
]

const UNLOCK_CONTENT = {
    leftContent: [
        {
            title: "Event-Driven Operations",
            description:
                "React instantly to new orders, stock updates, or customer actions.",
        },
        {
            title: "Centralized Workflow Control Plane",
            description:
                "Break down silos between systems and teams with unified orchestration.",
        },
    ],
    rightContent: [
        {
            title: "Observability & Monitoring",
            description:
                "Track every execution with logs, metrics, retries, and alerting.",
        },
        {
            title: "Quick to Learn, Easy to Master",
            description:
                "Kestra’s intuitive interface and comprehensive documentation make it easy for retailers to quickly build and deploy powerful workflows.",
        },
    ],
}
---

<Layout {title} {description} headerTheme="lightText">
    <TopHero
        title="Orchestrate Your <br /> Retail Ecosystem <br /> with Kestra"
        description="Automate inventory, supply chain, customer data, and analytics workflows with a scalable, event-driven orchestration platform."
        image={heroFront}
    >
        <Link
            slot="cta"
            href="/docs/quickstart#start-kestra"
            class="btn btn-primary"
        >
            Get Started
        </Link>
    </TopHero>

    <CardGrid title="Use Cases in Retail" items={ITEMS} />

    <Quotes {quotes} />

    <Unlock
        client:visible
        title="Retail Ecosystem"
        description="From inventory management to personalized customer engagement, Kestra empowers retail teams to orchestrate workflows across stores, warehouses, e-commerce platforms, and suppliers, in real time."
        logo={{
            src: CartMinus.src,
            alt: "retail basket",
        }}
        content={UNLOCK_CONTENT}
    />

    <PluginsBlock />

    <SeeHow
        cta={{
            text: "Contact Sales",
            href: "/demo",
        }}
    >
        <Fragment slot="title">
            End-To-End Solution for Managing Complex Retail Operations
        </Fragment>
        Replace Cron jobs, legacy schedulers, and manual scripts with a modern orchestration
        platform built for scale.
    </SeeHow>
</Layout>
