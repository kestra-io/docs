const BUILD_TABS = [
    {
        name: "DataMesh per-domain pipeline",
        title: "Per-domain data pipeline with namespace isolation and signed lineage. The DataMesh-at-scale pattern.",
        description:
            "Each business domain owns its namespace, secrets, and runtime. The same flow shape runs per domain: extract from operational systems, transform with dbt, validate quality, publish to the lakehouse, register in the catalog. The pattern that scales modern retail data teams to thousands of workflows and hundreds of users.",
        code: `id: domain-data-pipeline
namespace: company.retail.domain_supply

triggers:
  - id: nightly
    type: io.kestra.plugin.core.trigger.Schedule
    cron: "0 3 * * *"

tasks:
  - id: extract_source
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://ops-{{ flow.namespace }}:5432/data"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    fetchType: STORE
    sql: "SELECT * FROM events WHERE event_date = CURRENT_DATE - 1"

  - id: dbt_build
    type: io.kestra.plugin.dbt.cli.Build
    projectDir: "./dbt"
    commands:
      - dbt build --target {{ flow.namespace }}

  - id: quality_checks
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python validate.py --domain {{ flow.namespace }}

  - id: publish_to_lakehouse
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "retail-lakehouse"
    key: "{{ flow.namespace }}/{{ execution.startDate | date('yyyy/MM/dd') }}/output.parquet"
    from: "{{ outputs.dbt_build.outputFiles.results }}"

  - id: register_in_catalog
    type: io.kestra.plugin.core.http.Request
    uri: "https://catalog.internal/api/datasets"
    method: POST
    contentType: application/json
    body: |
      {
        "domain": "{{ flow.namespace }}",
        "execution_id": "{{ execution.id }}",
        "completed_at": "{{ execution.endDate }}"
      }`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.dbt.cli.Build" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
            { cls: "io.kestra.plugin.core.http.Request" },
        ],
        href: "/blueprints",
    },
    {
        name: "Approval workflow with Apps",
        title: "Self-service approval workflow in front of operations. Forms, gates, and audit out of the box.",
        description:
            "A buyer submits a price change via an App form. Kestra validates against margin policy, pauses for merchandiser approval, applies the change to the PIM, notifies the team, and archives the audit bundle. The pattern retailers use to scale workflow managers from dozens to hundreds.",
        code: `id: price-change-approval
namespace: company.retail.merch

inputs:
  - id: change
    type: JSON
    displayName: Price change request (SKU, new price, justification)

tasks:
  - id: validate_margin
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python check_margin.py --change '{{ inputs.change | toJson }}'

  - id: route_approval
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.validate_margin.vars.margin_pct < 10 }}"
    then:
      - id: merchandiser_approval
        type: io.kestra.plugin.core.flow.Pause
        description: |
          Merchandiser must approve price change for SKU
          {{ inputs.change.sku }}. Margin below 10 percent threshold.

  - id: apply_to_pim
    type: io.kestra.plugin.core.http.Request
    uri: "https://pim.internal/api/products/{{ inputs.change.sku }}/price"
    method: PUT
    contentType: application/json
    body: |
      {
        "price": {{ inputs.change.new_price }},
        "currency": "{{ inputs.change.currency }}"
      }
    headers:
      Authorization: "Bearer {{ secret('PIM_TOKEN') }}"

  - id: notify_team
    type: io.kestra.plugin.notifications.slack.SlackIncomingWebhook
    url: "{{ secret('SLACK_MERCH_URL') }}"
    payload: |
      { "text": "Price change applied for {{ inputs.change.sku }}. Run {{ execution.id }}." }

  - id: archive_audit
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "merch-audit"
    key: "price-changes/{{ execution.startDate | date('yyyy/MM/dd') }}/{{ inputs.change.sku }}.json"
    from: "{{ outputs.validate_margin.outputFiles.report }}"`,
        plugins: [
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
    {
        name: "Supplier file normalization",
        title: "Suppliers drop files in any format. Kestra normalizes them and loads them to ERP.",
        description:
            "Suppliers drop order or ASN files on the SFTP. Kestra polls the inbox, normalizes each file with a Python script, validates against rules, loads to your ERP staging table, and routes exceptions to the right ops queue. Replace bespoke mapping pipelines with one declarative flow.",
        code: `id: supplier-file-ingestion
namespace: company.retail.supply

triggers:
  - id: every_15_min
    type: io.kestra.plugin.core.trigger.Schedule
    cron: "*/15 * * * *"

tasks:
  - id: list_files
    type: io.kestra.plugin.fs.sftp.List
    host: "supplier-feed.internal"
    port: "22"
    username: "{{ secret('SFTP_USER') }}"
    password: "{{ secret('SFTP_PASSWORD') }}"
    from: "/inbound/orders/"

  - id: normalize
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python normalize_suppliers.py --listing {{ outputs.list_files.uri }}

  - id: load_to_erp
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://erp-staging:5432/staging"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    sql: |
      INSERT INTO staging.supplier_batch (batch_id, file_count, loaded_at)
      VALUES ('{{ execution.id }}', {{ outputs.normalize.vars.file_count }}, NOW())

  - id: route_exceptions
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.normalize.vars.errors > 0 }}"
    then:
      - id: notify_ops
        type: io.kestra.plugin.notifications.slack.SlackIncomingWebhook
        url: "{{ secret('SLACK_SUPPLY_URL') }}"
        payload: |
          { "text": "{{ outputs.normalize.vars.errors }} supplier file errors. Batch {{ execution.id }}." }

  - id: archive_batch
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "supply-archive"
    key: "orders/{{ execution.startDate | date('yyyy/MM/dd') }}/{{ execution.id }}.json"
    from: "{{ outputs.normalize.outputFiles.batch }}"`,
        plugins: [
            { cls: "io.kestra.plugin.fs.sftp.List" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
    {
        name: "Customer service automation",
        title: "Gorgias ticket lands. Kestra assembles context. Agent gets the answer one click away.",
        description:
            "A Gorgias ticket fires a webhook. Kestra pulls the order, shipment, and refund history, scores the customer tier, assembles the agent context, and posts back to the ticket. No more agents opening five tabs to resolve one issue.",
        code: `id: gorgias-context-assembly
namespace: company.retail.cs

triggers:
  - id: gorgias_webhook
    type: io.kestra.plugin.core.trigger.Webhook
    key: "gorgias-events"

inputs:
  - id: ticket
    type: JSON
    displayName: Gorgias ticket payload

tasks:
  - id: fetch_orders
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://oms:5432/orders"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    fetchType: FETCH
    sql: |
      SELECT order_id, total, currency, status, fulfilled_at
      FROM orders.completed
      WHERE customer_email = '{{ inputs.ticket.customer.email }}'
      ORDER BY fulfilled_at DESC
      LIMIT 5

  - id: score_tier
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python score_tier.py --customer '{{ inputs.ticket.customer | toJson }}' --orders {{ outputs.fetch_orders.uri }}

  - id: post_context
    type: io.kestra.plugin.core.http.Request
    uri: "https://api.gorgias.com/api/tickets/{{ inputs.ticket.id }}/internal-notes"
    method: POST
    contentType: application/json
    headers:
      Authorization: "Basic {{ secret('GORGIAS_TOKEN') }}"
    body: |
      {
        "body_html": "Customer tier: {{ outputs.score_tier.vars.tier }}. Recent orders attached. Run {{ execution.id }}.",
        "channel": "internal-note"
      }

  - id: route_high_value
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.score_tier.vars.tier == 'platinum' }}"
    then:
      - id: notify_vip_team
        type: io.kestra.plugin.notifications.slack.SlackIncomingWebhook
        url: "{{ secret('SLACK_VIP_URL') }}"
        payload: |
          { "text": "Platinum customer ticket {{ inputs.ticket.id }}. Customer: {{ inputs.ticket.customer.email }}." }`,
        plugins: [
            { cls: "io.kestra.plugin.core.trigger.Webhook" },
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.core.http.Request" },
        ],
        href: "/blueprints",
    },
]

