---
export const prerender = false
// redirect random slugs to the correct slug

const { id } = Astro.params

// look in the file system in content/customerStories for the folder with the id
const fs = await import("fs/promises")
const path = await import("path")
const storiesPath = path.resolve("./src/contents/customer-stories")
const storyFolders = await fs.readdir(storiesPath)
if (id) {
    const storyFolder = storyFolders.find((folder) => folder === id)
    if (storyFolder) {
        // find the markdown file in the folder
        const storyFiles = await fs.readdir(path.join(storiesPath, storyFolder))
        const storyFile = storyFiles.find((file) => file.endsWith(".md"))
        if (storyFile) {
            const storyContent = await fs.readFile(
                path.join(storiesPath, storyFolder, storyFile),
                "utf-8",
            )
            const titleMatch = storyContent.match(/title:\s*(.+)/)
            if (titleMatch) {
                // redirect to the correct slug
                return Astro.rewrite(`/use-cases/stories/${id}`)
            }
        }
    }
}
