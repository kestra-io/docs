---
import { getCollection } from "astro:content"
import StoriesList from "~/components/stories/StoriesList.vue"
import Layout from "~/components/layout.astro"
import FooterContact from "~/components/layout/FooterContact.astro"

const title = "Kestra's Customers Stories"
const description =
    "Learn how we helped companies manage their critical operations."

const allEntries = (await getCollection("customerStories")).sort((a, b) =>
    parseInt(a.id) > parseInt(b.id) ? -1 : 1,
)

const totalStories = allEntries.length
const stories = allEntries.map((e) => ({
    id: e.id,
    ...e.data,
    heroImage: e.data.heroImage.src,
    featuredImage: e.data.featuredImage.src,
    logo: e.data.logo?.src,
    logoDark: e.data.logoDark?.src,
    content: e.body ?? "",
}))
---

<Layout title={title} description={description}>
    <div class="main">
        <StoriesList
            stories={stories}
            totalStories={totalStories}
            client:idle
        />
        <FooterContact
            title="Getting started with Kestra"
            subtitle="Start building with Kestra — Automate Everything Everywhere All at Once."
            dark={{
                text: "Get started",
                href: "/docs/quickstart#start-kestra",
            }}
            purple={{ text: "Read the docs", href: "/docs" }}
        />
    </div>
</Layout>
