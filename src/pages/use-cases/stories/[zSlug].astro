---
export const prerender = false

import { slugify } from "@kestra-io/ui-libs"
import yaml from "js-yaml"
import type { CollectionEntry } from "astro:content"

// redirect random slugs to the correct slug

const storiesFiles = import.meta.glob<string>(
    "~/contents/customer-stories/*/*.md",
    { query: "?raw", import: "default" },
)

const { zSlug } = Astro.params

const id = zSlug?.split("-")[0]

// look in the file system in content/customerStories for the folder with the id
if (id) {
    const storyFolder = Object.keys(storiesFiles).find((key) =>
        key.includes(`src/contents/customer-stories/${id}/`),
    )
    const storyContent = storyFolder ? await storiesFiles[storyFolder]() : null
    const match = storyContent?.match(/---\n([\s\S]*?)\n---/)
    if (match) {
        const metadataRaw = match[1]
        const metadata = yaml.load(
            metadataRaw,
        ) as CollectionEntry<"customerStories">["data"]
        if (metadata.title) {
            // redirect to the correct slug
            return Astro.redirect(
                `/use-cases/stories/${id}-${slugify(metadata.title)}`,
            )
        } else {
            console.warn(`No title found for story with id ${id}`)
        }
    }
    return Astro.redirect(`/use-cases/stories/${id}`)
}
---
