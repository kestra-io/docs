    $ps-blue-deep:   #1E3A8A;
    $ps-platinum:    #E8EDF0;

    .public-services { overflow: clip; }

    :global(html.dark) .public-services {
        .flow,
        .workloads,
        .build,
        .enterprise {
            background: #1C1C20;
        }
        :global(section.quotes-wrapper),
        :global(section.plugin-block),
        :global(.see) {
            background: #1C1C20;
        }
    }

    .hero {
        position: relative;
        overflow: hidden;
        background: #050a14;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin-top: calc(-1 * var(--top-bar-height, 67px) - var(--announce-height, 0px));
        padding: calc(var(--top-bar-height, 67px) + var(--announce-height, 0px) + 5rem) 1.5rem 6rem;

        @include media-breakpoint-down(md) {
            padding: calc(var(--top-bar-height, 67px) + var(--announce-height, 0px) + 3rem) 1rem 4rem;
        }

        &::after {
            content: "";
            position: absolute;
            bottom: -260px;
            left: 50%;
            transform: translateX(-50%);
            width: 1100px;
            height: 520px;
            background: radial-gradient(ellipse at center, rgba(37, 99, 235, 0.32) 0%, rgba(37, 99, 235, 0) 70%);
            pointer-events: none;
            z-index: 0;
        }
    }

    .hero-bg-grid {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        max-width: 1720px;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        pointer-events: none;
        z-index: 0;
        opacity: 0.5;
    }

    .hero-inner {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        width: 100%;
        max-width: 68rem;
        color: $white;
        text-align: center;

        @include media-breakpoint-down(md) { gap: 1.5rem; }

        h1 {
            color: $white;
            font-weight: 600;
            line-height: 1.1;
            letter-spacing: -0.02em;
            margin: 0;
        }

        .gradient {
            background: linear-gradient(90deg, #{$ps-blue-bright}, #{$ps-blue-light});
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            color: rgba(255, 255, 255, 0.82);
            font-size: $font-size-lg;
            line-height: 1.6;
            max-width: 48rem;
            margin: 0;

            @include media-breakpoint-down(md) { font-size: $font-size-md; }
        }
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 4px 1.125rem;
        gap: 0.5rem;
        border-radius: 2.5rem;
        background: #050a14;
        position: relative;
        z-index: 1;
        font-size: $font-size-xs;
        font-weight: 600;
        color: $ps-blue-bright;

        &::before {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: 2.5rem;
            padding: 1px;
            background: linear-gradient(90deg, #{$ps-blue} 0%, #{$ps-blue-light} 100%);
            -webkit-mask: linear-gradient($white 0 0) content-box, linear-gradient($white 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            z-index: -1;
        }
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
    }

    .tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 9999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.78);
        font-size: $font-size-xs;
        white-space: nowrap;
        transition: all 0.2s ease;

        &:hover {
            border-color: rgba(96, 165, 250, 0.55);
            background: rgba(37, 99, 235, 0.14);
            color: $white;

            :global(.tag-icon) { color: $ps-blue-light; }
        }

        :global(.tag-icon) {
            width: 12px;
            height: 12px;
            color: $ps-blue-bright;
            flex-shrink: 0;
        }
    }

    @property --ps-neon-angle {
        syntax: '<angle>';
        inherits: false;
        initial-value: 0deg;
    }

    @keyframes ps-neon-trace {
        to { --ps-neon-angle: 360deg; }
    }

    .exec-panel-wrapper {
        --ps-neon-angle: 0deg;
        border-radius: 10px;
        background: conic-gradient(
            from var(--ps-neon-angle),
            rgba(37, 99, 235, 0.16) 0deg,
            rgba(37, 99, 235, 0.16) 320deg,
            #{$ps-blue}              340deg,
            $ps-platinum             350deg,
            #{$ps-blue}              360deg
        );
        padding: 1px;
        box-shadow:
            0 1.214px 10.321px 0 rgba(37, 99, 235, 0.28) inset,
            -6.667px -7.143px 31.334px 3.333px rgba(37, 99, 235, 0.6);
        width: 100%;
        max-width: 640px;
        animation: ps-neon-trace 5s linear infinite;
    }

    .exec-panel {
        background: #060d1d;
        border-radius: 9px;
        overflow: hidden;
        backdrop-filter: blur(12px);
        text-align: left;

        &__header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 12px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(37, 99, 235, 0.08);
            flex-wrap: wrap;
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
        }

        &__dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: $ps-blue-bright;
            box-shadow: 0 0 8px $ps-blue-bright;
            flex-shrink: 0;
        }

        &__title {
            color: $white;
            font-weight: 600;
        }

        &__meta {
            color: rgba(255, 255, 255, 0.45);
