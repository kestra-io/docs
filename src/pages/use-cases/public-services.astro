        &__duration {
            color: $ps-blue-light;
            font-weight: 500;
        }

        &__body {
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        &__footer {
            padding: 10px 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(37, 99, 235, 0.06);
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            color: $ps-blue-light;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .exec-footer__sep { color: rgba(255, 255, 255, 0.25); }
    }

    .exec-row {
        display: grid;
        grid-template-columns: 20px minmax(130px, 1fr) minmax(150px, 1fr) minmax(90px, auto);
        align-items: center;
        gap: 1rem;
        padding: 6px 8px;
        border-radius: 4px;
        font-family: $font-family-monospace;
        font-size: $font-size-xs;
        transition: background 0.2s;

        &:hover { background: rgba(37, 99, 235, 0.10); }

        @include media-breakpoint-down(sm) {
            grid-template-columns: 20px 1fr auto;
        }

        &__check {
            color: $ps-blue-bright;
            font-weight: 700;
        }

        &__name {
            color: $white;
            font-weight: 500;
        }

        &__type {
            color: rgba(255, 255, 255, 0.45);

            @include media-breakpoint-down(sm) { display: none; }
        }

        &__result {
            color: $ps-blue-light;
            text-align: right;
            white-space: nowrap;
        }
    }

    .hero-ctas {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;

        .btn {
            justify-content: center;

            @include media-breakpoint-down(md) {
                width: auto;
                min-width: 200px;
            }
        }
    }

    // ── Hero logo strip ──────────────────────────────────────────────
    // 5 logos on a single row at md+, normalised to the same optical
    // weight via per-logo max-height + max-width tuned to each SVG's
    // aspect ratio.
    .hero-logos {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        align-items: center;
        justify-content: center;
        margin-top: 1rem;
        padding-top: 2rem;
        width: 100%;
        max-width: 60rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;

        &__label {
            font-size: $font-size-xs;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.6);
        }

        &__row {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            align-items: center;
            justify-items: center;
            column-gap: 2rem;
            row-gap: 1.5rem;
            width: 100%;

            @include media-breakpoint-down(md) {
                grid-template-columns: repeat(2, 1fr);
                column-gap: 1.5rem;
                row-gap: 1.75rem;
            }
        }

        &__item {
            width: auto;
            height: auto;
            display: block;
            filter: brightness(0) invert(1);
            opacity: 0.85;
            transition: opacity 0.2s;
            object-fit: contain;
            max-width: 100%;

            &:hover { opacity: 1; }

            // Unified optical sizing across all industry pages:
            // text wordmarks 36px, small text 32px, compact icon+text
            // 42px, stacked vertically icon+text 52–56px.
            &--coe           { max-height: 56px; max-width: 130px; }  // stacked icon + text + stars
            &--itzbund       { max-height: 56px; max-width: 150px; }  // stacked icon + text
            &--dataport      { max-height: 36px; max-width: 170px; }  // text
            &--bundesagentur { max-height: 36px; max-width: 180px; }  // text + symbol
            &--battelle      { max-height: 32px; max-width: 140px; }  // small text

            @include media-breakpoint-down(md) {
                &--coe, &--itzbund { max-height: 60px; max-width: 160px; }
                &--dataport        { max-height: 40px; max-width: 190px; }
                &--bundesagentur   { max-height: 40px; max-width: 200px; }
                &--battelle        { max-height: 36px; max-width: 150px; }
            }
        }
    }

