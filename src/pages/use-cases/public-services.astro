const BUILD_TABS = [
    {
        name: "VMware safe-patch with rollback",
        title: "Snapshot, patch, verify, rollback. VMware orchestration with the safety net built in.",
        description:
            "Snapshot the VM through the native vSphere plugin, apply the change, verify health, and roll back automatically if validation fails. The safe-patching pattern most teams build by hand, expressed as one declarative flow. Automation that fails safely.",
        code: `id: vmware-safe-patch
namespace: company.platform.vmware

inputs:
  - id: vm_name
    type: STRING
    displayName: VM name to patch

tasks:
  - id: snapshot_before
    type: io.kestra.plugin.ee.vmware.esxi.CreateVmSnapshot
    server: "{{ secret('VCENTER_HOST') }}"
    username: "{{ secret('VCENTER_USER') }}"
    password: "{{ secret('VCENTER_PASS') }}"
    vmName: "{{ inputs.vm_name }}"
    snapshotName: "pre-change-{{ execution.id }}"
    description: "Automatic snapshot before patching"

  - id: apply_patch
    type: io.kestra.plugin.scripts.shell.Commands
    commands:
      - ansible-playbook patch.yml -e vm={{ inputs.vm_name }}

  - id: verify_health
    type: io.kestra.plugin.core.http.Request
    uri: "https://monitoring.internal/health/{{ inputs.vm_name }}"
    allowFailed: true

  - id: rollback_if_failed
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.verify_health.code != 200 }}"
    then:
      - id: restore_snapshot
        type: io.kestra.plugin.ee.vmware.esxi.RestoreVmFromSnapshot
        server: "{{ secret('VCENTER_HOST') }}"
        username: "{{ secret('VCENTER_USER') }}"
        password: "{{ secret('VCENTER_PASS') }}"
        vmName: "{{ inputs.vm_name }}"
        snapshotName: "pre-change-{{ execution.id }}"

      - id: alert_team
        type: io.kestra.plugin.notifications.slack.SlackIncomingWebhook
        url: "{{ secret('SLACK_WEBHOOK') }}"
        messageText: "Patch failed for {{ inputs.vm_name }}. VM rolled back to snapshot."`,
        plugins: [
            { cls: "io.kestra.plugin.ee.vmware.esxi.CreateVmSnapshot" },
            { cls: "io.kestra.plugin.scripts.shell.Commands" },
            { cls: "io.kestra.plugin.core.flow.If" },
            { cls: "io.kestra.plugin.ee.vmware.esxi.RestoreVmFromSnapshot" },
        ],
        href: "/blueprints",
    },
    {
        name: "SOC alert triage & containment",
        title: "Triage SIEM alerts, enrich, and contain. The open alternative to closed SOAR platforms.",
        description:
            "Receive alerts from your SIEM, enrich with threat intelligence, score with a Python model, branch on severity, pause for analyst confirmation on critical events, isolate hosts, and open ServiceNow incidents. Replaces Palo Alto SOAR, Splunk SOAR, and the script glue between them.",
        code: `id: soc-alert-triage
namespace: company.soc.alerts

triggers:
  - id: siem_webhook
    type: io.kestra.plugin.core.trigger.Webhook
    key: "siem-events"

inputs:
  - id: alert
    type: JSON
    displayName: SIEM alert payload

tasks:
  - id: enrich_indicators
    type: io.kestra.plugin.core.http.Request
    uri: "https://intel.internal/enrich"
    method: POST
    contentType: application/json
    body: "{{ inputs.alert | toJson }}"
    headers:
      Authorization: "Bearer {{ secret('INTEL_TOKEN') }}"

  - id: score_risk
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python score.py --alert '{{ inputs.alert | toJson }}' --intel '{{ outputs.enrich_indicators.body | toJson }}'

  - id: route_decision
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.score_risk.vars.risk == 'critical' }}"
    then:
      - id: analyst_confirm
        type: io.kestra.plugin.core.flow.Pause
        description: |
          Analyst must confirm containment for alert {{ inputs.alert.id }}.

      - id: isolate_host
        type: io.kestra.plugin.core.http.Request
        uri: "https://edr.internal/hosts/{{ inputs.alert.host_id }}/isolate"
        method: POST
        headers:
          Authorization: "Bearer {{ secret('EDR_TOKEN') }}"

  - id: create_incident
    type: io.kestra.plugin.core.http.Request
    uri: "https://servicenow.example/api/now/table/incident"
    method: POST
    contentType: application/json
    headers:
      Authorization: "Bearer {{ secret('SNOW_TOKEN') }}"
    body: |
      {
        "short_description": "SOC alert {{ inputs.alert.id }}",
        "assignment_group": "soc-tier1"
      }`,
        plugins: [
            { cls: "io.kestra.plugin.core.trigger.Webhook" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.core.http.Request" },
        ],
        href: "/blueprints",
    },
    {
        name: "Bare metal + NetBox source-of-truth",
        title: "Provision bare metal through MAAS and update NetBox in one execution. No drift by design.",
        description:
            "Commission a server through MAAS, deploy the OS image, register the device in NetBox, assign the IP. If the inventory write fails, the workflow fails. Metal provisioning, source-of-truth, and downstream automation become one execution you can debug.",
        code: `id: provision-metal-and-register
namespace: company.platform.bare-metal

inputs:
  - id: hostname
    type: STRING
  - id: mac_address
    type: STRING

tasks:
  - id: enlist
    type: io.kestra.plugin.ee.canonical.maas.EnlistMachine
    url: "{{ secret('MAAS_URL') }}"
    apiKey: "{{ secret('MAAS_API_KEY') }}"
    macAddress: "{{ inputs.mac_address }}"
    hostname: "{{ inputs.hostname }}"
    architecture: "amd64/generic"
    powerType: "ipmi"
    powerParameters:
      power_address: "192.168.1.100"
      power_user: "{{ secret('IPMI_USER') }}"
      power_pass: "{{ secret('IPMI_PASSWORD') }}"

  - id: commission
    type: io.kestra.plugin.ee.canonical.maas.CommissionMachine
    url: "{{ secret('MAAS_URL') }}"
    apiKey: "{{ secret('MAAS_API_KEY') }}"
    systemId: "{{ outputs.enlist.systemId }}"
    waitForCompletion: true
    timeout: PT30M

  - id: deploy
    type: io.kestra.plugin.ee.canonical.maas.DeployMachine
    url: "{{ secret('MAAS_URL') }}"
    apiKey: "{{ secret('MAAS_API_KEY') }}"
    systemId: "{{ outputs.commission.systemId }}"
    osystem: "ubuntu"
    distroSeries: "jammy"
    waitForDeployment: true
    timeout: PT45M

  - id: register_in_netbox
    type: io.kestra.plugin.ee.netbox.CreateDevice
    url: "{{ secret('NETBOX_URL') }}"
    token: "{{ secret('NETBOX_API_TOKEN') }}"
    name: "{{ inputs.hostname }}"

  - id: assign_ip
    type: io.kestra.plugin.ee.netbox.AssignIpAddress
    url: "{{ secret('NETBOX_URL') }}"
    token: "{{ secret('NETBOX_API_TOKEN') }}"
    address: "10.100.1.45/24"
    status: "active"
    assignedObjectType: "dcim.interface"
    assignedObjectId: "{{ outputs.register_in_netbox.primary_interface_id }}"
    dnsName: "{{ inputs.hostname }}.mgmt.example.com"`,
        plugins: [
            { cls: "io.kestra.plugin.ee.canonical.maas.EnlistMachine" },
            { cls: "io.kestra.plugin.ee.canonical.maas.CommissionMachine" },
            { cls: "io.kestra.plugin.ee.canonical.maas.DeployMachine" },
            { cls: "io.kestra.plugin.ee.netbox.CreateDevice" },
        ],
        href: "/blueprints",
    },
    {
        name: "Multi-tenant data pipeline",
        title: "Per-tenant data pipeline with namespace isolation and signed lineage.",
        description:
            "Each department or programme owns its own namespace, secrets, and runtime. The same flow shape runs per tenant: extract, transform with dbt, validate, publish to the sovereign lakehouse, archive lineage. Zero blast radius between teams. Full audit per run.",
        code: `id: tenant-data-pipeline
namespace: company.data.tenant_a

triggers:
  - id: nightly
    type: io.kestra.plugin.core.trigger.Schedule
    cron: "0 2 * * *"

tasks:
  - id: extract_source
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://source-{{ flow.namespace }}:5432/data"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    fetchType: STORE
    sql: "SELECT * FROM events WHERE event_date = CURRENT_DATE - 1"

  - id: dbt_build
    type: io.kestra.plugin.dbt.cli.Build
    projectDir: "./dbt"
    commands:
      - dbt build --target {{ flow.namespace }}

  - id: quality_checks
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python validate.py --tenant {{ flow.namespace }}

  - id: publish_lakehouse
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "sovereign-lakehouse"
    key: "{{ flow.namespace }}/{{ execution.startDate | date('yyyy/MM/dd') }}/output.parquet"
    from: "{{ outputs.dbt_build.outputFiles.results }}"

  - id: archive_lineage
    type: io.kestra.plugin.core.http.Request
    uri: "https://lineage.internal/runs"
    method: POST
    contentType: application/json
    body: |
      {
        "tenant": "{{ flow.namespace }}",
        "execution_id": "{{ execution.id }}",
        "completed_at": "{{ execution.endDate }}"
      }`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.dbt.cli.Build" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
            { cls: "io.kestra.plugin.core.http.Request" },
        ],
        href: "/blueprints",
    },
]

const FAQ = [
    {
        question: "Can Kestra orchestrate VMware lifecycle, vSphere, vCenter, and ESXi without a portal layer above it?",
        answer: "Yes. The native VMware plugin orchestrates the full VM lifecycle (provision, snapshot, clone, template, restore, power state) across vCenter and ESXi. Event-driven triggers react to vCenter lifecycle events. The point is to replace the brittle automation UI layer (Aria, vRealize Automation) while keeping the virtualization substrate intact. No big-bang rewrite, no rip-and-replace.",
    },
    {
        question: "How does Kestra fit alongside legacy automation suites like VMware Aria, vRealize Automation, vRO, Rundeck, HP Operations Orchestration, Control-M, and Autosys?",
        answer: "Kestra is the open-source modernization path. Most public-sector teams start by wrapping existing jobs as Kestra flows, then migrate workflow by workflow at their own pace. No big-bang cutover, no freezing of existing automation. Procurement-friendly licensing, open standards (YAML, REST, OIDC, OpenTelemetry), and a clear exit path for every workflow.",
    },
    {
        question: "Can Kestra orchestrate bare metal through MAAS, NetBox, and existing source-of-truth systems?",
        answer: "Yes. Plugins for Canonical MAAS (Metal as a Service) cover the full lifecycle: list, enlist, commission, deploy, power-control machines. The NetBox plugin keeps your DCIM and IPAM source-of-truth in sync as part of the same execution. If inventory update fails, the workflow fails. No drift by design.",
    },
    {
        question: "Can Kestra run SOC and security-automation workflows on-prem?",
        answer: "Yes. Public-sector SOCs use Kestra as an open alternative to Palo Alto SOAR and Splunk SOAR: triage SIEM alerts, enrich with threat intelligence, score with rules or ML, isolate hosts, rotate credentials, snapshot evidence, open ServiceNow incidents. Multi-tenant by namespace for multi-state and multi-agency estates. Replayable per alert, audit-ready by default.",
    },
    {
        question: "Can Kestra run fully air-gapped, sovereign, or on-premise for restricted environments?",
        answer: "Yes. Kestra Enterprise runs fully self-hosted in your private cloud, VPC, or air-gapped datacenter with no egress required. Workers sit on-premise; the control plane can live in a different zone. Kestra Cloud runs in EU or US regions. Pick the deployment that fits your jurisdiction and information-classification regime, with no cross-region data transfer.",
    },
    {
        question: "Does Kestra deploy on Kubernetes, OpenShift, and Docker?",
        answer: "Yes. Native deployment on Docker, Helm charts for Kubernetes, and OpenShift. Worker groups let you isolate Linux, Windows, GPU, and secure-zone runtimes on a shared control plane. PostgreSQL backend handles millions of executions without requiring Kafka or Elasticsearch, keeping your operational footprint minimal.",
    },
    {
        question: "How does Kestra handle multi-tenant isolation across departments, agencies, or states?",
        answer: "Namespace-scoped RBAC and multi-tenant isolation let each department, agency, programme, or state own its flows, secrets, and runtime on a shared platform. Subflows and triggers coordinate work across tenants when needed. Zero blast radius between environments. A single platform team operates the control plane while consuming teams self-serve their own workloads.",
    },
    {
        question: "Does Kestra support OIDC, SAML, LDAP, Keycloak, and existing identity providers?",
        answer: "Yes. SSO via SAML, OIDC, and OAuth2; user and group provisioning via SCIM; integration with Active Directory, LDAP, Keycloak, Azure AD, Okta, and any standards-compliant IdP. Fine-grained RBAC enforces least privilege per namespace, environment, and resource type. Aligned with how public-sector identity governance is already organized.",
    },
    {
        question: "How does Kestra handle secrets like Vault, CyberArk, Delinea, and AWS, Azure, or GCP secret managers?",
        answer: "Native integrations with HashiCorp Vault, CyberArk, Delinea Secrets Manager, AWS Secrets Manager, GCP Secret Manager, and Azure Key Vault. Secrets are scoped per namespace, per tenant, per flow, and never written to logs. Combined with namespace-scoped RBAC, each department or programme gets an isolated secret store on a shared, audited platform.",
    },
    {
        question: "Is Kestra open source, and does it fit public-sector procurement requirements?",
        answer: "Yes. Kestra is Apache 2.0. Enterprise Edition adds SSO, RBAC, multi-tenancy, worker groups, advanced audit, Kill Switch, Apps for self-service UIs, and 24x7 support. Open standards throughout (YAML, REST, OIDC, OpenTelemetry), no proprietary runtime lock-in, transparent licensing. Maps cleanly to public-sector procurement, framework agreements, and open-source-by-default policies.",
    },
    {
        question: "Can Kestra build self-service infrastructure portals in front of flows?",
        answer: "Yes. Apps let you build a UI in front of any flow: forms for data entry, approval buttons, controlled output views. The flow remains the backend. Combined with ServiceNow triggers and CMDB integration, you can turn catalog requests into provisioned resources in minutes, with audit proof end-to-end.",
    },
    {
        question: "How does Kestra support AI-assisted triage and runbooks while keeping humans in the loop?",
        answer: "Orchestrate OCR, LLM extraction, classification, and decision-support models alongside rule-based checks. Pause for human review at any decision point: analyst confirmation, change-advisory approval, model promotion, exception handling. Models, prompts, and PII stay inside your environment. Every model output and human decision is captured in the immutable audit trail.",
    },
]

---

<Layout {title} {description} headerTheme="lightText">
    <div class="public-services">

        <section class="hero">
            <img src="/hero-grid.svg" alt="" class="hero-bg-grid" aria-hidden="true" />
            <div class="hero-inner">
                <div class="badge-pill" data-usal="zoomin">
                    <Icon name="mdi:city-variant-outline" />
                    <span>Public Services &amp; Institutions</span>
                </div>

                <h1 data-usal="fade-u">
                    Modernize public-sector IT.<br />
                    <span class="gradient">On a platform you fully control.</span>
