    },
    {
        icon: FileDocumentCheckOutline,
        title: "Four-Eyes Clinical & Compliance Gates",
        description: "Pause any workflow pending human sign-off. Enforce dual control on PHI-touching decisions, prior-auth approvals, and production promotions.",
    },
    {
        icon: AccountGroupOutline,
        title: "RBAC & Multi-Tenant Isolation",
        description: "Namespace-scoped RBAC with SSO/SAML/SCIM. Every business unit owns its secrets and runtime on a shared platform. Zero blast radius across teams.",
    },
    {
        icon: CodeTagsCheck,
        title: "Audit Logs & SIEM Integration",
        description: "Every execution, user action, and resource change recorded. Stream logs directly to Splunk, Elastic, or your preferred SIEM for HITRUST and SOC 2 evidence.",
    },
]

const BUILD_TABS = [
    {
        name: "Prior authorization",
        title: "From request to payer decision, with clinical sign-off in the loop.",
        description:
            "A provider submits a prior-auth request. Kestra checks eligibility, persists a PHI-safe case, pauses for clinical review, submits the decision to the payer, and notifies the provider. Every step auditable.",
        code: `id: prior-auth-intake
namespace: company.health.auth

inputs:
  - id: request
    type: JSON
    displayName: Prior auth request (patient, codes, docs)

tasks:
  - id: check_eligibility
    type: io.kestra.plugin.core.http.Request
    uri: "https://payer.example/api/eligibility"
    method: POST
    contentType: application/json
    body: "{{ inputs.request | toJson }}"
    headers:
      Authorization: "Bearer {{ secret('PAYER_TOKEN') }}"

  - id: persist_case
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://phi-vault:5432/auth"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    sql: |
      INSERT INTO auth.requests (patient_ref, payload, eligibility, status)
      VALUES (
        '{{ inputs.request.patient_ref }}',
        '{{ inputs.request | toJson }}',
        '{{ outputs.check_eligibility.body | toJson }}',
        'pending_review'
      ) RETURNING case_id

  - id: clinical_review
    type: io.kestra.plugin.core.flow.Pause
    description: |
      Clinician must review case {{ outputs.persist_case.row.case_id }}
      before decision is submitted to the payer.

  - id: submit_decision
    type: io.kestra.plugin.core.http.Request
    uri: "https://payer.example/api/prior-auth"
    method: POST
    contentType: application/json
    body: |
      {
        "case_id": "{{ outputs.persist_case.row.case_id }}",
        "decision": "approved",
        "reviewer": "{{ execution.taskrun.value }}"
      }

  - id: notify_provider
    type: io.kestra.plugin.email.MailSend
    host: smtp.health.example
    port: 465
    username: "{{ secret('SMTP_USER') }}"
    password: "{{ secret('SMTP_PASSWORD') }}"
    from: auth@health.example
    to: "{{ inputs.request.provider_email }}"
    subject: "Prior-auth {{ outputs.persist_case.row.case_id }} decision"
    htmlTextContent: "The payer has issued a decision on the prior-auth request."`,
        plugins: [
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.email.MailSend" },
        ],
        href: "/blueprints",
    },
    {
        name: "Denials & appeals",
        title: "Turn a payer denial into a reviewed, evidence-backed appeal.",
        description:
            "A denial lands on the webhook. Kestra pulls the claim, assembles clinical evidence from EHR and attachments, pauses for reviewer sign-off, resubmits to the payer, and ships a signed audit bundle for RCM leadership.",
        code: `id: denial-appeal-pipeline
namespace: company.health.rcm

inputs:
  - id: denial
    type: JSON
    displayName: Payer denial notification

tasks:
  - id: fetch_claim
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://rcm:5432/claims"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    fetchType: FETCH_ONE
    sql: |
      SELECT claim_id, patient_ref, encounter_id, payload
      FROM claims.submitted
      WHERE claim_id = '{{ inputs.denial.claim_id }}'

  - id: assemble_evidence
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python assemble_evidence.py --claim {{ outputs.fetch_claim.row.claim_id }}

  - id: reviewer_pause
    type: io.kestra.plugin.core.flow.Pause
    description: |
      Clinical reviewer must approve appeal package
      for claim {{ outputs.fetch_claim.row.claim_id }}.

  - id: submit_appeal
    type: io.kestra.plugin.core.http.Request
    uri: "https://payer.example/api/appeals"
    method: POST
    contentType: application/json
    body: |
      {
        "claim_id": "{{ outputs.fetch_claim.row.claim_id }}",
        "evidence_uri": "{{ outputs.assemble_evidence.outputFiles.bundle }}"
      }
    headers:
      Authorization: "Bearer {{ secret('PAYER_TOKEN') }}"

  - id: publish_audit
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "rcm-audit"
    key: "appeals/{{ execution.startDate | date('yyyy/MM/dd') }}/{{ outputs.fetch_claim.row.claim_id }}.json"
    from: "{{ outputs.assemble_evidence.outputFiles.bundle }}"`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
    {
        name: "HL7 to FHIR interop",
        title: "Keep legacy HL7 feeds flowing into a modern FHIR estate.",
        description:
            "Pull HL7 v2 messages from partner SFTP, transform to FHIR resources, publish to the data platform, and open a ServiceNow case if validation fails. One declarative pipeline, fully observable.",
        code: `id: hl7-to-fhir-pipeline
namespace: company.health.interop

triggers:
  - id: every_5_min
    type: io.kestra.plugin.core.trigger.Schedule
    cron: "*/5 * * * *"

tasks:
  - id: pull_hl7
    type: io.kestra.plugin.fs.sftp.Downloads
    host: "hl7-feed.example"
    port: "22"
    username: "{{ secret('SFTP_USER') }}"
    password: "{{ secret('SFTP_PASSWORD') }}"
    from: "/outbound/"
    regExp: ".*\\\\.hl7$"
    action: MOVE
    moveDirectory: "/processed/"

  - id: transform
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python hl7_to_fhir.py --in {{ outputs.pull_hl7.files }}

  - id: publish_fhir
    type: io.kestra.plugin.core.http.Request
    uri: "https://fhir.health.example/R4/Bundle"
    method: POST
    contentType: application/fhir+json
    body: "{{ outputs.transform.outputFiles.bundle }}"
    headers:
      Authorization: "Bearer {{ secret('FHIR_TOKEN') }}"

  - id: route_errors
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.transform.vars.errors > 0 }}"
    then:
      - id: open_case
        type: io.kestra.plugin.core.http.Request
        uri: "https://servicenow.example/api/now/table/incident"
        method: POST
        contentType: application/json
        headers:
          Authorization: "Bearer {{ secret('SNOW_TOKEN') }}"
        body: |
          {
            "short_description": "HL7 to FHIR: {{ outputs.transform.vars.errors }} validation errors",
            "assignment_group": "health-interop"
          }`,
        plugins: [
            { cls: "io.kestra.plugin.fs.sftp.Downloads" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.core.flow.If" },
        ],
        href: "/blueprints",
    },
]

const FAQ = [
    {
        question: "Can Kestra orchestrate prior authorization without replacing our EHR or payer portals?",
        answer: "Yes. Kestra sits in front of Epic, Cerner, Meditech, and payer portals. It receives the request, checks eligibility, persists a PHI-safe case, pauses for clinical review, and submits the decision back to the payer via X12 278 or portal API. The EHR stays in place.",
    },
    {
        question: "Can Kestra orchestrate HL7 and FHIR interoperability without replacing our interface engine?",
        answer: "Yes. Kestra sits alongside Mirth, Rhapsody, Cloverleaf, or native EHR interfaces. Pull HL7 v2 from SFTP or MLLP, transform to FHIR R4, validate against US Core or custom profiles, and publish to your data platform or downstream systems. Wrap existing interface flows first, modernize incrementally.",
    },
    {
        question: "How does Kestra support denials, appeals, and revenue cycle workflows?",
        answer: "A payer denial fires a webhook. Kestra pulls the original claim, assembles clinical evidence from EHR and attachments, pauses for clinical reviewer sign-off, and resubmits the appeal — with a signed audit bundle for RCM leadership. Eligibility, billing, remittance reconciliation, and collections run on the same engine.",
    },
    {
        question: "Is PHI safe inside Kestra? Where does sensitive data live?",
        answer: "PHI never has to leave your perimeter. Workers run next to your data; the control plane can live in a separate, segmented zone. Secrets come from Vault, AWS Secrets Manager, Azure Key Vault, GCP Secret Manager, or CyberArk. Self-hosted and air-gapped deployments keep PHI fully on-prem.",
    },
    {
        question: "How does Kestra support HIPAA, HITRUST, and SOC 2 evidence?",
        answer: "Every flow is YAML in Git. Every execution is immutable and replayable. Namespace-scoped RBAC enforces least privilege. Audit logs stream to Splunk, Elastic, or your SIEM. Four-eyes Pause tasks enforce dual control on any PHI-touching decision, claim appeal, or production promotion.",
    },
    {
        question: "Can Kestra handle fax, document, and LLM-assisted review workflows?",
        answer: "Yes. Ingest from SFTP, email-to-fax gateways, portals, and partner drops. Run OCR, schema extraction, and LLM review with humans in the loop on any PHI decision. One declarative flow covers referrals, prior auth, claims evidence, and member servicing paperwork.",
    },
    {
        question: "Does Kestra work with mainframes, HL7 MLLP, MQ, and other legacy healthcare plumbing?",
        answer: "Yes. Plugins for JDBC (DB2, Oracle, SQL Server), SFTP/FTPS, MLLP, JMS/IBM MQ, Kafka, and shell execution for CICS or custom adapters. Most providers and payers start by wrapping existing jobs, then modernize incrementally.",
    },
    {
        question: "Can Kestra orchestrate genomics and research pipelines alongside operational workflows?",
        answer: "Yes. Parallelize sequencing jobs, manage long-running batches on Azure Batch, AWS Batch, or Kubernetes, and coordinate researcher, scientist, and IT handoffs. The same engine that runs prior auth runs your bioinformatics pipelines — versioned, reproducible, and replayable.",
    },
    {
        question: "What deployment options exist for restricted or air-gapped healthcare environments?",
        answer: "Kestra Enterprise runs fully self-hosted in your private cloud, VPC, or air-gapped datacenter with no egress required. Workers sit on-premise; the control plane can live in a different zone. Kestra Cloud runs in EU or US regions with no cross-region data transfer.",
    },
    {
        question: "Is Kestra open source, and what does the licensing model look like?",
        answer: "Kestra is Apache 2.0. Enterprise Edition adds SSO, RBAC, multi-tenancy, worker groups, advanced audit, and 24x7 support. Start with OSS. Upgrade when you need enterprise governance.",
    },
]

---

<Layout {title} {description} headerTheme="lightText">
    <div class="healthcare">

        <section class="hero">
            <img src="/hero-grid.svg" alt="" class="hero-bg-grid" aria-hidden="true" />
            <div class="hero-inner">
                <div class="badge-pill" data-usal="zoomin">
                    <Icon name="mdi:heart-pulse" />
                    <span>Healthcare &amp; Life Sciences</span>
                </div>

                <h1 data-usal="fade-u">
                    Kestra runs the workflows your EHR,<br />
                    <span class="gradient">payers, and partner systems don't.</span>
                </h1>

                <p class="subtitle" data-usal="fade-l">
                    Providers, payers, and life-sciences teams use Kestra to replace fax-and-portal ping-pong with declarative
                    automation. Prior authorization, claims, denials, HL7/FHIR interop, revenue cycle, and research pipelines —
                    with PHI inside your perimeter and an audit trail any compliance team can sign off on.
                </p>

                <div class="tags" data-usal="fade-l">
                    {HERO_TAGS.map((tag) => (
                        <span class="tag">
                            <Icon name={tag.icon} class="tag-icon" />
                            {tag.label}
                        </span>
                    ))}
                </div>

                <div class="exec-panel-wrapper" data-usal="fade-up">
                    <div class="exec-panel">
                        <div class="exec-panel__header">
                            <span class="exec-panel__dot"></span>
                            <span class="exec-panel__title">prior-auth-intake</span>
                            <span class="exec-panel__meta">namespace · company.health.ops</span>
                            <span class="exec-panel__duration">1.3s</span>
                        </div>

                        <div class="exec-panel__body">
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">receive_request</span>
                                <span class="exec-row__type">core.http.Webhook</span>
                                <span class="exec-row__result">accepted</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">check_eligibility</span>
                                <span class="exec-row__type">core.http.Request</span>
                                <span class="exec-row__result">covered</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">persist_case</span>
                                <span class="exec-row__type">jdbc.postgresql.Query</span>
                                <span class="exec-row__result">case #48213</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">clinical_review</span>
                                <span class="exec-row__type">core.flow.Pause</span>
                                <span class="exec-row__result">Approved</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">submit_decision</span>
                                <span class="exec-row__type">core.http.Request</span>
                                <span class="exec-row__result">payer ack</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">notify_provider</span>
                                <span class="exec-row__type">email.MailSend</span>
                                <span class="exec-row__result">sent</span>
                            </div>
                        </div>

                        <div class="exec-panel__footer">
                            <span class="exec-footer__item">PHI-safe</span>
                            <span class="exec-footer__sep">·</span>
                            <span class="exec-footer__item">Replayable</span>
                            <span class="exec-footer__sep">·</span>
                            <span class="exec-footer__item">Human-approved</span>
                        </div>
                    </div>
                </div>

                <div class="hero-ctas" data-usal="zoomin">
                    <Link href="/demo" class="btn btn-primary btn-lg">Book a Demo</Link>
                </div>

                <div class="hero-logos" data-usal="fade-u">
                    <span class="hero-logos__label">Used by healthcare, pharmacy, and life-sciences teams</span>
                    <div class="hero-logos__row">
                        <Image src={ApotekHjartatLogoImg} alt="Apotek Hjärtat" class="hero-logos__item" />
                        <Image src={SophiaGeneticsLogoImg} alt="Sophia Genetics" class="hero-logos__item" />
                        <Image src={BrainlabLogoImg} alt="Brainlab" class="hero-logos__item" />
                    </div>
                </div>
            </div>
        </section>

        <section class="flow">
            <div class="container-xxl">
                <h2 class="flow__title text-center">
                    Any <span class="highlight">system</span>. Any <span class="highlight">workflow</span>. Any <span class="highlight">control model</span>.
                </h2>
                <p class="flow__lead">
                    Referral, prior auth, claim, HL7 feed, lab result, or encounter update. The orchestration job is the same: connect systems, route exceptions, trigger actions, capture PHI-safe evidence.
                </p>

                <div class="flow__grid">
                    <div class="flow__steps">
                        {FLOW_STAGES.map((stage, idx) => (
                            <div class={`flow-block flow-${idx}`}>
                                <div class="flow-block__content">
                                    <span class={`flow-block__label label-${stage.id}`}>{stage.label}</span>
                                    <div class={`flow-block__card card-${stage.id}`}>
                                        <div class="flow-block__items">
                                            {stage.items.map(item => (
                                                <div class="flow-block__item">{item}</div>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                                {idx < FLOW_STAGES.length - 1 && (
                                    <div class={`flow-arrow arrow-${idx}`}>
                                        <div class="line" />
                                        <Icon name="mdi:play" class="head" width={16} height={16} />
                                    </div>
                                )}
                            </div>
                        ))}
                    </div>
                </div>

                <h5 class="flow__footer text-center">
                    Each step is a declarative YAML task. Change the source system, workflow step, or destination without rebuilding the whole process.
                </h5>
            </div>
        </section>

        <section class="workloads">
            <div class="container">
                <div class="workloads__head">
                    <h2>Every critical workflow in healthcare and life sciences.</h2>
                    <p>Intake and authorizations, claims and revenue cycle, interoperability and data, compliance and operations. One engine runs them all.</p>
                </div>
                {WORKLOAD_CATEGORIES.map(cat => (
                    <div class="workloads__group">
                        <h3 class="workloads__category">{cat.name}</h3>
                        <div class="workloads__grid">
                            {cat.items.map(item => (
                                <div class="workload-card">
                                    <Icon name={item.icon} class="workload-card__icon" />
                                    <h4 class="workload-card__title">{item.title}</h4>
                                    <p class="workload-card__desc">{item.description}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <Quotes {quotes} client:load />

        <section class="enterprise">
            <div class="container-xxl">
                <h2 class="enterprise__title" data-usal="fade-r">
                    <span class="highlight">Enterprise-Grade</span> Orchestration for PHI-Safe Workloads.
                </h2>
                <NoGapGrid items={ENTERPRISE_FEATURES}>
                    <div class="feature-card feature-card--cta">
                        <a href="/demo" class="btn btn-secondary" data-usal="zoomin">
                            Book a Demo
                        </a>
                    </div>
                </NoGapGrid>
            </div>
        </section>

        <section class="build">
            <div class="container">
                <h2><span class="highlight">Blueprints</span> for healthcare and life sciences.</h2>
                <p class="build__lead">Production workflows, from prior-auth intake to HL7-to-FHIR interop. Copy the YAML. Wire it to your stack. Ship it through your CI.</p>
                <div class="wrapper">
                    <div class="inner">
                        <div class="header row g-0">
                            {BUILD_TABS.map((tab, idx) => (
                                <div
                                    class:list={[
                                        "col-6 col-md-4 header-tab",
                                        { active: idx === 0, "middle-part": idx > 0 && idx < BUILD_TABS.length - 1 },
                                    ]}
                                    data-tab-target={idx}
                                >
                                    {tab.name}
                                </div>
                            ))}
                        </div>

                        {BUILD_TABS.map((tab, idx) => (
                            <div class:list={["content", { active: idx === 0 }]} data-tab-content={idx}>
                                <div class="panel panel-1">
                                    <Snippets client:idle code={tab.code} lang="yaml" />
                                </div>
                                <div class="panel panel-2">
                                    <h3 data-usal="fade-r">{tab.title}</h3>
                                    <p data-usal="fade-l">{tab.description}</p>
                                    <div class="plugins" data-usal="zoomin">
                                        {tab.plugins.map(plugin => (
                                            <div class="plugin-icon">
                                                <TaskIcon cls={plugin.cls} />
                                            </div>
                                        ))}
                                    </div>
                                    <Link class="goto" href={tab.href} data-usal="fade-r">
                                        Explore Blueprints
                                    </Link>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <GoFurther />

        <PluginsBlock>
            <Fragment slot="title">
                Integrates with the <span class="highlight">systems healthcare teams</span> already rely on.
            </Fragment>
            <Fragment slot="description">
                Connect EHRs, HL7 and FHIR engines, payer APIs, clearinghouses, lab and imaging systems,
                data platforms, and security controls through {totalPlugins}+ plugins. Or build the exact integration
                your environment requires.
            </Fragment>
        </PluginsBlock>

        <SeeHow cta={{ text: "Book a Demo", href: "/demo" }}>
            <Fragment slot="title">One platform for healthcare operations.</Fragment>
            Modernize legacy interfaces, connect the tools your teams already use, and add lineage, approvals,
            and PHI-safe auditability across referrals, prior auth, claims, revenue cycle, interoperability, and clinical data.
        </SeeHow>

        <Faq items={FAQ} client:visible />
    </div>
</Layout>

<style lang="scss">
    $hc-blue:        #2563EB;
