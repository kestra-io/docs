        max-width: 1720px;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        pointer-events: none;
        z-index: 0;
        opacity: 0.5;
    }

    .hero-inner {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        width: 100%;
        max-width: 68rem;
        color: $white;
        text-align: center;

        @include media-breakpoint-down(md) { gap: 1.5rem; }

        h1 {
            color: $white;
            font-weight: 600;
            line-height: 1.1;
            letter-spacing: -0.02em;
            margin: 0;
        }

        .gradient {
            background: linear-gradient(90deg, #{$hc-blue-bright}, #{$hc-blue-light});
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
