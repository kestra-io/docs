</Layout>

<style lang="scss">
    // ── Healthcare palette: medical green ────────────────────────────
    // Distinct from FSI (yellow), Public Services (cobalt), Automotive
    // (red), Retail (purple). Reads as wellness, vital, sovereign green.
    $hc-green:        #16A34A;
    $hc-green-bright: #4ADE80;
    $hc-green-light:  #BBF7D0;
    $hc-green-deep:   #14532D;
    $hc-platinum:     #E8EDF0;

    .healthcare { overflow: clip; }

    :global(html.dark) .healthcare {
        .flow,
        .workloads,
        .build,
        .enterprise {
            background: #1C1C20;
        }
        :global(section.quotes-wrapper),
        :global(section.plugin-block),
        :global(.see) {
            background: #1C1C20;
        }
    }

    .hero {
        position: relative;
        overflow: hidden;
        background: #050d08;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin-top: calc(-1 * var(--top-bar-height, 67px) - var(--announce-height, 0px));
        padding: calc(var(--top-bar-height, 67px) + var(--announce-height, 0px) + 5rem) 1.5rem 6rem;

        @include media-breakpoint-down(md) {
            padding: calc(var(--top-bar-height, 67px) + var(--announce-height, 0px) + 3rem) 1rem 4rem;
        }

        &::after {
            content: "";
            position: absolute;
            bottom: -260px;
            left: 50%;
            transform: translateX(-50%);
            width: 1100px;
            height: 520px;
            background: radial-gradient(ellipse at center, rgba(22, 163, 74, 0.32) 0%, rgba(22, 163, 74, 0) 70%);
            pointer-events: none;
            z-index: 0;
        }
    }

    .hero-bg-grid {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        max-width: 1720px;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        pointer-events: none;
        z-index: 0;
        opacity: 0.5;
    }

    .hero-inner {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        width: 100%;
        max-width: 68rem;
        color: $white;
        text-align: center;

        @include media-breakpoint-down(md) { gap: 1.5rem; }

        h1 {
            color: $white;
            font-weight: 600;
            line-height: 1.1;
            letter-spacing: -0.02em;
            margin: 0;
        }

        .gradient {
            background: linear-gradient(90deg, #{$hc-green-bright}, #{$hc-green-light});
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            color: rgba(255, 255, 255, 0.82);
            font-size: $font-size-lg;
            line-height: 1.6;
            max-width: 48rem;
            margin: 0;

            @include media-breakpoint-down(md) { font-size: $font-size-md; }
        }
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 4px 1.125rem;
        gap: 0.5rem;
        border-radius: 2.5rem;
        background: #050d08;
        position: relative;
        z-index: 1;
        font-size: $font-size-xs;
        font-weight: 600;
        color: $hc-green-bright;

        &::before {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: 2.5rem;
            padding: 1px;
            background: linear-gradient(90deg, #{$hc-green} 0%, #{$hc-green-light} 100%);
            -webkit-mask: linear-gradient($white 0 0) content-box, linear-gradient($white 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            z-index: -1;
        }
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
    }

    .tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 9999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.78);
        font-size: $font-size-xs;
        white-space: nowrap;
        transition: all 0.2s ease;

        &:hover {
            border-color: rgba(74, 222, 128, 0.55);
            background: rgba(22, 163, 74, 0.14);
            color: $white;

            :global(.tag-icon) { color: $hc-green-light; }
        }

        :global(.tag-icon) {
            width: 12px;
            height: 12px;
            color: $hc-green-bright;
            flex-shrink: 0;
        }
    }

    @property --hc-neon-angle {
        syntax: '<angle>';
        inherits: false;
        initial-value: 0deg;
    }

    @keyframes hc-neon-trace {
        to { --hc-neon-angle: 360deg; }
    }

    .exec-panel-wrapper {
        --hc-neon-angle: 0deg;
        border-radius: 10px;
        background: conic-gradient(
            from var(--hc-neon-angle),
            rgba(22, 163, 74, 0.16) 0deg,
            rgba(22, 163, 74, 0.16) 320deg,
            #{$hc-green}             340deg,
            $hc-platinum             350deg,
            #{$hc-green}             360deg
        );
        padding: 1px;
        box-shadow:
            0 1.214px 10.321px 0 rgba(22, 163, 74, 0.28) inset,
            -6.667px -7.143px 31.334px 3.333px rgba(22, 163, 74, 0.6);
        width: 100%;
        max-width: 640px;
        animation: hc-neon-trace 5s linear infinite;
    }

    .exec-panel {
        background: #061a0e;
        border-radius: 9px;
        overflow: hidden;
        backdrop-filter: blur(12px);
        text-align: left;

        &__header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 12px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(22, 163, 74, 0.08);
            flex-wrap: wrap;
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
        }

        &__dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: $hc-green-bright;
            box-shadow: 0 0 8px $hc-green-bright;
            flex-shrink: 0;
        }

        &__title {
            color: $white;
            font-weight: 600;
        }

        &__meta {
            color: rgba(255, 255, 255, 0.45);
            flex: 1;

            @include media-breakpoint-down(sm) { display: none; }
        }

        &__duration {
            color: $hc-green-light;
            font-weight: 500;
        }

        &__body {
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        &__footer {
            padding: 10px 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(22, 163, 74, 0.06);
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            color: $hc-green-light;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .exec-footer__sep { color: rgba(255, 255, 255, 0.25); }
    }

    .exec-row {
        display: grid;
        grid-template-columns: 20px minmax(130px, 1fr) minmax(150px, 1fr) minmax(90px, auto);
        align-items: center;
        gap: 1rem;
        padding: 6px 8px;
        border-radius: 4px;
        font-family: $font-family-monospace;
        font-size: $font-size-xs;
        transition: background 0.2s;

        &:hover { background: rgba(22, 163, 74, 0.10); }

        @include media-breakpoint-down(sm) {
            grid-template-columns: 20px 1fr auto;
        }

        &__check {
            color: $hc-green-bright;
            font-weight: 700;
        }

        &__name {
            color: $white;
            font-weight: 500;
        }

        &__type {
            color: rgba(255, 255, 255, 0.45);

            @include media-breakpoint-down(sm) { display: none; }
        }

        &__result {
            color: $hc-green-light;
            text-align: right;
            white-space: nowrap;
        }
    }

    .hero-ctas {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;

        .btn {
            justify-content: center;

            @include media-breakpoint-down(md) {
                width: auto;
                min-width: 200px;
            }
        }
    }

    // ── Hero logo strip ──────────────────────────────────────────────
    // 3 logos, optically balanced per SVG aspect ratio.
    .hero-logos {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        align-items: center;
        justify-content: center;
        margin-top: 1rem;
        padding-top: 2rem;
        width: 100%;
        max-width: 52rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;

        &__label {
            font-size: $font-size-xs;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.6);
        }

        &__row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            align-items: center;
            justify-items: center;
            column-gap: 3rem;
            row-gap: 1.5rem;
            width: 100%;

            @include media-breakpoint-down(md) {
                grid-template-columns: 1fr;
                row-gap: 1.75rem;
            }
        }

        &__item {
            width: auto;
            height: auto;
            display: block;
            filter: brightness(0) invert(1);
            opacity: 0.85;
            transition: opacity 0.2s;
            object-fit: contain;
            max-width: 100%;

            &:hover { opacity: 1; }

            // Unified optical sizing across all industry pages:
            // text wordmarks 36px, compact icon+text 42px, stacked
            // vertically icon+text 52–56px.
            &--apotek   { max-height: 42px; max-width: 180px; }  // icon + text
            &--brainlab { max-height: 36px; max-width: 180px; }  // text
            &--sophia   { max-height: 36px; max-width: 200px; }  // text wide

            @include media-breakpoint-down(md) {
                &--apotek   { max-height: 48px; max-width: 200px; }
                &--brainlab { max-height: 40px; max-width: 200px; }
                &--sophia   { max-height: 40px; max-width: 220px; }
            }
        }
    }

