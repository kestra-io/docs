const BUILD_TABS = [
    {
        name: "Medical image AI pipeline",
        title: "From DICOM arrival to clinician review, with the AI pipeline orchestrated end to end.",
        description:
            "A medical study lands on the webhook. Kestra loads credentials from Vault, segments the volume with a Python container, scores anomalies, pauses for case-analyst confirmation on flagged studies, and writes results back to PACS. A common pattern for cardiac, radiology, and pathology AI at scale.",
        code: `id: medical-image-pipeline
namespace: company.health.imaging

inputs:
  - id: study
    type: JSON
    displayName: DICOM study payload (study UID, modality, patient ref)

tasks:
  - id: load_secrets
    type: io.kestra.plugin.hashicorp.vault.kv.Read
    url: "{{ secret('VAULT_URL') }}"
    token: "{{ secret('VAULT_TOKEN') }}"
    path: "secret/health/imaging"

  - id: segment_volume
    type: io.kestra.plugin.scripts.python.Commands
    containerImage: "ghcr.io/health/segmentation:1.4"
    commands:
      - python segment.py --study '{{ inputs.study | toJson }}'

  - id: score_anomaly
    type: io.kestra.plugin.scripts.python.Commands
    containerImage: "ghcr.io/health/scoring:2.1"
    commands:
      - python score.py --segments {{ outputs.segment_volume.outputFiles.segments }}

  - id: route_review
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.score_anomaly.vars.flagged == true }}"
    then:
      - id: analyst_review
        type: io.kestra.plugin.core.flow.Pause
        description: |
          Case analyst must confirm finding for study
          {{ inputs.study.study_uid }} before posting back to PACS.

  - id: post_to_pacs
    type: io.kestra.plugin.core.http.Request
    uri: "https://pacs.internal/api/studies/{{ inputs.study.study_uid }}/findings"
    method: POST
    contentType: application/json
    headers:
      Authorization: "Bearer {{ outputs.load_secrets.data.pacs_token }}"
    body: "{{ outputs.score_anomaly.outputFiles.report }}"

  - id: archive_lineage
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "imaging-audit"
    key: "studies/{{ execution.startDate | date('yyyy/MM/dd') }}/{{ inputs.study.study_uid }}.json"
    from: "{{ outputs.score_anomaly.outputFiles.report }}"`,
        plugins: [
            { cls: "io.kestra.plugin.hashicorp.vault.kv.Read" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
    {
        name: "Pharmacy supply chain ingestion",
        title: "Normalize supplier files from any format and load them to the back office.",
        description:
            "Suppliers drop order files in any format. Kestra polls the SFTP, normalizes each file with a Python script, validates against business rules, loads to the back-office database, and routes exceptions to the right ops queue. The pattern running pharmacy retail networks at scale.",
        code: `id: supplier-order-ingestion
namespace: company.pharmacy.supply

triggers:
  - id: every_5_min
    type: io.kestra.plugin.core.trigger.Schedule
    cron: "*/5 * * * *"

tasks:
  - id: list_files
    type: io.kestra.plugin.fs.sftp.List
    host: "supplier-feed.internal"
    port: "22"
    username: "{{ secret('SFTP_USER') }}"
    password: "{{ secret('SFTP_PASSWORD') }}"
    from: "/inbound/orders/"

  - id: normalize
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python normalize.py --listing {{ outputs.list_files.uri }}

  - id: validate
    type: io.kestra.plugin.core.flow.If
    condition: "{{ outputs.normalize.vars.errors > 0 }}"
    then:
      - id: notify_ops
        type: io.kestra.plugin.notifications.slack.SlackIncomingWebhook
        url: "{{ secret('SLACK_OPS_URL') }}"
        payload: |
          { "text": "{{ outputs.normalize.vars.errors }} supplier file errors. Run {{ execution.id }}." }

  - id: load_to_backoffice
    type: io.kestra.plugin.jdbc.mysql.Query
    url: "jdbc:mysql://backoffice:3306/orders"
    username: "{{ secret('MYSQL_USER') }}"
    password: "{{ secret('MYSQL_PASSWORD') }}"
    sql: |
      INSERT INTO orders.supplier_batch (batch_id, file_count, loaded_at)
      VALUES ('{{ execution.id }}', {{ outputs.normalize.vars.file_count }}, NOW())

  - id: archive_batch
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "supply-chain-archive"
    key: "orders/{{ execution.startDate | date('yyyy/MM/dd') }}/{{ execution.id }}.json"
    from: "{{ outputs.normalize.outputFiles.batch }}"`,
        plugins: [
            { cls: "io.kestra.plugin.fs.sftp.List" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.jdbc.mysql.Query" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
    {
        name: "Genomics pipeline per team",
        title: "Per-team genomics pipeline with namespace isolation and signed lineage.",
        description:
            "Each research team owns its namespace, secrets, and runtime. The same flow shape runs per team: pull raw sequencing data, run a containerized bioinformatics step on Kubernetes, validate, publish to the secure lakehouse, archive the lineage. Hypersensitive data never leaves your perimeter.",
        code: `id: genomics-pipeline
namespace: company.research.team_a

triggers:
  - id: nightly
    type: io.kestra.plugin.core.trigger.Schedule
    cron: "0 3 * * *"

tasks:
  - id: pull_raw_data
    type: io.kestra.plugin.aws.s3.Downloads
    bucket: "raw-sequencing"
    prefix: "{{ flow.namespace }}/inbound/"

  - id: run_pipeline
    type: io.kestra.plugin.kubernetes.kubectl.Apply
    namespace: "research-{{ flow.namespace }}"
    spec: |
      apiVersion: batch/v1
      kind: Job
      metadata:
        name: bioinformatics-{{ execution.id }}
      spec:
        template:
          spec:
            containers:
              - name: pipeline
                image: ghcr.io/research/bio:v3
                args: ["--input", "{{ outputs.pull_raw_data.uri }}"]
            restartPolicy: Never

  - id: quality_checks
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python validate_run.py --execution {{ execution.id }}

  - id: publish_to_lakehouse
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "research-lakehouse"
    key: "{{ flow.namespace }}/{{ execution.startDate | date('yyyy/MM/dd') }}/results.parquet"
    from: "{{ outputs.quality_checks.outputFiles.parquet }}"

  - id: notify_team
    type: io.kestra.plugin.notifications.slack.SlackIncomingWebhook
    url: "{{ secret('SLACK_TEAM_URL') }}"
    payload: |
      { "text": "Genomics run {{ execution.id }} complete. Results in lakehouse." }`,
        plugins: [
            { cls: "io.kestra.plugin.aws.s3.Downloads" },
            { cls: "io.kestra.plugin.kubernetes.kubectl.Apply" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
    {
        name: "HIPAA-compliant intake",
        title: "High-volume PHI intake with policy enforcement, retention controls, and signed audit.",
        description:
            "A document or fax lands on the webhook. Kestra enforces PHI policy at the edge, runs OCR and extraction, transforms with dbt, archives the bundle with retention metadata for HIPAA, and notifies the team. Bursty, replayable, audit-ready.",
        code: `id: hipaa-intake
namespace: company.health.intake

triggers:
  - id: intake_webhook
    type: io.kestra.plugin.core.trigger.Webhook
    key: "phi-intake"

inputs:
  - id: document
    type: JSON
    displayName: Incoming document or fax payload

tasks:
  - id: enforce_policy
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python enforce_phi_policy.py --doc '{{ inputs.document | toJson }}'

  - id: ocr_extract
    type: io.kestra.plugin.scripts.python.Commands
    containerImage: "ghcr.io/health/ocr:5.2"
    commands:
      - python extract.py --doc '{{ inputs.document | toJson }}'

  - id: dbt_transform
    type: io.kestra.plugin.dbt.cli.Build
    projectDir: "./dbt/intake"
    commands:
      - dbt build --target intake

  - id: archive_with_retention
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "phi-archive"
    key: "intake/{{ execution.startDate | date('yyyy/MM/dd') }}/{{ execution.id }}.json"
    from: "{{ outputs.ocr_extract.outputFiles.bundle }}"
    metadata:
      retention-class: "hipaa-7y"
      execution-id: "{{ execution.id }}"

  - id: notify_team
    type: io.kestra.plugin.notifications.slack.SlackIncomingWebhook
    url: "{{ secret('SLACK_INTAKE_URL') }}"
    payload: |
      { "text": "PHI intake {{ execution.id }} archived with HIPAA retention." }`,
        plugins: [
            { cls: "io.kestra.plugin.core.trigger.Webhook" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.dbt.cli.Build" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
]

