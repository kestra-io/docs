const WORKLOAD_CATEGORIES = [
    {
        name: "Intake, Referrals & Authorizations",
        items: [
            {
                icon: "mdi:clipboard-pulse-outline",
                title: "Prior Authorization Automation",
                description: "Collect eligibility, run medical-necessity checks, route to clinical review, and submit decisions back to payers. Replace fax-and-portal ping-pong with one declarative, audit-ready flow.",
            },
            {
                icon: "mdi:share-variant-outline",
