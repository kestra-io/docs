const ENTERPRISE_FEATURES = [
    {
        icon: ShieldCheckOutline,
        title: "Air-Gapped & PHI-Safe Deployment",
        description: "Self-hosted, VPC, or fully air-gapped. HIPAA-ready. Segment control plane and workers across restricted zones so PHI never leaves your perimeter.",
    },
    {
        icon: Git,
        title: "Immutable, Replayable Execution",
