---
import Layout from "~/components/layout.astro"
import heroFront from "~/assets/use-cases/healthcare/hero-front.webp"
import HeartPulse from "~/assets/use-cases/healthcare/heart-pulse.svg"
import SophiaGenetics from "~/assets/use-cases/healthcare/SophiaGenetics.svg?raw"
import { optimizeSvgIcon } from "~/utils/svgo"

import Link from "~/components/common/Link.astro"
import Quotes from "~/components/common/Quotes.vue"
import TopHero from "~/components/layout/TopHero.astro"
import SeeHow from "~/components/common/SeeHow.astro"
import Unlock from "~/components/use-cases/Unlock.vue"
import CardGrid from "~/components/card/CardGrid.astro"
import PluginsBlock from "~/components/common/PluginsBlock.astro"

const title = "Kestra for Healthcare"
const description =
    "Streamline data processing, accelerate research, and enhance collaboration with Kestra’s advanced orchestration and scheduling solutions"

const ITEMS = [
    {
        icon: "mdi:clipboard-pulse-outline",
        title: "Healthcare Data Management",
        description:
            "Integrate patient records, laboratory systems, and analytics platforms into automated workflows to maintain accurate, real-time data.",
    },
    {
        icon: "mdi:dna",
        title: "Genomic Data Processing",
        description:
            "Automate sequencing workflows and large-scale genomic data analysis. Parallelize tasks and manage dependencies declaratively.",
    },
    {
        icon: "mdi:shield-check",
        title: "Regulatory Compliance",
        description:
            "Automate compliance reporting, access logs, and audit trails to meet healthcare regulatory standards.",
    },
    {
        icon: "mdi:head-snowflake-outline",
        title: "Predictive Analytics",
        description:
            "Integrate ML models into data workflows to support diagnosis support systems and patient risk prediction.",
    },
    {
        icon: "mdi:lan-connect",
        title: "Secure Research Collaboration",
        description:
            "Coordinate workflows between researchers, data scientists, and IT teams with centralized monitoring and version control.",
    },
]

const quotes = [
    {
        quote: "Kestra strong observability, ease of development, and flexibility make it a versatile solution for managing data pipelines in the field of genomics.",
        author: "Yohann Nédélec - Tech Lead",
        smallLogoSvg: optimizeSvgIcon(SophiaGenetics, "sophia-genetics-logo"),
        kpis: [
            {
                name: "Increased productivity",
                value: "200%",
            },
            {
                name: "Reduction of Azure Batch processing costs",
                value: "50%",
            },
            {
                name: "faster processing of large datasets",
                value: "85%",
            },
        ],
    },
]

const UNLOCK_CONTENT = {
    leftContent: [
        {
            title: "Accelerate Data Processing",
            description:
                "Kestra facilitates seamless data sharing and workflow coordination among bioinformaticians, data scientists, and IT teams.",
        },
        {
            title: "Improve Data Accuracy and Reliability",
            description:
                "Kestra prioritizes data security and compliance, ensuring all information is handled according to the highest standards for trust and reliability in your healthcare operations.",
        },
    ],
    rightContent: [
        {
            title: "Enhance Collaboration",
            description:
                "Whether dealing with genomic sequences, patient records, or research data, Kestra ensures that your data is processed swiftly and accurately.",
        },
        {
            title: "Secure and Compliant Data Handling",
            description:
                "Manual data processing is prone to errors and inconsistencies. Kestra’s automation capabilities minimize these risks by ensuring that data is handled consistently and accurately.",
        },
    ],
}
---

<Layout {title} {description} headerTheme="lightText">
    <TopHero
        title="Transform Healthcare <br /> with Automated <br /> Workflows"
        description="Orchestrate patient data, research pipelines, and compliance processes with secure, scalable automation that run in the most restricted environments"
        image={heroFront}
    >
        <Link
            slot="cta"
            href="/docs/quickstart#start-kestra"
            class="btn btn-primary"
        >
            Get Started
        </Link>
    </TopHero>

    <CardGrid title="Use Cases in Healthcare" items={ITEMS} />

    <Quotes {quotes} />

    <Unlock
        client:visible
        title="Healthcare"
        description="Kestra prioritizes security and compliance, ensuring all information is handled according to the highest standards for trust and reliability in your healthcare operations."
        logo={{
            src: HeartPulse.src,
            alt: "heart pulse",
        }}
        content={UNLOCK_CONTENT}
    />

    <PluginsBlock />

    <SeeHow
        cta={{
            text: "Contact Sales",
            href: "/demo",
        }}
    >
        <Fragment slot="title"> Secure and Compliant Data Handling </Fragment>
        Kestra prioritizes security and compliance, ensuring all information is handled
        according to the highest standards for trust and reliability in your healthcare
        operations.
    </SeeHow>
</Layout>
