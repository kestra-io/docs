                row-gap: 80px;
                column-gap: 40px;
            }

            @include media-breakpoint-down(sm) {
                grid-template-columns: 1fr;
                row-gap: 60px;
                column-gap: 0;
            }
        }
    }

    .flow-block {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;

        &__content {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            z-index: 1;

            @include media-breakpoint-down(sm) {
                width: 100%;
                max-width: 320px;
                margin-top: 0.5rem;
            }
        }

        &__label {
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            text-transform: uppercase;
            font-weight: 700;

            @each $id, $colors in $stages {
                &.label-#{$id} { color: map-get($colors, "label"); }
            }
        }

        &__card {
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            width: 240px;
            min-height: 340px;
            padding: 16px;
            border-radius: 8px;

            @include media-breakpoint-down(lg) {
                width: 220px;
                min-height: 330px;
            }

            @include media-breakpoint-down(sm) {
                width: 100%;
                min-height: auto;
                padding: 24px 16px;
            }

            @each $id, $colors in $stages {
                &.card-#{$id} {
                    background: map-get($colors, "bg");
                    border: 1px solid map-get($colors, "border");
                }
