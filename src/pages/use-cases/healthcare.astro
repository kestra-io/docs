    $stages: (
        "trigger": ( "bg": #fff3d3, "border": #a87f4f, "label": #b87f00 ),
        "ingest":  ( "bg": #cbe2ff, "border": #6b62f2, "label": #0069c6 ),
        "process": ( "bg": #e3cffe, "border": #bb62f2, "label": #822bfd ),
        "act":     ( "bg": #d3ffe0, "border": #4fa876, "label": #007336 )
    );

    .flow {
        position: relative;
        background: var(--ks-background-secondary);
        padding: 5.5rem 1rem;
        overflow: hidden;

        .container-xxl {
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        &__title {
            margin-bottom: 1rem;
            color: var(--ks-content-primary);

            .highlight {
                background: linear-gradient(90deg, #{$hc-blue}, #{$hc-blue-bright});
