    @property --fs-neon-angle {
        syntax: '<angle>';
        inherits: false;
        initial-value: 0deg;
    }

    @keyframes fs-neon-trace {
        to { --fs-neon-angle: 360deg; }
    }

    .exec-panel-wrapper {
        --fs-neon-angle: 0deg;
        border-radius: 10px;
        background: conic-gradient(
            from var(--fs-neon-angle),
            rgba(37, 99, 235, 0.12) 0deg,
            rgba(37, 99, 235, 0.12) 320deg,
            #{$hc-blue}              340deg,
            $hc-platinum             350deg,
            #{$hc-blue}              360deg
        );
        padding: 1px;
        box-shadow:
            0 1.214px 10.321px 0 rgba(37, 99, 235, 0.22) inset,
            -6.667px -7.143px 31.334px 3.333px rgba(37, 99, 235, 0.55);
        width: 100%;
        max-width: 640px;
        animation: fs-neon-trace 5s linear infinite;
    }

    .exec-panel {
        background: #06100f;
        border-radius: 9px;
        overflow: hidden;
        backdrop-filter: blur(12px);
        text-align: left;

        &__header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 12px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(37, 99, 235, 0.04);
            flex-wrap: wrap;
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
        }

        &__dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: $hc-blue-bright;
            box-shadow: 0 0 8px $hc-blue-bright;
            flex-shrink: 0;
        }

        &__title {
            color: $white;
            font-weight: 600;
        }

        &__meta {
            color: rgba(255, 255, 255, 0.45);
            flex: 1;

            @include media-breakpoint-down(sm) { display: none; }
        }

        &__duration {
            color: $hc-blue-light;
            font-weight: 500;
        }

        &__body {
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        &__footer {
            padding: 10px 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(37, 99, 235, 0.03);
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            color: $hc-blue-light;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .exec-footer__sep { color: rgba(255, 255, 255, 0.25); }
    }

    .exec-row {
        display: grid;
        grid-template-columns: 20px minmax(130px, 1fr) minmax(150px, 1fr) minmax(90px, auto);
        align-items: center;
        gap: 1rem;
        padding: 6px 8px;
        border-radius: 4px;
        font-family: $font-family-monospace;
        font-size: $font-size-xs;
        transition: background 0.2s;

        &:hover { background: rgba(37, 99, 235, 0.06); }

        @include media-breakpoint-down(sm) {
            grid-template-columns: 20px 1fr auto;
        }

        &__check {
            color: $hc-blue-bright;
            font-weight: 700;
        }

        &__name {
            color: $white;
            font-weight: 500;
        }

        &__type {
            color: rgba(255, 255, 255, 0.45);

            @include media-breakpoint-down(sm) { display: none; }
        }

        &__result {
            color: $hc-blue-light;
            text-align: right;
            white-space: nowrap;
        }
    }

    .hero-ctas {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;

        .btn {
            justify-content: center;

            @include media-breakpoint-down(md) {
                width: auto;
                min-width: 200px;
            }
        }
    }

    .hero-logos {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        align-items: center;
        justify-content: center;
        margin-top: 1rem;
        padding-top: 2rem;
        width: 100%;
        max-width: 52rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;

        &__label {
            font-size: $font-size-xs;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.55);
        }

        &__row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            align-items: center;
            justify-items: center;
            column-gap: 0.5rem;
            row-gap: 1.25rem;
            width: 100%;
            max-width: 36rem;
            margin: 0 auto;

            @include media-breakpoint-down(md) {
                grid-template-columns: repeat(2, 1fr);
                column-gap: 1rem;
                row-gap: 1.25rem;
            }
        }

        &__item {
            width: auto;
            height: auto;
            display: block;
            filter: brightness(0) invert(1);
            opacity: 0.8;
            transition: opacity 0.2s;
            max-width: 100%;

            &:hover { opacity: 1; }

            // Normalised optical sizing: text-logos ≈ 28–32px tall,
            // icon-centric logos ≈ 40–44px tall so they read at the same weight.
            &:nth-child(1) { max-height: 30px; max-width: 150px; }  // Apotek Hjärtat
            &:nth-child(2) { max-height: 32px; max-width: 160px; }  // Sophia Genetics
            &:nth-child(3) { max-height: 38px; max-width: 180px; }  // Brainlab
        }
