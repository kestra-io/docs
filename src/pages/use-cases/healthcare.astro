        @include media-breakpoint-down(md) {
            padding: calc(var(--top-bar-height, 67px) + var(--announce-height, 0px) + 3rem) 1rem 4rem;
        }

        &::after {
            content: "";
            position: absolute;
            bottom: -260px;
            left: 50%;
            transform: translateX(-50%);
            width: 1100px;
            height: 520px;
            background: radial-gradient(ellipse at center, rgba(37, 99, 235, 0.20) 0%, rgba(37, 99, 235, 0) 70%);
            pointer-events: none;
            z-index: 0;
        }
    }

    .hero-bg-grid {
        position: absolute;
        top: 0;
        left: 50%;
