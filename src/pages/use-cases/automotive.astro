const ENTERPRISE_FEATURES = [
    {
        icon: ShieldCheckOutline,
        title: "Plant, Edge & Cloud Deployment",
        description: "Self-hosted on plant networks, in a VPC, or fully air-gapped. Run workers next to OT systems and keep sensitive IP and telemetry inside your perimeter.",
    },
    {
        icon: Git,
        title: "Immutable, Replayable Execution",
        description: "Every flow is YAML in Git. Every execution frozen in time. Replay any recall, warranty batch, or engineering release years later with the exact code and inputs.",
    },
    {
        icon: FileDocumentCheckOutline,
        title: "Engineering & Quality Approval Gates",
        description: "Pause any workflow pending engineering, quality, or compliance sign-off. Enforce dual control on ECO/ECN promotions, recalls, and production rollouts.",
    },
    {
        icon: AccountGroupOutline,
        title: "RBAC & Multi-Plant Isolation",
        description: "Namespace-scoped RBAC with SSO/SAML/SCIM. Every plant, brand, or supplier owns its secrets and runtime on a shared platform. Zero blast radius across sites.",
    },
    {
        icon: CodeTagsCheck,
        title: "Audit Logs & OT-Safe Observability",
        description: "Every execution, user action, and resource change recorded. Stream logs to Splunk, Elastic, Datadog, or your preferred SIEM for ISO and IATF evidence.",
    },
]

const BUILD_TABS = [
    {
        name: "Quality & NCR response",
        title: "A defect on the line becomes a routed, auditable NCR, automatically.",
        description:
            "A quality event fires a webhook. Kestra opens an NCR, pulls context from MES and PLM, notifies engineering, pauses for sign-off, and closes the loop across ERP and supplier systems. Full audit trail for IATF.",
        code: `id: quality-ncr-response
namespace: company.auto.quality

inputs:
  - id: defect
    type: JSON
    displayName: Quality defect payload from MES

tasks:
  - id: open_ncr
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://quality:5432/ncr"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    sql: |
      INSERT INTO ncr.records (part, station, defect, payload, status)
      VALUES (
        '{{ inputs.defect.part }}',
        '{{ inputs.defect.station }}',
        '{{ inputs.defect.code }}',
        '{{ inputs.defect | toJson }}',
        'open'
      ) RETURNING ncr_id

  - id: fetch_plm_context
    type: io.kestra.plugin.core.http.Request
    uri: "https://plm.example/api/parts/{{ inputs.defect.part }}"
    method: GET
    headers:
      Authorization: "Bearer {{ secret('PLM_TOKEN') }}"

  - id: notify_engineering
    type: io.kestra.plugin.notifications.slack.SlackIncomingWebhook
    url: "{{ secret('SLACK_ENG_URL') }}"
    payload: |
      { "text": "NCR {{ outputs.open_ncr.row.ncr_id }} on {{ inputs.defect.part }} @ {{ inputs.defect.station }}" }

  - id: engineering_signoff
    type: io.kestra.plugin.core.flow.Pause
    description: |
      Engineering must disposition NCR {{ outputs.open_ncr.row.ncr_id }}
      before supplier containment can be triggered.

  - id: notify_supplier
    type: io.kestra.plugin.email.MailSend
    host: smtp.auto.example
    port: 465
    username: "{{ secret('SMTP_USER') }}"
    password: "{{ secret('SMTP_PASSWORD') }}"
    from: quality@auto.example
    to: "{{ outputs.fetch_plm_context.body.supplier_email }}"
    subject: "Containment required — NCR {{ outputs.open_ncr.row.ncr_id }}"
    htmlTextContent: "Please review and initiate containment actions."`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.email.MailSend" },
        ],
        href: "/blueprints",
    },
    {
        name: "Warranty claim pipeline",
        title: "Dealer warranty claims, validated and paid without a spreadsheet.",
        description:
            "A dealer submits a warranty claim. Kestra validates against policy and VIN history, pauses for warranty-ops review on high-value claims, triggers dealer payment, and publishes aggregate reporting.",
        code: `id: warranty-claim-pipeline
namespace: company.auto.warranty

inputs:
  - id: claim
    type: JSON
    displayName: Dealer warranty claim

tasks:
  - id: persist_claim
    type: io.kestra.plugin.jdbc.postgresql.Query
    url: "jdbc:postgresql://warranty:5432/claims"
    username: "{{ secret('PG_USER') }}"
    password: "{{ secret('PG_PASSWORD') }}"
    sql: |
      INSERT INTO warranty.claims (vin, dealer, part, payload, status)
      VALUES (
        '{{ inputs.claim.vin }}',
        '{{ inputs.claim.dealer_id }}',
        '{{ inputs.claim.part }}',
        '{{ inputs.claim | toJson }}',
        'received'
      ) RETURNING claim_id

  - id: validate_policy
    type: io.kestra.plugin.core.http.Request
    uri: "https://policy.example/api/validate"
    method: POST
    contentType: application/json
    body: "{{ inputs.claim | toJson }}"

  - id: route_review
    type: io.kestra.plugin.core.flow.If
    condition: "{{ inputs.claim.amount > 2000 }}"
    then:
      - id: warranty_review
        type: io.kestra.plugin.core.flow.Pause
        description: "High-value claim. Warranty ops must approve."

  - id: pay_dealer
    type: io.kestra.plugin.core.http.Request
    uri: "https://payments.example/v1/dealer-disbursements"
    method: POST
    contentType: application/json
    body: |
      {
        "dealer_id": "{{ inputs.claim.dealer_id }}",
        "claim_id": "{{ outputs.persist_claim.row.claim_id }}",
        "amount": {{ inputs.claim.amount }}
      }

  - id: publish_audit
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "warranty-audit"
    key: "claims/{{ execution.startDate | date('yyyy/MM/dd') }}/{{ outputs.persist_claim.row.claim_id }}.json"
    from: "{{ outputs.validate_policy.body }}"`,
        plugins: [
            { cls: "io.kestra.plugin.jdbc.postgresql.Query" },
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
    {
        name: "Telemetry & OTA rollout",
        title: "Stream vehicle telemetry, trigger staged OTA campaigns, prove every rollout.",
        description:
            "Consume telemetry from a Kafka topic, detect target fleets, pause for engineering approval, roll out staged OTA updates via partner APIs, and ship signed audit bundles for safety teams.",
        code: `id: telemetry-ota-rollout
namespace: company.auto.connected

triggers:
  - id: telemetry_stream
    type: io.kestra.plugin.kafka.Trigger
    topic: vehicle-telemetry
    properties:
      bootstrap.servers: "{{ secret('KAFKA_BROKERS') }}"
    groupId: kestra-ota
    serdeProperties:
      valueDeserializer: JSON

  - id: detect_targets
    type: io.kestra.plugin.scripts.python.Commands
    commands:
      - python detect_fleet.py --batch {{ trigger.value }}

  - id: engineering_approval
    type: io.kestra.plugin.core.flow.Pause
    description: "Engineering must approve OTA rollout to {{ outputs.detect_targets.vars.count }} vehicles."

  - id: trigger_ota
    type: io.kestra.plugin.core.http.Request
    uri: "https://ota-partner.example/api/rollouts"
    method: POST
    contentType: application/json
    body: |
      {
        "fleet": "{{ outputs.detect_targets.vars.fleet_id }}",
        "campaign": "{{ outputs.detect_targets.vars.campaign_id }}"
      }
    headers:
      Authorization: "Bearer {{ secret('OTA_TOKEN') }}"

  - id: publish_audit
    type: io.kestra.plugin.aws.s3.Upload
    bucket: "auto-safety-audit"
    key: "ota/{{ execution.startDate | date('yyyy/MM/dd/HH') }}/rollout.json"
    from: "{{ outputs.trigger_ota.body }}"`,
        plugins: [
            { cls: "io.kestra.plugin.kafka.Trigger" },
            { cls: "io.kestra.plugin.scripts.python.Commands" },
            { cls: "io.kestra.plugin.core.flow.Pause" },
            { cls: "io.kestra.plugin.core.http.Request" },
            { cls: "io.kestra.plugin.aws.s3.Upload" },
        ],
        href: "/blueprints",
    },
]

const FAQ = [
    {
        question: "Can Kestra orchestrate manufacturing workflows across MES, ERP, and PLM without replacing them?",
        answer: "Yes. Kestra sits alongside SAP, Oracle, Teamcenter, Catia, Ignition, Rockwell, and custom MES. It connects plants to data platforms, PLM systems, supplier portals, and cloud services with Git-backed, declarative flows. You modernize incrementally without risking production continuity.",
    },
    {
        question: "Can Kestra run inside plant networks or at the edge, not just in the cloud?",
        answer: "Yes. Self-hosted workers run inside plant networks, air-gapped zones, or on edge hardware next to OT systems. The control plane can live in a separate segmented zone so sensitive IP and telemetry never leave your perimeter. Purdue-level-appropriate deployment is the default pattern for OEMs.",
    },
    {
        question: "How does Kestra handle warranty, recall, and dealer workflows?",
        answer: "Warranty claims flow from dealer DMS to policy validation to payment to reporting — with four-eyes review on high-value claims. Recall campaigns coordinate parts dispatch, dealer scheduling, customer notification, and regulator reporting end-to-end. Everything replayable for any vehicle, any date, years later.",
    },
    {
        question: "How does Kestra handle connected-vehicle telemetry and OTA rollouts?",
        answer: "Native Kafka and MQTT triggers handle high-volume telemetry. Staged OTA rollouts pause for engineering approval, target fleets by cohort, and ship signed audit bundles for safety and type-approval teams. The same engine runs one test vehicle or a million deployed cars.",
    },
    {
        question: "How does Kestra support ISO 9001, IATF 16949, ASPICE, and engineering controls?",
        answer: "Every flow is YAML in Git. Every execution is immutable and replayable. Four-eyes Pause tasks enforce engineering, quality, and compliance sign-off. RBAC scopes access per plant, brand, or supplier. Audit logs stream to Splunk, Elastic, or your SIEM for ISO, IATF, and ASPICE evidence.",
    },
    {
        question: "Can Kestra coordinate engineering release (ECO/ECN) across PLM, MES, and ERP?",
        answer: "Yes. Validate change requests, route for engineering review, propagate downstream BOM and routing updates, sequence MES rollouts, and notify suppliers. Approvals are first-class, lineage is automatic, and the whole release is replayable.",
    },
    {
        question: "How does Kestra coordinate tier-N supplier workflows?",
        answer: "Ingest EDI feeds via AS2, SFTP, or API. Validate schemas, route exceptions, process POs and ASNs, enforce quality containment, and publish performance reports. Kestra replaces bespoke mapping scripts and fragile broker pipelines with declarative, auditable flows across tier-1, tier-2, and tier-N partners.",
    },
    {
        question: "How is Kestra different from IBM Maximo, SAP IPC, or hand-rolled MES scripts?",
        answer: `Maximo and SAP IPC are domain suites, not orchestration engines. Hand-rolled scripts die the day the engineer who wrote them leaves. Kestra is declarative YAML in Git with ${totalPlugins}+ plugins covering plant floor to cloud — so quality, warranty, recall, and telemetry live in one versioned, owned-by-your-team system.`,
    },
    {
        question: "How do you handle secrets and engineering IP?",
        answer: "Native integrations with HashiCorp Vault, AWS Secrets Manager, GCP Secret Manager, Azure Key Vault, and CyberArk. Secrets and sensitive engineering IP are scoped per namespace, per plant, per flow, and never written to logs or shipped cross-region.",
    },
    {
        question: "Is Kestra open source, and what does the licensing model look like?",
        answer: "Kestra is Apache 2.0. Enterprise Edition adds SSO, RBAC, multi-tenancy, worker groups, advanced audit, and 24x7 support. Start with OSS. Upgrade when you need enterprise governance.",
    },
    {
        question: "What workflow automation tools do automotive manufacturers typically use?",
        answer: "Automotive IT teams commonly rely on SAP scheduling, IBM Workload Automation, Automic, or homegrown scripts tied to MES and PLM systems. Kestra replaces them on one engine — orchestrating shop-floor data collection, Teamcenter and SAP integrations, quality workflows, warranty and recall pipelines, and connected-vehicle telemetry jobs, with IATF-grade audit evidence and Kubernetes-native scaling.",
    },
    {
        question: "How does Kestra compare to IBM Workload Automation or Automic for automotive manufacturing?",
        answer: "IBM Workload Automation and Automic require proprietary agents and vendor-specific configuration, and are designed for batch. Kestra is open-source, container-native, and event-driven. It handles the same batch scheduling plus real-time event-driven flows from CAN bus, telematics, or MES systems — with YAML-backed flows in Git, native Kubernetes workers, and API-first architecture that integrates with your PLM, DMS, and ERP systems without custom middleware.",
    },
    {
        question: "Can Kestra orchestrate connected-vehicle and IoT data pipelines?",
        answer: "Yes. Kestra handles real-time telemetry ingestion from vehicle fleets, MQTT and Kafka event streams, OTA update pipelines, and fleet monitoring workflows. Workers scale horizontally on Kubernetes to process high-volume vehicle data. The same declarative YAML model covers both the edge data ingestion and the downstream analytics, alerting, and CRM update workflows.",
    },
]

---

<Layout {title} {description} headerTheme="lightText">
    <SchemaFAQ items={FAQ} slot="head" />
    <SchemaService
        slot="head"
        serviceType="Automotive and Manufacturing Workflow Orchestration"
        audienceType="Automotive Manufacturers, Tier-1 Suppliers, and Manufacturing Operations Teams"
        description={description}
    />
    <div class="automotive">

        <section class="hero">
            <img src="/hero-grid.svg" alt="" class="hero-bg-grid" aria-hidden="true" />
            <div class="hero-inner">
                <div class="badge-pill" data-usal="zoomin">
                    <Icon name="mdi:car" />
                    <span>Automotive &amp; Manufacturing</span>
                </div>

                <h1 data-usal="fade-u">
                    Workflow orchestration for automotive<br />
                    <span class="gradient">manufacturing and connected vehicles.</span>
                </h1>

                <p class="subtitle" data-usal="fade-l">
                    Automakers and suppliers use Kestra to orchestrate quality, warranty, recall, engineering release,
                    and telemetry workflows across MES, SAP, PLM, dealer DMS, and connected-vehicle stacks.
                    Without ripping anything out. With IATF-grade audit evidence.
                </p>

                <div class="tags" data-usal="fade-l">
                    {HERO_TAGS.map((tag) => (
                        <span class="tag">
                            <Icon name={tag.icon} class="tag-icon" />
                            {tag.label}
                        </span>
                    ))}
                </div>

                <div class="exec-panel-wrapper" data-usal="fade-up">
                    <div class="exec-panel">
                        <div class="exec-panel__header">
                            <span class="exec-panel__dot"></span>
                            <span class="exec-panel__title">quality-ncr-response</span>
                            <span class="exec-panel__meta">namespace · company.auto.quality</span>
                            <span class="exec-panel__duration">1.5s</span>
                        </div>

                        <div class="exec-panel__body">
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">defect_event</span>
                                <span class="exec-row__type">kafka.Trigger</span>
                                <span class="exec-row__result">station #7</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">open_ncr</span>
                                <span class="exec-row__type">jdbc.postgresql.Query</span>
                                <span class="exec-row__result">NCR #91244</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">fetch_plm</span>
                                <span class="exec-row__type">core.http.Request</span>
                                <span class="exec-row__result">part + supplier</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">engineering_signoff</span>
                                <span class="exec-row__type">core.flow.Pause</span>
                                <span class="exec-row__result">Approved</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">notify_supplier</span>
                                <span class="exec-row__type">email.MailSend</span>
                                <span class="exec-row__result">sent</span>
                            </div>
                            <div class="exec-row">
                                <span class="exec-row__check">✓</span>
                                <span class="exec-row__name">publish_audit</span>
                                <span class="exec-row__type">aws.s3.Upload</span>
                                <span class="exec-row__result">archived</span>
                            </div>
                        </div>

                        <div class="exec-panel__footer">
                            <span class="exec-footer__item">IATF-ready</span>
                            <span class="exec-footer__sep">·</span>
                            <span class="exec-footer__item">Replayable</span>
                            <span class="exec-footer__sep">·</span>
                            <span class="exec-footer__item">Engineering-approved</span>
                        </div>
                    </div>
                </div>

                <div class="hero-ctas" data-usal="zoomin">
                    <Link href="/demo" class="btn btn-primary btn-lg">Book a Demo</Link>
                </div>

                <div class="hero-logos" data-usal="fade-u">
                    <span class="hero-logos__label">Used by automotive, mobility, and manufacturing teams</span>
                    <div class="hero-logos__row">
                        <Image src={QuadisLogoImg} alt="Quadis" class="hero-logos__item" />
                        <Image src={RenaultLogoImg} alt="Renault" class="hero-logos__item" />
                        <Image src={MichelinLogoImg} alt="Michelin" class="hero-logos__item" />
                        <Image src={XiaomiLogoImg} alt="Xiaomi" class="hero-logos__item" />
                    </div>
                </div>
            </div>
        </section>

        <section class="flow">
            <div class="container-xxl">
                <h2 class="flow__title text-center">
                    Any <span class="highlight">system</span>. Any <span class="highlight">workflow</span>. Any <span class="highlight">control model</span>.
                </h2>
                <p class="flow__lead">
                    Plant event, quality defect, warranty claim, supplier feed, engineering release, or vehicle telemetry. The orchestration job is the same: connect systems, route exceptions, trigger actions, capture evidence.
                </p>

                <div class="flow__grid">
                    <div class="flow__steps">
                        {FLOW_STAGES.map((stage, idx) => (
                            <div class={`flow-block flow-${idx}`}>
                                <div class="flow-block__content">
                                    <span class={`flow-block__label label-${stage.id}`}>{stage.label}</span>
                                    <div class={`flow-block__card card-${stage.id}`}>
                                        <div class="flow-block__items">
                                            {stage.items.map(item => (
                                                <div class="flow-block__item">{item}</div>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                                {idx < FLOW_STAGES.length - 1 && (
                                    <div class={`flow-arrow arrow-${idx}`}>
                                        <div class="line" />
                                        <Icon name="mdi:play" class="head" width={16} height={16} />
                                    </div>
                                )}
                            </div>
                        ))}
                    </div>
                </div>

                <h5 class="flow__footer text-center">
                    Each step is a declarative YAML task. Change the source system, workflow step, or destination without rebuilding the whole process.
                </h5>
            </div>
        </section>

        <section class="workloads">
            <div class="container">
                <div class="workloads__head">
                    <h2>Every critical workflow in automotive and manufacturing.</h2>
                    <p>Manufacturing and quality, warranty and aftersales, engineering and supplier, data and platform operations. One engine runs them all.</p>
                </div>
                {WORKLOAD_CATEGORIES.map(cat => (
                    <div class="workloads__group">
                        <h3 class="workloads__category">{cat.name}</h3>
                        <div class="workloads__grid">
                            {cat.items.map(item => (
                                <div class="workload-card">
                                    <Icon name={item.icon} class="workload-card__icon" />
                                    <h4 class="workload-card__title">{item.title}</h4>
                                    <p class="workload-card__desc">{item.description}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <Quotes {quotes} client:load />

        <section class="enterprise">
            <div class="container-xxl">
                <h2 class="enterprise__title" data-usal="fade-r">
                    <span class="highlight">Enterprise-Grade</span> Orchestration from Plant to Cloud.
                </h2>
                <NoGapGrid items={ENTERPRISE_FEATURES}>
                    <div class="feature-card feature-card--cta">
                        <a href="/demo" class="btn btn-secondary" data-usal="zoomin">
                            Book a Demo
                        </a>
                    </div>
                </NoGapGrid>
            </div>
        </section>

        <section class="build">
            <div class="container">
                <h2><span class="highlight">Blueprints</span> for automotive and manufacturing.</h2>
                <p class="build__lead">Production workflows, from quality response to OTA rollout. Copy the YAML. Wire it to your stack. Ship it through your CI.</p>
                <div class="wrapper">
                    <div class="inner">
                        <div class="header row g-0">
                            {BUILD_TABS.map((tab, idx) => (
                                <div
                                    class:list={[
                                        "col-6 col-md-4 header-tab",
                                        { active: idx === 0, "middle-part": idx > 0 && idx < BUILD_TABS.length - 1 },
                                    ]}
                                    data-tab-target={idx}
                                >
                                    {tab.name}
                                </div>
                            ))}
                        </div>

                        {BUILD_TABS.map((tab, idx) => (
                            <div class:list={["content", { active: idx === 0 }]} data-tab-content={idx}>
                                <div class="panel panel-1">
                                    <Snippets client:idle code={tab.code} lang="yaml" />
                                </div>
                                <div class="panel panel-2">
                                    <h3 data-usal="fade-r">{tab.title}</h3>
                                    <p data-usal="fade-l">{tab.description}</p>
                                    <div class="plugins" data-usal="zoomin">
                                        {tab.plugins.map(plugin => (
                                            <div class="plugin-icon">
                                                <TaskIcon cls={plugin.cls} />
                                            </div>
                                        ))}
                                    </div>
                                    <Link class="goto" href={tab.href} data-usal="fade-r">
                                        Explore Blueprints
                                    </Link>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <GoFurther />

        <PluginsBlock>
            <Fragment slot="title">
                Integrates with the <span class="highlight">systems automotive teams</span> already rely on.
            </Fragment>
            <Fragment slot="description">
                Connect MES, SCADA, PLM, ERP, dealer DMS, supplier EDI feeds, telemetry platforms, data stacks,
                and security controls through {totalPlugins}+ plugins. Or build the exact integration your environment requires.
            </Fragment>
        </PluginsBlock>

        <SeeHow cta={{ text: "Book a Demo", href: "/demo" }}>
            <Fragment slot="title">One platform for automotive and manufacturing.</Fragment>
            Connect plants, PLM, dealers, and connected vehicles to the tools your teams already use. Add lineage, approvals,
            and audit-ready execution across quality, warranty, recall, engineering, supplier, and telemetry workflows.
        </SeeHow>

        <Faq items={FAQ} client:visible />
    </div>
</Layout>

<style lang="scss">
    $au-red:        #DC2626;
    $au-red-bright: #F87171;
    $au-red-light:  #FECACA;
    $au-red-deep:   #7F1D1D;
    $au-platinum:    #E8EDF0;

    .automotive { overflow: clip; }

    :global(html.dark) .automotive {
        .flow,
        .workloads,
        .build,
        .enterprise {
            background: #1C1C20;
        }
        :global(section.quotes-wrapper),
        :global(section.plugin-block),
        :global(.see) {
            background: #1C1C20;
        }
    }

    .hero {
        position: relative;
        overflow: hidden;
        background: #060a0c;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin-top: calc(-1 * var(--top-bar-height, 67px) - var(--announce-height, 0px));
        padding: calc(var(--top-bar-height, 67px) + var(--announce-height, 0px) + 5rem) 1.5rem 6rem;

        @include media-breakpoint-down(md) {
            padding: calc(var(--top-bar-height, 67px) + var(--announce-height, 0px) + 3rem) 1rem 4rem;
        }

        &::after {
            content: "";
            position: absolute;
            bottom: -260px;
            left: 50%;
            transform: translateX(-50%);
            width: 1100px;
            height: 520px;
            background: radial-gradient(ellipse at center, rgba(220, 38, 38, 0.20) 0%, rgba(220, 38, 38, 0) 70%);
            pointer-events: none;
            z-index: 0;
        }
    }

    .hero-bg-grid {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        max-width: 1720px;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        pointer-events: none;
        z-index: 0;
        opacity: 0.5;
    }

    .hero-inner {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        width: 100%;
        max-width: 68rem;
        color: $white;
        text-align: center;

        @include media-breakpoint-down(md) { gap: 1.5rem; }

        h1 {
            color: $white;
            font-weight: 600;
            line-height: 1.1;
            letter-spacing: -0.02em;
            margin: 0;
        }

        .gradient {
            background: linear-gradient(90deg, #{$au-red-bright}, #{$au-red-light});
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            color: rgba(255, 255, 255, 0.82);
            font-size: $font-size-lg;
            line-height: 1.6;
            max-width: 48rem;
            margin: 0;

            @include media-breakpoint-down(md) { font-size: $font-size-md; }
        }
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 4px 1.125rem;
        gap: 0.5rem;
        border-radius: 2.5rem;
        background: #060b0d;
        position: relative;
        z-index: 1;
        font-size: $font-size-xs;
        font-weight: 600;
        color: $au-red-bright;

        &::before {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: 2.5rem;
            padding: 1px;
            background: linear-gradient(90deg, #{$au-red} 0%, #{$au-red-light} 100%);
            -webkit-mask: linear-gradient($white 0 0) content-box, linear-gradient($white 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            z-index: -1;
        }
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px;
    }

    .tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 9999px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.04);
        color: rgba(255, 255, 255, 0.72);
        font-size: $font-size-xs;
        white-space: nowrap;
        transition: all 0.2s ease;

        &:hover {
            border-color: rgba(248, 113, 113, 0.4);
            background: rgba(220, 38, 38, 0.08);
            color: $white;

            :global(.tag-icon) { color: $au-red-light; }
        }

        :global(.tag-icon) {
            width: 12px;
            height: 12px;
            color: $au-red-bright;
            flex-shrink: 0;
        }
    }

    @property --fs-neon-angle {
        syntax: '<angle>';
        inherits: false;
        initial-value: 0deg;
    }

    @keyframes fs-neon-trace {
        to { --fs-neon-angle: 360deg; }
    }

    .exec-panel-wrapper {
        --fs-neon-angle: 0deg;
        border-radius: 10px;
        background: conic-gradient(
            from var(--fs-neon-angle),
            rgba(220, 38, 38, 0.12) 0deg,
            rgba(220, 38, 38, 0.12) 320deg,
            #{$au-red}              340deg,
            $au-platinum             350deg,
            #{$au-red}              360deg
        );
        padding: 1px;
        box-shadow:
            0 1.214px 10.321px 0 rgba(220, 38, 38, 0.22) inset,
            -6.667px -7.143px 31.334px 3.333px rgba(220, 38, 38, 0.55);
        width: 100%;
        max-width: 640px;
        animation: fs-neon-trace 5s linear infinite;
    }

    .exec-panel {
        background: #06100f;
        border-radius: 9px;
        overflow: hidden;
        backdrop-filter: blur(12px);
        text-align: left;

        &__header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 12px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(220, 38, 38, 0.04);
            flex-wrap: wrap;
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
        }

        &__dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: $au-red-bright;
            box-shadow: 0 0 8px $au-red-bright;
            flex-shrink: 0;
        }

        &__title {
            color: $white;
            font-weight: 600;
        }

        &__meta {
            color: rgba(255, 255, 255, 0.45);
            flex: 1;

            @include media-breakpoint-down(sm) { display: none; }
        }

        &__duration {
            color: $au-red-light;
            font-weight: 500;
        }

        &__body {
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        &__footer {
            padding: 10px 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            background: rgba(220, 38, 38, 0.03);
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            color: $au-red-light;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .exec-footer__sep { color: rgba(255, 255, 255, 0.25); }
    }

    .exec-row {
        display: grid;
        grid-template-columns: 20px minmax(130px, 1fr) minmax(150px, 1fr) minmax(90px, auto);
        align-items: center;
        gap: 1rem;
        padding: 6px 8px;
        border-radius: 4px;
        font-family: $font-family-monospace;
        font-size: $font-size-xs;
        transition: background 0.2s;

        &:hover { background: rgba(220, 38, 38, 0.06); }

        @include media-breakpoint-down(sm) {
            grid-template-columns: 20px 1fr auto;
        }

        &__check {
            color: $au-red-bright;
            font-weight: 700;
        }

        &__name {
            color: $white;
            font-weight: 500;
        }

        &__type {
            color: rgba(255, 255, 255, 0.45);

            @include media-breakpoint-down(sm) { display: none; }
        }

        &__result {
            color: $au-red-light;
            text-align: right;
            white-space: nowrap;
        }
    }

    .hero-ctas {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;

        .btn {
            justify-content: center;

            @include media-breakpoint-down(md) {
                width: auto;
                min-width: 200px;
            }
        }
    }

    .hero-logos {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        align-items: center;
        justify-content: center;
        margin-top: 1rem;
        padding-top: 2rem;
        width: 100%;
        max-width: 52rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;

        &__label {
            font-size: $font-size-xs;
            font-weight: 600;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.55);
        }

        &__row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            align-items: center;
            justify-items: center;
            column-gap: 0.5rem;
            row-gap: 1.25rem;
            width: 100%;
            max-width: 44rem;
            margin: 0 auto;

            @include media-breakpoint-down(md) {
                grid-template-columns: repeat(2, 1fr);
                column-gap: 1rem;
                row-gap: 1.25rem;
            }
        }

        &__item {
            width: auto;
            height: auto;
            display: block;
            filter: brightness(0) invert(1);
            opacity: 0.8;
            transition: opacity 0.2s;
            max-width: 100%;

            &:hover { opacity: 1; }

            // Normalised optical sizing: text-logos ≈ 28–32px tall,
            // icon-centric logos ≈ 40–44px tall so they read at the same weight.
            // Unified optical sizing across all industry pages:
            // text wordmarks 36px, compact icon+text 42px, stacked
            // vertically icon+text 52–56px.
            &:nth-child(1) { max-height: 36px; max-width: 150px; }  // Quadis (text)
            &:nth-child(2) { max-height: 42px; max-width: 130px; }  // Renault (icon)
            &:nth-child(3) { max-height: 52px; max-width: 180px; }  // Michelin (icon + text)
            &:nth-child(4) { max-height: 36px; max-width: 130px; }  // Xiaomi (text)
        }
    }

    $stages: (
        "trigger": ( "bg": #fff3d3, "border": #a87f4f, "label": #b87f00 ),
        "ingest":  ( "bg": #cbe2ff, "border": #6b62f2, "label": #0069c6 ),
        "process": ( "bg": #e3cffe, "border": #bb62f2, "label": #822bfd ),
        "act":     ( "bg": #d3ffe0, "border": #4fa876, "label": #007336 )
    );

    .flow {
        position: relative;
        background: var(--ks-background-secondary);
        padding: 5.5rem 1rem;
        overflow: hidden;

        .container-xxl {
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        &__title {
            margin-bottom: 1rem;
            color: var(--ks-content-primary);

            .highlight {
                background: linear-gradient(90deg, #{$au-red}, #{$au-red-bright});
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }
        }

        &__lead {
            text-align: center;
            color: var(--ks-content-secondary);
            font-size: $font-size-lg;
            line-height: 1.55;
            max-width: 50rem;
            margin: 0 auto 3rem;
        }

        &__footer {
            margin-top: 2rem;
            color: var(--ks-content-secondary);
            font-weight: 500;
        }

        &__grid {
            width: 100%;
            padding: 2rem 1rem;
            background-color: rgba(220, 38, 38, 0.04);
            background-image: url("data:image/svg+xml,%3csvg width='100%25' height='100%25' xmlns='http://www.w3.org/2000/svg'%3e%3crect width='100%25' height='100%25' fill='none' rx='10' ry='10' stroke='%23DC2626' stroke-width='1' stroke-dasharray='8%2c 8' stroke-dashoffset='0' stroke-linecap='square'/%3e%3c/svg%3e");
            border-radius: 10px;
        }

        &__steps {
            display: flex;
            justify-content: center;
            align-items: stretch;
            width: 100%;

            @include media-breakpoint-down(xl) {
                display: grid;
                grid-template-columns: repeat(2, auto);
                row-gap: 80px;
                column-gap: 40px;
            }

            @include media-breakpoint-down(sm) {
                grid-template-columns: 1fr;
                row-gap: 60px;
                column-gap: 0;
            }
        }
    }

    .flow-block {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;

        &__content {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            z-index: 1;

            @include media-breakpoint-down(sm) {
                width: 100%;
                max-width: 320px;
                margin-top: 0.5rem;
            }
        }

        &__label {
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            text-transform: uppercase;
            font-weight: 700;

            @each $id, $colors in $stages {
                &.label-#{$id} { color: map-get($colors, "label"); }
            }
        }

        &__card {
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            width: 240px;
            min-height: 340px;
            padding: 16px;
            border-radius: 8px;

            @include media-breakpoint-down(lg) {
                width: 220px;
                min-height: 330px;
            }

            @include media-breakpoint-down(sm) {
                width: 100%;
                min-height: auto;
                padding: 24px 16px;
            }

            @each $id, $colors in $stages {
                &.card-#{$id} {
                    background: map-get($colors, "bg");
                    border: 1px solid map-get($colors, "border");
                }
            }
        }

        &__items {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        &__item {
            position: relative;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px;
            background: #ffffff;
            border: 1px solid #333638;
            border-radius: 4px;
            color: #333638;
            font-family: $font-family-monospace;
            font-size: $font-size-xs;
            font-weight: 700;
            box-shadow: 4px 4px 0 0 #EBEBEB, 4px 4px 0 1px #333638CC;
        }
    }

    .flow-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 2;

        .line {
            background: #000000;
            html.dark & { background: #ffffff; }
        }

        .head {
            position: absolute;
            color: #000000;
            html.dark & { color: #ffffff; }
        }

        @include media-breakpoint-up(xl) {
            width: 90px;

            .line { width: 100%; height: 1.5px; }
            .head {
                right: -4px;
                top: 50%;
                transform: translateY(-50%);
            }
        }

        @include media-breakpoint-between(sm, xl) {
            &.arrow-0, &.arrow-1 {
                position: absolute;
                top: calc(100% + 4px);
                left: 50%;
                height: 72px;
                width: 1.5px;
                transform: translateX(-50%);

                .line { width: 1.5px; height: 100%; }
                .head {
                    bottom: -5px;
                    left: 50%;
                    transform: translateX(-50%) rotate(90deg);
                }
            }
            &.arrow-2 { display: none; }
        }

        @include media-breakpoint-down(sm) {
            position: absolute;
            top: calc(100% + 4px);
            left: 50%;
            height: 58px;
            width: 1.5px;
            transform: translateX(-50%);

            .line { width: 1.5px; height: 100%; }
            .head {
                bottom: -6px;
                left: 50%;
                transform: translateX(-50%) rotate(90deg);
            }
        }
    }

    .workloads {
        position: relative;
        padding: 5rem 1rem;
        background: var(--ks-background-body);
        overflow: hidden;

        > .container {
            position: relative;
            z-index: 1;
        }

        &__head {
            text-align: center;
            max-width: 46rem;
            margin: 0 auto 3rem;

            h2 { color: var(--ks-content-primary); margin-bottom: 0.75rem; }
            p { color: var(--ks-content-secondary); font-size: $font-size-lg; margin: 0; }
        }

        &__group {
            max-width: 72rem;
            margin: 0 auto 3rem;

            &:last-child { margin-bottom: 0; }
        }

        &__category {
            font-size: $font-size-sm;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: $au-red-deep;
            margin: 0 0 1rem;

            :global(html.dark) & { color: $au-red-bright; }
        }

        &__grid {
            display: grid;
            gap: 1rem;
            grid-template-columns: 1fr;

            @include media-breakpoint-up(md) { grid-template-columns: repeat(3, 1fr); }
        }
    }

    .workload-card {
        padding: 1.5rem;
        background: var(--ks-background-primary);
        border: 1px solid var(--ks-border-secondary);
        border-radius: 10px;
        box-shadow: 0 1px 3px 0 var(--ks-shadows-light);
        transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;

        &:hover {
            border-color: $au-red;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px 0 var(--ks-shadows-light);
        }

        &__icon {
            font-size: 1.375rem;
            color: $au-red-deep;
            margin-bottom: 0.75rem;
            width: 1.375rem;
            height: 1.375rem;

            :global(html.dark) & { color: $au-red-bright; }
        }

        &__title {
            font-size: $font-size-md;
            font-weight: 600;
            color: var(--ks-content-primary);
            margin: 0 0 0.5rem;
            line-height: 1.3;
        }

        &__desc {
            font-size: $font-size-sm;
            color: var(--ks-content-secondary);
            line-height: 1.5;
            margin: 0;
        }
    }

    .build {
        padding: 3rem 0 4.5rem;
        background: var(--ks-background-primary);
        border-bottom: $block-border;

        .container {
            max-width: 73.75rem;
            margin: 0 auto;
            padding-inline: 0;

            h2 {
                margin-bottom: 1rem;
                padding-inline: $rem-1;
                text-align: center;

                .highlight { color: $au-red; }

                @include media-breakpoint-up(xl) { padding-inline: 0; }
            }

            .wrapper {
                border: 1px solid var(--ks-border-primary);
                box-shadow: 2px 3px 16px 0 var(--ks-shadows-light);
                border-radius: 13px;

                @include media-breakpoint-down(xl) { border-radius: 0; }

                .inner {
                    border-radius: $rem-1;
                    background: var(--ks-background-primary-inverse);
                    overflow: clip;

                    @include media-breakpoint-down(xxl) { border-radius: 0; }

                    .header {
                        border-bottom: 1px solid var(--ks-border-secondary-inverse);

                        & > div {
                            padding: 1.1875rem $rem-2;
                            font-size: $font-size-md;
                            color: var(--ks-content-secondary-inverse);
                            text-align: center;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            cursor: pointer;
                            transition: background-color 0.2s, color 0.2s, border-color 0.2s;

                            @include media-breakpoint-down(sm) { font-size: $font-size-sm; }

                            &.active {
                                background: var(--ks-background-secondary-inverse);
                                border-bottom: 1px solid var(--ks-border-active);
                                color: var(--ks-content-primary-inverse);
                                font-weight: 600;
                            }
                        }

                        & .middle-part {
                            border-left: 1px solid var(--ks-border-primary-inverse);
                            border-right: 1px solid var(--ks-border-primary-inverse);
                        }
                    }

                    .content {
                        display: none;
                        flex-direction: row;
                        gap: $rem-2;
                        padding: $rem-2;
                        justify-content: center;

                        &.active { display: flex; }

                        @include media-breakpoint-down(xl) {
                            flex-direction: column;
                            align-items: center;
                        }

                        @include media-breakpoint-down(sm) { padding: $rem-2 $rem-1; }

                        .panel {
                            border-radius: 0.5rem;
                            flex-shrink: 0;

                            &.panel-1 {
                                width: 39.4375rem;

                                @include media-breakpoint-down(xl) { width: 100%; }

                                :global(.code-card) {
                                    border: 1px solid var(--ks-border-secondary-inverse);
                                    background: var(--ks-background-input);
                                    height: 100%;

                                    :global(.code-inner) { transition: max-height 0.3s ease; }
                                    :global(.mdc-renderer pre) { padding: 0 1rem 1rem 1rem; }

                                    &:global(:not(.is-expanded)) {
                                        :global(.code-inner) { max-height: 27.9375rem !important; }
                                    }
                                }
                            }

                            &.panel-2 {
                                position: relative;
                                padding-top: $rem-2;
                                color: var(--ks-content-primary-inverse);
                                width: 27.5625rem;

                                @include media-breakpoint-down(xl) {
                                    width: 100%;
                                    padding-top: 0;
                                }

                                p {
                                    font-size: $font-size-lg;
                                    margin-top: $rem-1;
                                    margin-bottom: $rem-2;
                                }

                                .plugins {
                                    display: flex;
                                    gap: 0.5rem;
                                    flex-wrap: wrap;

                                    .plugin-icon {
                                        width: 2.125rem;
                                        height: 2.125rem;
                                        padding: 0.375rem;
                                        background: $white;
                                        border: $block-border;
                                        border-radius: $border-radius;
                                    }
                                }

                                .goto {
                                    position: absolute;
                                    bottom: 0;
                                    right: 0;
                                    color: var(--ks-content-link-inverse);
                                    font-weight: 600;

                                    @include media-breakpoint-down(xl) {
                                        position: relative;
                                        margin-top: $rem-3;
                                        float: right;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        &__lead {
            text-align: center;
            color: var(--ks-content-secondary);
            font-size: $font-size-lg;
            margin: 0 auto $rem-2;
            max-width: 44rem;
            padding-inline: $rem-1;
        }
    }

    .enterprise {
        padding: 140px 1rem 80px;
        gap: 40px;
        background: var(--ks-background-primary-inverse);
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        overflow: hidden;

        @include media-breakpoint-down(lg) { padding: 4rem 1rem 3rem; }

        &__title {
            color: #fff;
            margin-bottom: 2.5rem;
            text-align: center;

            .highlight { color: $au-red-bright; }
        }

        :global(.features-grid) {
            box-shadow: 0 9px 36px 0 var(--ks-shadows-light-inverse);
        }

        :global(.feature-icon) {
            color: $au-red !important;
        }
        :global(.feature-title) {
            color: #fff !important;
        }
        :global(.feature-desc) {
            color: rgba(255, 255, 255, 0.72) !important;
        }

        .container-xxl { max-width: 1420px; }
    }

    .enterprise :global(.feature-card--cta) {
        width: 100%;
        padding: 2rem 4rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 1px 1px 0 0 var(--ks-border-secondary-inverse);

        @include media-breakpoint-down(lg) { padding: 2rem; }

        .btn { white-space: nowrap; }
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        for (const container of document.querySelectorAll(".build .inner")) {
            container.addEventListener("click", (e) => {
                const tab = (e.target as Element).closest(".header-tab") as HTMLElement
                const target = tab && (container as Element).querySelector(
                    `[data-tab-content="${tab.dataset.tabTarget}"]`
                )
                if (!target) return

                for (const el of container.querySelectorAll(".header-tab, .content")) {
                    el.classList.remove("active")
                }
                tab.classList.add("active")
                target.classList.add("active")
            })
        }
    })
</script>
