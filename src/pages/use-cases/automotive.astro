---
import Layout from "~/components/layout.astro"
import Car from "~/assets/use-cases/automotive/car.svg"
import heroFront from "~/assets/use-cases/automotive/hero-front.svg"
import Quadis from "~/assets/use-cases/automotive/quadis.svg?raw"

import Link from "~/components/common/Link.astro"
import Quotes from "~/components/common/Quotes.vue"
import SeeHow from "~/components/common/SeeHow.astro"
import Unlock from "~/components/use-cases/Unlock.vue"
import CardGrid from "~/components/card/CardGrid.astro"
import TopHero from "~/components/layout/TopHero.astro"
import PluginsBlock from "~/components/common/PluginsBlock.astro"

const title = "Kestra for Automotive"
const description =
    "Kestra empowers data engineers, software engineers, and platform engineers in the automotive industry to create custom workflows effortlessly."

const ITEMS = [
    {
        icon: "mdi:leak",
        title: "Predictive Maintenance",
        description:
            "Orchestrate telemetry from vehicles, production lines, and IoT sensors. Trigger automated diagnostics and maintenance workflows based on real-time data to reduce downtime and prevent costly failures.",
    },
    {
        icon: "mdi:hub-outline",
        title: "Supply Chain Report Automation",
        description:
            "Automate supplier evaluations, shipment tracking, and performance reporting. Orchestrate workflows across multiple partners with built-in monitoring and retries.",
    },
    {
        icon: "mdi:checkbox-multiple-marked-circle-outline",
        title: "Quality Control Automation",
        description:
            "Integrate production-line information, testing systems, and analytics platforms. Automatically trigger alerts, defect analysis, and compliance documentation.",
    },
    {
        icon: "mdi:stack-overflow",
        title: "Inventory Management",
        description:
            "Synchronize inventory across manufacturers, warehouses, and dealerships. Automate stock updates, demand forecasting workflows, and reporting pipelines.",
    },
    {
        icon: "mdi:bell-ring",
        title: "Delivery Alerting",
        description:
            "Automate delivery notifications and logistics workflows by integrating CRM, ERP, and transport systems. Ensure real-time updates from factory to customer pickup.",
    },
]

// TODO: Quadis

const quotes = [
    {
        quote: "We're convinced to have chosen the right tool. The support and communication are great, it's easy to adapt to any tool and for any people to understand",
        author: "Rubén Boniz Martinez - Senior Engineering Manager",
        smallLogoSvg: Quadis,
        kpis: [
            {
                name: "Downtime",
                value: "ZERO",
            },
            {
                name: "cost reduction of processing",
                value: "50%",
            },
            {
                name: "datasets orchestrated",
                value: "+250",
            },
        ],
    },
]

const UNLOCK_CONTENT = {
    leftContent: [
        {
            title: "Event-Driven Orchestration",
            description:
                "Capabilities for real-time data processing and decision-making, critical for time-sensitive automotive operations.",
        },
        {
            title: "Monitoring and Alerting",
            description:
                "Kestra’s intuitive interface and comprehensive documentation make it easy for automotive engineers to quickly build and deploy powerful workflows.",
        },
    ],
    rightContent: [
        {
            title: "Real-Time Processing",
            description:
                "React instantly to production events, shipment updates, or IoT triggers with real-time workflow execution.",
        },
        {
            title: "Quick to Learn, Easy to Master",
            description:
                "Robust monitoring and alerting features that ensure proactive issue resolution, minimizing operational disruptions.",
        },
    ],
}
---

<Layout {title} {description} headerTheme="lightText">
    <TopHero
        title="Orchestrate Your <br /> Automotive Ecosystem <br /> with Kestra"
        description="Build, run, and scale event-driven workflows across manufacturing, supply chain, dealerships, and connected vehicles, all from a unified control plane."
        image={heroFront}
    >
        <Link
            slot="cta"
            href="/docs/quickstart#start-kestra"
            class="btn btn-primary"
        >
            Get Started
        </Link>
    </TopHero>

    <CardGrid title="Use Cases in Automotive" items={ITEMS} />

    <Quotes {quotes} />

    <Unlock
        client:visible
        title="Automotive Ecosystem"
        description="Kestra empowers engineers in the automotive industry to orchestrate complex operations across factories, suppliers, logistics, and dealerships. From IoT sensor ingestion to ERP integrations, Kestra ensures real-time visibility, reliability, and scalability."
        logo={{
            src: Car.src,
            alt: "car",
        }}
        content={UNLOCK_CONTENT}
    />

    <PluginsBlock />

    <SeeHow
        cta={{
            text: "Talk to sales",
            href: "/demo",
        }}
    >
        <Fragment slot="title"> Scale With Kestra Enterprise Edition </Fragment>
        Replace legacy schedulers, brittle scripts, and disconnected automation tools
        with a unified orchestration platform.
    </SeeHow>
</Layout>
