---
import Layout from "~/components/layout.astro"
import SeeHow from "~/components/common/SeeHow.astro"
import CardGrid from "~/components/card/CardGrid.astro"
import TopHero from "~/components/layout/TopHero.astro"
import PluginsBlock from "~/components/common/PluginsBlock.astro"
import SchedulingFeat from "~/components/features/scheduling/SchedulingFeat.astro"

import visualHero from "~/assets/landing/features/scheduling/scheduling_hero.png"

const title = "Schedule all your workflows with Kestra"
const description = "Automate scheduled and event-driven workflows with Kestra."

const MAIN_ITEMS = [
    {
        icon: "mdi:restore",
        title: "Backfill Support",
        description:
            "Kestra's Backfills can automatically catch up on missed workflows after an outage. You can trigger backfills from the UI without having to redeploy your code.",
    },
    {
        icon: "mdi:clock-time-five-outline",
        title: "Time-Based Scheduling",
        description:
            "Kestra provides versatile scheduling options for timely and reliable task execution, from regular intervals to condition-based triggers.",
        class: "mask",
    },
    {
        icon: "mdi:calendar-month",
        title: "Event-Driven Triggers",
        description:
            "Initiate workflows based on real-time events, and schedule them to listen for specific events at designated times.",
    },
    {
        icon: "mdi:connection",
        title: "API-Based Triggers",
        description:
            "Leverage API-based triggers for smooth integration with your existing systems, allowing automated workflows to adapt to external conditions.",
    },
    {
        icon: "mdi:puzzle-check-outline",
        title: "Modularity with Subflows",
        description:
            "Build modular and reusable reusable components. Write your logic once and call it from any other workflow when needed. Pass data between flows for seamless orchestration.",
    },
]
---

<Layout {title} {description} headerTheme="lightText">
    <TopHero
        title="Scheduling and Automation"
        description="Automate scheduled and event-driven workflows with Kestra"
        image={visualHero}
    />
    <SchedulingFeat />
    <PluginsBlock>
        <Fragment slot="title">
            Connect Your Entire Tech Stack <br class="d-none d-lg-block" />
            with Dedicated Plugins
        </Fragment>
        <Fragment slot="description">
            Integrate with your existing technology landscape using Kestra's
            robust plugin architecture. From databases and cloud services to
            custom applications, plugins enable you to connect, schedule, and
            automate your entire tech stack.
        </Fragment>
    </PluginsBlock>
    <CardGrid title="Automation and Scheduling Features" items={MAIN_ITEMS} />

    <SeeHow>
        <Fragment slot="title">Scale With Kestra Enterprise Edition</Fragment>
        Built for Enterprises and SMBs, with strong governance, enterprise-grade security,
        seamless scalability, and dedicated enterprise support backed by SLAs.
    </SeeHow>
</Layout>
