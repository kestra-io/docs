---
import { getEntry } from "astro:content"
import Layout from "~/components/layout.astro"
import Intro from "~/components/versus/Intro.astro"
import Philosophy from "~/components/versus/Philosophy.astro"
import BusinessValue from "~/components/versus/BusinessValue.astro"
import SetupSpeed from "~/components/versus/SetupSpeed.astro"
import EaseOfUse from "~/components/versus/EaseOfUse.astro"
import VisualPreview from "~/components/versus/VisualPreview.astro"
import FeatureGrid from "~/components/versus/FeatureGrid.astro"
import SocialProof from "~/components/common/SocialProof.astro"
import PlatformStrengths from "~/components/common/PlatformStrengths.astro"
import DecisionGuide from "~/components/versus/DecisionGuide.astro"
import SeeHow from "~/components/common/SeeHow.astro"
import Faq from "~/components/common/Faq.vue"

import competitorLogo from "~/components/versus/assets/rundeck-full.svg?raw"
import competitorMonogram from "~/components/versus/assets/rundeck-full-monograme.svg?raw"
import hcImage from "~/components/versus/assets/hc.png"
import data1 from "~/components/versus/assets/data-1.svg"
import data2 from "~/components/versus/assets/data-2.svg"
import data3 from "~/components/versus/assets/data-3.svg"
import kestraImg from "~/components/versus/assets/kestra-img.svg"
import competitorImg from "~/components/versus/assets/rundeck-full-img.svg"
import heroUI from "~/components/versus/assets/hero_ui_rundeck.webp"
import heroBg from "~/components/versus/assets/hero_bg.webp"

const entry = await getEntry("vsPages", "rundeck")
if (!entry) throw new Error("Could not find vsPages/rundeck collection entry")

const {
    title,
    description,
    competitorName,

    intro,
    philosophy,
    businessValue,
    setupSpeed,
    easeOfUse,
    visualPreview,
    featureGrid,
    socialProof,
    platformStrengths,
    decisionGuide,
    commonQuestions,
} = entry.data
---

<Layout {title} {description} headerTheme="lightText">
    <Intro
        {...intro}
        competitor={{
            name: competitorName,
            monogram: competitorMonogram,
        }}
        image={{ src: heroUI, alt: "kestra ui" }}
        bgImg={heroBg.src}
    />
    <Philosophy
        {...philosophy}
        competitor={{
            ...philosophy.competitor,
            logo: competitorLogo,
        }}
    />
    <BusinessValue
        {...businessValue}
        competitor={{
            ...businessValue.competitor,
            logo: competitorLogo,
        }}
    />
    <SetupSpeed
        {...setupSpeed}
        competitor={{
            ...setupSpeed.competitor,
            logo: competitorLogo,
        }}
    />
    <EaseOfUse
        {...easeOfUse}
        competitor={{
            ...easeOfUse.competitor,
            logo: competitorLogo,
        }}
    />
    <VisualPreview
        {...visualPreview}
        kestra={{
            ...visualPreview.kestra,
            linkImg: kestraImg,
        }}
        competitor={{
            ...visualPreview.competitor,
            logo: competitorLogo,
            linkImg: competitorImg,
        }}
    />
    <FeatureGrid
        featureGrid={{
            ...featureGrid,
            competitorLogo: competitorLogo,
        }}
    />
    <SocialProof
        {...socialProof}
        image={{ ...socialProof.image, src: hcImage }}
    />
    <PlatformStrengths
        {...platformStrengths}
        features={platformStrengths.features?.map((f: any, i: number) => ({
            ...f,
            image: { src: [data1, data2, data3][i] },
        }))}
    />
    <DecisionGuide
        {...decisionGuide}
        competitor={{
            ...decisionGuide.competitor,
            logo: competitorLogo,
        }}
    />
    <Faq items={commonQuestions} client:visible />
    <SeeHow>
        <Fragment slot="title">
            Getting Started with Modern Runbook Orchestration
        </Fragment>
        See how Kestra modernizes operational runbooks with declarative YAML and event-driven triggers.
    </SeeHow>
</Layout>
