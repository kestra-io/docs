---
import { getEntry } from "astro:content"
import Layout from "~/components/layout.astro"
import Intro from "~/components/versus/Intro.astro"
import Philosophy from "~/components/versus/Philosophy.astro"
import BusinessValue from "~/components/versus/BusinessValue.astro"
import SetupSpeed from "~/components/versus/SetupSpeed.astro"
import EaseOfUse from "~/components/versus/EaseOfUse.astro"
import VisualPreview from "~/components/versus/VisualPreview.astro"
import FeatureGrid from "~/components/versus/FeatureGrid.astro"
import VsTestimonial from "~/components/versus/VsTestimonial.astro"
import PlatformStrengths from "~/components/common/PlatformStrengths.astro"
import DecisionGuide from "~/components/versus/DecisionGuide.astro"
import SeeHow from "~/components/common/SeeHow.astro"
import Faq from "~/components/common/Faq.vue"

import snowflakeLogo from "~/components/versus/assets/snowflake-tasks.svg?raw"
import snowflakeMonogram from "~/components/versus/assets/snowflake-tasks-monograme.svg?raw"
import data1 from "~/components/versus/assets/data-1.svg"
import data2 from "~/components/versus/assets/data-2.svg"
import data3 from "~/components/versus/assets/data-3.svg"
import kestraImg from "~/components/versus/assets/kestra-img.svg"
import snowflakeImg from "~/components/versus/assets/snowflake-tasks-img.svg"

const entry = await getEntry("vs", "snowflake-tasks")
if (!entry) throw new Error("Could not find vs/snowflake-tasks collection entry")

const {
    title,
    shortDescription,
    competitorName,

    intro,
    philosophy,
    businessValue,
    setupSpeed,
    easeOfUse,
    visualPreview,
    featureGrid,
    testimonials,
    platformStrengths,
    decisionGuide,
    commonQuestions,
} = entry.data
---

<Layout {title} description={shortDescription}>
    <Intro
        {...intro}
        competitor={{
            name: competitorName,
            monogram: snowflakeMonogram,
        }}
    />
    <Philosophy
        {...philosophy}
        competitor={{
            ...philosophy.competitor,
            logo: snowflakeLogo,
        }}
    />
    <BusinessValue
        {...businessValue}
        competitor={{
            ...businessValue.competitor,
            logo: snowflakeLogo,
        }}
    />
    <SetupSpeed
        {...setupSpeed}
        competitor={{
            ...setupSpeed.competitor,
            logo: snowflakeLogo,
        }}
    />
    <EaseOfUse
        {...easeOfUse}
        competitor={{
            ...easeOfUse.competitor,
            logo: snowflakeLogo,
        }}
    />
    <VisualPreview
        {...visualPreview}
        kestra={{
            ...visualPreview.kestra,
            linkImg: kestraImg,
        }}
        competitor={{
            ...visualPreview.competitor,
            logo: snowflakeLogo,
            linkImg: snowflakeImg,
        }}
    />
    <FeatureGrid
        featureGrid={{
            ...featureGrid,
            competitorLogo: snowflakeLogo,
        }}
    />
    <VsTestimonial
        quotes={testimonials}
    />
    <PlatformStrengths
        {...platformStrengths}
        features={platformStrengths.features?.map((f: any, i: number) => ({
            ...f,
            image: { src: [data1, data2, data3][i] },
        }))}
    />
    <DecisionGuide
        {...decisionGuide}
        competitor={{
            ...decisionGuide.competitor,
            logo: snowflakeLogo,
        }}
    />
    <Faq items={commonQuestions} client:visible />
    <SeeHow>
        <Fragment slot="title">
            Getting Started with Declarative Orchestration
        </Fragment>
        See how Kestra can simplify your data pipelines—and orchestrate beyond the data warehouse.
    </SeeHow>
</Layout>
